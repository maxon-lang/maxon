// Test: contextual-literal-typing.byte-vs-byte.1
function main() returns int
    var a = 50 as byte
    var b = 50 as byte
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 50
    %tmp_const.1 = const.i64 i64 255
    %tmp_band = band i64 %tmp_const %tmp_const.1
    %a = alloca ptr
    store %a %tmp_band
    %tmp_const.2 = const.i64 i64 50
    %tmp_const.3 = const.i64 i64 255
    %tmp_band.1 = band i64 %tmp_const.2 %tmp_const.3
    %b = alloca ptr
    store %b %tmp_band.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_load.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.4 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end:
    %tmp_const.5 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.5
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

// Test: match-statements.match-range.open-lower-inclusive.1
function main() returns int
    var x = 5
    match x 'check'
        ..=5 then return 1
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    br @match_check_1
match_check_1:
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.le i64 %tmp_const %tmp_const.2
    br.cond %tmp_icmp @match_body_2 @match_default_3
match_body_2:
    %tmp_const.3 = const.i64 i64 1
    ret %tmp_const.3
match_default_3:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
match_merge_4:
}

---

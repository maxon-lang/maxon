// Test: challenge-struct-field-assign.struct-field-reassignment.1
type Counter
    export var value int
end 'Counter'

function main() returns int
    var c = Counter{value: 10}
    c.value = 42
    return c.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    memset %c 0 8
    %tmp_const.1 = const.i64 i64 42
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

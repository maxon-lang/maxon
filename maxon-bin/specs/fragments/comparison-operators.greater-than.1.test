// Test: comparison-operators.greater-than.1
function main() returns int
    if 5 > 3 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 3
    %tmp_icmp = icmp.gt i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 42
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const.2
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
end:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.3
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

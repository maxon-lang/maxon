// Test: comparison-operators.less-than-or-equal.1
function main() returns int
    var a = 5
    var b = 10
    if a <= b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 10
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_icmp = icmp.le i64 %tmp_load %tmp_load.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.3
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

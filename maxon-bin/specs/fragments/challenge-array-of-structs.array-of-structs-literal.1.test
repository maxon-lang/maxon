// Test: challenge-array-of-structs.array-of-structs-literal.1
type Point
    var x int
    var y int
end 'Point'

function main() returns int
    var p1 = Point{x: 1, y: 2}
    var p2 = Point{x: 3, y: 4}
    var points = [p1, p2]
    var sum = 0
    if let pt0 = points[0] 'g0'
        sum = sum + pt0.x
    end 'g0'
    if let pt1 = points[1] 'g1'
        sum = sum + pt1.y
    end 'g1'
    return sum
end 'main'

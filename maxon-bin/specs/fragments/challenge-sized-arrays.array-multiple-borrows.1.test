// Test: challenge-sized-arrays.array-multiple-borrows.1
function readFirst(arr Array of 3 int) returns int
    if let val = arr[0] 'get'
        return val
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'readFirst'

function main() returns int
    var arr = Array of 3 int
    arr[0] = 10
    var a = readFirst(arr)
    var b = readFirst(arr)
    var c = readFirst(arr)
    return a + b + c
end 'main'

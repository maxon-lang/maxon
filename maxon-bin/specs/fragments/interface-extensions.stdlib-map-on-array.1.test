// Test: interface-extensions.stdlib-map-on-array.1
function main() returns int
    var nums = [1, 2, 3, 4, 5]
    var doubled = nums.map((x int) gives x * 2)
    
    var sum = 0
    for n in doubled 'loop'
        sum = sum + n
    end 'loop'
    
    // 2 + 4 + 6 + 8 + 10 = 30
    return sum
end 'main'

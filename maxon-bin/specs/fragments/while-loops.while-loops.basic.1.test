// Test: while-loops.while-loops.basic.1
function main() returns int
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 3
    %i = alloca ptr
    store %i %tmp_const.1
    br @whilecond_1
whilecond_1:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @whilebody_2 @whilecont_5
whilebody_2:
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 2
    %tmp_add = add i64 %tmp_load.1 %tmp_const.3
    store %x %tmp_add
    %tmp_load.2 = load i64 %i
    %tmp_const.4 = const.i64 i64 1
    %tmp_sub = sub i64 %tmp_load.2 %tmp_const.4
    store %i %tmp_sub
    %tmp_load.3 = load i64 %i
    %tmp_const.5 = const.i64 i64 0
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.3 %tmp_const.5
    br.cond %tmp_icmp.1 @then$check_3 @end$check_4
then$check_3:
    br @whilecont_5
    br @end$check_4
end$check_4:
    br @whilecond_1
whilecont_5:
    %tmp_load.4 = load i64 %x
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.4
    %tmp_load.5 = load i64 %tmp_alloca.2
    ret %tmp_load.5
}


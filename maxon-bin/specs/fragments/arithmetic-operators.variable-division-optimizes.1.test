// Test: arithmetic-operators.variable-division-optimizes.1
function main() returns int
    var a = 7
    var b = 2
    return trunc(a / b)      // Should optimize to sdiv after Mem2Reg
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 7
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 2
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_sitofp = sitofp f64 %tmp_load
    %tmp_sitofp.1 = sitofp f64 %tmp_load.1
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_fptosi
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

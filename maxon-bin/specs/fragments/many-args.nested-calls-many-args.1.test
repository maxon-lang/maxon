function add5() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %c = param i64 2
    %c.1 = alloca ptr
    store %c.1 %c
    %d = param i64 3
    %d.1 = alloca ptr
    store %d.1 %d
    %e = param i64 4
    %e.1 = alloca ptr
    store %e.1 %e
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_load.2 = load i64 %c.1
    %tmp_add.1 = add i64 %tmp_add %tmp_load.2
    %tmp_load.3 = load i64 %d.1
    %tmp_add.2 = add i64 %tmp_add.1 %tmp_load.3
    %tmp_load.4 = load i64 %e.1
    %tmp_add.3 = add i64 %tmp_add.2 %tmp_load.4
    ret %tmp_add.3
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %tmp_const.1 = const.i64 i64 2
    %tmp_const.2 = const.i64 i64 3
    %tmp_const.3 = const.i64 i64 4
    %tmp_const.4 = const.i64 i64 5
    %tmp_call = call i64 @add5(%tmp_const, %tmp_const.1, %tmp_const.2, %tmp_const.3, %tmp_const.4)
    %x = alloca ptr
    store %x %tmp_call
    %tmp_const.5 = const.i64 i64 10
    %tmp_const.6 = const.i64 i64 20
    %tmp_const.7 = const.i64 i64 30
    %tmp_const.8 = const.i64 i64 40
    %tmp_const.9 = const.i64 i64 50
    %tmp_call.1 = call i64 @add5(%tmp_const.5, %tmp_const.6, %tmp_const.7, %tmp_const.8, %tmp_const.9)
    %y = alloca ptr
    store %y %tmp_call.1
    %tmp_load = load i64 %x
    %tmp_load.1 = load i64 %y
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}


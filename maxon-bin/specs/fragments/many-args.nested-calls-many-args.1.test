// Test: many-args.nested-calls-many-args.1
function add5(a int, b int, c int, d int, e int) returns int
    return a + b + c + d + e
end 'add5'

function main() returns int
    let x int = add5(1, 2, 3, 4, 5)
    let y int = add5(10, 20, 30, 40, 50)
    return x + y
end 'main'

// Test: variables.multiple-variables.1
function main() returns int
    let a = 10
    let b = 20
    return a + b
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_add
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

// Test: alloc-tracking.array-in-loop.1
function main() returns int
    var i = 0
    var sum = 0
    while i < 3 'loop'
        let size = 5
        var arr = Array of size int
        arr.set(0, value: i)
        var val = try arr.get(0) otherwise 0
        sum = sum + val
        i = i + 1
    end 'loop'
    return sum
end 'main'

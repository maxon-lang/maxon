    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %count = alloca ptr
    store %count %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 3
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block8
whilebody:
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.3
    store %x %tmp_add
    %tmp_const.4 = const.i64 i64 0
    %y = alloca ptr
    store %y %tmp_const.4
    br @block3
whilecond:
    %tmp_load.2 = load i64 %y
    %tmp_const.5 = const.i64 i64 5
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.2 %tmp_const.5
    br.cond %tmp_icmp.1 @block4 @block7
whilebody:
    %tmp_load.3 = load i64 %y
    %tmp_const.6 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.6
    store %y %tmp_add.1
    %tmp_load.4 = load i64 %count
    %tmp_const.7 = const.i64 i64 1
    %tmp_add.2 = add i64 %tmp_load.4 %tmp_const.7
    store %count %tmp_add.2
    %tmp_load.5 = load i64 %y
    %tmp_const.8 = const.i64 i64 2
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.5 %tmp_const.8
    br.cond %tmp_icmp.2 @block5 @block6
then:
    br @block1
    br @block6
end:
    br @block3
whilecont:

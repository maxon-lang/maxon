// Test: error-handling.error.enum-int-backed-error.1
// Int-backed enum error type (type inferred from values)
enum MyError is Error
    invalidInput = 1
    notFound = 404
end 'MyError'

function main() returns int
    return 42
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


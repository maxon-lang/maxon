// Test: nil-optional-types.struct-optional-param-with-value.1
type Point
    export var x int
    export var y int
end 'Point'

function getX(p Point or nil) returns int
    if let pt = p 'hasPoint'
        return pt.x
    end 'hasPoint' else 'noPoint'
        return 0
    end 'noPoint'
end 'getX'

function main() returns int
    var p = Point{x: 42, y: 10}
    return getX(p)
end 'main'
---
ExitCode: 42
---
function getX() -> i64 {
entry:
    %tmp_param = param ptr 0
    %p = alloca ptr
    store %p %tmp_param
    %tmp_load = load ptr %p
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    br.cond %tmp_icmp @block1 @block2
if_let_then:
    %pt = getfieldptr ptr %tmp_load 8
    %tmp_fieldptr.1 = getfieldptr ptr %pt 0
    %tmp_load.2 = load i64 %tmp_fieldptr.1
    ret %tmp_load.2
if_let_else:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
if_let_end:
}

function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 10
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_alloca.1 = alloca.sized ptr 24
    %tmp_const.2 = const.i64 i64 1
    store %tmp_alloca.1 %tmp_const.2
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_alloca.1 8
    memcpy %tmp_fieldptr.2 %p 16
    %tmp_call = call i64 @getX(%tmp_alloca.1)
    ret %tmp_call
}

---

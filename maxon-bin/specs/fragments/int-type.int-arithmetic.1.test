// Test: int-type.int-arithmetic.1
function main() returns int
    var a = 10
    var b = 20
    var sum = a + b
    return sum
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %sum = alloca ptr
    store %sum %tmp_add
    %tmp_load.2 = load i64 %sum
    ret %tmp_load.2
}

---

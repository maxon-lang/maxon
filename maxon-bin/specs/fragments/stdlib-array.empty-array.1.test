// Test: stdlib-array.empty-array.1
function main() returns int
    var arr = Array of int{}
    if arr.count() != 0 'check'
        return 1
    end 'check'
    if arr.isEmpty() == false 'empty'
        return 2
    end 'empty'
    return 0
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %arr = alloca.sized ptr 32
    memset %arr 0 32
    %tmp_call = call i64 @Array$int$count(%arr)
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.ne i64 %tmp_call %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    %tmp_load = load ptr %arr
    heap.free %tmp_load
    ret %tmp_const.1
end:
    %tmp_call.1 = call i64 @Array$int$isEmpty(%arr)
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp.1 = icmp.eq i64 %tmp_call.1 %tmp_const.2
    br.cond %tmp_icmp.1 @block3 @block4
then:
    %tmp_const.3 = const.i64 i64 2
    %tmp_load.1 = load ptr %arr
    heap.free %tmp_load.1
    ret %tmp_const.3
end:
    %tmp_const.4 = const.i64 i64 0
    %tmp_load.2 = load ptr %arr
    heap.free %tmp_load.2
    ret %tmp_const.4
}

function Array$int$count() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 8
    %tmp_load = load i64 %tmp_fieldptr.1
    ret %tmp_load
}

function Array$int$isEmpty() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 8
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    ret %tmp_icmp
}


    %tmp_load.5 = load ptr %tmp_fieldptr.4
    %tmp_elemptr = getelemptr ptr %tmp_load.5 %tmp_load.4 elemsize=40
    %tmp_const.5 = const.i64 i64 0
    store %tmp_param %tmp_const.5
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_param 8
    memcpy %tmp_fieldptr.5 %tmp_elemptr 40
    %tmp_fieldptr.6 = getfieldptr ptr %tmp_fieldptr.5 24
    %tmp_load.6 = load i32 %tmp_fieldptr.6
    %tmp_const.6 = const.i32 i32 3
    %tmp_band = band i32 %tmp_load.6 %tmp_const.6
    %tmp_const.7 = const.i32 i32 1
    %tmp_icmp.2 = icmp.eq i32 %tmp_band %tmp_const.7
    br.cond %tmp_icmp.2 @heap_incref_5 @slice_check_6
heap_incref_5:
    %tmp_load.7 = load ptr %tmp_fieldptr.5
    %tmp_const.8 = const.i64 i64 8
    %tmp_sub = sub ptr %tmp_load.7 %tmp_const.8
    %tmp_load.8 = load i64 %tmp_sub
    %tmp_const.9 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.8 %tmp_const.9
    store %tmp_sub %tmp_add
    br @incref_end_8
slice_check_6:
    %tmp_fieldptr.7 = getfieldptr ptr %tmp_fieldptr.5 24
    %tmp_load.9 = load i32 %tmp_fieldptr.7
    %tmp_const.10 = const.i32 i32 3
    %tmp_band.1 = band i32 %tmp_load.9 %tmp_const.10
    %tmp_const.11 = const.i32 i32 2
    %tmp_icmp.3 = icmp.eq i32 %tmp_band.1 %tmp_const.11
    br.cond %tmp_icmp.3 @slice_incref_7 @incref_end_8
slice_incref_7:
    %tmp_load.10 = load ptr %tmp_fieldptr.5
    %tmp_fieldptr.8 = getfieldptr ptr %tmp_fieldptr.5 28
    %tmp_load.11 = load i32 %tmp_fieldptr.8
    %tmp_sext = sext.i32.i64 i64 %tmp_load.11
    %tmp_sub.1 = sub ptr %tmp_load.10 %tmp_sext
    %tmp_const.12 = const.i64 i64 8
    %tmp_sub.2 = sub ptr %tmp_sub.1 %tmp_const.12
    %tmp_load.12 = load i64 %tmp_sub.2
    %tmp_const.13 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.12 %tmp_const.13
    store %tmp_sub.2 %tmp_add.1
    br @incref_end_8
incref_end_8:
    ret %tmp_param
}


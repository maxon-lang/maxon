// Test: command-line-args.numeric-args.1
function main(args Array of String) returns int
    // Args are strings, just verify we can access them
    if args.count() == 2 'check'
        var arg = try args.get(1) otherwise ""
        print(arg)
        return 0
    end 'check'
    return 1
end 'main'

then$upper_3:
    %tmp_const.3 = const.i64 i64 0
    %tmp_const.4 = const.i64 i64 1
    store %tmp_param %tmp_const.4
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_param 8

// Test: parameter-labels.mixed-positional-named.1
function process(value int, scale int) returns int
    return value * scale
end 'process'

function main() returns int
    return process(5, scale = 3)
end 'main'
---
ExitCode: 15
---
function process() -> i64 {
entry:
    %value = param i64 0
    %value.1 = alloca ptr
    store %value.1 %value
    %scale = param i64 1
    %scale.1 = alloca ptr
    store %scale.1 %scale
    %tmp_load = load i64 %value.1
    %tmp_load.1 = load i64 %scale.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    ret %tmp_mul
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 3
    %tmp_call = call i64 @process(%tmp_const, %tmp_const.1)
    ret %tmp_call
}

---

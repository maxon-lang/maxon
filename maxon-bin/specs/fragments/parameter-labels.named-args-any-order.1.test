// Test: parameter-labels.named-args-any-order.1
function subtract(a int, b int) returns int
    return a - b
end 'subtract'

function main() returns int
    return subtract(b: 3, a: 10)
end 'main'
---
ExitCode: 7
---
function subtract() -> i64 {
entry_0:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_sub = sub i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_sub
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 3
    %tmp_call = call i64 @subtract(%tmp_const, %tmp_const.1)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


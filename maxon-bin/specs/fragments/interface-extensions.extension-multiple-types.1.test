// Test: interface-extensions.extension-multiple-types.1
interface Valued
    function val() returns int
end 'Valued'

extension Valued
    function valPlusTen() returns int
        return self.val() + 10
    end 'valPlusTen'
end 'Valued'

type TypeA is Valued
    var a int
    function Valued.val() returns int
        return a
    end 'val'
end 'TypeA'

type TypeB is Valued
    var b int
    function Valued.val() returns int
        return b * 2
    end 'val'
end 'TypeB'

function main() returns int
    var ta = TypeA{a: 5}
    var tb = TypeB{b: 10}
    return ta.valPlusTen() + tb.valPlusTen()
end 'main'
---
ExitCode: 45
---
function main() -> i64 {
entry:
    %ta = alloca.sized ptr 8
    memset %ta 0 8
    %tmp_fieldptr = getfieldptr ptr %ta 0
    %tmp_const = const.i64 i64 5
    store %tmp_fieldptr %tmp_const
    %tb = alloca.sized ptr 8
    memset %tb 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %tb 0
    %tmp_const.1 = const.i64 i64 10
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call = call i64 @TypeA$valPlusTen(%ta)
    %tmp_call.1 = call i64 @TypeB$valPlusTen(%tb)
    %tmp_add = add i64 %tmp_call %tmp_call.1
    ret %tmp_add
}

function TypeA$valPlusTen() -> i64 {
entry:
    %self = param ptr 0
    %tmp_call = call i64 @TypeA$val(%self)
    %tmp_const = const.i64 i64 10
    %tmp_add = add i64 %tmp_call %tmp_const
    ret %tmp_add
}

function TypeB$valPlusTen() -> i64 {
entry:
    %self = param ptr 0
    %tmp_call = call i64 @TypeB$val(%self)
    %tmp_const = const.i64 i64 10
    %tmp_add = add i64 %tmp_call %tmp_const
    ret %tmp_add
}

function TypeA$val() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function TypeB$val() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load %tmp_const
    ret %tmp_mul
}


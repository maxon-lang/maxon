// Test: alloc-tracking.multiple-arrays.1
typealias IntArray is Array with int

function main() returns int
    let size1 = 5
    let size2 = 10
    var arr1 = IntArray{}
    arr1.resize(size1)
    var arr2 = IntArray{}
    arr2.resize(size2)
    arr1.set(0, value: 1)
    arr2.set(0, value: 2)
    var a = try arr1.get(0) otherwise 0
    var b = try arr2.get(0) otherwise 0
    return a + b
end 'main'

// Test: alloc-tracking.multiple-arrays.1
function main() returns int
    let size1 = 5
    let size2 = 10
    var arr1 = array of size1 int
    var arr2 = array of size2 int
    arr1[0] = 1
    arr2[0] = 2
    var sum = 0
    if let a = arr1[0] 'g1'
        sum = sum + a
    end 'g1'
    if let b = arr2[0] 'g2'
        sum = sum + b
    end 'g2'
    return sum
end 'main'

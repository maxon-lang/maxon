// Test: alloc-tracking.multiple-arrays.1
function main() returns int
    let size1 = 5
    let size2 = 10
    var arr1 = Array of size1 int
    var arr2 = Array of size2 int
    arr1.set(0, value: 1)
    arr2.set(0, value: 2)
    var a = try arr1.get(0) otherwise 0
    var b = try arr2.get(0) otherwise 0
    return a + b
end 'main'

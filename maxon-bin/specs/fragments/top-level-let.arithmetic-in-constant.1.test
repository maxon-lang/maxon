// Test: top-level-let.arithmetic-in-constant.1
let BASE = 10
let DOUBLED = BASE * 2

function main() returns int
    return DOUBLED
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 20
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


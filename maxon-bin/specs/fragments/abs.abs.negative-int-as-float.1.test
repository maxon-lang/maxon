// Test: abs.abs.negative-int-as-float.1
function main() returns int
    var neg = -42.0
    var x = abs(neg)
    return trunc(x)
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 42
    %tmp_fconst.1 = const.f64 f64 0
    %tmp_fsub = fsub f64 %tmp_fconst.1 %tmp_fconst
    %neg = alloca ptr
    store %neg %tmp_fsub
    %tmp_load = load f64 %neg
    %tmp_fabs = fabs f64 %tmp_load
    %x = alloca ptr
    store %x %tmp_fabs
    %tmp_load.1 = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_fptosi
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

// Test: enums.float-rawvalue-in-function.1
enum Weights
    light = 1.5
    medium = 2.5
end 'Weights'

function getRaw(w Weights) returns float
    return w.rawValue
end 'getRaw'

function main() returns int
    var w = Weights.medium
    var raw = getRaw(w)
    if raw > 2.0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function getRaw() -> f64 {
entry:
    %w = param i64 0
    %w.1 = alloca ptr
    store %w.1 %w
    %tmp_load = load i64 %w.1
    %tmp_bitcast = bitcast.i64.f64 f64 %tmp_load
    ret %tmp_bitcast
}

function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 2.5
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    %w = alloca ptr
    store %w %tmp_bitcast
    %tmp_load = load i64 %w
    %tmp_call = call f64 @getRaw(%tmp_load)
    %raw = alloca ptr
    store %raw %tmp_call
    %tmp_load.1 = load f64 %raw
    %tmp_fconst.1 = const.f64 f64 2
    %tmp_fcmp = fcmp.gt i64 %tmp_load.1 %tmp_fconst.1
    br.cond %tmp_fcmp @block1 @block2
then:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
end:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

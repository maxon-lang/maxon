// Test: bool-type.doc-example-1.1
function isPositive(x int) returns bool
    if x > 0 'check'
        return true
    end 'check'
    return false
end 'isPositive'

function main() returns int
    if isPositive(5) 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
ExitCode: 1
---
function isPositive() -> i64 {
entry:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load i64 %x.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @isPositive(%tmp_const)
    br.cond %tmp_call @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

---

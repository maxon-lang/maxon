// Test: bool-type.doc-example-1.1
function isPositive(x int) returns bool
    if x > 0 'check'
        return true
    end 'check'
    return false
end 'isPositive'

function main() returns int
    if isPositive(5) 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
ExitCode: 1
---
function isPositive() -> i64 {
entry_0:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load i64 %x.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @isPositive(%tmp_const)
    br.cond %tmp_call @then$test_1 @end$test_2
then$test_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const.1
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
end$test_2:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}


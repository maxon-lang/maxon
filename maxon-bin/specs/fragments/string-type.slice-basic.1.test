// Test: string-type.slice-basic.1
function main() returns int
    var s = "hello world"
    var start = s.startIndex()
    if let spaceIdx = s.find(" ") 'found'
        var sub = s.slice(start, spaceIdx)
        print(sub)
    end 'found'
    return 0
end 'main'

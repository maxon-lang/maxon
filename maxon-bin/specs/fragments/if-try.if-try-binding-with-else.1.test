// Test: if-try.if-try-binding-with-else.1
enum MyError is Error
    failed
end 'MyError'

function mayFail(succeed bool) returns int throws MyError
    if not succeed 'check'
        throw MyError.failed
    end 'check'
    return 42
end 'mayFail'

function main() returns int
    if let value = try mayFail(false) 'check'
        return value
    end 'check' else 'err'
        return 77
    end 'err'
    return 0
end 'main'
---
ExitCode: 77
---
function mayFail() -> i64 {
entry:
    %tmp_param = param ptr 0
    %succeed = param i64 1
    %succeed.1 = alloca ptr
    store %succeed.1 %succeed
    %tmp_load = load i64 %succeed.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 0
    %tmp_const.2 = const.i64 i64 1
    store %tmp_param %tmp_const.2
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const.1
    ret %tmp_param
end:
    %tmp_const.3 = const.i64 i64 42
    %tmp_const.4 = const.i64 i64 0
    store %tmp_param %tmp_const.4
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.3
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 0
    %tmp_call = call ptr @mayFail(%tmp_alloca, %tmp_const)
    %tmp_load = load i64 %tmp_alloca
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    %tmp_alloca.1 = alloca ptr
    br.cond %tmp_icmp @block1 @block2
try_success:
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca 8
    %tmp_load.1 = load i64 %tmp_fieldptr
    store %tmp_alloca.1 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
if_try_else:
    %tmp_const.2 = const.i64 i64 77
    ret %tmp_const.2
try_merge:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

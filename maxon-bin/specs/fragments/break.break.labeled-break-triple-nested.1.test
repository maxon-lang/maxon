    %tmp_const.2 = const.i64 i64 1
    br.cond %tmp_const.2 @whilebody_4 @whilecont_10
whilebody_4:
    br @whilecond_5
whilecond_5:
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @whilebody_6 @whilecont_9
whilebody_6:
    %tmp_load = load i64 %result
    %tmp_const.4 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const.4
    store %result %tmp_add
    %tmp_load.1 = load i64 %result
    %tmp_const.5 = const.i64 i64 5
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.5
    br.cond %tmp_icmp @then$check_7 @end$check_8
then$check_7:

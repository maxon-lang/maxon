function sumFloats() -> f64 {
entry:
    %a = param f64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param f64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %c = param f64 2
    %c.1 = alloca ptr
    store %c.1 %c
    %d = param f64 3
    %d.1 = alloca ptr
    store %d.1 %d
    %e = param f64 4
    %e.1 = alloca ptr
    store %e.1 %e
    %f = param f64 5
    %f.1 = alloca ptr
    store %f.1 %f
    %g = param f64 6
    %g.1 = alloca ptr
    store %g.1 %g
    %h = param f64 7
    %h.1 = alloca ptr

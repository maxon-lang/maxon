// Test: ownership.reassignment.1
function main() returns int
    var a = 10
    a = 20
    a = 30
    return a
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 20
    store %a %tmp_const.1
    %tmp_const.2 = const.i64 i64 30
    store %a %tmp_const.2
    %tmp_load = load i64 %a
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

// Test: interface-conformance.conformance-basic.1
interface Counter
    function get() returns int
    function increment()
end 'Counter'

type SimpleCounter is Counter
    var value int

    function Counter.get() returns int
        return value
    end 'get'

    function Counter.increment()
        value = value + 1
    end 'increment'
end 'SimpleCounter'

function main() returns int
    var c = SimpleCounter{value: 40}
    c.increment()
    c.increment()
    return c.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    memset %c 0 8
    %tmp_fieldptr = getfieldptr ptr %c 0
    %tmp_const = const.i64 i64 40
    store %tmp_fieldptr %tmp_const
    call @SimpleCounter$increment(%c)
    call @SimpleCounter$increment(%c)
    %tmp_call = call i64 @SimpleCounter$get(%c)
    ret %tmp_call
}

function SimpleCounter$get() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function SimpleCounter$increment() -> void {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret
}

---

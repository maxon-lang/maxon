// Test: assignment.doc-example-1.1
function main() returns int
    var x = 10
    x = 20          // Update x
    x = x + 5       // x is now 25
    return x
end 'main'
---
ExitCode: 25
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 20
    store %x %tmp_const.1
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 5
    %tmp_add = add i64 %tmp_load %tmp_const.2
    store %x %tmp_add
    %tmp_load.1 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
}

---

// Test: challenge-sized-arrays.variable-sized-array-from-parameter.1
function make_array(size int) returns int
    var arr = Array of size int
    arr[0] = 42
    if let val = arr[0] 'get'
        return val
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'make_array'

function main() returns int
    return make_array(5)
end 'main'
---
ExitCode: 42
---
function make_array() -> i64 {
entry:
    %size = param i64 0
    %size.1 = alloca ptr
    store %size.1 %size
    %tmp_load = load i64 %size.1
    %tmp_const = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.1 = load ptr %arr
    %tmp_const.1 = const.i64 i64 0
    %tmp_const.2 = const.i64 i64 42
    %10 = getelemptr ptr %tmp_load.1 %tmp_const.1
    store %10 %tmp_const.2
    %tmp_load.2 = load ptr %arr
    %tmp_const.3 = const.i64 i64 0
    %13 = getelemptr ptr %tmp_load.2 %tmp_const.3
    %tmp_load.3 = load i64 %13
    %tmp_alloca.2 = alloca.sized ptr 16
    %tmp_const.4 = const.i64 i64 1
    store %tmp_alloca.2 %tmp_const.4
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca.2 8
    store %tmp_fieldptr %tmp_load.3
    %tmp_load.4 = load i64 %tmp_alloca.2
    %tmp_const.5 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.4 %tmp_const.5
    %tmp_load = br.cond %tmp_icmp @block1
if_let_then:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.2 8
    %tmp_load.5 = load i64 %tmp_fieldptr.1
    %val = alloca ptr
    store %val %tmp_load.5
    %tmp_load.6 = load i64 %val
    %tmp_load.7 = load ptr %arr
    heap.free %tmp_load.7
    ret %tmp_load.6
if_let_else:
    %tmp_const.6 = const.i64 i64 0
    %tmp_load.8 = load ptr %arr
    heap.free %tmp_load.8
    ret %tmp_const.6
if_let_end:
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @make_array(%tmp_const)
    ret %tmp_call
}

---

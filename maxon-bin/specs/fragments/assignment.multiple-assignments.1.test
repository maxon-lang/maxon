// Test: assignment.multiple-assignments.1
function main() returns int
    var x = 10
    var y = 20
    x = y
    y = 30
    return x + y
end 'main'
---
ExitCode: 50
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %y = alloca ptr
    store %y %tmp_const.1
    %tmp_load = load i64 %y
    store %x %tmp_load
    %tmp_const.2 = const.i64 i64 30
    store %y %tmp_const.2
    %tmp_load.1 = load i64 %x
    %tmp_load.2 = load i64 %y
    %tmp_add = add i64 %tmp_load.1 %tmp_load.2
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_add
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
}

---

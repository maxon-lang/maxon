// Test: print-function.doc-example-1.1
function main() returns int
    var x = 42
    print("{x}\n")        // Prints: 42
    print("{10 + 5}\n")   // Prints: 15
    print("{100}\n")      // Prints: 100
    return 0
end 'main'

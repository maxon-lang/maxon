    memcpy %14 %value 32
    %tmp_fieldptr.3 = getfieldptr ptr %value 24
    %tmp_load.4 = load i32 %tmp_fieldptr.3
    %tmp_const.2 = const.i32 i32 3
    %tmp_band = band i32 %tmp_load.4 %tmp_const.2
    %tmp_const.3 = const.i32 i32 1
    %tmp_icmp = icmp.eq i32 %tmp_band %tmp_const.3
    br.cond %tmp_icmp @block1 @block2
incref:
    %tmp_load.5 = load ptr %value
    %tmp_const.4 = const.i64 i64 8
    %tmp_sub = sub ptr %tmp_load.5 %tmp_const.4
    %tmp_load.6 = load i64 %tmp_sub
    %tmp_const.5 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.6 %tmp_const.5
    store %tmp_sub %tmp_add.1
    br @block2
incref_end:
    %tmp_fieldptr.4 = getfieldptr ptr %self 0
    %tmp_load.7 = load i64 %len
    %tmp_const.6 = const.i64 i64 1
    %tmp_add.2 = add i64 %tmp_load.7 %tmp_const.6
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_fieldptr.4 8
    store %tmp_fieldptr.5 %tmp_add.2
    memcpy %tmp_param %self 40
    ret %tmp_param
}

function Array$String$ensureCapacity() -> void {
entry:
    %self = param ptr 0
    %requiredLen = param i64 1
    %requiredLen.1 = alloca ptr
    store %requiredLen.1 %requiredLen
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 16
    %tmp_load = load i64 %tmp_fieldptr.1
    %cap = alloca ptr
    store %cap %tmp_load
    %tmp_load.1 = load i64 %requiredLen.1
    %tmp_load.2 = load i64 %cap
    %tmp_icmp = icmp.gt i64 %tmp_load.1 %tmp_load.2
    br.cond %tmp_icmp @block1 @block7
then:
    %tmp_load.3 = load i64 %cap
    %newCap = alloca ptr
    store %newCap %tmp_load.3
    %tmp_load.4 = load i64 %newCap
    %tmp_const = const.i64 i64 4
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.4 %tmp_const
    br.cond %tmp_icmp.1 @block2 @block3
then:
    %tmp_const.1 = const.i64 i64 4
    store %newCap %tmp_const.1
    br @block3
end:
    br @block4
whilecond:
    %tmp_load.5 = load i64 %newCap
    %tmp_load.6 = load i64 %requiredLen.1
    %tmp_icmp.2 = icmp.lt i64 %tmp_load.5 %tmp_load.6
    br.cond %tmp_icmp.2 @block5 @block6
whilebody:
    %tmp_load.7 = load i64 %newCap
    %tmp_const.2 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load.7 %tmp_const.2
    store %newCap %tmp_mul
    br @block4
whilecont:
    %tmp_fieldptr.2 = getfieldptr ptr %self 0
    %tmp_load.8 = load i64 %newCap
    %tmp_const.3 = const.i64 i64 32
    %tmp_mul.1 = mul i64 %tmp_load.8 %tmp_const.3
    %tmp_load.9 = load ptr %tmp_fieldptr.2
    %tmp_realloc = heap.realloc ptr %tmp_load.9 %tmp_mul.1 tag="array grow"
    store %tmp_fieldptr.2 %tmp_realloc
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_fieldptr.2 16
    store %tmp_fieldptr.3 %tmp_load.8
    br @block7
end:
    ret
}


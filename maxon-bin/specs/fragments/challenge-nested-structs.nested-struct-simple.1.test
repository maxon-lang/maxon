// Test: challenge-nested-structs.nested-struct-simple.1
type Inner
    var x int
    var y int
end 'Inner'

type Outer
    var inner Inner
    var z int
end 'Outer'

function main() returns int
    var inner = Inner{x: 10, y: 20}
    var outer = Outer{inner: inner, z: 30}
    return outer.inner.x + outer.inner.y + outer.z
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %inner = alloca.sized ptr 16
    %tmp_fieldptr.8 = memset %inner 0
    %tmp_fieldptr = getfieldptr ptr %inner 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %inner 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %outer = alloca.sized ptr 24
    %24 = memset %outer 0
    %tmp_fieldptr.2 = getfieldptr ptr %outer 0
    %tmp_fieldptr.8 = memcpy %tmp_fieldptr.2 %inner
    %tmp_fieldptr.3 = getfieldptr ptr %outer 16
    %tmp_const.2 = const.i64 i64 30
    store %tmp_fieldptr.3 %tmp_const.2
    %tmp_fieldptr.4 = getfieldptr ptr %outer 0
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_fieldptr.4 0
    %tmp_load = load i64 %tmp_fieldptr.5
    %tmp_fieldptr.6 = getfieldptr ptr %outer 0
    %tmp_fieldptr.7 = getfieldptr ptr %tmp_fieldptr.6 8
    %tmp_load.1 = load i64 %tmp_fieldptr.7
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_add.1 = add i64 %tmp_add %tmp_const.2
    ret %tmp_add.1
}

---

    %tmp_const = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const
    %tmp_const.1 = const.i64 i64 1
    %x = alloca ptr
    store %x %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.le i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block3
whilebody:
    %tmp_load.1 = load i64 %result
    %tmp_load.2 = load i64 %x
    %tmp_const.3 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load.2 %tmp_const.3
    %tmp_add = add i64 %tmp_load.1 %tmp_mul
    store %result %tmp_add
    %tmp_load.3 = load i64 %x
    %tmp_const.4 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.4
    store %x %tmp_add.1
    br @block1
whilecont:
    %tmp_load.4 = load i64 %result
    ret %tmp_load.4
}

function main() -> i64 {
entry:
    %tmp_call = call i64 @compute()
    ret %tmp_call

// Test: ir-generation.optimization-verification.1
function compute() returns int
    var result = 0
    var x = 1
    while x <= 5 'loop'
        result = result + x * 2
        x = x + 1
    end 'loop'
    return result
end 'compute'

function main() returns int
    return compute()
end 'main'

// Test: string-interpolation.custom-stringable.1
type Pair is Stringable
    var first int
    var second int

    function Stringable.toString(_ String or nil) returns String
        return "[{first}, {second}]"
    end 'toString'
end 'Pair'

function main() returns int
    var p = Pair{first: 1, second: 2}
    print("{p}")
    return 0
end 'main'
---
ExitCode: 0
Stdout: [1, 2]
---

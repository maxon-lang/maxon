// Test: alloc-tracking.array-zero-size-no-alloc.1
typealias IntArray is Array with int

function main() returns int
    let size = 0
    var arr = IntArray{}
    arr.resize(size)
    if size > 0 'check'
        arr.set(0, value: 1)
    end 'check'
    return 42
end 'main'

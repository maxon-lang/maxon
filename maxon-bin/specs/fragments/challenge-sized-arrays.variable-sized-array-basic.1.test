function main() returns int
    var n = 3
    var arr = Array of n int
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    var sum = 0
    if let a = arr[0] 'g0'
        sum = sum + a
    end 'g0'
    if let b = arr[1] 'g1'
        sum = sum + b
    end 'g1'
    if let c = arr[2] 'g2'
        sum = sum + c
    end 'g2'
    return sum
end 'main'

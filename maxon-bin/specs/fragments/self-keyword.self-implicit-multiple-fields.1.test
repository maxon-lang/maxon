// Test: self-keyword.self-implicit-multiple-fields.1
type Rectangle
    var width int
    var height int

    function area() returns int
        return width * height
    end 'area'
end 'Rectangle'

function main() returns int
    var r = Rectangle{width: 6, height: 7}
    return r.area()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %r = alloca.sized ptr 16
    memset %r 0 16
    %tmp_fieldptr = getfieldptr ptr %r 0
    %tmp_const = const.i64 i64 6
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %r 8
    %tmp_const.1 = const.i64 i64 7
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call = call i64 @Rectangle$area(%r)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Rectangle$area() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %self 8
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_mul
    %tmp_load.2 = load i64 %tmp_alloca
    ret %tmp_load.2
}

---

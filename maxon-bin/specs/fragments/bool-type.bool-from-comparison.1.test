// Test: bool-type.bool-from-comparison.1
function main() returns int
    var result = 5 > 3
    if result 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 3
    %tmp_icmp = icmp.gt i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 42
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

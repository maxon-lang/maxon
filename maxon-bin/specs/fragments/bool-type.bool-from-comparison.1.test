// Test: bool-type.bool-from-comparison.1
function main() returns int
    var result = 5 > 3
    if result 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 3
    %tmp_icmp = icmp.gt i64 %tmp_const %tmp_const.1
    %result = alloca ptr
    store %result %tmp_icmp
    %tmp_load = load i64 %result
    br.cond %tmp_load @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 42
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.3
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

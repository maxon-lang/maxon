// Test: match-statements.match-statements.assignment.1
function main() returns int
    var x = 2
    var result = 0
    match x 'process'
        1 then result = 100
        2 then result = 200
        default then result = 0
    end 'process'
    return result
end 'main'
---
ExitCode: 200
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 2
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const.1
    %tmp_load.1 = load i64 %x
    br @block1
match_check:
    %tmp_const.4 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.4
    br.cond %tmp_icmp @block2 @block3
match_body:
    %tmp_const.5 = const.i64 i64 100
    store %result %tmp_const.5
    br @block6
match_check:
    %tmp_const.6 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.6
    br.cond %tmp_icmp.1 @block4 @block5
match_body:
    %tmp_const.7 = const.i64 i64 200
    store %result %tmp_const.7
    br @block6
match_default:
    %tmp_const.8 = const.i64 i64 0
    store %result %tmp_const.8
    br @block6
match_merge:
    %tmp_load.2 = load i64 %result
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
}

---

// Test: match-statements.match-statements.assignment.1
function main() returns int
    var x = 2
    var result = 0
    match x 'process'
        1 then result = 100
        2 then result = 200
        default then result = 0
    end 'process'
    return result
end 'main'
---
ExitCode: 200
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    %tmp_const.1 = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const.1
    br @match_check_1
match_check_1:
    %tmp_const.4 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.4
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.5 = const.i64 i64 100
    store %result %tmp_const.5
    br @match_merge_6
match_check_3:
    %tmp_const.6 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_const %tmp_const.6
    br.cond %tmp_icmp.1 @match_body_4 @match_default_5
match_body_4:
    %tmp_const.7 = const.i64 i64 200
    store %result %tmp_const.7
    br @match_merge_6
match_default_5:
    %tmp_const.8 = const.i64 i64 0
    store %result %tmp_const.8
    br @match_merge_6
match_merge_6:
    %tmp_load.2 = load i64 %result
    ret %tmp_load.2
}

---

// Test: pow.square.1
function main() returns int
    var result = Math.pow(5.0, 2.0)
    return trunc(result)
end 'main'
---
ExitCode: 25
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 5
    %tmp_fconst.1 = const.f64 f64 2
    %tmp_call = call f64 @Math$pow(%tmp_fconst, %tmp_fconst.1)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}

---

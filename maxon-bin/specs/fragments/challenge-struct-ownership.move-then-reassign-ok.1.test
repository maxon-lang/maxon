// Test: challenge-struct-ownership.move-then-reassign-ok.1
type Data
    var value int
end 'Data'

function consume(d Data) returns int
    d.value = 100
    return d.value
end 'consume'

function main() returns int
    var d = Data{value: 10}
    var first = consume(d)
    d = Data{value: 20}
    var second = consume(d)
    return first + second
end 'main'
---
ExitCode: 200
---
function consume() -> i64 {
entry:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 100
    store %tmp_fieldptr %tmp_const
    ret %tmp_const
}

function main() -> i64 {
entry:
    %d = alloca.sized ptr 8
    memset %d 0 8
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @consume(%d)
    %first = alloca ptr
    store %first %tmp_call
    %tmp_alloca.2 = alloca.sized ptr 8
    memset %tmp_alloca.2 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.2 0
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call.1 = call i64 @consume(%tmp_alloca.2)
    %second = alloca ptr
    store %second %tmp_call.1
    %tmp_load = load i64 %first
    %tmp_load.1 = load i64 %second
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

---

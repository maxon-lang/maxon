// Test: arithmetic-operators.modulo.1
function main() returns int
    return 17 mod 5
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry:
    %tmp_mod = const.i64 i64 2
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_mod
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


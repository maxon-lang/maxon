// Test: bitwise-operators.shift-vs-comparison.1
function main() returns int
    // Shift has higher precedence than comparison
    // 1 << 3 = 8, then 8 > 5 = true
    if 1 << 3 > 5 'check'
        print("{1}\n")
    end 'check' else 'else_check'
        print("{0}\n")
    end 'else_check'
    return 0
end 'main'

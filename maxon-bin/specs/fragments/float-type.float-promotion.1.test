// Test: float-type.float-promotion.1
function main() returns int
    var x = 5
    var y = 2.0
    var result = x + y
    return trunc(result)
end 'main'
---
ExitCode: 7
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_fconst = const.f64 f64 2
    %y = alloca ptr
    store %y %tmp_fconst
    %tmp_load = load i64 %x
    %tmp_load.1 = load f64 %y
    %tmp_sitofp = sitofp f64 %tmp_load
    %tmp_fadd = fadd f64 %tmp_sitofp %tmp_load.1
    %result = alloca ptr
    store %result %tmp_fadd
    %tmp_load.2 = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load.2
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_fptosi
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}


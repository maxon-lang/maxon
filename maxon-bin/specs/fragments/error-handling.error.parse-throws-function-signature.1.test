// Test: error-handling.error.parse-throws-function-signature.1
// Functions can declare they throw a specific error type
type MyError is Error
    var code int
end 'MyError'

// This function signature declares it throws MyError
// (body doesn't actually throw - just testing signature parsing)
function mayFail() returns int throws MyError
    return 10
end 'mayFail'

function main() returns int
    return 42
end 'main'
---
ExitCode: 42
---
function mayFail() -> i64 {
entry:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 0
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    ret %tmp_const
}

---

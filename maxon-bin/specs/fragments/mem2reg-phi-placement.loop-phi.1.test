// Test: mem2reg-phi-placement.loop-phi.1
function main() returns int
    var sum = 0
    var i = 1
    while i <= 5 'loop'
        sum = sum + i
        i = i + 1
    end 'loop'
    return sum
end 'main'
---
ExitCode: 15
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %sum = alloca ptr
    store %sum %tmp_const
    %tmp_const.1 = const.i64 i64 1
    %i = alloca ptr
    store %i %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.le i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block3
whilebody:
    %tmp_load.1 = load i64 %sum
    %tmp_load.2 = load i64 %i
    %tmp_add = add i64 %tmp_load.1 %tmp_load.2
    store %sum %tmp_add
    %tmp_load.3 = load i64 %i
    %tmp_const.3 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.3
    store %i %tmp_add.1
    br @block1
whilecont:
    %tmp_load.4 = load i64 %sum
    ret %tmp_load.4
}

---

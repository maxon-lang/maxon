// Test: self-keyword.self-modify-and-return.1
type Value
    var n int

    function double()
        self.n = self.n * 2
    end 'double'

    function get() returns int
        return self.n
    end 'get'
end 'Value'

function main() returns int
    var v = Value{n: 21}
    v.double()
    return v.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %v = alloca.sized ptr 8
    memset %v 0 8
    %tmp_fieldptr = getfieldptr ptr %v 0
    %tmp_const = const.i64 i64 21
    store %tmp_fieldptr %tmp_const
    call @Value$double(%v)
    %tmp_call = call i64 @Value$get(%v)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Value$double() -> void {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load %tmp_const
    store %tmp_fieldptr %tmp_mul
    ret
}

function Value$get() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

---

// Test: enums.match-enum-binding-simple.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = Container.value(42)
    match c 'extract'
        empty then return 0
        value(n) then return n
    end 'extract'
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_alloca = alloca ptr
    %tmp_const = const.i64 i64 16
    %tmp_heap = heap.alloc ptr %tmp_const tag="enum storage"
    store %tmp_alloca %tmp_heap
    %tmp_const.1 = const.i64 i64 1
    store %tmp_heap %tmp_const.1
    %tmp_const.2 = const.i64 i64 42
    %tmp_fieldptr = getfieldptr ptr %tmp_heap 8
    store %tmp_fieldptr %tmp_const.2
    %tmp_load = load ptr %tmp_alloca
    %c = alloca ptr
    store %c %tmp_load
    %tmp_load.2 = load i64 %c
    br @block1
match_check:
    %tmp_const.5 = const.i64 i64 0
    %tmp_load.3 = load i64 %tmp_load.2
    %tmp_icmp = icmp.eq i64 %tmp_load.3 %tmp_const.5
    br.cond %tmp_icmp @block2 @block3
match_body:
    %tmp_const.6 = const.i64 i64 0
    ret %tmp_const.6
match_check:
    %tmp_const.7 = const.i64 i64 1
    %tmp_load.4 = load i64 %tmp_load.2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.4 %tmp_const.7
    br.cond %tmp_icmp.1 @block4 @block5
match_body:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_load.2 8
    %tmp_load.5 = load i64 %tmp_fieldptr.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.5
    %tmp_load.6 = load i64 %tmp_alloca.2
    ret %tmp_load.6
match_merge:
}


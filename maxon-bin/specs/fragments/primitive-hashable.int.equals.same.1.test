// Test: primitive-hashable.int.equals.same.1
function main() returns int
    var a = 42
    var b = 42
    if a.equals(b) 'eq'
        return 1
    end 'eq'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 42
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_load.1
    %tmp_const.1 = br.cond %tmp_icmp @block1
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

// Test: enums.match-enum-no-binding.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = Container.empty
    match c 'check'
        empty then return 1
        value(n) then return n
    end 'check'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    br @match_check_1
match_check_1:
    %tmp_const.3 = const.i64 i64 0
    %tmp_load.2 = load i64 %tmp_const
    %tmp_icmp = icmp.eq i64 %tmp_load.2 %tmp_const.3
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.4 = const.i64 i64 1
    ret %tmp_const.4
match_check_3:
    %tmp_const.5 = const.i64 i64 1
    %tmp_load.4 = load i64 %tmp_const
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.4 %tmp_const.5
    br.cond %tmp_icmp.1 @match_body_4 @match_merge_5
match_body_4:
    %tmp_fieldptr = getfieldptr ptr %tmp_const 8
    %tmp_load.5 = load i64 %tmp_fieldptr
    ret %tmp_load.5
match_merge_5:
}

---

// Test: challenge-struct-lifetime.multiple-struct-returns.1
type Value
    export var n int
end 'Value'

function step1() returns Value
    return {n: 1}
end 'step1'

function step2(v Value) returns Value
    return {n: v.n + 10}
end 'step2'

function step3(v Value) returns Value
    return {n: v.n + 100}
end 'step3'

function main() returns int
    var v1 = step1()
    var v2 = step2(v1)
    var v3 = step3(v2)
    return v3.n
end 'main'
---
ExitCode: 111
---
function step1() -> ptr {
entry:
    %tmp_param = param ptr 0
    memset %tmp_param 0 8
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_const = const.i64 i64 1
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function step2() -> ptr {
entry:
    %tmp_param = param ptr 0
    %v = param ptr 1
    memset %tmp_param 0 8
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_fieldptr.1 = getfieldptr ptr %v 0
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 10
    %tmp_add = add i64 %tmp_load %tmp_const
    store %tmp_fieldptr %tmp_add
    ret %tmp_param
}

function step3() -> ptr {
entry:
    %tmp_param = param ptr 0
    %v = param ptr 1
    memset %tmp_param 0 8
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_fieldptr.1 = getfieldptr ptr %v 0
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 100
    %tmp_add = add i64 %tmp_load %tmp_const
    store %tmp_fieldptr %tmp_add
    ret %tmp_param
}

function main() -> i64 {
entry:
    %v1 = alloca.sized ptr 8
    %tmp_call = call ptr @step1(%v1)
    %v2 = alloca.sized ptr 8
    %tmp_call.1 = call ptr @step2(%v2, %v1)
    %v3 = alloca.sized ptr 8
    %tmp_call.2 = call ptr @step3(%v3, %v2)
    %tmp_fieldptr = getfieldptr ptr %v3 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.3
    ret %tmp_load.1
}


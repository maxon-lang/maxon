// Test: while-loops.while-loops.zero-iterations.1
function main() returns int
    var x = 10
    while x < 5 'loop'
        x = x + 1
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    br @whilecond_1
whilecond_1:
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @whilebody_2 @whilecont_3
whilebody_2:
    %tmp_load.1 = load i64 %x
    %tmp_const.2 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.2
    store %x %tmp_add
    br @whilecond_1
whilecont_3:
    %tmp_load.2 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.1
    ret %tmp_load.3
}

---

// Test: string-type.grapheme-iteration-emoji.1
function main() returns int
    var s = "a🎉b"
    var count = 0
    for c in s 'loop'
        print("{c}")  // Use c to avoid unused warning
        count = count + 1
    end 'loop'
    print("\n{count}\n")
    return 0
end 'main'

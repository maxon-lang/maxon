    %tmp_load.37 = load ptr %s
    %tmp_sub.18 = sub ptr %tmp_load.37 %tmp_const.100
    heap.free %tmp_sub.18 tag="string cleanup"
    br @block23
decref_end:
    ret %tmp_const.97
}


// Test: challenge-sized-arrays.variable-sized-array-computed-size.1
function main() returns int
    var base = 2
    var multiplier = 3
    var size = base * multiplier
    var arr = Array of size int
    arr[5] = 99
    if let val = arr[5] 'get'
        return val
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'main'
---
ExitCode: 99
---
function main() -> i64 {

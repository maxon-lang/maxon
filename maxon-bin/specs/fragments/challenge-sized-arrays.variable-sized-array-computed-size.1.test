    %tmp_const.3 = const.i64 i64 5
    %tmp_const.4 = const.i64 i64 99
    %16 = getelemptr ptr %tmp_load.3 %tmp_const.3
    store %16 %tmp_const.4
    %tmp_load.4 = load ptr %arr
    %tmp_const.5 = const.i64 i64 5
    %19 = getelemptr ptr %tmp_load.4 %tmp_const.5
    %tmp_load.5 = load i64 %19
    %tmp_alloca.4 = alloca.sized ptr 16
    %tmp_const.6 = const.i64 i64 1
    store %tmp_alloca.4 %tmp_const.6
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca.4 8
    store %tmp_fieldptr %tmp_load.5
    %tmp_load.6 = load i64 %tmp_alloca.4
    %tmp_const.7 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.6 %tmp_const.7
    %tmp_const.1 = br.cond %tmp_icmp @block1
if_let_then:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.4 8
    %tmp_load.7 = load i64 %tmp_fieldptr.1
    %val = alloca ptr
    store %val %tmp_load.7
    %tmp_load.8 = load i64 %val

// Test: associated-types.doc-example-1.1
function main() returns int
    var s = "Hi"
    for ch in s 'chars'
        // ch has type 'character' (inferred from string's Element type - grapheme cluster)
        var cps = ch.codepoints()
        if let cp = cps.next() 'get_cp'
            print("{cp}\n")
        end 'get_cp'
    end 'chars'
    return 0
end 'main'

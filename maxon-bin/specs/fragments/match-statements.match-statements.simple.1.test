// Test: match-statements.match-statements.simple.1
function main() returns int
    var x = 2
    match x 'check'
        1 then return 10
        2 then return 20
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    br @match_check_1
match_check_1:
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.3
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.4 = const.i64 i64 10
    ret %tmp_const.4
match_check_3:
    %tmp_const.5 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_const %tmp_const.5
    br.cond %tmp_icmp.1 @match_body_4 @match_default_5
match_body_4:
    %tmp_const.6 = const.i64 i64 20
    ret %tmp_const.6
match_default_5:
    %tmp_const.7 = const.i64 i64 0
    ret %tmp_const.7
match_merge_6:
}

---

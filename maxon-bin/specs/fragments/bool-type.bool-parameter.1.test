ExitCode: 1
---
function test_bool_param() -> i64 {
entry_0:
    %flag = param i64 0
    br.cond %flag @then$check_1 @else$check_2
then$check_1:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
else$check_2:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
end$check_3:
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    %tmp_call = call i64 @test_bool_param(%tmp_const)
    ret %tmp_call

// Test: bool-type.bool-parameter.1
function test_bool_param(flag bool) returns int
    if flag 'check'
        return 1
    end 'check' else 'else_check'
        return 0
    end 'else_check'
end 'test_bool_param'

function main() returns int
    return test_bool_param(true)
end 'main'
---
ExitCode: 1
---
function test_bool_param() -> i64 {
entry_0:
    %flag = param i64 0
    %flag.1 = alloca ptr
    store %flag.1 %flag
    %tmp_load = load i64 %flag.1
    br.cond %tmp_load @then$check_1 @else$check_2
then$check_1:
    %tmp_const = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
else$check_2:
    %tmp_const.1 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end$check_3:
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    %tmp_call = call i64 @test_bool_param(%tmp_const)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


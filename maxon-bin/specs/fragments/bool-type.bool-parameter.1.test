// Test: bool-type.bool-parameter.1
function test_bool_param(flag bool) returns int
    if flag 'check'
        return 1
    end 'check' else 'else_check'
        return 0
    end 'else_check'
end 'test_bool_param'

function main() returns int
    return test_bool_param(true)
end 'main'

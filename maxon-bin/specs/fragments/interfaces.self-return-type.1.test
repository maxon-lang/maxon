// Test: interfaces.self-return-type.1
interface Movable
    function move(dx int, dy int) returns Self
end 'Movable'

type Point is Movable
    export var x int
    export var y int

    function Movable.move(dx int, dy int) returns Point
        return {x: x + dx, y: y + dy}
    end 'move'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    var p2 = p.move(5, 10)
    return p2.x + p2.y
end 'main'
---
ExitCode: 45
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %p2 = alloca.sized ptr 16
    %tmp_const.2 = const.i64 i64 5
    %tmp_const.3 = const.i64 i64 10
    %tmp_call = call ptr @Point$move(%p2, %p, %tmp_const.2, %tmp_const.3)
    %tmp_fieldptr.2 = getfieldptr ptr %p2 0
    %tmp_load = load i64 %tmp_fieldptr.2
    %tmp_fieldptr.3 = getfieldptr ptr %p2 8
    %tmp_load.1 = load i64 %tmp_fieldptr.3
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

function Point$move() -> ptr {
entry:
    %tmp_param = param ptr 0
    %self = param ptr 1
    %dx = param i64 2
    %dx.1 = alloca ptr
    store %dx.1 %dx
    %dy = param i64 3
    %dy.1 = alloca ptr
    store %dy.1 %dy
    memset %tmp_param 0 16
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_load.1 = load i64 %dx.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    store %tmp_fieldptr %tmp_add
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_param 8
    %tmp_fieldptr.3 = getfieldptr ptr %self 8
    %tmp_load.2 = load i64 %tmp_fieldptr.3
    %tmp_load.3 = load i64 %dy.1
    %tmp_add.1 = add i64 %tmp_load.2 %tmp_load.3
    store %tmp_fieldptr.2 %tmp_add.1
    ret %tmp_param
}


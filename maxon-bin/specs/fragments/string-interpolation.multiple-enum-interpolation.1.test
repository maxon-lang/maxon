// Test: string-interpolation.multiple-enum-interpolation.1
enum Priority int
    low = 1
    medium = 2
    high = 3
end 'Priority'

function main() returns int
    var p1 = Priority.low
    var p2 = Priority.high
    print("Priorities: {p1} and {p2}")
    return 0
end 'main'
---
ExitCode: 0
Stdout: Priorities: 1 and 3
---

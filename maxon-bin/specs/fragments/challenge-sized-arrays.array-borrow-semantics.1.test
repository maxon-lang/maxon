// Test: challenge-sized-arrays.array-borrow-semantics.1
function readFirst(arr Array of 3 int) returns int
    if let val = arr[0] 'get'
        return val
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'readFirst'

function main() returns int
    var arr = Array of 3 int
    arr[0] = 42
    var result = readFirst(arr)
    var val = 0
    if let v = arr[0] 'get'
        val = v
    end 'get'
    return val + result
end 'main'

// Test: mem2reg-phi-placement.loop-counter.1
function main() returns int
    var count = 0
    var i = 0
    while i < 10 'loop'
        if i mod 2 == 0 'even'
            count = count + 1
        end 'even'
        i = i + 1
    end 'loop'
    return count
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %count = alloca ptr
    store %count %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %i = alloca ptr
    store %i %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 10
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block5
whilebody:
    %tmp_load.1 = load i64 %i
    %tmp_const.3 = const.i64 i64 2
    %tmp_mod = mod i64 %tmp_load.1 %tmp_const.3
    %tmp_const.4 = const.i64 i64 0
    %tmp_icmp.1 = icmp.eq i64 %tmp_mod %tmp_const.4
    br.cond %tmp_icmp.1 @block3 @block4
then:
    %tmp_load.2 = load i64 %count
    %tmp_const.5 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.2 %tmp_const.5
    store %count %tmp_add
    br @block4
end:
    %tmp_load.3 = load i64 %i
    %tmp_const.6 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.6
    store %i %tmp_add.1
    br @block1
whilecont:
    %tmp_load.4 = load i64 %count
    ret %tmp_load.4
}

---

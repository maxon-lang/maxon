// Test: export-var-fields.export-var-basic.1
type Value
    export var n int
    var private int

    static function create() returns Self
        return {n: 42, private: 100}
    end 'create'
end 'Value'

function main() returns int
    var v = Value.create()
    return v.n
end 'main'
---
ExitCode: 42

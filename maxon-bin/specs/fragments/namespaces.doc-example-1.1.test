// Test: namespaces.doc-example-1.1
export function add(a int, b int) returns int
    return a + b
end 'add'

export function multiply(x int, y int) returns int
    return x * y
end 'multiply'

function main() returns int
    return add(3, 4)  // Called from within same file
end 'main'
---
ExitCode: 7
---
function add() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

function multiply() -> i64 {
entry:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %y = param i64 1
    %y.1 = alloca ptr
    store %y.1 %y
    %tmp_load = load i64 %x.1
    %tmp_load.1 = load i64 %y.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    ret %tmp_mul
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %tmp_const.1 = const.i64 i64 4
    %tmp_call = call i64 @add(%tmp_const, %tmp_const.1)
    ret %tmp_call
}


// Test: nil-optional-types.optional-param-implicit-wrap.1
function add(a int, b int or nil) returns int
	var result = b else 'default'
		result = 0
	end 'default'
	return a + result
end 'add'

function main() returns int
	return add(5, 10)
end 'main'
---
ExitCode: 15
---
function add() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %tmp_param.1 = param ptr 1
    %b = alloca ptr
    store %b %tmp_param.1
    %tmp_load = load ptr %b
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    %result = alloca ptr
    br.cond %tmp_icmp @block1 @block2
else_unwrap_some:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    store %result %tmp_load.2
    br @block3
else_unwrap_nil:
    %tmp_const.1 = const.i64 i64 0
    store %result %tmp_const.1
    br @block3
else_unwrap_end:
    %tmp_load.3 = load i64 %a.1
    %tmp_load.4 = load i64 %result
    %tmp_add = add i64 %tmp_load.3 %tmp_load.4
    ret %tmp_add
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 10
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const.2 = const.i64 i64 1
    store %tmp_alloca %tmp_const.2
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca 8
    store %tmp_fieldptr %tmp_const.1
    %tmp_call = call i64 @add(%tmp_const, %tmp_alloca)
    ret %tmp_call
}

---

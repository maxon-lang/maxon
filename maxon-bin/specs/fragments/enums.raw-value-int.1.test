// Test: enums.raw-value-int.1
enum HttpStatus
    ok = 200
    notFound = 404
    serverError = 500
end 'HttpStatus'

function main() returns int
    var status = HttpStatus.ok
    if status.rawValue == 200 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 200
    %status = alloca ptr
    store %status %tmp_const
    %tmp_load = load i64 %status
    %tmp_const.1 = const.i64 i64 200
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

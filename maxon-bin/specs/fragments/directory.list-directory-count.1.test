// Test: directory.list-directory-count.1
function main() returns int
    do 'list'
        let files = try Directory.list("../bin")
        // bin directory has at least maxon.exe and maxon.pdb
        if files.count() >= 2 'ok'
            return 42
        end 'ok'
        return files.count()
    end 'list' catch (e DirectoryError) 'err'
        return 99
    end 'err'
end 'main'

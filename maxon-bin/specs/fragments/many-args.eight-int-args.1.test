// Test: many-args.eight-int-args.1
function sum8(a int, b int, c int, d int, e int, f int, g int, h int) returns int
    return a + b + c + d + e + f + g + h
end 'sum8'

function main() returns int
    return sum8(1, 2, 3, 4, 5, 6, 7, 8)
end 'main'

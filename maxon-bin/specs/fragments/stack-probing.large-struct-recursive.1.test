function recurse(n int) returns int
    var s = BigStruct { f0: n }
    if n == 0 'base'
        return s.f1999
    end 'base'
    return recurse(n - 1)
end 'recurse'

function main() returns int
    return recurse(50)
end 'main'
---
ExitCode: 0
---
function recurse() -> i64 {
entry:
    %n = param i64 0
    %n.1 = alloca ptr
    store %n.1 %n
    %s = alloca.sized ptr 16000
    memset %s 0 16000
    %tmp_fieldptr = getfieldptr ptr %s 0
    %tmp_load = load i64 %n.1
    store %tmp_fieldptr %tmp_load
    %tmp_load.1 = load i64 %n.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_fieldptr.1 = getfieldptr ptr %s 15992
    %tmp_load.2 = load i64 %tmp_fieldptr.1
    ret %tmp_load.2
end:
    %tmp_load.3 = load i64 %n.1
    %tmp_const.1 = const.i64 i64 1
    %tmp_sub = sub i64 %tmp_load.3 %tmp_const.1
    %tmp_call = call i64 @recurse(%tmp_sub)
    ret %tmp_call
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 50
    %tmp_call = call i64 @recurse(%tmp_const)
    ret %tmp_call
}


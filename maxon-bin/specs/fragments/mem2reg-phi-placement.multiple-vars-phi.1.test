// Test: mem2reg-phi-placement.multiple-vars-phi.1
function main() returns int
    var a = 0
    var b = 0
    if 1 > 0 'branch'
        a = 10
        b = 20
    end 'branch' else 'else_branch'
        a = 100
        b = 200
    end 'else_branch'
    return a + b
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_const.2 = const.i64 i64 1
    %tmp_const.3 = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_const.2 %tmp_const.3
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.4 = const.i64 i64 10
    store %a %tmp_const.4
    %tmp_const.5 = const.i64 i64 20
    store %b %tmp_const.5
    br @block3
else:
    %tmp_const.6 = const.i64 i64 100
    store %a %tmp_const.6
    %tmp_const.7 = const.i64 i64 200
    store %b %tmp_const.7
    br @block3
end:
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

---

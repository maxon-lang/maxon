// Test: structs.var-struct-field-assign.1
type Point
    export var x int
    export var y int
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    p.x = 30
    return p.x
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_const.2 = const.i64 i64 30
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

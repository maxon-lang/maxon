// Test: if-statements.if-statements.nested.1
function main() returns int
    var x = 3
    if x == 1 'outer'
        return 1
    end 'outer' else 'else_outer'
        if x == 2 'inner'
            return 2
        end 'inner' else 'else_inner'
            return 3
        end 'else_inner'
    end 'else_outer'
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
else:
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp.1 @block3 @block4
then:
    %tmp_const.4 = const.i64 i64 2
    ret %tmp_const.4
else:
    %tmp_const.5 = const.i64 i64 3
    ret %tmp_const.5
end:
    br @block6
end:
}

---

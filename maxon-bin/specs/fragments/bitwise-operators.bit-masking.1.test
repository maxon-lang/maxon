// Test: bitwise-operators.bit-masking.1
function main() returns int
    var flags = 0
    flags = flags | 1    // Set bit 0
    flags = flags | 4    // Set bit 2
    print("{flags}\n")         // 5 (binary 101)
    
    // Check if bit 2 is set
    if (flags & 4) > 0 'check'
        print("{1}\n")
    end 'check'
    return 0
end 'main'

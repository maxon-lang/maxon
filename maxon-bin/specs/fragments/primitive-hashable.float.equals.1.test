// Test: primitive-hashable.float.equals.1
function main() returns int
    var a = 3.14
    var b = 3.14
    if a.equals(b) 'eq'
        return 1
    end 'eq'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.14
    %a = alloca ptr
    store %a %tmp_fconst
    %tmp_fconst.1 = const.f64 f64 3.14
    %b = alloca ptr
    store %b %tmp_fconst.1
    %tmp_load = load f64 %a
    %tmp_load.1 = load f64 %b
    %tmp_fcmp = fcmp.eq i64 %tmp_load %tmp_load.1
    br.cond %tmp_fcmp @then$eq_1 @end$eq_2
then$eq_1:
    %tmp_const = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end$eq_2:
    %tmp_const.1 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.1
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

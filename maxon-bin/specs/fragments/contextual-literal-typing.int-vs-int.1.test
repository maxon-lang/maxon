// Test: contextual-literal-typing.int-vs-int.1
function main() returns int
    var a = 1000
    var b = 1000
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1000
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 1000
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_load.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

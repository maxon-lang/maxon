// Test: nil-optional-types.multiple-optionals.1
function first() returns int or nil
	return 10
end 'first'

function second() returns int or nil
	return nil
end 'second'

function main() returns int
	var a = first()
	var b = second()

	var sum = 0
	if let val = a 'checkA'
		sum = val
	end 'checkA'

	if let val = b 'checkB'
		sum = sum + val
	end 'checkB'

	return sum
end 'main'
---
ExitCode: 10
---
function first() -> ptr {
entry:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function second() -> ptr {
entry:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 0
    store %tmp_param %tmp_const
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_call = call ptr @first(%tmp_alloca)
    %a = alloca ptr
    store %a %tmp_alloca
    %tmp_alloca.2 = alloca.sized ptr 16
    %tmp_call.1 = call ptr @second(%tmp_alloca.2)
    %b = alloca ptr
    store %b %tmp_alloca.2
    %tmp_const = const.i64 i64 0
    %sum = alloca ptr
    store %sum %tmp_const
    %tmp_load = load ptr %a
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
if_let_then:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    %val = alloca ptr
    store %val %tmp_load.2
    %tmp_load.3 = load i64 %val
    store %sum %tmp_load.3
    br @block3
if_let_else:
    br @block3
if_let_end:
    %tmp_load.4 = load ptr %b
    %tmp_load.5 = load i64 %tmp_load.4
    %tmp_const.2 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.5 %tmp_const.2
    br.cond %tmp_icmp.1 @block4 @block5
if_let_then:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_load.4 8
    %tmp_load.6 = load i64 %tmp_fieldptr.1
    %val.1 = alloca ptr
    store %val.1 %tmp_load.6
    %tmp_load.7 = load i64 %sum
    %tmp_load.8 = load i64 %val.1
    %tmp_add = add i64 %tmp_load.7 %tmp_load.8
    store %sum %tmp_add
    br @block6
if_let_else:
    br @block6
if_let_end:
    %tmp_load.9 = load i64 %sum
    ret %tmp_load.9
}

---

// Test: stdlib-set.empty-set.1
function main() returns int
    var s = Set of int{}
    if s.count() != 0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %s = alloca.sized ptr 88
    memset %s 0 88
    %tmp_call = call i64 @Set$int$count(%s)
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.ne i64 %tmp_call %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

function Set$int$count() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 64
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

---

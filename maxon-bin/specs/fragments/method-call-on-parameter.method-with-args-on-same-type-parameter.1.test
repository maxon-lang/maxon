// Test: method-call-on-parameter.method-with-args-on-same-type-parameter.1
type Adder
    var value int
    
    function addTo(n int) returns int
        return value + n
    end 'addTo'
    
    function delegateAdd(other Adder, n int) returns int
        return other.addTo(n)
    end 'delegateAdd'
end 'Adder'

function main() returns int
    var a = Adder{value: 100}
    var b = Adder{value: 50}
    return a.delegateAdd(b, 7)
end 'main'
---
ExitCode: 57
---
function main() -> i64 {
entry_0:
    %a = alloca.sized ptr 8
    memset %a 0 8
    %tmp_fieldptr = getfieldptr ptr %a 0
    %tmp_const = const.i64 i64 100
    store %tmp_fieldptr %tmp_const
    %b = alloca.sized ptr 8
    memset %b 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %b 0
    %tmp_const.1 = const.i64 i64 50
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_const.2 = const.i64 i64 7
    %tmp_call = call i64 @Adder$delegateAdd(%a, %b, %tmp_const.2)
    ret %tmp_call
}

function Adder$addTo() -> i64 {
entry_0:
    %self = param ptr 0
    %n = param i64 1
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_add = add i64 %tmp_load %n
    ret %tmp_add
}

function Adder$delegateAdd() -> i64 {
entry_0:
    %other = param ptr 1
    %n = param i64 2
    %tmp_call = call i64 @Adder$addTo(%other, %n)
    ret %tmp_call
}

---

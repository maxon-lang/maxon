// Test: error-handling.error.do-catch-handles-thrown-error.1
// Test do-catch catches thrown errors
enum MyError int is Error
    failed = 42
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
    if shouldFail 'check'
        throw MyError.failed
    end 'check'
    return 100
end 'mayFail'

function main() returns int
    do 'io'
        let x = try mayFail(true)
        return x
    end 'io' catch (e MyError) 'err'
        // e is the enum ordinal (0 for first member)
        return 42
    end 'err'
end 'main'
---
ExitCode: 42
---
function mayFail() -> i64 {
entry:
    %tmp_param = param ptr 0
    %shouldFail = param i64 1
    %shouldFail.1 = alloca ptr
    store %shouldFail.1 %shouldFail
    %tmp_load = load i64 %shouldFail.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 42
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
end:
    %tmp_const.2 = const.i64 i64 100
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.2
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 64
    %tmp_alloca.1 = alloca.sized ptr 16
    %tmp_const = const.i64 i64 1
    %tmp_call = call ptr @mayFail(%tmp_alloca.1, %tmp_const)
    %tmp_load = load i64 %tmp_alloca.1
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
try_success:
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca.1 8
    %tmp_alloca.2 = alloca ptr
    %tmp_load.1 = load i64 %tmp_fieldptr
    store %tmp_alloca.2 %tmp_load.1
    br @block3
try_propagate:
    memcpy %tmp_alloca %tmp_alloca.1 64
    br @block4
try_merge:
    %tmp_load.2 = load i64 %tmp_alloca.2
    %x = alloca ptr
    store %x %tmp_load.2
    %tmp_load.3 = load i64 %x
    ret %tmp_load.3
    br @block6
catch_dispatch:
    br @block5
catch_0:
    %tmp_const.2 = const.i64 i64 42
    ret %tmp_const.2
    br @block6
do_end:
}

---

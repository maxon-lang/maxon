// Test: nil-optional-types.optional-with-value.1
function returnsValue() returns int or nil
	return 42
end 'returnsValue'

function main() returns int
	var x = returnsValue()
	if let val = x 'check'
		return val
	end 'check' else 'nil_case'
		return 0
	end 'nil_case'
end 'main'
---
ExitCode: 42
---
function returnsValue() -> ptr {
entry:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 42
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_call = call ptr @returnsValue(%tmp_alloca)
    %x = alloca ptr
    store %x %tmp_alloca
    %tmp_load = load ptr %x
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    br.cond %tmp_icmp @block1 @block2
if_let_then:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    %val = alloca ptr
    store %val %tmp_load.2
    %tmp_load.3 = load i64 %val
    ret %tmp_load.3
if_let_else:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
if_let_end:
}

---

// Test: type-methods.type-method-returning-value.1
type Calculator
    var value int

    function double() returns int
        return value * 2
    end 'double'
end 'Calculator'

function main() returns int
    var c = Calculator{value: 21}
    return c.double()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %c = alloca.sized ptr 8
    memset %c 0 8
    %tmp_fieldptr = getfieldptr ptr %c 0
    %tmp_const = const.i64 i64 21
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @Calculator$double(%c)
    ret %tmp_call
}

function Calculator$double() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load %tmp_const
    ret %tmp_mul
}

---

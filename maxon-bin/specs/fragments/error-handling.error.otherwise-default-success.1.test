// Test: error-handling.error.otherwise-default-success.1
// Test try otherwise when no error occurs
enum MyError is Error
    failed
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
    if shouldFail 'check'
        throw MyError.failed
    end 'check'
    return 100
end 'mayFail'

function main() returns int
    let val = try mayFail(false) otherwise 42
    return val
end 'main'
---
ExitCode: 100
---
function mayFail() -> i64 {
entry:
    %tmp_param = param ptr 0
    %shouldFail = param i64 1
    %shouldFail.1 = alloca ptr
    store %shouldFail.1 %shouldFail
    %tmp_load = load i64 %shouldFail.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
end:
    %tmp_const.2 = const.i64 i64 100
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.2
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 0
    %tmp_call = call ptr @mayFail(%tmp_alloca, %tmp_const)
    %tmp_load = load i64 %tmp_alloca
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    %tmp_alloca.1 = alloca ptr
    br.cond %tmp_icmp @block1 @block2
try_success:
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca 8
    %tmp_load.1 = load i64 %tmp_fieldptr
    store %tmp_alloca.1 %tmp_load.1
    br @block3
try_default:
    %tmp_const.2 = const.i64 i64 42
    store %tmp_alloca.1 %tmp_const.2
    br @block3
try_merge:
    %tmp_load.2 = load i64 %tmp_alloca.1
    %val = alloca ptr
    store %val %tmp_load.2
    %tmp_load.3 = load i64 %val
    ret %tmp_load.3
}

---

// Test: string-type.heap-string-contains.1
function main() returns int
    var s = "This is a very long string that is heap allocated"
    if s.contains("long string") 'c21'
        print("{1}")
    end 'c21'
    if s.contains("short string") 'c22'
        print("{0}")
    end 'c22'
    return 0
end 'main'

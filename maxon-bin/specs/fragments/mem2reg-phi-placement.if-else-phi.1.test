// Test: mem2reg-phi-placement.if-else-phi.1
function main() returns int
    var x = 0
    if 5 > 3 'check'
        x = 42
    end 'check' else 'else_check'
        x = 100
    end 'else_check'
    return x
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 5
    %tmp_const.2 = const.i64 i64 3
    %tmp_icmp = icmp.gt i64 %tmp_const.1 %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.3 = const.i64 i64 42
    store %x %tmp_const.3
    br @block3
else:
    %tmp_const.4 = const.i64 i64 100
    store %x %tmp_const.4
    br @block3
end:
    %tmp_load = load i64 %x
    ret %tmp_load
}

---

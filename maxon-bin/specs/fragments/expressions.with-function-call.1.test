// Test: expressions.with-function-call.1
function main() returns int
    var x = 3
    return 5 + add(x, b: 4)
end 'main'

function add(a int, b int) returns int
    return a + b
end 'add'
---
ExitCode: 12
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 3
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 5
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 4
    %tmp_call = call i64 @add(%tmp_load, %tmp_const.2)
    %tmp_add = add i64 %tmp_const.1 %tmp_call
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_add
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

function add() -> i64 {
entry_0:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_add
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}


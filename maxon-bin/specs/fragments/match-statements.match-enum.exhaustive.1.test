// Test: match-statements.match-enum.exhaustive.1
enum Color
    red
    green
    blue
end 'Color'

function main() returns int
    var c = Color.green
    match c 'check'
        Color.red then return 1
        Color.green then return 2
        Color.blue then return 3
    end 'check'
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    br @match_check_1
match_check_1:
    %tmp_const.4 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.4
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.5 = const.i64 i64 1
    ret %tmp_const.5
match_check_3:
    %tmp_const.6 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_const %tmp_const.6
    br.cond %tmp_icmp.1 @match_body_4 @match_check_5
match_body_4:
    %tmp_const.7 = const.i64 i64 2
    ret %tmp_const.7
match_check_5:
    %tmp_const.8 = const.i64 i64 2
    %tmp_icmp.2 = icmp.eq i64 %tmp_const %tmp_const.8
    br.cond %tmp_icmp.2 @match_body_6 @match_merge_7
match_body_6:
    %tmp_const.9 = const.i64 i64 3
    ret %tmp_const.9
match_merge_7:
}

---

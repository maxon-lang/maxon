// Test: match-statements.match-enum.exhaustive.1
enum Color
    red
    green
    blue
end 'Color'

function main() returns int
    var c = Color.green
    match c 'check'
        Color.red then return 1
        Color.green then return 2
        Color.blue then return 3
    end 'check'
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %c = alloca ptr
    store %c %tmp_const
    %tmp_load.1 = load i64 %c
    br @block1
match_check:
    %tmp_const.4 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.4
    br.cond %tmp_icmp @block2 @block3
match_body:
    %tmp_const.5 = const.i64 i64 1
    ret %tmp_const.5
match_check:
    %tmp_const.6 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.6
    br.cond %tmp_icmp.1 @block4 @block5
match_body:
    %tmp_const.7 = const.i64 i64 2
    ret %tmp_const.7
match_check:
    %tmp_const.8 = const.i64 i64 2
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.1 %tmp_const.8
    br.cond %tmp_icmp.2 @block6 @block7
match_body:
    %tmp_const.9 = const.i64 i64 3
    ret %tmp_const.9
match_merge:
}

---

// Test: enums.enum-assignment.1
enum Color
    red
    green
    blue
end 'Color'

function main() returns int
    var c = Color.red
    c = Color.blue
    if c == Color.blue 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %c = alloca ptr
    store %c %tmp_const
    %tmp_const.1 = const.i64 i64 2
    store %c %tmp_const.1
    %tmp_load = load i64 %c
    %tmp_const.2 = const.i64 i64 2
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.3 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.3
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.4 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

// Test: enums.enum-assignment.1
enum Color
    red
    green
    blue
end 'Color'

function main() returns int
    var c = Color.red
    c = Color.blue
    if c == Color.blue 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const.1 = const.i64 i64 2
    %tmp_const.2 = const.i64 i64 2
    %tmp_icmp = icmp.eq i64 %tmp_const.1 %tmp_const.2
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.3 = const.i64 i64 1
    ret %tmp_const.3
end$check_2:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
}

---

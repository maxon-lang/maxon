// Test: parameter-labels.named-args-multiply.1
function multiply(x int, y int) returns int
    return x * y
end 'multiply'

function main() returns int
    return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
function multiply() -> i64 {
entry:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %y = param i64 1
    %y.1 = alloca ptr
    store %y.1 %y
    %tmp_load = load i64 %x.1
    %tmp_load.1 = load i64 %y.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_mul
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 6
    %tmp_const.1 = const.i64 i64 7
    %tmp_call = call i64 @multiply(%tmp_const, %tmp_const.1)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

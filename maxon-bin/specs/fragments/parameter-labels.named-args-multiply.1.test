// Test: parameter-labels.named-args-multiply.1
function multiply(x int, y int) returns int
    return x * y
end 'multiply'

function main() returns int
    return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
function multiply() -> i64 {
entry_0:
    %x = param i64 0
    %y = param i64 1
    %tmp_mul = mul i64 %x %y
    ret %tmp_mul
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 6
    %tmp_const.1 = const.i64 i64 7
    %tmp_call = call i64 @multiply(%tmp_const, %tmp_const.1)
    ret %tmp_call
}


// Test: ownership.reassign-after-move-primitive.1
function consume(x int)
    x = x + 1
end 'consume'

function main() returns int
    var a = 10
    consume(a)
    a = 20
    return a
end 'main'
---
ExitCode: 20
---
function consume() -> void {
entry_0:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load i64 %x.1
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    store %x.1 %tmp_add
    ret
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_load = load i64 %a
    call @consume(%tmp_load)
    %tmp_const.1 = const.i64 i64 20
    store %a %tmp_const.1
    %tmp_load.1 = load i64 %a
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
}

---

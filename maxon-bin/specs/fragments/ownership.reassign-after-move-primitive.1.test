// Test: ownership.reassign-after-move-primitive.1
function consume(x int)
    x = x + 1
end 'consume'

function main() returns int
    var a = 10
    consume(a)
    a = 20
    return a
end 'main'
---
ExitCode: 20
---
function consume() -> void {
entry_0:
    ret
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    call @consume(%tmp_const)
    %tmp_const.1 = const.i64 i64 20
    ret %tmp_const.1
}


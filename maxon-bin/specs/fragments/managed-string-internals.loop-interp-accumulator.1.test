// Test: managed-string-internals.loop-interp-accumulator.1
function main() returns int
    var s = ""
    var a = "a"
    var i = 0
    while i < 5 'loop'
        s = "{s}{a}"
        i = i + 1
    end 'loop'
    print("{s.count()}\n")
    return 0
end 'main'

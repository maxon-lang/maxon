// Test: string-type.find.1
function main() returns int
    var s = "hello world"
    var idx = try s.find("world") otherwise s.endIndex()
    print("{idx.charIndex()}\n")
    var idx2 = try s.find("xyz") otherwise s.endIndex()
    if idx2 == s.endIndex() 'not_found'
        print("-1\n")
    end 'not_found'
    return 0
end 'main'

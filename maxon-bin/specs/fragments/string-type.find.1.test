// Test: string-type.find.1
function main() returns int
    var s = "hello world"
    if let idx = s.find("world") 'found'
        print("{idx.charIndex()}")
    end 'found' else 'not_found'
        print("{0 - 1}")
    end 'not_found'
    if let idx2 = s.find("xyz") 'found2'
        print("{idx2.charIndex()}")
    end 'found2' else 'not_found2'
        print("{0 - 1}")
    end 'not_found2'
    return 0
end 'main'

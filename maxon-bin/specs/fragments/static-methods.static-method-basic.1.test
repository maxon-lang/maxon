// Test: static-methods.static-method-basic.1
type Box
    var value int

    static function make(v int) returns Box
        return Box{value: v}
    end 'make'
end 'Box'

function main() returns int
    var b = Box.make(42)
    return b.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %b = alloca.sized ptr 8
    %tmp_const = const.i64 i64 42
    %tmp_call = call ptr @Box$make(%b, %tmp_const)
    %tmp_fieldptr = getfieldptr ptr %b 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function Box$make() -> ptr {
entry:
    %tmp_param = param ptr 0
    %v = param i64 1
    %v.1 = alloca ptr
    store %v.1 %v
    memset %tmp_param 0 8
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_load = load i64 %v.1
    store %tmp_fieldptr %tmp_load
    ret %tmp_param
}

---

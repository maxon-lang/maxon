// Test: challenge-struct-field-assign.nested-struct-field-reassignment.1
type Inner
    export var x int
end 'Inner'

type Outer
    export var inner Inner
end 'Outer'

function main() returns int
    var i = Inner{x: 10}
    var o = Outer{inner: i}
    o.inner.x = 42
    return o.inner.x
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %i = alloca.sized ptr 8
    memset %i 0 8
    %tmp_fieldptr = getfieldptr ptr %i 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %o = alloca.sized ptr 8
    memset %o 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %o 0
    memcpy %tmp_fieldptr.1 %i 8
    %tmp_const.1 = const.i64 i64 42
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.2
    ret %tmp_load.1
}

---

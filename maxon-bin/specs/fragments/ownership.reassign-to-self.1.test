// Test: ownership.reassign-to-self.1
function main() returns int
    var x = 10
    x = x + 5
    x = x + 5
    return x
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 5
    %tmp_add = add i64 %tmp_load %tmp_const.1
    store %x %tmp_add
    %tmp_load.1 = load i64 %x
    %tmp_const.2 = const.i64 i64 5
    %tmp_add.1 = add i64 %tmp_load.1 %tmp_const.2
    store %x %tmp_add.1
    %tmp_load.2 = load i64 %x
    ret %tmp_load.2
}

---

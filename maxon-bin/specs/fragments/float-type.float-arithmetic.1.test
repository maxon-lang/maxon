// Test: float-type.float-arithmetic.1
function main() returns int
    var a = 10.0
    var b = 3.0
    var result = a / b
    return trunc(result)
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 10
    %a = alloca ptr
    store %a %tmp_fconst
    %tmp_fconst.1 = const.f64 f64 3
    %b = alloca ptr
    store %b %tmp_fconst.1
    %tmp_load = load f64 %a
    %tmp_load.1 = load f64 %b
    %tmp_fdiv = fdiv f64 %tmp_load %tmp_load.1
    %result = alloca ptr
    store %result %tmp_fdiv
    %tmp_load.2 = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load.2
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_fptosi
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

// Test: string-type.cow-original-unchanged.1
function main() returns int
    var a = "TEST STRING"
    var b = a
    var c = a
    b = b.toLower()
    print("{a}\n")
    print("{b}\n")
    print("{c}\n")
    return 0
end 'main'

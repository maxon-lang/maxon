// Test: enums.enum-function-param.1
enum Status
    on
    off
end 'Status'

function isOn(s Status) returns bool
    if s == Status.on 'check'
        return true
    end 'check'
    return false
end 'isOn'

function main() returns int
    var status = Status.on
    if isOn(status) 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
ExitCode: 1
---
function isOn() -> i64 {
entry_0:
    %s = param i64 0
    %s.1 = alloca ptr
    store %s.1 %s
    %tmp_load = load i64 %s.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %status = alloca ptr
    store %status %tmp_const
    %tmp_load = load i64 %status
    %tmp_call = call i64 @isOn(%tmp_load)
    br.cond %tmp_call @then$test_1 @end$test_2
then$test_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$test_2:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

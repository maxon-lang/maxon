// Test: pow.zero-exponent.1
function main() returns int
    var result = pow(123.0, 0.0)
    return trunc(result)
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 123
    %tmp_fconst.1 = const.f64 f64 0
    %tmp_call = call f64 @pow(%tmp_fconst, %tmp_fconst.1)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}

---

// Test: floor.floor.positive.1
function main() returns int
    var x = 3.9
    var y = floor(x)
    return y
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.9
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_load = load f64 %x
    %tmp_ffloor = ffloor i64 %tmp_load
    %y = alloca ptr
    store %y %tmp_ffloor
    %tmp_load.1 = load i64 %y
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

// Test: enums.enum-return-type.1
enum Result
    success
    failure
end 'Result'

function getResult(succeed bool) returns Result
    if succeed 'check'
        return Result.success
    end 'check'
    return Result.failure
end 'getResult'

function main() returns int
    var r = getResult(true)
    if r == Result.success 'handle'
        return 1
    end 'handle'
    return 0
end 'main'
---
ExitCode: 1
---
function getResult() -> i64 {
entry:
    %succeed = param i64 0
    %succeed.1 = alloca ptr
    store %succeed.1 %succeed
    %tmp_load = load i64 %succeed.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %tmp_call = call i64 @getResult(%tmp_const)
    %r = alloca ptr
    store %r %tmp_call
    %tmp_load = load i64 %r
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.3
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}


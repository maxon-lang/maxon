// Test: enums.enum-return-type.1
enum Result
    success
    failure
end 'Result'

function getResult(succeed bool) returns Result
    if succeed 'check'
        return Result.success
    end 'check'
    return Result.failure
end 'getResult'

function main() returns int
    var r = getResult(true)
    if r == Result.success 'handle'
        return 1
    end 'handle'
    return 0
end 'main'
---
ExitCode: 1
---
function getResult() -> i64 {
entry_0:
    %succeed = param i64 0
    br.cond %succeed @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    %tmp_call = call i64 @getResult(%tmp_const)
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_call %tmp_const.1
    br.cond %tmp_icmp @then$handle_1 @end$handle_2
then$handle_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$handle_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}


// Test: match-statements.doc-example-8.1
function classify(age int) returns int
    match age 'category'
        ..<0 then return 0       // invalid (negative)
        0..<18 then return 1     // minor
        18.. then return 2       // adult
    end 'category'
end 'classify'

function main() returns int
    return classify(25)
end 'main'
---
ExitCode: 2
---
function classify() -> i64 {
entry_0:
    %age = param i64 0
    br @match_check_1
match_check_1:
    %tmp_const.3 = const.i64 i64 0
    %tmp_icmp = icmp.lt i64 %age %tmp_const.3
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
match_check_3:
    %tmp_const.5 = const.i64 i64 0
    %tmp_icmp.1 = icmp.ge i64 %age %tmp_const.5
    %tmp_const.6 = const.i64 i64 18
    %tmp_icmp.2 = icmp.lt i64 %age %tmp_const.6
    %tmp_band = band i64 %tmp_icmp.1 %tmp_icmp.2
    br.cond %tmp_band @match_body_4 @match_check_5
match_body_4:
    %tmp_const.7 = const.i64 i64 1
    ret %tmp_const.7
match_check_5:
    %tmp_const.8 = const.i64 i64 18
    %tmp_icmp.3 = icmp.ge i64 %age %tmp_const.8
    br.cond %tmp_icmp.3 @match_body_6 @match_merge_7
match_body_6:
    %tmp_const.9 = const.i64 i64 2
    ret %tmp_const.9
match_merge_7:
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 25
    %tmp_call = call i64 @classify(%tmp_const)
    ret %tmp_call
}


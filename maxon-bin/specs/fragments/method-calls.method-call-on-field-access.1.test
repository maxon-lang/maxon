// Test: method-calls.method-call-on-field-access.1
type Inner
    var value int

    function get() returns int
        return value
    end 'get'
end 'Inner'

type Outer
    var inner Inner

    function getInnerValue() returns int
        return inner.get()
    end 'getInnerValue'
end 'Outer'

function main() returns int
    var o = Outer{inner: Inner{value: 42}}
    return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %o = alloca.sized ptr 8
    memset %o 0 8
    %tmp_fieldptr = getfieldptr ptr %o 0
    %tmp_alloca.1 = alloca.sized ptr 8
    memset %tmp_alloca.1 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.1 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr.1 %tmp_const
    memcpy %tmp_fieldptr %tmp_alloca.1 8
    %tmp_call = call i64 @Outer$getInnerValue(%o)
    ret %tmp_call
}

function Inner$get() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function Outer$getInnerValue() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_call = call i64 @Inner$get(%tmp_fieldptr)
    ret %tmp_call
}

---

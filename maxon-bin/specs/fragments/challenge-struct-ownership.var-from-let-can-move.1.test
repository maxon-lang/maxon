// Test: challenge-struct-ownership.var-from-let-can-move.1
type Data
    var value int
end 'Data'

function consume(d Data) returns int
    d.value = 100
    return d.value
end 'consume'

function main() returns int
    let original = Data{value: 42}
    var copy = original
    return consume(copy)
end 'main'
---
ExitCode: 100
---
function consume() -> i64 {
entry:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 100
    store %tmp_fieldptr %tmp_const
    ret %tmp_const
}

function main() -> i64 {
entry:
    %original = alloca.sized ptr 8
    %8 = memset %original 0
    %tmp_fieldptr = getfieldptr ptr %original 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %copy = alloca.sized ptr 8
    %8 = memcpy %copy %original
    %tmp_call = call i64 @consume(%copy)
    ret %tmp_call
}

---

// Test: challenge-struct-ownership.var-from-let-can-move.1
type Data
    export var value int
end 'Data'

function consume(d Data) returns int
    d.value = 100
    return d.value
end 'consume'

function main() returns int
    let original = Data{value: 42}
    var copy = original
    return consume(copy)
end 'main'
---
ExitCode: 100
---
function consume() -> i64 {
entry_0:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 100
    store %tmp_fieldptr %tmp_const
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

function main() -> i64 {
entry_0:
    %original = alloca.sized ptr 8
    memset %original 0 8
    %tmp_fieldptr = getfieldptr ptr %original 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %copy = alloca.sized ptr 8
    memcpy %copy %original 8
    %tmp_call = call i64 @consume(%copy)
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_call
    %tmp_load = load i64 %tmp_alloca.2
    ret %tmp_load
}

---

typealias IntArray is Array with int

function main() returns int
    var arr = IntArray{}
    arr.reserve(100)

    if arr.capacity() < 100 'cap'
        return 1
    end 'cap'

    if arr.count() != 0 'cnt'
        return 2
    end 'cnt'

    return 0
end 'main'

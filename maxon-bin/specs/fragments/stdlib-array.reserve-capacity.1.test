// Test: stdlib-array.reserve-capacity.1
function main() returns int
    var arr = Array of int{}
    arr.reserve(100)

    if arr.capacity() < 100 'cap'
        return 1
    end 'cap'

    if arr.count() != 0 'cnt'
        return 2
    end 'cnt'

    return 0
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %arr = alloca.sized ptr 32
    memset %arr 0 32
    %tmp_alloca.1 = alloca.sized ptr 32
    %tmp_const = const.i64 i64 100
    %tmp_call = call ptr @Array$int$reserve(%tmp_alloca.1, %arr, %tmp_const)
    %tmp_call.1 = call i64 @Array$int$capacity(%arr)
    %tmp_const.1 = const.i64 i64 100
    %tmp_icmp = icmp.lt i64 %tmp_call.1 %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    %tmp_load = load ptr %arr
    heap.free %tmp_load tag="array cleanup"
    ret %tmp_const.2
end:
    %tmp_call.2 = call i64 @Array$int$count(%arr)
    %tmp_const.3 = const.i64 i64 0
    %tmp_icmp.1 = icmp.ne i64 %tmp_call.2 %tmp_const.3
    br.cond %tmp_icmp.1 @block3 @block4
then:
    %tmp_const.4 = const.i64 i64 2
    %tmp_load.1 = load ptr %arr
    heap.free %tmp_load.1 tag="array cleanup"
    ret %tmp_const.4
end:
    %tmp_const.5 = const.i64 i64 0
    %tmp_load.2 = load ptr %arr
    heap.free %tmp_load.2 tag="array cleanup"
    ret %tmp_const.5
}

function Array$int$reserve() -> ptr {
entry:
    %tmp_param = param ptr 0
    %self = param ptr 1
    %minCapacity = param i64 2
    %minCapacity.1 = alloca ptr
    store %minCapacity.1 %minCapacity
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 16
    %tmp_load = load i64 %tmp_fieldptr.1
    %cap = alloca ptr
    store %cap %tmp_load
    %tmp_load.1 = load i64 %minCapacity.1
    %tmp_load.2 = load i64 %cap
    %tmp_icmp = icmp.gt i64 %tmp_load.1 %tmp_load.2
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_fieldptr.2 = getfieldptr ptr %self 0
    %tmp_load.3 = load i64 %minCapacity.1
    %tmp_const = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load.3 %tmp_const
    %tmp_load.4 = load ptr %tmp_fieldptr.2
    %tmp_realloc = heap.realloc ptr %tmp_load.4 %tmp_mul tag="array grow"
    store %tmp_fieldptr.2 %tmp_realloc
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_fieldptr.2 16
    store %tmp_fieldptr.3 %tmp_load.3
    br @block2
end:
    memcpy %tmp_param %self 32
    ret %tmp_param
}

function Array$int$capacity() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 16
    %tmp_load = load i64 %tmp_fieldptr.1
    ret %tmp_load
}

function Array$int$count() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 8
    %tmp_load = load i64 %tmp_fieldptr.1
    ret %tmp_load
}

---

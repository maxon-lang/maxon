// Test: primitive-hashable.int.equals.different.1
function main() returns int
    var a = 42
    var b = 17
    if a.equals(b) 'eq'
        return 1
    end 'eq'
    return 0
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 42
    %tmp_const.1 = const.i64 i64 17
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$eq_1 @end$eq_2
then$eq_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$eq_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

// Test: primitive-hashable.int.equals.different.1
function main() returns int
    var a = 42
    var b = 17
    if a.equals(b) 'eq'
        return 1
    end 'eq'
    return 0
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 17
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_load.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.3
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

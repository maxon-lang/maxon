// Test: top-level-let.boolean-constant.1
let DEBUG = true

function main() returns int
    if DEBUG 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    br.cond %tmp_const @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const.1
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
end:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}


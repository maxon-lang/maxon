// Test: nil-optional-types.nested-iflet.1
function makeOpt(n int) returns int or nil
	return n
end 'makeOpt'

function main() returns int
	var a = makeOpt(5)
	if let x = a 'checkOuter'
		var b = makeOpt(3)
		if let y = b 'checkInner'
			return x + y
		end 'checkInner'
	end 'checkOuter'
	return 0
end 'main'
---
ExitCode: 8
---
function makeOpt() -> ptr {
entry:
    %tmp_param = param ptr 0
    %n = param i64 1
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_load = load i64 %n.1
    %tmp_const = const.i64 i64 1
    store %tmp_param %tmp_const
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_load
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 5
    %tmp_call = call ptr @makeOpt(%tmp_alloca, %tmp_const)
    %a = alloca ptr
    store %a %tmp_alloca
    %tmp_load = load ptr %a
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.1
    br.cond %tmp_icmp @block1 @block5
if_let_then:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    %x = alloca ptr
    store %x %tmp_load.2
    %tmp_alloca.3 = alloca.sized ptr 16
    %tmp_const.2 = const.i64 i64 3
    %tmp_call.1 = call ptr @makeOpt(%tmp_alloca.3, %tmp_const.2)
    %b = alloca ptr
    store %b %tmp_alloca.3
    %tmp_load.3 = load ptr %b
    %tmp_load.4 = load i64 %tmp_load.3
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.4 %tmp_const.3
    br.cond %tmp_icmp.1 @block2 @block3
if_let_then:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_load.3 8
    %tmp_load.5 = load i64 %tmp_fieldptr.1
    %y = alloca ptr
    store %y %tmp_load.5
    %tmp_load.6 = load i64 %x
    %tmp_load.7 = load i64 %y
    %tmp_add = add i64 %tmp_load.6 %tmp_load.7
    ret %tmp_add
if_let_else:
    br @block4
if_let_end:
    br @block6
if_let_else:
    br @block6
if_let_end:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
}

---

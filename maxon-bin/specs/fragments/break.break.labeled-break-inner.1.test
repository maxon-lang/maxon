// Test: break.break.labeled-break-inner.1
function main() returns int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %y = alloca ptr
    store %y %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block8
whilebody:
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.3
    store %x %tmp_add
    br @block3
whilecond:
    %tmp_load.2 = load i64 %y
    %tmp_const.4 = const.i64 i64 10
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.2 %tmp_const.4
    br.cond %tmp_icmp.1 @block4 @block7
whilebody:
    %tmp_load.3 = load i64 %y
    %tmp_const.5 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.5
    store %y %tmp_add.1
    %tmp_load.4 = load i64 %y
    %tmp_const.6 = const.i64 i64 3
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.4 %tmp_const.6
    br.cond %tmp_icmp.2 @block5 @block6
then:
    br @block7
    br @block6
end:
    br @block3
whilecont:
    br @block1
whilecont:
    %tmp_load.5 = load i64 %x
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.5
    %tmp_load.6 = load i64 %tmp_alloca.2
    ret %tmp_load.6
}


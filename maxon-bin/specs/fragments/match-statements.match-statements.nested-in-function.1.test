// Test: match-statements.match-statements.nested-in-function.1
function categorize(n int) returns int
    match n 'cat'
        1 or 2 or 3 then return 1
        4 or 5 or 6 then return 2
        default then return 0
    end 'cat'
end 'categorize'

function main() returns int
    return categorize(5)
end 'main'
---
ExitCode: 2
---
function categorize() -> i64 {
entry:
    %n = param i64 0
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_load.1 = load i64 %n.1
    br @block1
match_check:
    %tmp_const.6 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.6
    %tmp_const.7 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.7
    %tmp_bitor = bitor i64 %tmp_icmp %tmp_icmp.1
    %tmp_const.8 = const.i64 i64 3
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.1 %tmp_const.8
    %tmp_bitor.1 = bitor i64 %tmp_bitor %tmp_icmp.2
    br.cond %tmp_bitor.1 @block2 @block3
match_body:
    %tmp_const.9 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.9
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
match_check:
    %tmp_const.10 = const.i64 i64 4
    %tmp_icmp.3 = icmp.eq i64 %tmp_load.1 %tmp_const.10
    %tmp_const.11 = const.i64 i64 5
    %tmp_icmp.4 = icmp.eq i64 %tmp_load.1 %tmp_const.11
    %tmp_bitor.2 = bitor i64 %tmp_icmp.3 %tmp_icmp.4
    %tmp_const.12 = const.i64 i64 6
    %tmp_icmp.5 = icmp.eq i64 %tmp_load.1 %tmp_const.12
    %tmp_bitor.3 = bitor i64 %tmp_bitor.2 %tmp_icmp.5
    br.cond %tmp_bitor.3 @block4 @block5
match_body:
    %tmp_const.13 = const.i64 i64 2
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.13
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
match_default:
    %tmp_const.14 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.14
    %tmp_load.4 = load i64 %tmp_alloca.3
    ret %tmp_load.4
match_merge:
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @categorize(%tmp_const)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

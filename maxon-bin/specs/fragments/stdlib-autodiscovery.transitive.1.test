// Test: stdlib-autodiscovery.transitive.1
// pow -> log, exp
function main() returns int
    var result = Math.pow(2.0, 3.0)
    if result > 7.5 'check'
        return 8
    end 'check'
    return 0
end 'main'
---
ExitCode: 8
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 2
    %tmp_fconst.1 = const.f64 f64 3
    %tmp_call = call f64 @Math$pow(%tmp_fconst, %tmp_fconst.1)
    %tmp_fconst.2 = const.f64 f64 7.5
    %tmp_fcmp = fcmp.gt i64 %tmp_call %tmp_fconst.2
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 8
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

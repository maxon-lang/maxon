// Test: float-type.float-comparison.1
function main() returns int
    var x = 3.5
    var y = 2.1
    if x > y 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.5
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_fconst.1 = const.f64 f64 2.1
    %y = alloca ptr
    store %y %tmp_fconst.1
    %tmp_load = load f64 %x
    %tmp_load.1 = load f64 %y
    %tmp_fcmp = fcmp.gt i64 %tmp_load %tmp_load.1
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end$check_2:
    %tmp_const.1 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.1
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

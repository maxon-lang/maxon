// Test: enums.explicit-char-backed.1
enum Direction
    North = 'n'
    South = 's'
    East = 'e'
end 'Direction'

function main() returns int
    var d = Direction.North
    if d == Direction.South 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_strconst = const.string ptr <2 bytes> label="line:9"
    %tmp_strconst.1 = const.string ptr <2 bytes> label="line:10"
    %tmp_icmp = icmp.eq i64 %tmp_strconst %tmp_strconst.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}


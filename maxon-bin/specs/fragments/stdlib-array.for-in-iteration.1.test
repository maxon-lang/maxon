// Test: stdlib-array.for-in-iteration.1
function main() returns int
    var arr = Array of int{}
    arr.push(10)
    arr.push(20)
    arr.push(30)
    
    var sum = 0
    for item in arr 'loop'
        sum = sum + item
    end 'loop'
    
    if sum != 60 'check'
        return 1
    end 'check'
    
    return 0
end 'main'

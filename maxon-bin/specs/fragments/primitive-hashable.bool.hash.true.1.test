function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %t = alloca ptr
    store %t %tmp_const
    %tmp_load = load i64 %t
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1

// Test: error-handling.error.otherwise-block-success.1
// Test try otherwise block when no error
enum MyError is Error
    failed
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
    if shouldFail 'check'
        throw MyError.failed
    end 'check'
    return 100
end 'mayFail'

function main() returns int
    var result = 0
    try mayFail(false) otherwise 'err'
        result = 42
    end 'err'
    return result
end 'main'
---
ExitCode: 0
---
function mayFail() -> ptr {
entry:
    %tmp_param = param ptr 0
    %shouldFail = param i64 1
    %shouldFail.1 = alloca ptr
    store %shouldFail.1 %shouldFail
    %tmp_load = load i64 %shouldFail.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
end:
    %tmp_const.2 = const.i64 i64 100
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.2
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const
    %tmp_alloca.1 = alloca.sized ptr 16
    %tmp_const.1 = const.i64 i64 0
    %tmp_call = call ptr @mayFail(%tmp_alloca.1, %tmp_const.1)
    %tmp_load = load i64 %tmp_alloca.1
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
try_success:
    br @block3
try_otherwise_block:
    %tmp_const.3 = const.i64 i64 42
    store %result %tmp_const.3
    br @block3
try_merge:
    %tmp_load.3 = load i64 %result
    ret %tmp_load.3
}

---

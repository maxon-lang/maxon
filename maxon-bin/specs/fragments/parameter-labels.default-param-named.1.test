// Test: parameter-labels.default-param-named.1
function repeat(value int, times int = 1) returns int
    return value * times
end 'repeat'

function main() returns int
    return repeat(value: 7, times: 6)
end 'main'
---
ExitCode: 42
---
function repeat() -> i64 {
entry:
    %value = param i64 0
    %value.1 = alloca ptr
    store %value.1 %value
    %times = param i64 1
    %times.1 = alloca ptr
    store %times.1 %times
    %tmp_load = load i64 %value.1
    %tmp_load.1 = load i64 %times.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_mul
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 7
    %tmp_const.1 = const.i64 i64 6
    %tmp_call = call i64 @repeat(%tmp_const, %tmp_const.1)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

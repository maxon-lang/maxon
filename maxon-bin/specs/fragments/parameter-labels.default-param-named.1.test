// Test: parameter-labels.default-param-named.1
function repeat(value int, times int = 1) returns int
    return value * times
end 'repeat'

function main() returns int
    return repeat(value: 7, times: 6)
end 'main'
---
ExitCode: 42
---
function repeat() -> i64 {
entry_0:
    %value = param i64 0
    %times = param i64 1
    %tmp_mul = mul i64 %value %times
    ret %tmp_mul
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 7
    %tmp_const.1 = const.i64 i64 6
    %tmp_call = call i64 @repeat(%tmp_const, %tmp_const.1)
    ret %tmp_call
}


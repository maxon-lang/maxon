// Test: expressions.multiple-variables.1
function main() returns int
    var x = 42
    var y = 10
    var result = x + y
    return result
end 'main'
---
ExitCode: 52
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 10
    %y = alloca ptr
    store %y %tmp_const.1
    %tmp_load = load i64 %x
    %tmp_load.1 = load i64 %y
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %result = alloca ptr
    store %result %tmp_add
    %tmp_load.2 = load i64 %result
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

// Test: comparison-operators.doc-example-1.1
function main() returns int
    var x = 10
    var y = 20
    
    if x < y 'test1'
        if x != y 'test2'
            return 1
        end 'test2'
    end 'test1'
    
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %y = alloca ptr
    store %y %tmp_const.1
    %tmp_load = load i64 %x
    %tmp_load.1 = load i64 %y
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_load.1
    br.cond %tmp_icmp @then$test1_1 @end$test1_4
then$test1_1:
    %tmp_load.2 = load i64 %x
    %tmp_load.3 = load i64 %y
    %tmp_icmp.1 = icmp.ne i64 %tmp_load.2 %tmp_load.3
    br.cond %tmp_icmp.1 @then$test2_2 @end$test2_3
then$test2_2:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.4 = load i64 %tmp_alloca.2
    ret %tmp_load.4
end$test2_3:
    br @end$test1_4
end$test1_4:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.3
    %tmp_load.5 = load i64 %tmp_alloca.3
    ret %tmp_load.5
}

---

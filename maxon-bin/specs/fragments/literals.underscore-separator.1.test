// Test: literals.underscore-separator.1
function main() returns int
    var x = 1_000
    return x - 990
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1000
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 990
    %tmp_sub = sub i64 %tmp_load %tmp_const.1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_sub
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

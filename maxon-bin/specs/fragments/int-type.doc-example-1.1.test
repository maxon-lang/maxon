// Test: int-type.doc-example-1.1
function factorial(n int) returns int
    if n <= 1 'base'
        return 1
    end 'base'
    return n * factorial(n - 1)
end 'factorial'

function main() returns int
    return factorial(5)  // Returns 120
end 'main'
---
ExitCode: 120
---
function factorial() -> i64 {
entry_0:
    %n = param i64 0
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_load = load i64 %n.1
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.le i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @then$base_1 @end$base_2
then$base_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$base_2:
    %tmp_load.2 = load i64 %n.1
    %tmp_load.3 = load i64 %n.1
    %tmp_const.2 = const.i64 i64 1
    %tmp_sub = sub i64 %tmp_load.3 %tmp_const.2
    %tmp_call = call i64 @factorial(%tmp_sub)
    %tmp_mul = mul i64 %tmp_load.2 %tmp_call
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_mul
    %tmp_load.4 = load i64 %tmp_alloca.2
    ret %tmp_load.4
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @factorial(%tmp_const)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


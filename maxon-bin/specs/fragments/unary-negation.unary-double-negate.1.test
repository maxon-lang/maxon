// Test: unary-negation.unary-double-negate.1
function main() returns int
    var x = 42
    var y = --x
    return y
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 0
    %tmp_sub = sub i64 %tmp_const.1 %tmp_load
    %tmp_const.2 = const.i64 i64 0
    %tmp_sub.1 = sub i64 %tmp_const.2 %tmp_sub
    %y = alloca ptr
    store %y %tmp_sub.1
    %tmp_load.1 = load i64 %y
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

// Test: collection.doc-example-4.1
function double(x int) returns int
    return x * 2
end 'double'

function main() returns int
    var numbers = [1, 2, 3, 4, 5]
    var doubled = numbers.map(double)
    var val = try doubled.get(2) otherwise 0
    print("{val}\n")
    return 0
end 'main'

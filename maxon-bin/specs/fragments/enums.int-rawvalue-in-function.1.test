// Test: enums.int-rawvalue-in-function.1
enum HttpStatus
    ok = 200
    notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns int
    return s.rawValue
end 'getCode'

function main() returns int
    var status = HttpStatus.notFound
    var code = getCode(status)
    if code == 404 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function getCode() -> i64 {
entry_0:
    %s = param i64 0
    ret %s
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 404
    %tmp_call = call i64 @getCode(%tmp_const)
    %tmp_const.1 = const.i64 i64 404
    %tmp_icmp = icmp.eq i64 %tmp_call %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

// Test: nil-optional-types.else-unwrap-value.1
function returnsValue() returns int or nil
	return 5
end 'returnsValue'

function main() returns int
	var opt = returnsValue()
	var result = opt else 'default'
		result = 99
	end 'default'
	return result
end 'main'
---
ExitCode: 5
---
function returnsValue() -> ptr {
entry:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_call = call ptr @returnsValue(%tmp_alloca)
    %opt = alloca ptr
    store %opt %tmp_alloca
    %tmp_load = load ptr %opt
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    %result = alloca ptr
    br.cond %tmp_icmp @block1 @block2
else_unwrap_some:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    store %result %tmp_load.2
    br @block3
else_unwrap_nil:
    %tmp_const.1 = const.i64 i64 99
    store %result %tmp_const.1
    br @block3
else_unwrap_end:
    %tmp_load.3 = load i64 %result
    ret %tmp_load.3
}

---

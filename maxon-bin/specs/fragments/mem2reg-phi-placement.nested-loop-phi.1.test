// Test: mem2reg-phi-placement.nested-loop-phi.1
function main() returns int
    var total = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            total = total + 1
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return total
end 'main'
---
ExitCode: 9
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %total = alloca ptr
    store %total %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %i = alloca ptr
    store %i %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 3
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block6
whilebody:
    %tmp_const.3 = const.i64 i64 0
    %j = alloca ptr
    store %j %tmp_const.3
    br @block3
whilecond:
    %tmp_load.1 = load i64 %j
    %tmp_const.4 = const.i64 i64 3
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.1 %tmp_const.4
    br.cond %tmp_icmp.1 @block4 @block5
whilebody:
    %tmp_load.2 = load i64 %total
    %tmp_const.5 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.2 %tmp_const.5
    store %total %tmp_add
    %tmp_load.3 = load i64 %j
    %tmp_const.6 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.6
    store %j %tmp_add.1
    br @block3
whilecont:
    %tmp_load.4 = load i64 %i
    %tmp_const.7 = const.i64 i64 1
    %tmp_add.2 = add i64 %tmp_load.4 %tmp_const.7
    store %i %tmp_add.2
    br @block1
whilecont:
    %tmp_load.5 = load i64 %total
    ret %tmp_load.5
}


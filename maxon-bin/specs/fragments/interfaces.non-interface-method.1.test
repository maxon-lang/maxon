// Test: interfaces.non-interface-method.1
type Calculator
    var value int

    function double() returns int
        return value * 2
    end 'double'

    function triple() returns int
        return value * 3
    end 'triple'
end 'Calculator'

function main() returns int
    var c = Calculator{value: 7}
    return c.double() + c.triple()
end 'main'

// Test: if-try.if-try-else-with-error-binding.1
enum MyError is Error
    first
    second
end 'MyError'

function mayFail(which int) returns int throws MyError
    if which == 1 'check1'
        throw MyError.first
    end 'check1'
    if which == 2 'check2'
        throw MyError.second
    end 'check2'
    return 42
end 'mayFail'

function main() returns int
    var result = 0
    if try mayFail(1) 'check'
        result = 100
    end 'check' else (e) 'err'
        result = 50
    end 'err'
    return result
end 'main'
---
ExitCode: 50
---
function mayFail() -> ptr {
entry:
    %tmp_param = param ptr 0
    %which = param i64 1
    %which.1 = alloca ptr
    store %which.1 %which
    %tmp_load = load i64 %which.1
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 0
    %tmp_const.2 = const.i64 i64 1
    store %tmp_param %tmp_const.2
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const.1
    ret %tmp_param
end:
    %tmp_load.1 = load i64 %which.1
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp.1 @block3 @block4
then:
    %tmp_const.4 = const.i64 i64 1
    %tmp_const.5 = const.i64 i64 1
    store %tmp_param %tmp_const.5
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.4
    ret %tmp_param
end:
    %tmp_const.6 = const.i64 i64 42
    %tmp_const.7 = const.i64 i64 0
    store %tmp_param %tmp_const.7
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.2 %tmp_const.6
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const
    %tmp_alloca.1 = alloca.sized ptr 16
    %tmp_const.1 = const.i64 i64 1
    %tmp_call = call ptr @mayFail(%tmp_alloca.1, %tmp_const.1)
    %tmp_load = load i64 %tmp_alloca.1
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
try_success:
    %tmp_const.3 = const.i64 i64 100
    store %result %tmp_const.3
    br @block3
if_try_else:
    %tmp_const.4 = const.i64 i64 50
    store %result %tmp_const.4
    br @block3
try_merge:
    %tmp_load.3 = load i64 %result
    %tmp_alloca.4 = alloca ptr
    store %tmp_alloca.4 %tmp_load.3
    %tmp_load.4 = load i64 %tmp_alloca.4
    ret %tmp_load.4
}

---

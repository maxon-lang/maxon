// Test: first-class-functions.first-class-function.pass-as-argument.1
function apply(f (int) returns int, x int) returns int
    return f(x)
end 'apply'

function triple(n int) returns int
    return n * 3
end 'triple'

function main() returns int
    return apply(triple, 10)
end 'main'
---
ExitCode: 30
---
function apply() -> i64 {
entry:
    %f = param ptr 0
    %f.1 = alloca ptr
    store %f.1 %f
    %x = param i64 1
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load ptr %f.1
    %tmp_load.1 = load i64 %x.1
    %tmp_call_ind = call.indirect i64 %tmp_load(%tmp_load.1)
    ret %tmp_call_ind
}

function triple() -> i64 {
entry:
    %n = param i64 0
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_load = load i64 %n.1
    %tmp_const = const.i64 i64 3
    %tmp_mul = mul i64 %tmp_load %tmp_const
    ret %tmp_mul
}

function main() -> i64 {
entry:
    %tmp_funcaddr = func.addr ptr @triple
    %tmp_const = const.i64 i64 10
    %tmp_call = call i64 @apply(%tmp_funcaddr, %tmp_const)
    ret %tmp_call
}

---

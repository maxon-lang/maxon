function apply() -> i64 {
entry_0:
    %f = param ptr 0
    %x = param i64 1
    %tmp_call_ind = call.indirect i64 %f(%x)
    ret %tmp_call_ind
}

function triple() -> i64 {
entry_0:
    %n = param i64 0
    %tmp_const = const.i64 i64 3
    %tmp_mul = mul i64 %n %tmp_const
    ret %tmp_mul
}

function main() -> i64 {
entry_0:
    %tmp_funcaddr = func.addr ptr @triple
    %tmp_const = const.i64 i64 10

// Test: first-class-functions.first-class-function.reassign.1
function double(x int) returns int
    return x * 2
end 'double'

function triple(x int) returns int
    return x * 3
end 'triple'

function main() returns int
    var f = double
    var a = f(10)
    f = triple
    var b = f(10)
    return a + b
end 'main'
---
ExitCode: 50
---
function double() -> i64 {
entry:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load i64 %x.1
    %tmp_const = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load %tmp_const
    ret %tmp_mul
}

function triple() -> i64 {
entry:
    %x = param i64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load i64 %x.1
    %tmp_const = const.i64 i64 3
    %tmp_mul = mul i64 %tmp_load %tmp_const
    ret %tmp_mul
}

function main() -> i64 {
entry:
    %tmp_funcaddr = func.addr ptr @double
    %f = alloca ptr
    store %f %tmp_funcaddr
    %tmp_load = load ptr %f
    %tmp_const = const.i64 i64 10
    %tmp_call_ind = call.indirect i64 %tmp_load(%tmp_const)
    %a = alloca ptr
    store %a %tmp_call_ind
    %tmp_funcaddr.1 = func.addr ptr @triple
    store %f %tmp_funcaddr.1
    %tmp_load.1 = load ptr %f
    %tmp_const.1 = const.i64 i64 10
    %tmp_call_ind.1 = call.indirect i64 %tmp_load.1(%tmp_const.1)
    %b = alloca ptr
    store %b %tmp_call_ind.1
    %tmp_load.2 = load i64 %a
    %tmp_load.3 = load i64 %b
    %tmp_add = add i64 %tmp_load.2 %tmp_load.3
    ret %tmp_add
}

---

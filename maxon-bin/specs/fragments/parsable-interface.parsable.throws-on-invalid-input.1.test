// Test: parsable-interface.parsable.throws-on-invalid-input.1
// Parsable.fromString throws error on invalid input
enum ParseError is Error
    Empty = 1
end 'ParseError'

type Value is Parsable
    export var n int

    static function Parsable.fromString(input String) returns Self throws ParseError
        if input.byteLength() == 0 'check'
            throw ParseError.Empty
        end 'check'
        return {n: input.byteLength()}
    end 'fromString'
end 'Value'

function main() returns int
    var v = try Value.fromString("") otherwise 'err'
        return 42
    end 'err'
    return v.n
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_alloca.1 = alloca.sized ptr 32
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i32 i32 0
    store %tmp_alloca.1 %tmp_const
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca.1 8
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.1 16
    store %tmp_fieldptr.1 %tmp_const
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_alloca.1 24
    store.i32 %tmp_fieldptr.2 %tmp_const.1
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_alloca.1 28
    store.i32 %tmp_fieldptr.3 %tmp_const.1
    %tmp_alloca.2 = alloca.sized ptr 40
    %tmp_call = call ptr @String$init(%tmp_alloca.2, %tmp_alloca.1)
    %tmp_call.1 = call ptr @Value$fromString(%tmp_alloca, %tmp_alloca.2)
    %tmp_load = load i64 %tmp_alloca
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    %v = alloca.sized ptr 8
    br.cond %tmp_icmp @try_success_1 @try_otherwise_block_2
try_success_1:
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_alloca 8
    memcpy %v %tmp_fieldptr.4 8
    br @try_merge_3
try_otherwise_block_2:
    %tmp_const.3 = const.i64 i64 42
    ret %tmp_const.3
try_merge_3:
    %tmp_fieldptr.5 = getfieldptr ptr %v 0
    %tmp_load.2 = load i64 %tmp_fieldptr.5
    ret %tmp_load.2
}

function Value$fromString() -> ptr {
entry_0:
    %tmp_param = param ptr 0
    %input = param ptr 1
    %tmp_call = call i64 @String$byteLength(%input)
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_call %tmp_const
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_const.2 = const.i64 i64 1
    store %tmp_param %tmp_const.2
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const.1
    ret %tmp_param
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    memset %tmp_fieldptr.1 0 8
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_fieldptr.1 0
    %tmp_call.1 = call i64 @String$byteLength(%input)
    store %tmp_fieldptr.2 %tmp_call.1
    ret %tmp_param
}


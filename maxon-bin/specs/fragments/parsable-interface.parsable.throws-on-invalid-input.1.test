// Test: parsable-interface.parsable.throws-on-invalid-input.1
// Parsable.fromString throws error on invalid input
enum ParseError int is Error
    Empty = 1
end 'ParseError'

type Value is Parsable
    export var n int

    static function Parsable.fromString(input String) returns Self throws ParseError
        if input.byteLength() == 0 'check'
            throw ParseError.Empty
        end 'check'
        return Value{n: input.byteLength()}
    end 'fromString'
end 'Value'

function main() returns int
    do 'parse'
        var v = try Value.fromString("")
        return v.n
    end 'parse' catch (e ParseError) 'err'
        return 42
    end 'err'
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 64
    %tmp_alloca.1 = alloca.sized ptr 16
    %tmp_alloca.2 = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i32 i32 0
    %tmp_fieldptr = getfieldptr ptr %tmp_alloca.2 0
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.2 8
    store.i32 %tmp_fieldptr.1 %tmp_const.1
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_alloca.2 12
    store.i32 %tmp_fieldptr.2 %tmp_const.1
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_alloca.2 16
    store.i32 %tmp_fieldptr.3 %tmp_const.1
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_alloca.2 20
    store.i32 %tmp_fieldptr.4 %tmp_const.1
    %tmp_alloca.3 = alloca.sized ptr 32
    %tmp_call = call ptr @String$init(%tmp_alloca.3, %tmp_alloca.2)
    %tmp_call.1 = call ptr @Value$fromString(%tmp_alloca.1, %tmp_alloca.3)
    %tmp_load = load i64 %tmp_alloca.1
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
try_success:
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_alloca.1 8
    %tmp_alloca.4 = alloca ptr
    store %tmp_alloca.4 %tmp_fieldptr.5
    br @block3
try_propagate:
    memcpy %tmp_alloca %tmp_alloca.1 64
    br @block4
try_merge:
    %v = load ptr %tmp_alloca.4
    %tmp_fieldptr.6 = getfieldptr ptr %v 0
    %tmp_load.2 = load i64 %tmp_fieldptr.6
    ret %tmp_load.2
    br @block6
catch_dispatch:
    br @block5
catch_0:
    %tmp_const.3 = const.i64 i64 42
    ret %tmp_const.3
    br @block6
do_end:
}

function Value$fromString() -> ptr {
entry:
    %tmp_param = param ptr 0
    %input = param ptr 1
    %tmp_call = call i64 @String$byteLength(%input)
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_call %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    %tmp_const.2 = const.i64 i64 1
    store %tmp_param %tmp_const.2
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const.1
    ret %tmp_param
end:
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    memset %tmp_fieldptr.1 0 8
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_fieldptr.1 0
    %tmp_call.1 = call i64 @String$byteLength(%input)
    store %tmp_fieldptr.2 %tmp_call.1
    ret %tmp_param
}


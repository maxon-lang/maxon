// Test: ownership.multiple-vars-reassign.1
function main() returns int
    var a = 1
    var b = 2
    var c = 3
    a = 10
    b = 20
    c = 30
    return a + b + c
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 2
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_const.2 = const.i64 i64 3
    %c = alloca ptr
    store %c %tmp_const.2
    %tmp_const.3 = const.i64 i64 10
    store %a %tmp_const.3
    %tmp_const.4 = const.i64 i64 20
    store %b %tmp_const.4
    %tmp_const.5 = const.i64 i64 30
    store %c %tmp_const.5
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_load.2 = load i64 %c
    %tmp_add.1 = add i64 %tmp_add %tmp_load.2
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_add.1
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

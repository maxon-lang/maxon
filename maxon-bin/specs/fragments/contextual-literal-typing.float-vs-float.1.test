// Test: contextual-literal-typing.float-vs-float.1
function main() returns int
    var a = 3.14
    var b = 3.14
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.14
    %tmp_fconst.1 = const.f64 f64 3.14
    %tmp_fcmp = fcmp.eq i64 %tmp_fconst %tmp_fconst.1
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

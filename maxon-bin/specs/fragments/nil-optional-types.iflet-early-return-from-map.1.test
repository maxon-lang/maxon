// Test: nil-optional-types.iflet-early-return-from-map.1
function lookup(m Map from String to int, key String) returns int
    if let val = m.get(key) 'found'
        return val
    end 'found'
    return 0 - 1
end 'lookup'

function main() returns int
    var m = ["a": 10, "b": 20, "c": 30]
    return lookup(m, "b")
end 'main'

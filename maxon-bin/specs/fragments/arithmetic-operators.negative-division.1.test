// Test: arithmetic-operators.negative-division.1
function main() returns int
    var neg = -7
    let a = trunc(neg / 2)    // -7/2 = -3.5, trunc = -3 (toward zero)
    if a == -3 'pass'
      return 0
    end 'pass'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_sub = const.i64 i64 -7
    %neg = alloca ptr
    store %neg %tmp_sub
    %tmp_load = load i64 %neg
    %tmp_const.2 = const.i64 i64 2
    %tmp_sitofp = sitofp f64 %tmp_load
    %tmp_sitofp.1 = sitofp f64 %tmp_const.2
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %a = alloca ptr
    store %a %tmp_fptosi
    %tmp_load.1 = load i64 %a
    %tmp_sub.1 = const.i64 i64 -3
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_sub.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.5 = const.i64 i64 0
    ret %tmp_const.5
end:
    %tmp_const.6 = const.i64 i64 1
    ret %tmp_const.6
}

---

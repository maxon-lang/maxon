// Test: primitive-hashable.float.hash.nonzero.1
function main() returns int
    var f = 3.14
    var h = f.hash()
    if h != 0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.14
    %f = alloca ptr
    store %f %tmp_fconst
    %tmp_load = load f64 %f
    %tmp_fconst.1 = const.f64 f64 0
    %tmp_fcmp = fcmp.eq i64 %tmp_load %tmp_fconst.1
    %tmp_alloca.1 = alloca ptr
    br.cond %tmp_fcmp @float_hash_zero_1 @float_hash_nonzero_2
float_hash_zero_1:
    %tmp_const = const.i64 i64 0
    store %tmp_alloca.1 %tmp_const
    br @float_hash_end_3
float_hash_nonzero_2:
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_load
    store %tmp_alloca.1 %tmp_bitcast
    br @float_hash_end_3
float_hash_end_3:
    %tmp_load.1 = load i64 %tmp_alloca.1
    %h = alloca ptr
    store %h %tmp_load.1
    %tmp_load.2 = load i64 %h
    %tmp_const.1 = const.i64 i64 0
    %tmp_icmp = icmp.ne i64 %tmp_load.2 %tmp_const.1
    br.cond %tmp_icmp @then$check_4 @end$check_5
then$check_4:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.2
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
end$check_5:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.4 = alloca ptr
    store %tmp_alloca.4 %tmp_const.3
    %tmp_load.4 = load i64 %tmp_alloca.4
    ret %tmp_load.4
}

---

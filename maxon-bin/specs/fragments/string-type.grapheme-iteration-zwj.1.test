// Test: string-type.grapheme-iteration-zwj.1
function main() returns int
    var s = "👨‍👩‍👧"  // Family emoji (1 grapheme)
    var count = 0
    for c in s 'loop'
        var _unused = c.bytes().count()  // Use c to avoid unused warning
        _unused = _unused
        count = count + 1
    end 'loop'
    print("{count}\n")
    return 0
end 'main'

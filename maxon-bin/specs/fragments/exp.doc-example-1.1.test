// Test: exp.doc-example-1.1
function main() returns int
    var result = Math.exp(0.0)  // e^0 = 1
    return trunc(result)
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 0
    %tmp_call = call f64 @Math$exp(%tmp_fconst)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_fptosi
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

// Test: enums.float-backed.1
enum FloatBacked
    North = 1.1
    South = 2.2
    East = 3.3
end 'FloatBacked'

function main() returns int
    var f = FloatBacked.North
    if f == FloatBacked.South 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 1.1
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    %f = alloca ptr
    store %f %tmp_bitcast
    %tmp_load = load i64 %f
    %tmp_fconst.1 = const.f64 f64 2.2
    %tmp_bitcast.1 = bitcast.f64.i64 i64 %tmp_fconst.1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_bitcast.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

---

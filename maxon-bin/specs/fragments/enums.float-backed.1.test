// Test: enums.float-backed.1
enum FloatBacked
    North = 1.1
    South = 2.2
    East = 3.3
end 'FloatBacked'

function main() returns int
    var f = FloatBacked.North
    if f == FloatBacked.South 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 1.1
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    %f = alloca ptr
    store %f %tmp_bitcast
    %tmp_load = load i64 %f
    %tmp_fconst.1 = const.f64 f64 2.2
    %tmp_bitcast.1 = bitcast.f64.i64 i64 %tmp_fconst.1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_bitcast.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

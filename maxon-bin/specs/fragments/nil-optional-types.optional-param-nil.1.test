// Test: nil-optional-types.optional-param-nil.1
function checkValue(x int or nil) returns int
	if let val = x 'check'
		return val
	end 'check' else 'nil_case'
		return 99
	end 'nil_case'
end 'checkValue'

function main() returns int
	return checkValue(nil)
end 'main'
---
ExitCode: 99
---
function checkValue() -> i64 {
entry:
    %tmp_param = param ptr 0
    %x = alloca ptr
    store %x %tmp_param
    %tmp_load = load ptr %x
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    br.cond %tmp_icmp @block1 @block2
if_let_then:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    %val = alloca ptr
    store %val %tmp_load.2
    %tmp_load.3 = load i64 %val
    ret %tmp_load.3
if_let_else:
    %tmp_const.1 = const.i64 i64 99
    ret %tmp_const.1
if_let_end:
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 0
    store %tmp_alloca %tmp_const
    %tmp_call = call i64 @checkValue(%tmp_alloca)
    ret %tmp_call
}

---

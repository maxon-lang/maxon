// Test: string-type.utf16-is-bmp.1
function main() returns int
    if utf16IsBmp(65) 'c10'
        print("{1}")       // ASCII
    end 'c10'
    if utf16IsBmp(945) 'c11'
        print("{2}")      // Greek α
    end 'c11'
    if utf16IsBmp(65535) 'c12'
        print("{3}")    // U+FFFF (last BMP)
    end 'c12'
    if utf16IsBmp(128512) 'c13'
        print("{0}")   // 😀 (not BMP)
    end 'c13'
    return 0
end 'main'
---

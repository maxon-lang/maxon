// Test: many-args.mixed-computation-many-args.1
function compute(a int, b int, c int, d int, e int, f int) returns int
    let reg_sum = a + b + c + d
    let stack_sum = e + f
    return reg_sum * stack_sum
end 'compute'

function main() returns int
    return compute(1, b: 2, c: 3, d: 4, e: 10, f: 5)
end 'main'

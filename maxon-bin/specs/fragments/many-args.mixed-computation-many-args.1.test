    %tmp_add.1 = add i64 %tmp_add %c
    %tmp_add.2 = add i64 %tmp_add.1 %d
    %tmp_add.3 = add i64 %e %f
    %tmp_mul = mul i64 %tmp_add.2 %tmp_add.3
    ret %tmp_mul
}

function main() -> i64 {
entry_0:

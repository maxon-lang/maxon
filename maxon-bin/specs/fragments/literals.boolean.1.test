// Test: literals.boolean.1
function main() returns int
    var flag = true
    if flag 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    %flag = alloca ptr
    store %flag %tmp_const
    %tmp_load = load i64 %flag
    br.cond %tmp_load @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.2

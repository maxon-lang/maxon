// Test: literals.boolean.1
function main() returns int
    var flag = true
    if flag 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %flag = alloca ptr
    store %flag %tmp_const
    %tmp_load = load i64 %flag
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

---

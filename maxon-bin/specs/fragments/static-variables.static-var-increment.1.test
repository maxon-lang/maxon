// Test: static-variables.static-var-increment.1
type Counter
    static var count = 0

    static function increment()
        Counter.count = Counter.count + 1
    end 'increment'
end 'Counter'

function main() returns int
    Counter.increment()
    Counter.increment()
    Counter.increment()
    return Counter.count
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_globaladdr = global.addr ptr @global.Counter.count elemsize=8
    store %tmp_globaladdr %tmp_const
    call @Counter$increment()
    call @Counter$increment()
    call @Counter$increment()
    %tmp_globaladdr.1 = global.addr ptr @global.Counter.count elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.1
    ret %tmp_load
}

function Counter$increment() -> void {
entry_0:
    %tmp_globaladdr = global.addr ptr @global.Counter.count elemsize=8
    %tmp_load = load i64 %tmp_globaladdr
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    %tmp_globaladdr.1 = global.addr ptr @global.Counter.count elemsize=8
    store %tmp_globaladdr.1 %tmp_add
    ret
}


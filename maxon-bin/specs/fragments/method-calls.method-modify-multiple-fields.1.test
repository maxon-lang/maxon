// Test: method-calls.method-modify-multiple-fields.1
type Point
    var x int
    var y int

    function moveBy(dx int, dy int)
        x = x + dx
        y = y + dy
    end 'moveBy'

    function sum() returns int
        return x + y
    end 'sum'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 10}
    p.moveBy(10, 12)
    return p.sum()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 10
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_const.2 = const.i64 i64 10
    %tmp_const.3 = const.i64 i64 12
    call @Point$moveBy(%p, %tmp_const.2, %tmp_const.3)
    %tmp_call = call i64 @Point$sum(%p)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Point$moveBy() -> void {
entry:
    %self = param ptr 0
    %dx = param i64 1
    %dx.1 = alloca ptr
    store %dx.1 %dx
    %dy = param i64 2
    %dy.1 = alloca ptr
    store %dy.1 %dy
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_load.1 = load i64 %dx.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    %tmp_fieldptr.2 = getfieldptr ptr %self 8
    %tmp_load.2 = load i64 %tmp_fieldptr.2
    %tmp_load.3 = load i64 %dy.1
    %tmp_add.1 = add i64 %tmp_load.2 %tmp_load.3
    %tmp_fieldptr.3 = getfieldptr ptr %self 8
    store %tmp_fieldptr.3 %tmp_add.1
    ret
}

function Point$sum() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %self 8
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_add
    %tmp_load.2 = load i64 %tmp_alloca
    ret %tmp_load.2
}

---

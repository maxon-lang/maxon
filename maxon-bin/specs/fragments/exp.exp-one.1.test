// Test: exp.exp-one.1
function main() returns int
    var result = exp(1.0)  // e^1 ≈ 2.71828
    return trunc(result)
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 1
    %tmp_call = call f64 @exp(%tmp_fconst)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}

---

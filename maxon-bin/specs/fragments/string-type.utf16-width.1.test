// Test: string-type.utf16-width.1
function main() returns int
    print("{utf16Width(65)}")      // ASCII 'A' = 1 code unit
    print("{utf16Width(945)}")     // Greek α = 1 code unit (BMP)
    print("{utf16Width(128512)}")  // 😀 U+1F600 = 2 code units
    return 0
end 'main'

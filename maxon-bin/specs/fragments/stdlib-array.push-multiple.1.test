// Test: stdlib-array.push-multiple.1
function main() returns int
    var arr = Array of int{}
    arr.push(10)
    arr.push(20)
    arr.push(30)
    if arr.count() != 3 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 0

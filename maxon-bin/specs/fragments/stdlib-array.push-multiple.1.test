    %tmp_alloca.3 = alloca.sized ptr 40
    %tmp_const.2 = const.i64 i64 30
    %tmp_call.2 = call ptr @Array$int$push(%tmp_alloca.3, %arr, %tmp_const.2)
    %tmp_call.3 = call i64 @Array$int$count(%arr)
    %tmp_const.3 = const.i64 i64 3
    %tmp_icmp = icmp.ne i64 %tmp_call.3 %tmp_const.3
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.4 = const.i64 i64 1
    %tmp_load = load ptr %arr
    heap.free %tmp_load tag="array cleanup"
    ret %tmp_const.4
end:
    %tmp_const.5 = const.i64 i64 0
    %tmp_load.1 = load ptr %arr
    heap.free %tmp_load.1 tag="array cleanup"
    ret %tmp_const.5
}


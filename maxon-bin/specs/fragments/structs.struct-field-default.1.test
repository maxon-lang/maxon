// Test: structs.struct-field-default.1
type Counter
	export var value = 0
	export var step = 1
end 'Counter'

function main() returns int
	var c1 = Counter{}
	var c2 = Counter{value: 40}
	var c3 = Counter{value: 10, step: 2}
	return c1.value + c2.value + c3.step
end 'main'

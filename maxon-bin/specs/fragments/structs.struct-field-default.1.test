    %c1 = alloca.sized ptr 16
    memset %c1 0 16
    %c2 = alloca.sized ptr 16
    memset %c2 0 16
    %c3 = alloca.sized ptr 16
    memset %c3 0 16
    %tmp_add.1 = const.i64 i64 42
    ret %tmp_add.1
}


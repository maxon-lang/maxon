// Test: interface-extensions.stdlib-map-on-map.1
typealias StringIntPair is Pair with (String, int)

function main() returns int
    var m = ["a": 1, "b": 2, "c": 3]
    var mapped = m.map((p) gives {key: p.key, value: p.value * 10})

    var sum = 0
    for pair in mapped 'loop'
        sum = sum + pair.value
    end 'loop'

    // 10 + 20 + 30 = 60
    return sum
end 'main'

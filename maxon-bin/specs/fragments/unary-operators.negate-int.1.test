// Test: unary-operators.negate-int.1
function main() returns int
    var x = -42
    var y = -x
    if y == 42 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_sub = const.i64 i64 -42
    %x = alloca ptr
    store %x %tmp_sub
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 0
    %tmp_sub.1 = sub i64 %tmp_const.2 %tmp_load
    %y = alloca ptr
    store %y %tmp_sub.1
    %tmp_load.1 = load i64 %y
    %tmp_const.3 = const.i64 i64 42
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.4 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end$check_2:
    %tmp_const.5 = const.i64 i64 1
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.5
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

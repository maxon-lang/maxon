// Test: match-statements.match-range.float.1
function main() returns int
    var x = 2.5
    match x 'check'
        0.0..=5.0 then return 1
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 2.5
    br @match_check_1
match_check_1:
    %tmp_fconst.2 = const.f64 f64 0
    %tmp_fcmp = fcmp.ge f64 %tmp_fconst %tmp_fconst.2
    %tmp_fconst.3 = const.f64 f64 5
    %tmp_fcmp.1 = fcmp.le f64 %tmp_fconst %tmp_fconst.3
    %tmp_band = band i64 %tmp_fcmp %tmp_fcmp.1
    br.cond %tmp_band @match_body_2 @match_default_3
match_body_2:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
match_default_3:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
match_merge_4:
}

---

// Test: string-type.isEmpty-method.1
function main() returns int
    var empty = ""
    var nonempty = "hello"
    if empty.isEmpty() 'check1'
        print("{1}")
    end 'check1'
    if nonempty.isEmpty() 'check2'
        print("{0}")
    end 'check2' else 'not_empty'
        print("{2}")
    end 'not_empty'
    return 0
end 'main'

// Test: float-type.basic-float.1
function main() returns int
    var x = 3.14
    var y = 2.0
    var z = x + y
    var result = trunc(z)
    return result
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 3.14
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_fconst.1 = const.f64 f64 2
    %y = alloca ptr
    store %y %tmp_fconst.1
    %tmp_load = load f64 %x
    %tmp_load.1 = load f64 %y
    %tmp_fadd = fadd f64 %tmp_load %tmp_load.1
    %z = alloca ptr
    store %z %tmp_fadd
    %tmp_load.2 = load f64 %z
    %tmp_fptosi = fptosi i64 %tmp_load.2
    %result = alloca ptr
    store %result %tmp_fptosi
    %tmp_load.3 = load i64 %result
    ret %tmp_load.3
}

---

// Test: break.break.with-if.1
function main() returns int
    var x = 0
    while true 'loop'
        x = x + 1
        if x == 10 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    br @whilecond_1
whilecond_1:
    %tmp_const.1 = const.i64 i64 1
    br.cond %tmp_const.1 @whilebody_2 @whilecont_5
whilebody_2:
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const.2
    store %x %tmp_add
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 10
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp @then$check_3 @end$check_4
then$check_3:
    br @whilecont_5
    br @end$check_4
end$check_4:
    br @whilecond_1
whilecont_5:
    %tmp_load.2 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.1
    ret %tmp_load.3
}

---

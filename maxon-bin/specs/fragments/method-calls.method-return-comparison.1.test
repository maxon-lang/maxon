// Test: method-calls.method-return-comparison.1
type Value
    var n int

    function isPositive() returns int
        if n > 0 'positive'
            return 1
        end 'positive'
        return 0
    end 'isPositive'
end 'Value'

function main() returns int
    var v = Value{n: 42}
    return v.isPositive()
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %v = alloca.sized ptr 8
    memset %v 0 8
    %tmp_fieldptr = getfieldptr ptr %v 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @Value$isPositive(%v)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Value$isPositive() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const.1
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
end:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
}

---

// Test: nil-optional-types.optional-struct-field-implicit-wrap.1
type Point
	export var x int
	export var y int or nil
end 'Point'

function main() returns int
	var p = Point{x: 10, y: 20}
	var result = p.y else 'default'
		result = 0
	end 'default'
	return p.x + result
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 24
    memset %p 0 24
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 20
    %tmp_const.2 = const.i64 i64 1
    store %tmp_fieldptr.1 %tmp_const.2
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_fieldptr.1 8
    store %tmp_fieldptr.2 %tmp_const.1
    %tmp_fieldptr.3 = getfieldptr ptr %p 8
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_const.2 %tmp_const.3
    %result = alloca ptr
    br.cond %tmp_icmp @block1 @block2
else_unwrap_some:
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_fieldptr.3 8
    %tmp_load.1 = load i64 %tmp_fieldptr.4
    store %result %tmp_load.1
    br @block3
else_unwrap_nil:
    %tmp_const.4 = const.i64 i64 0
    store %result %tmp_const.4
    br @block3
else_unwrap_end:
    %tmp_fieldptr.5 = getfieldptr ptr %p 0
    %tmp_load.2 = load i64 %tmp_fieldptr.5
    %tmp_load.3 = load i64 %result
    %tmp_add = add i64 %tmp_load.2 %tmp_load.3
    ret %tmp_add
}

---

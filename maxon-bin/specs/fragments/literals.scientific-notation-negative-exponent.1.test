// Test: literals.scientific-notation-negative-exponent.1
function main() returns int
    var x = 5.0e-1
    return trunc(x * 20.0)
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 0.5
    %tmp_fconst.1 = const.f64 f64 20
    %tmp_fmul = fmul f64 %tmp_fconst %tmp_fconst.1
    %tmp_fptosi = fptosi i64 %tmp_fmul
    ret %tmp_fptosi
}


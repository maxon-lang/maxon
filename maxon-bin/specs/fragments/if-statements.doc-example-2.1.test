// Test: if-statements.doc-example-2.1
function main() returns int
    var x = 3
    if x > 5 'gt5'
        return 1
    end 'gt5' else 'not_gt5'
        return 0
    end 'not_gt5'
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const.1
    %tmp_load = br.cond %tmp_icmp @block1
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
else:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
end:
}

---

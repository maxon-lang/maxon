// Test: error-handling.error.throw-and-return-success.1
// Test that throwing function can return success value
enum MyError is Error
    failed
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
    if shouldFail 'check'
        throw MyError.failed
    end 'check'
    return 42
end 'mayFail'

function main() returns int
    return 42
end 'main'
---
ExitCode: 42
---
function mayFail() -> i64 {
entry:
    %tmp_param = param ptr 0
    %shouldFail = param i64 1
    %shouldFail.1 = alloca ptr
    store %shouldFail.1 %shouldFail
    %tmp_load = load i64 %shouldFail.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
end:
    %tmp_const.2 = const.i64 i64 42
    %tmp_const.3 = const.i64 i64 0
    store %tmp_param %tmp_const.3
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %tmp_const.2
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    ret %tmp_const
}

---

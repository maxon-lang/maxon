// Test: top-level-let.constant-in-expression.1
let OFFSET = 10

function main() returns int
    let x = 5
    return x + OFFSET
end 'main'
---
ExitCode: 15
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 10
    %tmp_add = add i64 %tmp_load %tmp_const.1
    ret %tmp_add
}

---

// Test: many-args.six-int-args.1
function add6(a int, b int, c int, d int, e int, f int) returns int
    return a + b + c + d + e + f
end 'add6'

function main() returns int
    return add6(10, b: 20, c: 30, d: 40, e: 50, f: 60)
end 'main'
---
ExitCode: 210

// Test: nil-optional-types.optional-struct-field-nil.1
type Person
	export var name String
	export var age int or nil
end 'Person'

function main() returns int
	var p = Person{name: "Bob", age: nil}
	if let a = p.age 'check'
		return a
	end 'check' else 'nil_case'
		return 99
	end 'nil_case'
end 'main'

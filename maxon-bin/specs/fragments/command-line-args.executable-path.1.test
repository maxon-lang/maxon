// Test: command-line-args.executable-path.1
function main() returns int
    let exe = CommandLine.executablePath()
    // Just verify it returns something (the actual path varies)
    if exe.byteLength() > 0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %exe = alloca.sized ptr 40
    %tmp_call = call ptr @CommandLine$executablePath(%exe)
    %tmp_call.1 = call i64 @String$byteLength(%exe)
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_call.1 %tmp_const
    br.cond %tmp_icmp @block1 @block5
then:
    %tmp_const.1 = const.i64 i64 0
    %tmp_fieldptr = getfieldptr ptr %exe 24
    %tmp_load = load i32 %tmp_fieldptr
    %tmp_sext = sext.i32.i64 i64 %tmp_load
    %tmp_const.2 = const.i64 i64 3
    %tmp_band = band i64 %tmp_sext %tmp_const.2
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_band %tmp_const.3
    br.cond %tmp_icmp.1 @block2 @block4
arr_decref:
    %tmp_load.1 = load ptr %exe
    %tmp_const.4 = const.i64 i64 8
    %tmp_sub = sub ptr %tmp_load.1 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_sub
    %tmp_const.5 = const.i64 i64 1
    %tmp_sub.1 = sub i64 %tmp_load.2 %tmp_const.5
    store %tmp_sub %tmp_sub.1
    %tmp_const.6 = const.i64 i64 0
    %tmp_icmp.2 = icmp.eq i64 %tmp_sub.1 %tmp_const.6
    br.cond %tmp_icmp.2 @block3 @block4
arr_decref_free:
    %tmp_load.3 = load ptr %exe
    %tmp_sub.2 = sub ptr %tmp_load.3 %tmp_const.4
    heap.free %tmp_sub.2 tag="string cleanup"
    br @block4
arr_decref_end:
    ret %tmp_const.1
end:
    %tmp_const.7 = const.i64 i64 1
    %tmp_fieldptr.1 = getfieldptr ptr %exe 24
    %tmp_load.4 = load i32 %tmp_fieldptr.1
    %tmp_sext.1 = sext.i32.i64 i64 %tmp_load.4
    %tmp_const.8 = const.i64 i64 3
    %tmp_band.1 = band i64 %tmp_sext.1 %tmp_const.8
    %tmp_const.9 = const.i64 i64 1
    %tmp_icmp.3 = icmp.eq i64 %tmp_band.1 %tmp_const.9
    br.cond %tmp_icmp.3 @block6 @block8
arr_decref:
    %tmp_load.5 = load ptr %exe
    %tmp_const.10 = const.i64 i64 8
    %tmp_sub.3 = sub ptr %tmp_load.5 %tmp_const.10
    %tmp_load.6 = load i64 %tmp_sub.3
    %tmp_const.11 = const.i64 i64 1
    %tmp_sub.4 = sub i64 %tmp_load.6 %tmp_const.11
    store %tmp_sub.3 %tmp_sub.4
    %tmp_const.12 = const.i64 i64 0
    %tmp_icmp.4 = icmp.eq i64 %tmp_sub.4 %tmp_const.12
    br.cond %tmp_icmp.4 @block7 @block8
arr_decref_free:
    %tmp_load.7 = load ptr %exe
    %tmp_sub.5 = sub ptr %tmp_load.7 %tmp_const.10
    heap.free %tmp_sub.5 tag="string cleanup"
    br @block8
arr_decref_end:
    ret %tmp_const.7
}

---

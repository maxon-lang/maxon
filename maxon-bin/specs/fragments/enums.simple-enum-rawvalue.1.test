// Test: enums.simple-enum-rawvalue.1
enum Direction
    north
    south
    east
end 'Direction'

function main() returns int
    var d = Direction.south
    return d.rawValue
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %d = alloca ptr
    store %d %tmp_const
    %tmp_load = load i64 %d
    ret %tmp_load
}


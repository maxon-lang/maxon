// Test: string-type.sso-vs-heap-boundary.1
function main() returns int
    // Exactly 15 bytes - should use SSO (constant data)
    var sso = "123456789012345"
    print("{sso.count()}\n")

    // 16 bytes - should use heap
    var heap = "1234567890123456"
    print("{heap.count()}\n")
    return 0
end 'main'

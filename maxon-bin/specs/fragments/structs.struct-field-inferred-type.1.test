ExitCode: 55
---
function main() -> i64 {
entry:
    %s = alloca.sized ptr 16
    memset %s 0 16
    %tmp_const = const.i64 i64 5
    %tmp_fconst = const.f64 f64 50
    %tmp_fptosi = fptosi i64 %tmp_fconst
    %tmp_add = add i64 %tmp_const %tmp_fptosi
    ret %tmp_add
}


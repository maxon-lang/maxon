// Test: command-line-args.args-with-one-arg.1
function main() returns int
    let args = CommandLine.args()
    return args.count()
end 'main'
---
ExitCode: 1
Args: hello
---
function main() -> i64 {
entry:
    %args = alloca.sized ptr 40
    %tmp_call = call ptr @CommandLine$args(%args)
    %tmp_call.1 = call i64 @Array$String$count(%args)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call.1
    %tmp_fieldptr = getfieldptr ptr %args 8
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 8
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const
    br.cond %tmp_icmp @block6 @block1

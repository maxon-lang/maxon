function Array$String$count() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 8
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 8
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load

    %tmp_load.3 = load ptr %tmp_fieldptr
    %tmp_load.4 = load i64 %tmp_alloca.2
    %tmp_const.1 = const.i64 i64 40
    %tmp_mul = mul i64 %tmp_load.4 %tmp_const.1
    %tmp_add = add ptr %tmp_load.3 %tmp_mul
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_add 24
    %tmp_load.5 = load i32 %tmp_fieldptr.3
    %tmp_const.2 = const.i32 i32 3
    %tmp_band = band i32 %tmp_load.5 %tmp_const.2
    %tmp_const.3 = const.i32 i32 1
    %tmp_icmp.2 = icmp.eq i32 %tmp_band %tmp_const.3
    br.cond %tmp_icmp.2 @block3 @block5
arr_managed_cleanup_decref:
    %tmp_load.6 = load ptr %tmp_fieldptr
    %tmp_load.7 = load i64 %tmp_alloca.2
    %tmp_mul.1 = mul i64 %tmp_load.7 %tmp_const.1
    %tmp_add.1 = add ptr %tmp_load.6 %tmp_mul.1
    %tmp_load.8 = load ptr %tmp_add.1
    %tmp_const.4 = const.i64 i64 8
    %tmp_sub = sub ptr %tmp_load.8 %tmp_const.4
    %tmp_load.9 = load i64 %tmp_sub
    %tmp_const.5 = const.i64 i64 1
    %tmp_sub.1 = sub i64 %tmp_load.9 %tmp_const.5
    store %tmp_sub %tmp_sub.1
    %tmp_const.6 = const.i64 i64 0
    %tmp_icmp.3 = icmp.eq i64 %tmp_sub.1 %tmp_const.6
    br.cond %tmp_icmp.3 @block4 @block5
arr_managed_cleanup_heap_free:
    %tmp_load.10 = load ptr %tmp_fieldptr
    %tmp_load.11 = load i64 %tmp_alloca.2
    %tmp_mul.2 = mul i64 %tmp_load.11 %tmp_const.1
    %tmp_add.2 = add ptr %tmp_load.10 %tmp_mul.2
    %tmp_load.12 = load ptr %tmp_add.2
    %tmp_const.7 = const.i64 i64 8
    %tmp_sub.2 = sub ptr %tmp_load.12 %tmp_const.7
    heap.free %tmp_sub.2 tag="element cleanup"
    br @block5
arr_managed_cleanup_next:
    %tmp_const.8 = const.i64 i64 1
    %tmp_load.13 = load i64 %tmp_alloca.2
    %tmp_add.3 = add i64 %tmp_load.13 %tmp_const.8
    store %tmp_alloca.2 %tmp_add.3
    br @block1
arr_managed_cleanup_end:
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_fieldptr 24
    %tmp_load.14 = load i32 %tmp_fieldptr.4
    %tmp_const.9 = const.i32 i32 3
    %tmp_band.1 = band i32 %tmp_load.14 %tmp_const.9
    %tmp_const.10 = const.i32 i32 1
    %tmp_icmp.4 = icmp.eq i32 %tmp_band.1 %tmp_const.10
    br.cond %tmp_icmp.4 @block7 @block9
decref:
    %tmp_load.15 = load ptr %tmp_fieldptr
    %tmp_const.11 = const.i64 i64 8
    %tmp_sub.3 = sub ptr %tmp_load.15 %tmp_const.11
    %tmp_load.16 = load i64 %tmp_sub.3
    %tmp_const.12 = const.i64 i64 1
    %tmp_sub.4 = sub i64 %tmp_load.16 %tmp_const.12
    store %tmp_sub.3 %tmp_sub.4
    %tmp_const.13 = const.i64 i64 0
    %tmp_icmp.5 = icmp.eq i64 %tmp_sub.4 %tmp_const.13
    br.cond %tmp_icmp.5 @block8 @block9
decref_free:

// Test: challenge-struct-ownership.let-struct-borrow-ok.1
type Data
    export var value int
end 'Data'

function readOnly(d Data) returns int
    return d.value
end 'readOnly'

function main() returns int
    let d = Data{value: 50}
    var a = readOnly(d)
    var b = readOnly(d)
    return a + b
end 'main'
---
ExitCode: 100
---
function readOnly() -> i64 {
entry:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

function main() -> i64 {
entry:
    %d = alloca.sized ptr 8
    memset %d 0 8
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 50
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @readOnly(%d)
    %a = alloca ptr
    store %a %tmp_call
    %tmp_call.1 = call i64 @readOnly(%d)
    %b = alloca ptr
    store %b %tmp_call.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_add
    %tmp_load.2 = load i64 %tmp_alloca.3
    ret %tmp_load.2
}

---

// Test: duplicate-block-identifiers.doc-example-1.1
function main() returns int
    var x = 0
    if true 'outer'
        x = 1
    end 'outer'

    if true 'inner'
        x = 2
    end 'inner'

    return x
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    br.cond %tmp_const.1 @then$outer_1 @end$outer_2
then$outer_1:
    %tmp_const.2 = const.i64 i64 1
    store %x %tmp_const.2
    br @end$outer_2
end$outer_2:
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @then$inner_3 @end$inner_4
then$inner_3:
    %tmp_const.4 = const.i64 i64 2
    store %x %tmp_const.4
    br @end$inner_4
end$inner_4:
    %tmp_load = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

// Test: enums.raw-value-int-comparison.1
enum Priority
    low = 1
    medium = 5
    high = 10
end 'Priority'

function main() returns int
    var p = Priority.high
    if p.rawValue > 5 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %p = alloca ptr
    store %p %tmp_const
    %tmp_load = load i64 %p
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.3
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

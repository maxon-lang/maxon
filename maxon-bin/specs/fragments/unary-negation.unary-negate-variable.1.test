// Test: unary-negation.unary-negate-variable.1
function main() returns int
    var x = 47
    var y = -x
    return 42 + y
end 'main'
---
ExitCode: 251
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 47
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 0
    %tmp_sub = sub i64 %tmp_const.1 %tmp_load
    %y = alloca ptr
    store %y %tmp_sub
    %tmp_const.2 = const.i64 i64 42
    %tmp_load.1 = load i64 %y
    %tmp_add = add i64 %tmp_const.2 %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_add
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}


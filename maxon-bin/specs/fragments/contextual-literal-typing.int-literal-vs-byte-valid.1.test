// Test: contextual-literal-typing.int-literal-vs-byte-valid.1
function main() returns int
    var b = 42 as byte
    if b == 42 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 42
    %tmp_const.1 = const.i64 i64 255
    %tmp_band = band i64 %tmp_const %tmp_const.1
    %b = alloca ptr
    store %b %tmp_band
    %tmp_load = load i64 %b
    %tmp_const.2 = const.i64 i64 42
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.3 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.3
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end$check_2:
    %tmp_const.4 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

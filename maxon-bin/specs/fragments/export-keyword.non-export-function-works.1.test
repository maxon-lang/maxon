// Test: export-keyword.non-export-function-works.1
function helper() returns int
    return 42
end 'helper'

function main() returns int
    return helper()
end 'main'
---
ExitCode: 42
---
function helper() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

function main() -> i64 {
entry:
    %tmp_call = call i64 @helper()
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

// Test: enums.string-rawvalue-dynamic-comparison.1
enum Planet
    earth = "Earth"
    mars = "Mars"
end 'Planet'

function getName() returns String
    return "Mars"
end 'getName'

function main() returns int
    var p = Planet.mars
    var name = p.rawValue
    var expected = getName()
    if name == expected 'check'
        return 1
    end 'check'
    return 0
end 'main'

// Test: literals.large-decimal-literal.1
// Test decimal literal above 32-bit range
function main() returns int
    var x = 5368709120
    if x == 0x140000000 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5368709120
    %tmp_const.1 = const.i64 i64 5368709120
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 1
    ret %tmp_const.3
}

---

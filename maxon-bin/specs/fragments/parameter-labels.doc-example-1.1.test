// Test: parameter-labels.doc-example-1.1
function add(a int, b int) returns int
    return a + b
end 'add'

function main() returns int
    return add(a: 3, b: 4)
end 'main'
---
ExitCode: 7
---
function add() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %tmp_const.1 = const.i64 i64 4
    %tmp_call = call i64 @add(%tmp_const, %tmp_const.1)
    ret %tmp_call
}

---

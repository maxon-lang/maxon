// Test: string-type.heap-string-iteration.1
function main() returns int
    var s = "ABCDEFGHIJKLMNOP"  // 16 bytes, triggers heap
    var sum = 0
    for c in s 'loop'
        var cps = c.codepoints()
        if let cp = cps.next() 'get_cp'
            sum = sum + cp
        end 'get_cp'
    end 'loop'
    print("{sum}")  // 65+66+...+80 = 1160
    return 0
end 'main'
---
ExitCode: 0
Stdout: 1160
---

// Test: contextual-literal-typing.explicit-cast-float-to-int.1
function main() returns int
    var x = 5
    var y = 5.0
    if x == trunc(y) 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_fconst = const.f64 f64 5
    %y = alloca ptr
    store %y %tmp_fconst
    %tmp_load = load i64 %x
    %tmp_load.1 = load f64 %y
    %tmp_fptosi = fptosi i64 %tmp_load.1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_fptosi
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
end:
    %tmp_const.2 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.2
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

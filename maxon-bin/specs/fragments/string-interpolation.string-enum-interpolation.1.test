// Test: string-interpolation.string-enum-interpolation.1
enum Status string
    active = "Active"
    inactive = "Inactive"
    pending = "Pending"
end 'Status'

function main() returns int
    var s = Status.active
    print("Status: {s}")
    return 0
end 'main'
---
ExitCode: 0
Stdout: Status: Active
---

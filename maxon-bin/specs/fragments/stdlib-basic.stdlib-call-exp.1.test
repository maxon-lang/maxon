// Test: stdlib-basic.stdlib-call-exp.1
function main() returns int
    var result = Math.exp(0.0)
    if result == 1.0 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 0
    %tmp_call = call f64 @Math$exp(%tmp_fconst)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fconst.1 = const.f64 f64 1
    %tmp_fcmp = fcmp.eq i64 %tmp_load %tmp_fconst.1
    br.cond %tmp_fcmp @block1 @block2
then:
    %tmp_const = const.i64 i64 42
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.1 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

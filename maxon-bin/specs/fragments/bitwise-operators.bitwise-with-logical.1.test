// Test: bitwise-operators.bitwise-with-logical.1
function main() returns int
    // Logical operators have lower precedence than bitwise
    var a = 5 & 3        // 1
    var b = 5 | 2        // 7
    if a > 0 and b > 0 'check'
        print("{1}\n")
    end 'check'
    return 0
end 'main'

// Test: challenge-struct-ownership.borrow-after-borrow-ok.1
type Data
    export var value int
end 'Data'

function readOnly(d Data) returns int
    return d.value
end 'readOnly'

function main() returns int
    var d = Data{value: 10}
    var a = readOnly(d)
    var b = readOnly(d)
    var c = readOnly(d)
    return a + b + c
end 'main'
---
ExitCode: 30
---
function readOnly() -> i64 {
entry_0:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function main() -> i64 {
entry_0:
    %d = alloca.sized ptr 8
    memset %d 0 8
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @readOnly(%d)
    %tmp_call.1 = call i64 @readOnly(%d)
    %tmp_call.2 = call i64 @readOnly(%d)
    %tmp_add = add i64 %tmp_call %tmp_call.1
    %tmp_add.1 = add i64 %tmp_add %tmp_call.2
    ret %tmp_add.1
}


// Test: stdlib-array.first-last.1
function main() returns int
    var arr = Array of int{}
    arr.push(10)
    arr.push(20)
    arr.push(30)
    
    if let f = arr.first() 'first'
        if f != 10 'fc'
            return 1
        end 'fc'
    end 'first' else 'fe'
        return 2
    end 'fe'
    
    if let l = arr.last() 'last'
        if l != 30 'lc'
            return 3
        end 'lc'
    end 'last' else 'le'
        return 4
    end 'le'
    
    return 0
end 'main'

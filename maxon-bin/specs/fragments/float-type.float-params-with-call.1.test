// Test: float-type.float-params-with-call.1
// Test float parameters that must survive across a function call
// The float params are live across the call to identity(), requiring callee-saved XMMs
function identity(x float) returns float
    return x
end 'identity'

function useFloats(a float, b float, c float, d float) returns float
    // The call to identity() may clobber XMM0-3
    // So a, b, c, d must be saved to callee-saved XMM6-9 or stack
    var temp = identity(1.0)
    return a + b + c + d + temp
end 'useFloats'

function main() returns int
    var result = useFloats(10.0, 20.0, 30.0, 40.0)
    return trunc(result)
end 'main'
---
ExitCode: 101
---
function identity() -> f64 {
entry:
    %x = param f64 0
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_load = load f64 %x.1
    ret %tmp_load
}

function useFloats() -> f64 {
entry:
    %a = param f64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param f64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %c = param f64 2
    %c.1 = alloca ptr
    store %c.1 %c
    %d = param f64 3
    %d.1 = alloca ptr
    store %d.1 %d
    %tmp_fconst = const.f64 f64 1
    %tmp_call = call f64 @identity(%tmp_fconst)
    %temp = alloca ptr
    store %temp %tmp_call
    %tmp_load = load f64 %a.1
    %tmp_load.1 = load f64 %b.1
    %tmp_fadd = fadd f64 %tmp_load %tmp_load.1
    %tmp_load.2 = load f64 %c.1
    %tmp_fadd.1 = fadd f64 %tmp_fadd %tmp_load.2
    %tmp_load.3 = load f64 %d.1
    %tmp_fadd.2 = fadd f64 %tmp_fadd.1 %tmp_load.3
    %tmp_load.4 = load f64 %temp
    %tmp_fadd.3 = fadd f64 %tmp_fadd.2 %tmp_load.4
    ret %tmp_fadd.3
}

function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 10
    %tmp_fconst.1 = const.f64 f64 20
    %tmp_fconst.2 = const.f64 f64 30
    %tmp_fconst.3 = const.f64 f64 40
    %tmp_call = call f64 @useFloats(%tmp_fconst, %tmp_fconst.1, %tmp_fconst.2, %tmp_fconst.3)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}


// Test: many-args.five-int-args.1
function add5(a int, b int, c int, d int, e int) returns int
    return a + b + c + d + e
end 'add5'

function main() returns int
    return add5(1, 2, 3, 4, 5)
end 'main'
---
ExitCode: 15

// Test: type-methods.type-method-chain.1
type Value
    var n int

    function add(x int)
        n = n + x
    end 'add'

    function get() returns int
        return n
    end 'get'
end 'Value'

function main() returns int
    var v = Value{n: 0}
    v.add(10)
    v.add(20)
    v.add(12)
    return v.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %v = alloca.sized ptr 8
    memset %v 0 8
    %tmp_fieldptr = getfieldptr ptr %v 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 10
    call @Value$add(%v, %tmp_const.1)
    %tmp_const.3 = const.i64 i64 20
    call @Value$add(%v, %tmp_const.3)
    %tmp_const.5 = const.i64 i64 12
    call @Value$add(%v, %tmp_const.5)
    %tmp_call = call i64 @Value$get(%v)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Value$add() -> void {
entry_0:
    %self = param ptr 0
    %x = param i64 1
    %x.1 = alloca ptr
    store %x.1 %x
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_load.1 = load i64 %x.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret
}

function Value$get() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}


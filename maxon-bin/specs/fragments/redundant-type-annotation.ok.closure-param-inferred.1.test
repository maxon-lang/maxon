// Test: redundant-type-annotation.ok.closure-param-inferred.1
type Point
    export var x int
    export var y int
end 'Point'

function transform(f (Point) returns int) returns int
    return f(Point{x: 5, y: 10})
end 'transform'

function main() returns int
    return transform((p) gives p.x + p.y)
end 'main'

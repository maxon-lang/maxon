    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.1 8
    %tmp_const.1 = const.i64 i64 10
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call_ind = call.indirect i64 %tmp_load(%tmp_alloca.1)
    ret %tmp_call_ind
}

function main() -> i64 {

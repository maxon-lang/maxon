// Test: string-type.slice-iteration.1
function main() returns int
    var s = "abcdef"
    var start = s.startIndex()
    if let idx = s.find("d") 'found'
        var sub = s.slice(start, idx)
        for c in sub 'loop'
            print("{c}")
        end 'loop'
    end 'found'
    return 0
end 'main'

// Test: file-io.doc-example-1.1
function main() returns int
    do 'read'
        let content = try File.readText("example.txt")
        print("File content: {content}\n")
        return 1
    end 'read' catch (e FileError) 'err'
        print("Could not read file\n")
        return 0
    end 'err'
end 'main'

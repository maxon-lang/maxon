// Test: unused-parameters.none-unused.1
function multiply(a int, b int) returns int
    return a * b
end 'multiply'

function main() returns int
    return multiply(7, b: 6)
end 'main'
---
ExitCode: 42
---
function multiply() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_mul
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 7
    %tmp_const.1 = const.i64 i64 6
    %tmp_call = call i64 @multiply(%tmp_const, %tmp_const.1)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


// Test: structs.struct-param.1
type Vec2
    export var x int
    export var y int
end 'Vec2'

function dot(a Vec2, b Vec2) returns int
    return a.x * b.x + a.y * b.y
end 'dot'

function main() returns int
    var v1 = Vec2 { x: 3, y: 4 }
    var v2 = Vec2 { x: 2, y: 1 }
    return dot(v1, b: v2)
end 'main'
---
ExitCode: 10
---
function dot() -> i64 {
entry_0:
    %a = param ptr 0
    %b = param ptr 1
    %tmp_fieldptr = getfieldptr ptr %a 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %b 0
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.2 = getfieldptr ptr %a 8
    %tmp_load.2 = load i64 %tmp_fieldptr.2
    %tmp_fieldptr.3 = getfieldptr ptr %b 8
    %tmp_load.3 = load i64 %tmp_fieldptr.3
    %tmp_mul.1 = mul i64 %tmp_load.2 %tmp_load.3
    %tmp_add = add i64 %tmp_mul %tmp_mul.1
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_add
    %tmp_load.4 = load i64 %tmp_alloca
    ret %tmp_load.4
}

function main() -> i64 {
entry_0:
    %v1 = alloca.sized ptr 16
    memset %v1 0 16
    %tmp_fieldptr = getfieldptr ptr %v1 0
    %tmp_const = const.i64 i64 3
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %v1 8
    %tmp_const.1 = const.i64 i64 4
    store %tmp_fieldptr.1 %tmp_const.1
    %v2 = alloca.sized ptr 16
    memset %v2 0 16
    %tmp_fieldptr.2 = getfieldptr ptr %v2 0
    %tmp_const.2 = const.i64 i64 2
    store %tmp_fieldptr.2 %tmp_const.2
    %tmp_fieldptr.3 = getfieldptr ptr %v2 8
    %tmp_const.3 = const.i64 i64 1
    store %tmp_fieldptr.3 %tmp_const.3
    %tmp_call = call i64 @dot(%v1, %v2)
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_call
    %tmp_load = load i64 %tmp_alloca.2
    ret %tmp_load
}


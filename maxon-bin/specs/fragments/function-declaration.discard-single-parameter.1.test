// Test: function-declaration.discard-single-parameter.1
function useSecond(_ int, b int) returns int
    return b
end 'useSecond'

function main() returns int
    return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
function useSecond() -> i64 {
entry_0:
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %b.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.2
    ret %tmp_load.1
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 42
    %tmp_call = call i64 @useSecond(%tmp_const, %tmp_const.1)
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_call
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


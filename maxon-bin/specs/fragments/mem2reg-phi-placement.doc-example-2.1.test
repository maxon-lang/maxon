// Test: mem2reg-phi-placement.doc-example-2.1
function main() returns int
    var x = 0
    if 1 > 0 'branch'
        x = 10
    end 'branch' else 'else_branch'
        x = 20
    end 'else_branch'
    return x
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %tmp_const.1 %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const.3 = const.i64 i64 10
    store %x %tmp_const.3
    br @block3
else:
    %tmp_const.4 = const.i64 i64 20
    store %x %tmp_const.4
    br @block3
end:
    %tmp_load = load i64 %x
    ret %tmp_load
}

---

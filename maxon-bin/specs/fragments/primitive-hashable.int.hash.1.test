// Test: primitive-hashable.int.hash.1
function main() returns int
    var i = 42
    var h = i.hash()
    return h
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 42
    %i = alloca ptr
    store %i %tmp_const
    %tmp_load = load i64 %i
    %h = alloca ptr
    store %h %tmp_load
    %tmp_load.1 = load i64 %h
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}


// Test: static-variables.top-level-var-increment.1
var total = 10

function add(n int)
    total = total + n
end 'add'

function main() returns int
    add(5)
    add(27)
    return total
end 'main'
---
ExitCode: 42
---
function add() -> void {
entry_0:
    %n = param i64 0
    %tmp_globaladdr = global.addr ptr @global.total elemsize=8
    %tmp_load = load i64 %tmp_globaladdr
    %tmp_add = add i64 %tmp_load %n
    %tmp_globaladdr.1 = global.addr ptr @global.total elemsize=8
    store %tmp_globaladdr.1 %tmp_add
    ret
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %tmp_globaladdr = global.addr ptr @global.total elemsize=8
    store %tmp_globaladdr %tmp_const
    %tmp_const.1 = const.i64 i64 5
    call @add(%tmp_const.1)
    %tmp_const.2 = const.i64 i64 27
    call @add(%tmp_const.2)
    %tmp_globaladdr.1 = global.addr ptr @global.total elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.1
    ret %tmp_load
}


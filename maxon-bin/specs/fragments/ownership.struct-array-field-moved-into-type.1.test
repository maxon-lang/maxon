// Test: ownership.struct-array-field-moved-into-type.1
typealias IntArray is Array with int

type Container
    var data IntArray
end 'Container'

function main() returns int
    var arr = [10, 20, 30]
    var c = Container{data: arr}
    arr.set(0, value: 999)
    var val = try c.data.get(0) otherwise 0
    return val
end 'main'

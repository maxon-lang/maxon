// Test: unary-operators.doc-example-1.1
function main() returns int
    var x = 42
    var y = -x      // y is -42
    var z = -y      // z is 42
    return z
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 42
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 0
    %tmp_sub = sub i64 %tmp_const.1 %tmp_load
    %y = alloca ptr
    store %y %tmp_sub
    %tmp_load.1 = load i64 %y
    %tmp_const.2 = const.i64 i64 0
    %tmp_sub.1 = sub i64 %tmp_const.2 %tmp_load.1
    %z = alloca ptr
    store %z %tmp_sub.1
    %tmp_load.2 = load i64 %z
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

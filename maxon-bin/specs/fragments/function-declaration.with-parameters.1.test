// Test: function-declaration.with-parameters.1
function add(a int, b int) returns int
    return a + b
end 'add'

function main() returns int
    return add(10, b: 20)
end 'main'
---
ExitCode: 30
---
function add() -> i64 {
entry_0:
    %a = param i64 0
    %b = param i64 1
    %tmp_add = add i64 %a %b
    ret %tmp_add
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 20
    %tmp_call = call i64 @add(%tmp_const, %tmp_const.1)
    ret %tmp_call
}


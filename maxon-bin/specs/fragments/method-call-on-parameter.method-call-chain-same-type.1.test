// Test: method-call-on-parameter.method-call-chain-same-type.1
type Value
    var n int
    
    function get() returns int
        return n
    end 'get'
    
    function add(other Value) returns int
        return n + other.get()
    end 'add'
    
    function multiply(other Value) returns int
        return n * other.get()
    end 'multiply'
end 'Value'

function main() returns int
    var a = Value{n: 5}
    var b = Value{n: 3}
    var c = Value{n: 2}
    // a.add(b) = 5 + 3 = 8
    // a.multiply(c) = 5 * 2 = 10
    // total = 8 + 10 = 18
    return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
function main() -> i64 {
entry_0:
    %a = alloca.sized ptr 8
    memset %a 0 8
    %tmp_fieldptr = getfieldptr ptr %a 0
    %tmp_const = const.i64 i64 5
    store %tmp_fieldptr %tmp_const
    %b = alloca.sized ptr 8
    memset %b 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %b 0
    %tmp_const.1 = const.i64 i64 3
    store %tmp_fieldptr.1 %tmp_const.1
    %c = alloca.sized ptr 8
    memset %c 0 8
    %tmp_fieldptr.2 = getfieldptr ptr %c 0
    %tmp_const.2 = const.i64 i64 2
    store %tmp_fieldptr.2 %tmp_const.2
    %tmp_call = call i64 @Value$add(%a, %b)
    %tmp_call.1 = call i64 @Value$multiply(%a, %c)
    %tmp_add = add i64 %tmp_call %tmp_call.1
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_add
    %tmp_load = load i64 %tmp_alloca.3
    ret %tmp_load
}

function Value$get() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

function Value$add() -> i64 {
entry_0:
    %self = param ptr 0
    %other = param ptr 1
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_call = call i64 @Value$get(%other)
    %tmp_add = add i64 %tmp_load %tmp_call
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_add
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

function Value$multiply() -> i64 {
entry_0:
    %self = param ptr 0
    %other = param ptr 1
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_call = call i64 @Value$get(%other)
    %tmp_mul = mul i64 %tmp_load %tmp_call
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_mul
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}


// Test: ownership.nested-if-with-returns.1
type Position
    export var x int
    export var y int
end 'Position'

function test(a int, b int) returns int
    var pos = Position{x: 10, y: 20}

    if a == 1 'outer'
        if b == 1 'inner'
            var temp = pos
            return temp.x
        end 'inner'
        // pos still owned here if inner didn't match
        return pos.y
    end 'outer'

    // pos still owned here if outer didn't match
    return pos.x + pos.y
end 'test'

function main() returns int
    return test(2, b: 2)
end 'main'
---
ExitCode: 30
---
function test() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %pos = alloca.sized ptr 16
    memset %pos 0 16
    %tmp_fieldptr = getfieldptr ptr %pos 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %pos 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_load = load i64 %a.1
    %tmp_const.2 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block1 @block4
then:
    %tmp_load.1 = load i64 %b.1
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp.1 @block2 @block3
then:
    %temp = alloca.sized ptr 16
    memcpy %temp %pos 16
    %tmp_fieldptr.2 = getfieldptr ptr %temp 0
    %tmp_load.2 = load i64 %tmp_fieldptr.2
    ret %tmp_load.2
end:
    %tmp_fieldptr.3 = getfieldptr ptr %pos 8
    %tmp_load.3 = load i64 %tmp_fieldptr.3
    ret %tmp_load.3
end:
    %tmp_fieldptr.4 = getfieldptr ptr %pos 0
    %tmp_load.4 = load i64 %tmp_fieldptr.4
    %tmp_fieldptr.5 = getfieldptr ptr %pos 8
    %tmp_load.5 = load i64 %tmp_fieldptr.5
    %tmp_add = add i64 %tmp_load.4 %tmp_load.5
    ret %tmp_add
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 2
    %tmp_const.1 = const.i64 i64 2
    %tmp_call = call i64 @test(%tmp_const, %tmp_const.1)
    ret %tmp_call
}

---

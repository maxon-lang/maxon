    end 'nil'
end 'addTen'

function doubleAddTen(arr array of int) returns int
    var val = 0
    if let v = arr[0] 'get'
        val = v
    end 'get'
    arr[0] = val * 2
    return addTen(arr)
end 'doubleAddTen'

function main() returns int
    let size = 5
    var arr = array of size int
    arr[0] = 5
    return doubleAddTen(arr)
end 'main'

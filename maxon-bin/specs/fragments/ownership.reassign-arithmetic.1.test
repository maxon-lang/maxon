// Test: ownership.reassign-arithmetic.1
function main() returns int
    var x = 100
    x = x - 50
    x = x * 2
    x = trunc(x / 5)
    return x
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 100
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 50
    %tmp_sub = sub i64 %tmp_load %tmp_const.1
    store %x %tmp_sub
    %tmp_load.1 = load i64 %x
    %tmp_const.2 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load.1 %tmp_const.2
    store %x %tmp_mul
    %tmp_load.2 = load i64 %x
    %tmp_const.3 = const.i64 i64 5
    %tmp_sitofp = sitofp f64 %tmp_load.2
    %tmp_sitofp.1 = sitofp f64 %tmp_const.3
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    store %x %tmp_fptosi
    %tmp_load.3 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.3
    %tmp_load.4 = load i64 %tmp_alloca.1
    ret %tmp_load.4
}


// Test: challenge-struct-lifetime.return-struct-with-computed-fields.1
type Result
    var sum int
    var product int
end 'Result'

function compute(a int, b int) returns Result
    return Result{sum: a + b, product: a * b}
end 'compute'

function main() returns int
    var r = compute(3, 4)
    return r.sum + r.product
end 'main'
---
ExitCode: 19
---
function compute() -> ptr {
entry:
    %tmp_param = param ptr 0
    %a = param i64 1
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 2
    %b.1 = alloca ptr
    store %b.1 %b
    memset %tmp_param 0 16
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    store %tmp_fieldptr %tmp_add
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    %tmp_load.2 = load i64 %a.1
    %tmp_load.3 = load i64 %b.1
    %tmp_mul = mul i64 %tmp_load.2 %tmp_load.3
    store %tmp_fieldptr.1 %tmp_mul
    ret %tmp_param
}

function main() -> i64 {
entry:
    %r = alloca.sized ptr 16
    %tmp_const = const.i64 i64 3
    %tmp_const.1 = const.i64 i64 4
    %tmp_call = call ptr @compute(%r, %tmp_const, %tmp_const.1)
    %tmp_fieldptr = getfieldptr ptr %r 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %r 8
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}


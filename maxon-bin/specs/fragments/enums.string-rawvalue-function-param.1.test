// Test: enums.string-rawvalue-function-param.1
enum Planet
    earth = "Earth"
    mars = "Mars"
    venus = "Venus"
end 'Planet'

function getName(p Planet) returns String
    return p.rawValue
end 'getName'

function main() returns int
    var planet = Planet.mars
    var name = getName(planet)
    if name == "Mars" 'check'
        return 1
    end 'check'
    return 0
end 'main'

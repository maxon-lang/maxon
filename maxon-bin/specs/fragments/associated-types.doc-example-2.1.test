// Test: associated-types.doc-example-2.1
interface Summable uses Element
    function sum() returns Element
end 'Summable'

type IntPair is Summable with int
    var a int
    var b int

    function Summable.sum() returns int
        return a + b
    end 'sum'
end 'IntPair'

function main() returns int
    var p = IntPair{a: 10, b: 32}
    return p.sum()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 32
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call = call i64 @IntPair$sum(%p)
    ret %tmp_call
}

function IntPair$sum() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %self 8
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

---

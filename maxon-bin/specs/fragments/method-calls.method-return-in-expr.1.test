// Test: method-calls.method-return-in-expr.1
type Box
    var value int

    function getValue() returns int
        return value
    end 'getValue'
end 'Box'

function main() returns int
    var b = Box{value: 40}
    return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %b = alloca.sized ptr 8
    memset %b 0 8
    %tmp_fieldptr = getfieldptr ptr %b 0
    %tmp_const = const.i64 i64 40
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @Box$getValue(%b)
    %tmp_const.1 = const.i64 i64 2
    %tmp_add = add i64 %tmp_call %tmp_const.1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_add
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Box$getValue() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

---

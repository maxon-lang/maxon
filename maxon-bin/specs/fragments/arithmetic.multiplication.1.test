// Test: arithmetic.multiplication.1
function main() returns int
    return 6 * 7
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_mul = const.i64 i64 42
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_mul
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


    store.i32 %tmp_fieldptr.3 %tmp_const.8
    %tmp_const.9 = const.i32 i32 0
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_alloca.1 28
    store.i32 %tmp_fieldptr.4 %tmp_const.9
    %tmp_alloca.2 = alloca.sized ptr 32

// Test: static-variables.top-level-var-with-let.1
let BASE = 40
var offset = 0

function main() returns int
    offset = 2
    return BASE + offset
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_globaladdr = global.addr ptr @global.offset elemsize=8
    store %tmp_globaladdr %tmp_const
    %tmp_const.1 = const.i64 i64 2
    %tmp_globaladdr.1 = global.addr ptr @global.offset elemsize=8
    store %tmp_globaladdr.1 %tmp_const.1
    %tmp_const.2 = const.i64 i64 40
    %tmp_globaladdr.2 = global.addr ptr @global.offset elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.2
    %tmp_add = add i64 %tmp_const.2 %tmp_load
    ret %tmp_add
}

---

// Test: duplicate-block-identifiers.duplicate-block-identifiers.different-blocks.1
function main() returns int
    var x = 0
    if true 'outer'
        x = 1
    end 'outer'
    
    if true 'inner'
        x = 2
    end 'inner'
    
    return x
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    br.cond %tmp_const.1 @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    store %x %tmp_const.2
    br @block2
end:
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @block3 @block4
then:
    %tmp_const.4 = const.i64 i64 2
    store %x %tmp_const.4
    br @block4
end:
    %tmp_load = load i64 %x
    ret %tmp_load
}

---

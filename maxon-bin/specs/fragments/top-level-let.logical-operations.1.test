// Test: top-level-let.logical-operations.1
let BOTH = true and true
let EITHER = false or true
let NEITHER = not false

function main() returns int
    if BOTH and EITHER and NEITHER 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    %tmp_const.1 = const.i64 i64 1
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.ne i64 %tmp_const %tmp_const.2
    %tmp_icmp.1 = icmp.ne i64 %tmp_const.1 %tmp_const.2
    %tmp_mul = mul i64 %tmp_icmp %tmp_icmp.1
    %tmp_const.3 = const.i64 i64 1
    %tmp_const.4 = const.i64 i64 0
    %tmp_icmp.2 = icmp.ne i64 %tmp_mul %tmp_const.4
    %tmp_icmp.3 = icmp.ne i64 %tmp_const.3 %tmp_const.4
    %tmp_mul.1 = mul i64 %tmp_icmp.2 %tmp_icmp.3
    br.cond %tmp_mul.1 @block1 @block2
then:
    %tmp_const.5 = const.i64 i64 1
    ret %tmp_const.5
end:
    %tmp_const.6 = const.i64 i64 0
    ret %tmp_const.6
}

---

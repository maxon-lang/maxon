// Test: static-variables.static-var-multiple-types.1
type TypeA
    static var value = 10
end 'TypeA'

type TypeB
    static var value = 20
end 'TypeB'

function main() returns int
    TypeA.value = TypeA.value + 2
    TypeB.value = TypeB.value + 10
    return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 20
    %tmp_globaladdr = global.addr ptr @global.TypeB.value elemsize=8
    store %tmp_globaladdr %tmp_const
    %tmp_const.1 = const.i64 i64 10
    %tmp_globaladdr.1 = global.addr ptr @global.TypeA.value elemsize=8
    store %tmp_globaladdr.1 %tmp_const.1
    %tmp_globaladdr.2 = global.addr ptr @global.TypeA.value elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.2
    %tmp_const.2 = const.i64 i64 2
    %tmp_add = add i64 %tmp_load %tmp_const.2
    %tmp_globaladdr.3 = global.addr ptr @global.TypeA.value elemsize=8
    store %tmp_globaladdr.3 %tmp_add
    %tmp_globaladdr.4 = global.addr ptr @global.TypeB.value elemsize=8
    %tmp_load.1 = load i64 %tmp_globaladdr.4
    %tmp_const.3 = const.i64 i64 10
    %tmp_add.1 = add i64 %tmp_load.1 %tmp_const.3
    %tmp_globaladdr.5 = global.addr ptr @global.TypeB.value elemsize=8
    store %tmp_globaladdr.5 %tmp_add.1
    %tmp_globaladdr.6 = global.addr ptr @global.TypeA.value elemsize=8
    %tmp_load.2 = load i64 %tmp_globaladdr.6
    %tmp_globaladdr.7 = global.addr ptr @global.TypeB.value elemsize=8
    %tmp_load.3 = load i64 %tmp_globaladdr.7
    %tmp_add.2 = add i64 %tmp_load.2 %tmp_load.3
    ret %tmp_add.2
}

---

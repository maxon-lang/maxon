// Test: contextual-literal-typing.math-intrinsic-with-float-literal.1
function main() returns int
    var x = sqrt(16.0)
    return trunc(x)
end 'main'
---
ExitCode: 4
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 16
    %tmp_fsqrt = fsqrt f64 %tmp_fconst
    %x = alloca ptr
    store %x %tmp_fsqrt
    %tmp_load = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_fptosi
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

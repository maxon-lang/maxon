// Test: while-loops.while-loops.continue.1
function main() returns int
    var sum = 0
    var i = 0
    while i < 5 'loop'
        i = i + 1
        if i == 3 'skip'
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 12
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %sum = alloca ptr
    store %sum %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %i = alloca ptr
    store %i %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @block2 @block5
whilebody:
    %tmp_load.1 = load i64 %i
    %tmp_const.3 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.3
    store %i %tmp_add
    %tmp_load.2 = load i64 %i
    %tmp_const.4 = const.i64 i64 3
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.2 %tmp_const.4
    br.cond %tmp_icmp.1 @block3 @block4
then:
    br @block1
    br @block4
end:
    %tmp_load.3 = load i64 %sum
    %tmp_load.4 = load i64 %i
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_load.4
    store %sum %tmp_add.1
    br @block1
whilecont:
    %tmp_load.5 = load i64 %sum
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.5
    %tmp_load.6 = load i64 %tmp_alloca.2
    ret %tmp_load.6
}


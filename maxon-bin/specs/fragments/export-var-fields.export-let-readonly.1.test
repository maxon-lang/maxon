// Test: export-var-fields.export-let-readonly.1
type Config
    export let version int

    static function create() returns Self
        return {version: 42}
    end 'create'
end 'Config'

function main() returns int
    var c = Config.create()
    return c.version
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    %tmp_call = call ptr @Config$create(%c)
    %tmp_fieldptr = getfieldptr ptr %c 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function Config$create() -> ptr {
entry:
    %tmp_param = param ptr 0
    memset %tmp_param 0 8
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}


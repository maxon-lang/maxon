// Test: if-statements.if-statements.else.1
function main() returns int
    var x = 5
    if x == 5 'is5'
        return 1
    end 'is5' else 'not5'
        return 0
    end 'not5'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$is5_1 @else$is5_2
then$is5_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
else$is5_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
end$is5_3:
}


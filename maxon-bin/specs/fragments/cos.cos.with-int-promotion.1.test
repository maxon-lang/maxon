// Test: cos.cos.with-int-promotion.1
function main() returns int
    var x = 0  // int
    var result = Math.cos(x)  // x promoted to 0.0
    if result == 1.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_call = call f64 @Math$cos(%tmp_sitofp)
    %tmp_fconst = const.f64 f64 1
    %tmp_fcmp = fcmp.eq i64 %tmp_call %tmp_fconst
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
end$check_2:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
}

---

// Test: cos.cos.with-int-promotion.1
function main() returns int
    var x = 0  // int
    var result = Math.cos(x)  // x promoted to 0.0
    if result == 1.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_call = call f64 @Math$cos(%tmp_load)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load.1 = load f64 %result
    %tmp_fconst = const.f64 f64 1
    %tmp_fcmp = fcmp.eq i64 %tmp_load.1 %tmp_fconst
    br.cond %tmp_fcmp @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
}

---

// Test: duplicate-block-identifiers.duplicate-block-identifiers.multiple-nested.1
function main() returns int
    var x = 0
    if true 'outer'
        x = 1
        while true 'inner'
            x = 2
            break
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    br.cond %tmp_const.1 @block1 @block5
then:
    %tmp_const.2 = const.i64 i64 1
    store %x %tmp_const.2
    br @block2
whilecond:
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @block3 @block4
whilebody:
    %tmp_const.4 = const.i64 i64 2
    store %x %tmp_const.4
    br @block4
whilecont:
    br @block5
end:
    %tmp_load = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

// Test: parentheses.complex-expression.1
function main() returns int
    var result = trunc((10 + (2 * 3)) / (4 - 2))
    return result
end 'main'
---
ExitCode: 8
---
function main() -> i64 {
entry:
    %tmp_add = const.i64 i64 16
    %tmp_sub = const.i64 i64 2
    %tmp_sitofp = sitofp f64 %tmp_add
    %tmp_sitofp.1 = sitofp f64 %tmp_sub
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %result = alloca ptr
    store %result %tmp_fptosi
    %tmp_load = load i64 %result
    ret %tmp_load
}

---

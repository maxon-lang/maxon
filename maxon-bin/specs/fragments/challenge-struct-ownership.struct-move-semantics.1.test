// Test: challenge-struct-ownership.struct-move-semantics.1
type Data
    export var value int
end 'Data'

function takeOwnership(d Data) returns int
    d.value = 100
    return d.value
end 'takeOwnership'

function main() returns int
    var d = Data{value: 42}
    return takeOwnership(d)
end 'main'
---
ExitCode: 100
---
function takeOwnership() -> i64 {
entry_0:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 100
    store %tmp_fieldptr %tmp_const
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

function main() -> i64 {
entry_0:
    %d = alloca.sized ptr 8
    memset %d 0 8
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @takeOwnership(%d)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

---

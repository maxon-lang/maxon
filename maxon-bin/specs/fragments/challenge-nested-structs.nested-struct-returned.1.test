// Test: challenge-nested-structs.nested-struct-returned.1
type Inner
    var value int
end 'Inner'

type Outer
    var inner Inner
end 'Outer'

function makeOuter() returns Outer
    var i = Inner{value: 42}
    return Outer{inner: i}
end 'makeOuter'

function main() returns int
    var o = makeOuter()
    return o.inner.value
end 'main'
---
ExitCode: 42
---
function makeOuter() -> ptr {
entry:
    %tmp_param = param ptr 0
    %i = alloca.sized ptr 8
    %8 = memset %i 0
    %tmp_fieldptr = getfieldptr ptr %i 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %8 = memset %tmp_param 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 0
    %8 = memcpy %tmp_fieldptr.1 %i
    ret %tmp_param
}

function main() -> i64 {
entry:
    %o = alloca.sized ptr 8
    %tmp_call = call ptr @makeOuter(%o)
    %tmp_fieldptr = getfieldptr ptr %o 0
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_fieldptr 0
    %tmp_load = load i64 %tmp_fieldptr.1
    ret %tmp_load
}

---

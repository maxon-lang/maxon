// Test: structs.struct-field-access.1
type Rect
    var width int
    var height int
end 'Rect'

function main() returns int
    var r = Rect { width: 5, height: 10 }
    return r.width * r.height
end 'main'
---
ExitCode: 50
---
function main() -> i64 {
entry:
    %r = alloca.sized ptr 16
    memset %r 0 16
    %tmp_mul = const.i64 i64 50
    ret %tmp_mul
}


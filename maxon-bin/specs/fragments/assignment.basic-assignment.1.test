// Test: assignment.basic-assignment.1
function main() returns int
    var x = 3
    x = x + 2
    return x
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 2
    %tmp_add = add i64 %tmp_load %tmp_const.1
    store %x %tmp_add
    %tmp_load.1 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
}

---

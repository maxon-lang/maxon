// Test: log.doc-example-1.1
function main() returns int
    var e = 2.71828
    var result = Math.log(e)  // ln(e) ≈ 1.0
    return trunc(result)
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 2.71828
    %e = alloca ptr
    store %e %tmp_fconst
    %tmp_load = load f64 %e
    %tmp_call = call f64 @Math$log(%tmp_load)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load.1 = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load.1
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_fptosi
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}


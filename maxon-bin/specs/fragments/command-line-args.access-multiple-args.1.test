// Test: command-line-args.access-multiple-args.1
function main(args Array of String) returns int
    var arg1 = try args.get(1) otherwise ""
    var arg2 = try args.get(2) otherwise ""
    var arg3 = try args.get(3) otherwise ""
    print(arg1)
    print("\n")
    print(arg2)
    print("\n")
    print(arg3)
    print("\n")
    return 0
end 'main'

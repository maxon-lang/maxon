// Test: enums.implicit-string-backed.1
enum StringBacked
    "North"
    "South"
    "East"
end 'StringBacked'

function main() returns int
    var dir = StringBacked.North
    if dir == StringBacked.South 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_strconst = const.string ptr "North"
    %dir = alloca ptr
    store %dir %tmp_strconst
    %tmp_load = load i64 %dir
    %tmp_strconst.1 = const.string ptr "South"
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_strconst.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

---

// Test: byte-type.byte-zero.1
function main() returns int
    var b = 0 as byte
    return b as int
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 255
    %tmp_band = band i64 %tmp_const %tmp_const.1
    %b = alloca ptr
    store %b %tmp_band
    %tmp_load = load i64 %b
    ret %tmp_load
}

---

// Test: error-handling.error.otherwise-ignore.1
// Test try otherwise ignore
enum MyError is Error
    failed
end 'MyError'

function mayFail() returns int throws MyError
    throw MyError.failed
end 'mayFail'

function main() returns int
    try mayFail() otherwise ignore
    return 42
end 'main'
---
ExitCode: 42
---
function mayFail() -> ptr {
entry_0:
    %tmp_param = param ptr 0
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
}

function main() -> i64 {
entry_0:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_call = call ptr @mayFail(%tmp_alloca)
    %tmp_load = load i64 %tmp_alloca
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const
    br.cond %tmp_icmp @try_success_1 @try_ignore_2
try_success_1:
    br @try_merge_3
try_ignore_2:
    br @try_merge_3
try_merge_3:
    %tmp_const.2 = const.i64 i64 42
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.2
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
}

---

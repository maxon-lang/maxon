// Test: stdlib-autodiscovery.basic-autodiscovery.1
function main() returns int
    return trunc(sqrt(16.0))
end 'main'
---
ExitCode: 4
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 16
    %tmp_fsqrt = fsqrt f64 %tmp_fconst
    %tmp_fptosi = fptosi i64 %tmp_fsqrt
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_fptosi
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


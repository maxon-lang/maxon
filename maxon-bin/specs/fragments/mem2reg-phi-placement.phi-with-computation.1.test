// Test: mem2reg-phi-placement.phi-with-computation.1
function main() returns int
    var x = 5
    if x > 3 'check'
        x = x * 2
    end 'check' else 'else_check'
        x = x + 10
    end 'else_check'
    return x
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 3
    %tmp_icmp = icmp.gt i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block1 @block2
then:
    %tmp_load.1 = load i64 %x
    %tmp_const.2 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load.1 %tmp_const.2
    store %x %tmp_mul
    br @block3
else:
    %tmp_load.2 = load i64 %x
    %tmp_const.3 = const.i64 i64 10
    %tmp_add = add i64 %tmp_load.2 %tmp_const.3
    store %x %tmp_add
    br @block3
end:
    %tmp_load.3 = load i64 %x
    ret %tmp_load.3
}

---

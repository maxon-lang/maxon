// Test: match-statements.doc-example-3.1
function main() returns int
    var x = 2
    let result = match x 'convert'
        1 gives 10
        2 gives 20
        3 gives 30
        default gives 0
    end 'convert'
    return result
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_alloca.1 = alloca ptr
    br @match_expr_check_1
match_expr_check_1:
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @match_expr_body_2 @match_expr_check_3
match_expr_body_2:
    %tmp_const.2 = const.i64 i64 10
    store %tmp_alloca.1 %tmp_const.2
    br @match_expr_merge_8
match_expr_check_3:
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load %tmp_const.3
    br.cond %tmp_icmp.1 @match_expr_body_4 @match_expr_check_5
match_expr_body_4:
    %tmp_const.4 = const.i64 i64 20
    store %tmp_alloca.1 %tmp_const.4
    br @match_expr_merge_8
match_expr_check_5:
    %tmp_const.5 = const.i64 i64 3
    %tmp_icmp.2 = icmp.eq i64 %tmp_load %tmp_const.5
    br.cond %tmp_icmp.2 @match_expr_body_6 @match_expr_default_7
match_expr_body_6:
    %tmp_const.6 = const.i64 i64 30
    store %tmp_alloca.1 %tmp_const.6
    br @match_expr_merge_8
match_expr_default_7:
    %tmp_const.7 = const.i64 i64 0
    store %tmp_alloca.1 %tmp_const.7
    br @match_expr_merge_8
match_expr_merge_8:
    %tmp_load.1 = load i64 %tmp_alloca.1
    %result = alloca ptr
    store %result %tmp_load.1
    %tmp_load.2 = load i64 %result
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_load.2
    %tmp_load.3 = load i64 %tmp_alloca.3
    ret %tmp_load.3
}

---

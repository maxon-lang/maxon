// Maxon Language Syntax Showcase
// Demonstrates all major language features concisely

// ============================================================================
// INTERFACES
// ============================================================================

interface Describable
    function describe() returns String
end 'Describable'

interface Container uses Element
    function getFirst() returns Element
end 'Container'

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// Type with fields, methods, interface conformance, and static methods
type Point is Hashable, Describable
    export var x int
    export var y int

    // Interface method implementation
    function Hashable.hash() returns int
        return x * 31 + y
    end 'hash'

    function Describable.describe() returns String
        return "({x}, {y})"
    end 'describe'

    // Regular method
    function magnitude() returns float
        return sqrt((x * x + y * y) as float)
    end 'magnitude'

    // Static factory method
    static function origin() returns Point
        return {x: 0, y: 0}
    end 'origin'

    static function create(x int, y int) returns Point
        return {x: x, y: y}
    end 'create'
end 'Point'

// Type with default field values
type Config
    export var maxRetries int = 3
    export var timeout float = 30.0
    export let version int = 1
end 'Config'

// Type with associated type conformance
typealias IntArray is Array with int

type IntBox is Container with int
    var data IntArray

    function Container.getFirst() returns int
        return try data.get(0) otherwise 0
    end 'getFirst'
end 'IntBox'

// ============================================================================
// ENUMS
// ============================================================================

// Simple enum
enum Direction
    north
    south
    east
    west

    function opposite() returns Direction
        match self 'op'
            north then return Direction.south
            south then return Direction.north
            east then return Direction.west
            west then return Direction.east
        end 'op'
    end 'opposite'
end 'Direction'

// Int-backed enum
enum HttpStatus
    ok = 200
    notFound = 404
    serverError = 500
end 'HttpStatus'

// String-backed enum
enum Planet
    earth = "Earth"
    mars = "Mars"
    venus = "Venus"
end 'Planet'

// Enum with associated values
enum Result
    success(value int)
    failure(code int, message String)
    pending
end 'Result'

// Error enum (conforms to Error interface)
enum ParseError is Error
    invalidSyntax
    unexpectedEnd
    invalidNumber
end 'ParseError'

// ============================================================================
// FUNCTIONS
// ============================================================================

// Function with named parameters and default value
function greet(name String, title String = "Mr.") returns String
    return "Hello, {title} {name}!"
end 'greet'

// Function that throws
function parsePositive(s String) returns int throws ParseError
    if s == "" 'empty'
        throw ParseError.unexpectedEnd
    end 'empty'
    if s == "42" 'valid'
        return 42
    end 'valid'
    throw ParseError.invalidNumber
end 'parsePositive'

// Recursive function
function factorial(n int) returns int
    if n <= 1 'base'
        return 1
    end 'base'
    return n * factorial(n - 1)
end 'factorial'

// ============================================================================
// MAIN - demonstrates control flow and expressions
// ============================================================================

function main() returns int
    // Variables: let (immutable) vs var (mutable)
    let pi = 3.14159
    var counter = 0

    // Primitive types
    var intVal = 42
    var floatVal = 2.5
    var boolVal = true
    var charVal = 'A'
    var byteVal = 255 as byte
    var strVal = "Hello"

    // Numeric literals with different bases
    var hex = 0xFF
    var binary = 0b1010
    var octal = 0o777
    var withSeparator = 1_000_000

    // String interpolation
    print("Counter: {counter}, Pi: {pi}\n")
    print("Expression: {2 + 3 * 4}\n")

    // Arrays
    var numbers = [10, 20, 30, 40, 50]
    var first = try numbers.get(0) otherwise 0
    numbers.set(0, value: 100)
    numbers.push(60)

    // Empty typed array
    var empty = IntArray{}
    empty.reserve(10)
    empty.push(42)

    // Type instantiation
    var p1 = Point{x: 3, y: 4}
    var p2 = Point.create(5, y: 12)
    var origin = Point.origin()
    print("Point: {p1.describe()}, magnitude: {p1.magnitude()}\n")

    // Type with defaults
    var cfg = Config{}
    var cfg2 = Config{maxRetries: 5}

    // If statement
    if counter == 0 'check'
        print("Counter is zero\n")
    end 'check' else if counter < 0 'negative'
        print("Counter is negative\n")
    end 'negative' else 'positive'
        print("Counter is positive\n")
    end 'positive'

    // While loop with break and continue
    var i = 0
    while i < 10 'loop'
        i = i + 1
        if i == 3 'skip'
            continue
        end 'skip'
        if i == 7 'stop'
            break
        end 'stop'
        counter = counter + 1
    end 'loop'

    // Summation with while loop (for-in requires stdlib's range function)
    var sum = 0
    var j = 0
    while j < 5 'sumloop'
        sum = sum + j
        j = j + 1
    end 'sumloop'

    // Labeled break for nested loops
    var found = false
    while not found 'outer'
        var k = 0
        while k < 5 'inner'
            if k == 3 'exit'
                found = true
                break 'outer'
            end 'exit'
            k = k + 1
        end 'inner'
    end 'outer'

    // Enums
    var dir = Direction.north
    var opposite = dir.opposite()
    var status = HttpStatus.ok
    var code = status.rawValue
    var planet = Planet.mars
    var planetName = planet.rawValue

    // Enum with associated values
    var result = Result.success(42)

    // Match statement
    match dir 'direction'
        north then print("Going north\n")
        south then print("Going south\n")
        default then print("Going somewhere\n")
    end 'direction'

    // Match statement with enum binding
    match result 'result'
        success(v) then print("Success: {v}\n")
        failure(c, msg) then print("Error {c}: {msg}\n")
        pending then print("Pending...\n")
    end 'result'

    // Match expression
    var dirValue = match dir 'dirval'
        north gives 1
        south gives 2
        east gives 3
        west gives 4
    end 'dirval'

    // Match expression with binding
    var extracted = match result 'extract'
        success(v) gives v * 2
        failure(c, _) gives c
        pending gives 0
    end 'extract'

    // Error handling with try/otherwise
    var parsed = try parsePositive("42") otherwise 0
    try parsePositive("") otherwise ignore

    // Block handler for errors
    try parsePositive("invalid") otherwise 'handler'
        print("Parse failed, using default\n")
    end 'handler'

    // If-try for conditional error handling
    if let value = try parsePositive("42") 'trycheck'
        print("Parsed: {value}\n")
    end 'trycheck' else 'tryfail'
        print("Failed to parse\n")
    end 'tryfail'

    // Operators
    var arithmetic = 2 + 3 * 4 - 1
    var modulo = 17 mod 5
    var comparison = 5 < 10 and 3 > 1
    var logical = true or false
    var negation = not false

    // Type casting
    var asFloat = intVal as float
    var asByte = 300 as byte
    var byteAsInt = asByte as int

    // Math functions
    var sqrtVal = sqrt(16.0)
    var absVal = abs(-5.0)
    var roundVal = round(3.7)
    var truncVal = trunc(3.9)
    var floorVal = floor(3.9)
    var ceilVal = ceil(3.1)

    // Function calls with named arguments
    var greeting = greet("Smith")
    var greeting2 = greet("Jones", title: "Dr.")

    // Method calls
    var hash = p1.hash()
    var strLen = strVal.count()

    // Print all values to use them (avoiding unused variable errors)
    print("=== Primitives ===\n")
    print("intVal: {intVal}, floatVal: {floatVal}, boolVal: {boolVal}\n")
    print("charVal: {charVal}, byteVal: {byteVal as int}, strVal: {strVal}\n")
    print("hex: {hex}, binary: {binary}, octal: {octal}, sep: {withSeparator}\n")

    print("=== Arrays ===\n")
    print("first: {first}, empty count: {empty.count()}\n")

    print("=== Structs ===\n")
    print("p2: ({p2.x}, {p2.y}), origin: ({origin.x}, {origin.y})\n")
    print("cfg.timeout: {cfg.timeout}, cfg2.maxRetries: {cfg2.maxRetries}\n")

    print("=== Enums ===\n")
    print("opposite: {opposite.rawValue}, code: {code}, planetName: {planetName}\n")
    print("dirValue: {dirValue}, extracted: {extracted}\n")

    print("=== Operators & Casts ===\n")
    print("arithmetic: {arithmetic}, modulo: {modulo}\n")
    print("comparison: {comparison}, logical: {logical}, negation: {negation}\n")
    print("asFloat: {asFloat}, byteAsInt: {byteAsInt}\n")

    print("=== Math ===\n")
    print("sqrt: {sqrtVal}, abs: {absVal}\n")
    print("round: {roundVal}, trunc: {truncVal}, floor: {floorVal}, ceil: {ceilVal}\n")

    print("=== Functions ===\n")
    print("Factorial of 5: {factorial(5)}\n")
    print("Sum 0-4: {sum}, parsed: {parsed}\n")
    print("Greeting: {greeting}\n")
    print("Greeting2: {greeting2}\n")
    print("hash: {hash}, strLen: {strLen}\n")
    print("found: {found}\n")

    return 0
end 'main'

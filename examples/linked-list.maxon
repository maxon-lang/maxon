// Linked List implementation using array-based storage
// Since Maxon has no null/optional types, we use index-based linking
// where -1 represents "no next node" (end of list)

typealias Integer = int(i64.min to i64.max)
typealias Index = int(i64.min to i64.max)

// A node stores a value and the index of the next node (-1 = end)
type Node
    export var value Integer
    export var next Index
end 'Node'

typealias NodeArray = Array with Node

// The linked list tracks nodes in an array, plus head index and a free list
type LinkedList
    export var nodes NodeArray
    export var head Index
    export var length Integer

    // Push a value to the front of the list
    function pushFront(value Integer)
        var node = Node{value: value, next: self.head}
        self.nodes.push(node)
        self.head = self.nodes.count() - 1
        self.length = self.length + 1
    end 'pushFront'

    // Push a value to the back of the list
    function pushBack(value Integer)
        var node = Node{value: value, next: -1}
        self.nodes.push(node)
        let newIndex = self.nodes.count() - 1

        if self.head == -1 'emptyList'
            self.head = newIndex
        end 'emptyList' else 'findTail'
            // Walk to the tail
            var current = self.head
            var currentNode = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            while currentNode.next != -1 'walk'
                current = currentNode.next
                currentNode = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            end 'walk'
            // Link the old tail to the new node
            currentNode.next = newIndex
            self.nodes.set(current, value: currentNode)
        end 'findTail'

        self.length = self.length + 1
    end 'pushBack'

    // Get the value at a given position (0-indexed)
    function get(position Integer) returns Integer
        var current = self.head
        var i = 0
        while i < position 'seek'
            var node = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            current = node.next
            i = i + 1
        end 'seek'
        var node = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
        return node.value
    end 'get'

    // Check if the list contains a value
    function contains(value Integer) returns bool
        var current = self.head
        while current != -1 'search'
            var node = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            if node.value == value 'found'
                return true
            end 'found'
            current = node.next
        end 'search'
        return false
    end 'contains'

    // Print all elements in the list
    function printList()
        var current = self.head
        var i = 0
        while current != -1 'printLoop'
            var node = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            if i > 0 'sep'
                print(" -> ")
            end 'sep'
            print("{node.value}")
            current = node.next
            i = i + 1
        end 'printLoop'
        print("\n")
    end 'printList'

    // Get the number of elements
    function count() returns Integer
        return self.length
    end 'count'

    // Remove the first element and return its value
    function popFront() returns Integer
        var node = try self.nodes.get(self.head) otherwise Node{value: 0, next: -1}
        let value = node.value
        self.head = node.next
        self.length = self.length - 1
        return value
    end 'popFront'

    // Reverse the list in place
    function reverse()
        var prev = -1
        var current = self.head
        while current != -1 'rev'
            var node = try self.nodes.get(current) otherwise Node{value: 0, next: -1}
            let next = node.next
            node.next = prev
            self.nodes.set(current, value: node)
            prev = current
            current = next
        end 'rev'
        self.head = prev
    end 'reverse'
end 'LinkedList'

// Helper to create an empty linked list
function newLinkedList() returns LinkedList
    return LinkedList{nodes: NodeArray{}, head: -1, length: 0}
end 'newLinkedList'

function main() returns ExitCode
    var list = newLinkedList()

    // Build list: 10 -> 20 -> 30
    list.pushBack(10)
    list.pushBack(20)
    list.pushBack(30)

    print("List: ")
    list.printList()
    print("Length: {list.count()}\n")

    // Push to front: 5 -> 10 -> 20 -> 30
    list.pushFront(5)
    print("After pushFront(5): ")
    list.printList()

    // Check contains
    print("Contains 20: {list.contains(20)}\n")
    print("Contains 99: {list.contains(99)}\n")

    // Get by position
    print("Element at 0: {list.get(0)}\n")
    print("Element at 2: {list.get(2)}\n")

    // Pop front
    let popped = list.popFront()
    print("Popped: {popped}\n")
    print("After pop: ")
    list.printList()

    // Reverse
    list.reverse()
    print("Reversed: ")
    list.printList()

    return 0
end 'main'

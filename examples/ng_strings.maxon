function main() returns int
	var a = [1,2,3] // a is owned by main

	var b = foo(a) // b is owned by main, a is loaned to foo

	a.push(4) // works because foo did not modify a (it was only a borrow)

	let c = bar(a) // a is now owned by bar (ownership moved)

	a.push(5) // fails because bar changed a (ownership changed)

	return b + c
end 'main'

// foo borrows z, does not take ownership
function foo(z Array of int) returns int
	return z.count()
end 'foo'

// bar takes ownership of z because is changes it
function bar(z Array of int) returns int
	z.push(6)
	return z.count()
end 'bar'

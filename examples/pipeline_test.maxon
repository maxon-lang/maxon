// Pipeline Test Program
// Exercises all stages of the two-stage HIR/LIR compiler pipeline
//
// Coverage:
// - HIR: constants, variables, structs, loops, conditionals, functions, match
// - HIR Optimizations: constant folding, inlining, dead code
// - LIR: memory ops, arithmetic, comparisons, control flow, calls
// - LIR Optimizations: CSE, DCE, copy propagation, peephole

// ============================================================================
// 1. CONSTANTS AND BASIC ARITHMETIC (constant folding, peephole)
// ============================================================================

let MAX_SIZE = 100
let MULTIPLIER = 2

function testConstants() returns int
	// Constant folding: 10 + 20 should fold to 30 at compile time
	let a = 10 + 20

	// Peephole: x * 2 can become x << 1
	let b = a * 2

	// Peephole: x + 0 should be eliminated
	let c = b + 0

	// Peephole: x * 1 should be eliminated
	let d = c * 1

	return d  // Should be 60
end 'testConstants'

// ============================================================================
// 2. CONTROL FLOW (if/else, while, for - HIR structured, LIR flattened)
// ============================================================================

function testControlFlow(n int) returns int
	var result = 0

	// If/else - becomes condBranch in LIR
	if n > 0 'positive'
		result = 1
	end 'positive' else 'nonPositive'
		result = -1
	end 'nonPositive'

	// While loop - becomes branch/condBranch pattern in LIR
	var i = 0
	while i < n 'countLoop'
		result = result + i
		i = i + 1
	end 'countLoop'

	return result
end 'testControlFlow'

// ============================================================================
// 3. STRUCTS AND FIELD ACCESS (HIR preserves, LIR uses offsets)
// ============================================================================

type Point
	var x int
	var y int

	static function create(x int, y int) returns Point
		return Point{x: x, y: y}
	end 'create'

	function manhattanDistance() returns int
		// Field access uses getFieldPtr + load in LIR
		var absX = x
		if x < 0 'negX'
			absX = 0 - x
		end 'negX'

		var absY = y
		if y < 0 'negY'
			absY = 0 - y
		end 'negY'

		return absX + absY
	end 'manhattanDistance'

	function add(other Point) returns Point
		// CSE opportunity: multiple field accesses
		return Point{x: x + other.x, y: y + other.y}
	end 'add'
end 'Point'

function testStructs() returns int
	// Struct literal - becomes alloca + stores in LIR
	var p1 = Point.create(3, y: 4)
	var p2 = Point{x: 1, y: 2}

	// Method call - inlining candidate
	var p3 = p1.add(other: p2)

	// Field read
	var sum = p3.x + p3.y

	return sum  // Should be 10
end 'testStructs'

// ============================================================================
// 4. ENUMS AND MATCH (HIR preserves match, LIR uses jumps)
// ============================================================================

enum Result
	success(value int)
	failure(code int)
	pending
end 'Result'

function testMatch(r Result) returns int
	// Match statement - becomes series of comparisons/jumps in LIR
	match r 'handleResult'
	success(v) then return v * 2
	failure(c) then return 0 - c
	pending then return 0
	end 'handleResult'
end 'testMatch'

function testEnums() returns int
	var r1 = Result.success(42)
	var r2 = Result.failure(1)
	var r3 = Result.pending

	var total = testMatch(r1) + testMatch(r2) + testMatch(r3)
	return total  // Should be 84 + (-1) + 0 = 83
end 'testEnums'

// ============================================================================
// 5. FUNCTION CALLS AND INLINING
// ============================================================================

// Small function - inlining candidate
function square(n int) returns int
	return n * n
end 'square'

// Small function - inlining candidate
function double(n int) returns int
	return n * 2
end 'double'

function testInlining() returns int
	// These should be inlined
	var a = square(5)   // 25
	var b = double(a)   // 50
	var c = square(3)   // 9

	return a + b + c    // Should be 84
end 'testInlining'

// ============================================================================
// 6. COMMON SUBEXPRESSION ELIMINATION
// ============================================================================

function testCSE(a int, b int) returns int
	// CSE: (a + b) computed twice
	var x = a + b
	var y = a + b  // Same computation - should reuse

	// CSE: (a * b) computed twice
	var m = a * b
	var n = a * b  // Same computation - should reuse

	return x + y + m + n
end 'testCSE'

// ============================================================================
// 7. DEAD CODE ELIMINATION
// ============================================================================

function testDCE(flag bool) returns int
	var result = 10

	// Dead assignment - result is overwritten
	var unused = 42

	// Dead code after return
	if flag 'earlyReturn'
		return result
	end 'earlyReturn'

	// This code is reachable when flag is false
	result = result + 5

	return result
end 'testDCE'

// ============================================================================
// 8. COPY PROPAGATION
// ============================================================================

function testCopyProp(n int) returns int
	var a = n
	var b = a      // Copy - can propagate n
	var c = b      // Copy - can propagate n
	var d = c + 1  // Uses c, which is n

	return d
end 'testCopyProp'

// ============================================================================
// 9. NESTED CONTROL FLOW
// ============================================================================

function testNestedControl(x int, y int) returns int
	var result = 0

	if x > 0 'outerIf'
		if y > 0 'innerIf'
			result = 1
		end 'innerIf' else 'innerElse'
			result = 2
		end 'innerElse'
	end 'outerIf' else 'outerElse'
		while y > 0 'whileInElse'
			result = result + 1
			y = y - 1
		end 'whileInElse'
	end 'outerElse'

	return result
end 'testNestedControl'

// ============================================================================
// MAIN ENTRY POINT
// ============================================================================

function main() returns int
	var total = 0

	// Test all pipeline stages
	total = total + testConstants()      // Constant folding, peephole
	total = total + testControlFlow(5)   // Control flow lowering
	total = total + testStructs()        // Struct field access
	total = total + testEnums()          // Enum and match
	total = total + testInlining()       // Function inlining
	total = total + testCSE(3, b: 4)     // CSE
	total = total + testDCE(false)       // DCE
	total = total + testCopyProp(10)     // Copy propagation
	total = total + testNestedControl(1, y: 2)  // Nested control flow

	return total
end 'main'

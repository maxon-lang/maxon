export type Vector2D
    var x float
    var y float
end 'Vector2D'

export function createVector(x float, y float) returns Vector2D
    return Vector2D{x: x, y: y}
end 'createVector'

export function addVectors(a Vector2D, b Vector2D) returns Vector2D
    return Vector2D{x: a.x + b.x, y: a.y + b.y}
end 'addVectors'

export function magnitude(v Vector2D) returns float
    return sqrt(v.x * v.x + v.y * v.y)
end 'magnitude'

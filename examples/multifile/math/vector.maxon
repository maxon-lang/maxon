export typealias Coord = float(f64.min to f64.max)

export type Vector2D
	export var x Coord
	export var y Coord

	export static function create(x Coord, y Coord) returns Vector2D
		return Vector2D{x: x, y: y}
	end 'create'

	export static function add(a Vector2D, b Vector2D) returns Vector2D
		return Vector2D{x: a.x + b.x, y: a.y + b.y}
	end 'add'
end 'Vector2D'

export function createVector(x Coord, y Coord) returns Vector2D
	return Vector2D.create(x, y: y)
end 'createVector'

export function addVectors(a Vector2D, b Vector2D) returns Vector2D
	return Vector2D.add(a, b: b)
end 'addVectors'

export function magnitudeSquared(v Vector2D) returns Coord
	return v.x * v.x + v.y * v.y
end 'magnitudeSquared'

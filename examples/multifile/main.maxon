// Multi-file project demonstration
// Build with: cd examples/multifile && maxon build

function main() returns int
	let v1 = createVector(3.0, 4.0)
	let v2 = createVector(1.0, 2.0)

	// Compute some vector operations
	let sum = addVectors(v1, v2)
	let magSq = magnitudeSquared(sum)

	// Use magSq in a condition to avoid unused variable error
	if magSq > 0.0 'check'
		return 5
	end 'check'
	return 0
end 'main'

{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Maxon",
    "patterns": [
        { "include": "#comments" },
        { "include": "#block-labels" },
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#characters" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#types" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.maxon", "match": "//.*$" },
                { "name": "comment.block.maxon", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.maxon", "match": "\\b(if|then|else|while|for|in|end|return|break|continue|match|default|fallthrough|gives)\\b" },
                { "name": "keyword.other.maxon", "match": "\\b(function|var|let|struct|enum|interface|type|uses|with|extends|export|extern|from|to|case)\\b" },
                { "name": "constant.language.boolean.maxon", "match": "\\b(true|false|nil)\\b" },
                { "name": "support.function.math.maxon", "match": "\\b(sqrt|abs|floor|ceil|round|trunc|sin|cos|tan)\\b" }
            ]
        },
        "block-labels": {
            "patterns": [
                {
                    "comment": "Block labels like 'main' after end, if, then, while, for, etc.",
                    "match": "(\\b(?:end|if|then|else|while|for)\\b)\\s*('[^']*')",
                    "captures": {
                        "1": { "name": "keyword.control.maxon" },
                        "2": { "name": "entity.name.label.maxon" }
                    }
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.maxon",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.maxon", "match": "\\\\." }
                    ]
                }
            ]
        },
        "characters": {
            "patterns": [
                {
                    "comment": "Character literal with escape sequence",
                    "name": "constant.character.maxon",
                    "match": "'\\\\.'" 
                },
                {
                    "comment": "Single character literal",
                    "name": "constant.character.maxon",
                    "match": "'[^\\\\']'" 
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.float.maxon", "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b" },
                { "name": "constant.numeric.byte.maxon", "match": "\\b[0-9]+b\\b" },
                { "name": "constant.numeric.integer.maxon", "match": "\\b[0-9]+\\b" }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.arithmetic.maxon", "match": "[+\\-*/]" },
                { "name": "keyword.operator.comparison.maxon", "match": "(==|!=|>=?|<=?)" },
                { "name": "keyword.operator.assignment.maxon", "match": "=" }
            ]
        },
        "functions": {
            "patterns": [
                { "name": "entity.name.function.maxon", "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()" }
            ]
        },
        "types": {
            "patterns": [
                { "name": "storage.type.maxon", "match": "\\b(int|float|byte|bool|array|of)\\b" }
            ]
        }
    },
    "scopeName": "source.maxon"
}

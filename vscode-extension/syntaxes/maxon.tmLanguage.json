{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Maxon",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#block-identifiers" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#types" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.maxon", "match": "//.*$" },
                { "name": "comment.block.maxon", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.maxon", "match": "\\b(in|for|return|if|continue|else|end|while|break)\\b" },
                { "name": "keyword.other.maxon", "match": "\\b(let|function|var|struct|extern|export)\\b" },
                { "name": "constant.language.boolean.maxon", "match": "\\b(true|false)\\b" },
                { "name": "support.function.math.maxon", "match": "\\b(trunc|floor|sin|abs|sqrt|ceil|round|cos)\\b" }
            ]
        },
        "block-identifiers": {
            "patterns": [
                { "name": "entity.name.label.maxon", "match": "(?<=\\b(in|for|return|if|continue|else|end|while|break|let|function|var|struct|extern|export)\\s+[^'\"]*?)('[^']*'|\"[^\"]*\")" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.maxon", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.maxon", "match": "\\." }] },
                { "name": "string.quoted.single.maxon", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.maxon", "match": "\\." }] }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.float.maxon", "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b" },
                { "name": "constant.numeric.integer.maxon", "match": "\\b[0-9]+\\b" }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.arithmetic.maxon", "match": "[+\\-*/]" },
                { "name": "keyword.operator.comparison.maxon", "match": "(>=?|<=?|=)" },
                { "name": "keyword.operator.assignment.maxon", "match": "=" }
            ]
        },
        "functions": {
            "patterns": [
                { "name": "entity.name.function.maxon", "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()" }
            ]
        },
        "types": {
            "patterns": [
                { "name": "storage.type.maxon", "match": "\\b(bool|ptr|string|char|int|float)\\b" }
            ]
        }
    },
    "scopeName": "source.maxon"
}

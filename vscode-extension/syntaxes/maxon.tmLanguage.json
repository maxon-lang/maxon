{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Maxon",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#enum-body"
    },
    {
      "include": "#block-labels"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "enum-body": {
      "comment": "Enum declaration body - matches case names (including keywords) as enum members",
      "begin": "\\b(enum)\\s+([A-Z]\\w*)",
      "end": "\\b(end)\\s*('[^']*')",
      "beginCaptures": {
        "1": {
          "name": "keyword.other.maxon"
        },
        "2": {
          "name": "entity.name.type.enum.maxon"
        }
      },
      "endCaptures": {
        "1": {
          "name": "keyword.control.maxon"
        },
        "2": {
          "name": "entity.name.label.maxon"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "comment": "Enum case with raw value assignment (any valid identifier)",
          "match": "^\\s+([a-zA-Z_]\\w*)\\s*(=)",
          "captures": {
            "1": {
              "name": "variable.other.enummember.maxon"
            },
            "2": {
              "name": "keyword.operator.assignment.maxon"
            }
          }
        },
        {
          "comment": "Enum case name (any valid identifier, including keywords used as case names)",
          "match": "^\\s+([a-zA-Z_]\\w*)\\s*$",
          "captures": {
            "1": {
              "name": "variable.other.enummember.maxon"
            }
          }
        },
        {
          "include": "#block-labels"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#types"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#characters"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#operators"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.maxon",
          "match": "//.*$"
        },
        {
          "name": "comment.block.maxon",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.maxon",
          "match": "\\b(return|end|if|else|while|for|in|break|continue|gives|throw|try|otherwise|ignore|match|then|fallthrough|default|upto)\\b"
        },
        {
          "name": "keyword.other.maxon",
          "match": "\\b(function|returns|let|var|type|enum|uses|implements|typealias|with|static|export|self|Self|interface|extension|extends|from|to|throws)\\b"
        },
        {
          "name": "keyword.operator.logical.maxon",
          "match": "\\b(mod|and|or|not|as)\\b"
        },
        {
          "name": "constant.language.maxon",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "storage.type.maxon",
          "match": "\\b(of|int|float|bool|byte)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Typealias declaration - highlight the alias name",
          "match": "\\b(typealias)\\s+([A-Z]\\w*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.other.maxon"
            },
            "2": {
              "name": "entity.name.type.maxon"
            },
            "3": {
              "name": "keyword.operator.assignment.maxon"
            }
          }
        },
        {
          "comment": "Standard library types",
          "match": "\\b(Integer|Float|Byte|String|Character|Array|Map|Set|Optional|Result)\\b",
          "name": "support.type.maxon"
        },
        {
          "comment": "User-defined type in type position (after returns, parameter types, etc.)",
          "match": "(?<=\\breturns\\s+|:\\s*)[A-Z]\\w*\\b",
          "name": "entity.name.type.maxon"
        },
        {
          "comment": "Type constructor (Type{value})",
          "match": "\\b([A-Z]\\w*)(?=\\{)",
          "captures": {
            "1": {
              "name": "entity.name.type.maxon"
            }
          }
        },
        {
          "comment": "Type after 'with' keyword (Array with Type)",
          "match": "(?<=\\bwith\\s+)[A-Z]\\w*\\b",
          "name": "entity.name.type.maxon"
        },
        {
          "comment": "Generic PascalCase identifier that's likely a type",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b",
          "name": "entity.name.type.maxon"
        }
      ]
    },
    "block-labels": {
      "patterns": [
        {
          "comment": "Block labels like 'main' after end, if, then, while, for, or (guard-let), etc.",
          "match": "(\\b(?:end|if|else|while|for|or|otherwise|then)\\b)\\s*('[^']*')",
          "captures": {
            "1": {
              "name": "keyword.control.maxon"
            },
            "2": {
              "name": "entity.name.label.maxon"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.maxon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.maxon",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.maxon",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.maxon"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.maxon"
                }
              },
              "patterns": [
                {
                  "include": "#keywords"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#operators"
                }
              ]
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "comment": "Character literal with escape sequence",
          "name": "constant.character.maxon",
          "match": "'\\\\.'"
        },
        {
          "comment": "Single character literal",
          "name": "constant.character.maxon",
          "match": "'[^\\\\']'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.maxon",
          "match": "\\b0[xX][0-9a-fA-F](_?[0-9a-fA-F])*\\b"
        },
        {
          "name": "constant.numeric.binary.maxon",
          "match": "\\b0[bB][01](_?[01])*\\b"
        },
        {
          "name": "constant.numeric.octal.maxon",
          "match": "\\b0[oO][0-7](_?[0-7])*\\b"
        },
        {
          "name": "constant.numeric.float.maxon",
          "match": "\\b[0-9](_?[0-9])*\\.[0-9](_?[0-9])*([eE][+-]?[0-9](_?[0-9])*)?\\b"
        },
        {
          "name": "constant.numeric.byte.maxon",
          "match": "\\b[0-9](_?[0-9])*b\\b"
        },
        {
          "name": "constant.numeric.integer.maxon",
          "match": "\\b[0-9](_?[0-9])*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bitwise.maxon",
          "match": "<<|>>|&|\\||\\^"
        },
        {
          "name": "keyword.operator.comparison.maxon",
          "match": "==|!=|>=|>|<=|<"
        },
        {
          "name": "keyword.operator.arithmetic.maxon",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.maxon",
          "match": "="
        }
      ]
    }
  },
  "scopeName": "source.maxon"
}

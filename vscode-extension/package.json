{
  "name": "maxon-lsp-client",
  "displayName": "Maxon Language Support",
  "description": "Language support for Maxon programming language",
  "version": "0.1.0",
  "publisher": "maxon",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxon/maxon"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "workspaceContains:**/*.maxon"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "maxon",
        "aliases": [
          "Maxon",
          "maxon"
        ],
        "extensions": [
          ".maxon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "maxon",
        "scopeName": "source.maxon",
        "path": "./syntaxes/maxon.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "maxon"
      }
    ],
    "commands": [
      {
        "command": "maxon.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "Maxon"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "maxon",
        "scopes": {
          "label.level0": [
            "entity.name.label.level0.maxon"
          ],
          "label.level1": [
            "entity.name.label.level1.maxon"
          ],
          "label.level2": [
            "entity.name.label.level2.maxon"
          ],
          "label.level3": [
            "entity.name.label.level3.maxon"
          ],
          "label.level4": [
            "entity.name.label.level4.maxon"
          ],
          "label.level5": [
            "entity.name.label.level5.maxon"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[maxon]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "label.level0": "#C0B090",
          "label.level1": "#B090B0",
          "label.level2": "#90A0B0",
          "label.level3": "#90B090",
          "label.level4": "#90B0B0",
          "label.level5": "#B0A090"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm run check-types && node esbuild.js --watch",
    "pretest": "npm run compile",
    "test": "npm run test:grammar && node ./out/test/runTest.js",
    "test:grammar": "vscode-tmgrammar-snap -s source.maxon -g syntaxes/maxon.tmLanguage.json test-fixtures/**/*.maxon",
    "test:grammar:update": "vscode-tmgrammar-snap -u -s source.maxon -g syntaxes/maxon.tmLanguage.json test-fixtures/**/*.maxon",
    "package": "npm run bundle -- --production && vsce package",
    "install-extension": "code --install-extension maxon-lsp-client-0.1.0.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.11.9",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.27.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.2",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
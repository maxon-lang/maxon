package maxon:app;

// The world the maxon-emitted core module targets. Its imports are the Preview2
// interfaces the wasm runtime calls (replacing the old wasi_snapshot_preview1
// surface); `wasm-tools component embed`/`component new` lift/lower these into a
// component that wasmtime runs. The single export is the command entry point.
world command {
  // exit-with-code carries an arbitrary u8 exit status (the `exit` func only
  // signals ok/err → process exit 0/1). Gated @unstable(cli-exit-with-code):
  // built with `--features cli-exit-with-code`, run with `-S cli-exit-with-code=y`.
  @unstable(feature = cli-exit-with-code)
  import wasi:cli/exit@0.2.6;
  import wasi:cli/stdout@0.2.6;
  import wasi:cli/stderr@0.2.6;
  import wasi:cli/stdin@0.2.6;
  import wasi:cli/environment@0.2.6;
  import wasi:io/error@0.2.6;
  import wasi:io/streams@0.2.6;
  import wasi:io/poll@0.2.6;
  import wasi:clocks/monotonic-clock@0.2.6;
  import wasi:filesystem/preopens@0.2.6;
  import wasi:filesystem/types@0.2.6;
  import wasi:sockets/instance-network@0.2.6;
  import wasi:sockets/network@0.2.6;
  import wasi:sockets/tcp-create-socket@0.2.6;
  import wasi:sockets/tcp@0.2.6;
  import wasi:sockets/ip-name-lookup@0.2.6;

  export wasi:cli/run@0.2.6;
}

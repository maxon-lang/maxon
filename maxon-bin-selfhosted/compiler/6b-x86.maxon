// Maxon Compiler - x86-64 Instruction Encoder (Stage 6b)
// Encodes x86-64 machine instructions

// ============================================================================
// x86-64 Encoder
// ============================================================================

export type X86Encoder
	var _unused int  // placeholder field for empty struct

	/// Create encoder
	export static function create() returns X86Encoder
		return {_unused: 0}
	end 'create'

	// ========================================================================
	// REX prefix helpers
	// ========================================================================

	/// Build REX prefix: 0100WRXB
	function rex(w bool, r bool, x bool, b bool) returns byte
		var prefix = 0x40
		if w 'hasW'
			prefix = prefix | 0x08
		end 'hasW'
		if r 'hasR'
			prefix = prefix | 0x04
		end 'hasR'
		if x 'hasX'
			prefix = prefix | 0x02
		end 'hasX'
		if b 'hasB'
			prefix = prefix | 0x01
		end 'hasB'
		return prefix as byte
	end 'rex'

	/// Build ModR/M byte
	function modrm(modVal int, reg int, rm int) returns byte
		return (((modVal & 3) << 6) | ((reg & 7) << 3) | (rm & 7)) as byte
	end 'modrm'

	/// Build SIB byte
	function sib(scale int, index int, base int) returns byte
		return (((scale & 3) << 6) | ((index & 7) << 3) | (base & 7)) as byte
	end 'sib'

	// ========================================================================
	// Move instructions
	// ========================================================================

	/// MOV reg64, reg64
	export function movRegReg(dst Reg, src Reg, code ByteArray)
		let w = true  // 64-bit operand
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x89 as byte)  // MOV r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'movRegReg'

	/// MOV reg64, imm64 (or imm32 sign-extended)
	export function movRegImm(dst Reg, imm int, code ByteArray)
		let w = true
		let b = needsRex(dst)
		code.push(rex(w, r: false, x: false, b: b))

		// Use 32-bit immediate if it fits
		if imm >= -2147483648 and imm <= 2147483647 'fits32'
			code.push((0xC7) as byte)  // MOV r/m64, imm32
			code.push(modrm(3, reg: 0, rm: regCode(dst)))
			emitImm32(imm, code)
		end 'fits32' else 'use64'
			// MOV r64, imm64 (opcode B8+rd)
			code.push((0xB8 + (regCode(dst) & 7)) as byte)
			emitImm64(imm, code)
		end 'use64'
	end 'movRegImm'

	/// MOV reg64, [base + offset]
	export function movRegMem(dst Reg, base Reg, offset int, code ByteArray)
		let w = true
		let r = needsRex(dst)
		let b = needsRex(base)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x8B as byte)  // MOV r64, r/m64

		emitModrmWithOffset(regCode(dst), base, offset, code)
	end 'movRegMem'

	/// MOV [base + offset], reg64
	export function movMemReg(base Reg, offset int, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(base)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x89 as byte)  // MOV r/m64, r64

		emitModrmWithOffset(regCode(src), base, offset, code)
	end 'movMemReg'

	// ========================================================================
	// Arithmetic instructions
	// ========================================================================

	/// ADD reg64, reg64
	export function addRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x01 as byte)  // ADD r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'addRegReg'

	/// ADD reg64, imm32
	export function addRegImm(dst Reg, imm int, code ByteArray)
		let w = true
		let b = needsRex(dst)
		code.push(rex(w, r: false, x: false, b: b))

		if imm >= -128 and imm <= 127 'fits8'
			code.push(0x83 as byte)  // ADD r/m64, imm8
			code.push(modrm(3, reg: 0, rm: regCode(dst)))
			code.push(imm as byte)
		end 'fits8' else 'use32'
			code.push(0x81 as byte)  // ADD r/m64, imm32
			code.push(modrm(3, reg: 0, rm: regCode(dst)))
			emitImm32(imm, code)
		end 'use32'
	end 'addRegImm'

	/// SUB reg64, reg64
	export function subRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x29 as byte)  // SUB r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'subRegReg'

	/// SUB reg64, imm32
	export function subRegImm(dst Reg, imm int, code ByteArray)
		let w = true
		let b = needsRex(dst)
		code.push(rex(w, r: false, x: false, b: b))

		if imm >= -128 and imm <= 127 'fits8'
			code.push(0x83 as byte)  // SUB r/m64, imm8
			code.push(modrm(3, reg: 5, rm: regCode(dst)))
			code.push(imm as byte)
		end 'fits8' else 'use32'
			code.push(0x81 as byte)  // SUB r/m64, imm32
			code.push(modrm(3, reg: 5, rm: regCode(dst)))
			emitImm32(imm, code)
		end 'use32'
	end 'subRegImm'

	/// IMUL reg64, reg64
	export function imulRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(dst)
		let b = needsRex(src)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x0F as byte)
		code.push(0xAF as byte)  // IMUL r64, r/m64
		code.push(modrm(3, reg: regCode(dst), rm: regCode(src)))
	end 'imulRegReg'

	/// IDIV reg64 (divides RDX:RAX by r/m64)
	export function idivReg(src Reg, code ByteArray)
		let w = true
		let b = needsRex(src)
		code.push(rex(w, r: false, x: false, b: b))
		code.push(0xF7 as byte)  // IDIV r/m64
		code.push(modrm(3, reg: 7, rm: regCode(src)))
	end 'idivReg'

	/// CQO (sign-extend RAX into RDX:RAX)
	export function cqo(code ByteArray)
		code.push(rex(true, r: false, x: false, b: false))
		code.push(0x99 as byte)
	end 'cqo'

	/// NEG reg64
	export function negReg(dst Reg, code ByteArray)
		let w = true
		let b = needsRex(dst)
		code.push(rex(w, r: false, x: false, b: b))
		code.push(0xF7 as byte)  // NEG r/m64
		code.push(modrm(3, reg: 3, rm: regCode(dst)))
	end 'negReg'

	// ========================================================================
	// Logical instructions
	// ========================================================================

	/// AND reg64, reg64
	export function andRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x21 as byte)  // AND r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'andRegReg'

	/// OR reg64, reg64
	export function orRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x09 as byte)  // OR r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'orRegReg'

	/// XOR reg64, reg64
	export function xorRegReg(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(src)
		let b = needsRex(dst)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x31 as byte)  // XOR r/m64, r64
		code.push(modrm(3, reg: regCode(src), rm: regCode(dst)))
	end 'xorRegReg'

	// ========================================================================
	// Comparison instructions
	// ========================================================================

	/// CMP reg64, reg64
	export function cmpRegReg(src1 Reg, src2 Reg, code ByteArray)
		let w = true
		let r = needsRex(src2)
		let b = needsRex(src1)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x39 as byte)  // CMP r/m64, r64
		code.push(modrm(3, reg: regCode(src2), rm: regCode(src1)))
	end 'cmpRegReg'

	/// CMP reg64, imm32
	export function cmpRegImm(dst Reg, imm int, code ByteArray)
		let w = true
		let b = needsRex(dst)
		code.push(rex(w, r: false, x: false, b: b))

		if imm >= -128 and imm <= 127 'fits8'
			code.push(0x83 as byte)  // CMP r/m64, imm8
			code.push(modrm(3, reg: 7, rm: regCode(dst)))
			code.push(imm as byte)
		end 'fits8' else 'use32'
			code.push(0x81 as byte)  // CMP r/m64, imm32
			code.push(modrm(3, reg: 7, rm: regCode(dst)))
			emitImm32(imm, code)
		end 'use32'
	end 'cmpRegImm'

	/// TEST reg64, reg64
	export function testRegReg(src1 Reg, src2 Reg, code ByteArray)
		let w = true
		let r = needsRex(src2)
		let b = needsRex(src1)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x85 as byte)  // TEST r/m64, r64
		code.push(modrm(3, reg: regCode(src2), rm: regCode(src1)))
	end 'testRegReg'

	// ========================================================================
	// Branch instructions
	// ========================================================================

	/// JMP rel32
	export function jmpRel32(offset int, code ByteArray)
		code.push(0xE9 as byte)
		emitImm32(offset, code)
	end 'jmpRel32'

	/// Jcc rel32 (conditional jump)
	export function jccRel32(cc int, offset int, code ByteArray)
		code.push(0x0F as byte)
		code.push(cc as byte)
		emitImm32(offset, code)
	end 'jccRel32'

	/// CALL rel32
	export function callRel32(offset int, code ByteArray)
		code.push(0xE8 as byte)
		emitImm32(offset, code)
	end 'callRel32'

	/// RET
	export function ret(code ByteArray)
		code.push(0xC3 as byte)
	end 'ret'

	// ========================================================================
	// Stack instructions
	// ========================================================================

	/// PUSH reg64
	export function pushReg(src Reg, code ByteArray)
		if needsRex(src) 'needRex'
			code.push(rex(false, r: false, x: false, b: true))
		end 'needRex'
		code.push((0x50 + (regCode(src) & 7)) as byte)
	end 'pushReg'

	/// POP reg64
	export function popReg(dst Reg, code ByteArray)
		if needsRex(dst) 'needRex'
			code.push(rex(false, r: false, x: false, b: true))
		end 'needRex'
		code.push((0x58 + (regCode(dst) & 7)) as byte)
	end 'popReg'

	// ========================================================================
	// Address calculation
	// ========================================================================

	/// LEA reg64, [base + offset]
	export function leaRegMem(dst Reg, base Reg, offset int, code ByteArray)
		let w = true
		let r = needsRex(dst)
		let b = needsRex(base)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x8D as byte)  // LEA r64, m
		emitModrmWithOffset(regCode(dst), base, offset, code)
	end 'leaRegMem'

	// ========================================================================
	// Setcc instructions (set byte based on condition)
	// ========================================================================

	/// SETE r8 (set if equal)
	export function sete(dst Reg, code ByteArray)
		setcc(0x94, dst, code)
	end 'sete'

	/// SETNE r8 (set if not equal)
	export function setne(dst Reg, code ByteArray)
		setcc(0x95, dst, code)
	end 'setne'

	/// SETL r8 (set if less)
	export function setl(dst Reg, code ByteArray)
		setcc(0x9C, dst, code)
	end 'setl'

	/// SETLE r8 (set if less or equal)
	export function setle(dst Reg, code ByteArray)
		setcc(0x9E, dst, code)
	end 'setle'

	/// SETG r8 (set if greater)
	export function setg(dst Reg, code ByteArray)
		setcc(0x9F, dst, code)
	end 'setg'

	/// SETGE r8 (set if greater or equal)
	export function setge(dst Reg, code ByteArray)
		setcc(0x9D, dst, code)
	end 'setge'

	function setcc(cc int, dst Reg, code ByteArray)
		if needsRex(dst) 'needRex'
			code.push(rex(false, r: false, x: false, b: true))
		end 'needRex'
		code.push(0x0F as byte)
		code.push(cc as byte)
		code.push(modrm(3, reg: 0, rm: regCode(dst)))
	end 'setcc'

	/// MOVZX reg64, r8 (zero-extend byte to 64-bit)
	export function movzxRegReg8(dst Reg, src Reg, code ByteArray)
		let w = true
		let r = needsRex(dst)
		let b = needsRex(src)
		code.push(rex(w, r: r, x: false, b: b))
		code.push(0x0F as byte)
		code.push(0xB6 as byte)  // MOVZX r64, r/m8
		code.push(modrm(3, reg: regCode(dst), rm: regCode(src)))
	end 'movzxRegReg8'

	// ========================================================================
	// Helper functions
	// ========================================================================

	/// Emit ModR/M with optional SIB and displacement
	function emitModrmWithOffset(reg int, base Reg, offset int, code ByteArray)
		let baseCode = regCode(base) & 7

		// RSP/R12 always needs SIB byte
		let needSib = baseCode == 4

		if offset == 0 and baseCode != 5 'noDisp'
			// [base] - mod=00
			code.push(modrm(0, reg: reg, rm: baseCode))
			if needSib 'addSib'
				code.push(sib(0, index: 4, base: baseCode))  // index=RSP means no index
			end 'addSib'
		end 'noDisp' else if offset >= -128 and offset <= 127 'disp8'
				// [base + disp8] - mod=01
				code.push(modrm(1, reg: reg, rm: baseCode))
				if needSib 'addSib'
					code.push(sib(0, index: 4, base: baseCode))
				end 'addSib'
				code.push(offset as byte)
		end 'disp8' else 'disp32'
			// [base + disp32] - mod=10
			code.push(modrm(2, reg: reg, rm: baseCode))
			if needSib 'addSib'
				code.push(sib(0, index: 4, base: baseCode))
			end 'addSib'
			emitImm32(offset, code)
		end 'disp32'
	end 'emitModrmWithOffset'

	/// Emit 32-bit immediate (little-endian)
	function emitImm32(value int, code ByteArray)
		code.push((value & 0xFF) as byte)
		code.push(((value >> 8) & 0xFF) as byte)
		code.push(((value >> 16) & 0xFF) as byte)
		code.push(((value >> 24) & 0xFF) as byte)
	end 'emitImm32'

	/// Emit 64-bit immediate (little-endian)
	function emitImm64(value int, code ByteArray)
		code.push((value & 0xFF) as byte)
		code.push(((value >> 8) & 0xFF) as byte)
		code.push(((value >> 16) & 0xFF) as byte)
		code.push(((value >> 24) & 0xFF) as byte)
		code.push(((value >> 32) & 0xFF) as byte)
		code.push(((value >> 40) & 0xFF) as byte)
		code.push(((value >> 48) & 0xFF) as byte)
		code.push(((value >> 56) & 0xFF) as byte)
	end 'emitImm64'
end 'X86Encoder'

// MIR Code generator for the Maxon compiler

export enum IrError is Error
	undefinedVariable
	unsupportedStatement
	unsupportedExpression
end 'IrError'

export type CodeGen
	export let output String
	let tempCounter int
	let localVars Map from String to String

	export static function create() returns CodeGen
		var vars = Map from String to String{}
		var result = CodeGen{output: "", tempCounter: 0, localVars: vars}
		return result
	end 'create'

	export function newTemp() returns String
		let temp = "%t"
		tempCounter = tempCounter + 1
		return temp
	end 'newTemp'

	export function emit(code String)
		output = "{output}{code}\n"
	end 'emit'

	export function generate(program Program) throws IrError
		emit("; Maxon IR generated by self-hosted compiler")
		emit("; Source: {program.fileName}")
		emit("")

		var i = 0
		while i < program.functions.count() 'funcs'
			var fn = try program.functions.get(i)
			try genFunction(fn)
			i = i + 1
		end 'funcs'
	end 'generate'

	export function genFunction(fn FunctionDecl) throws IrError
		localVars = Map from String to String{}
		tempCounter = 0

		var returnTypeStr = "i64"
		if fn.returnType.kind == TypeKind.voidType 'void'
			returnTypeStr = "void"
		end 'void'

		emit("define {returnTypeStr} @{fn.name}() \{")
		emit("entry:")

		var i = 0
		while i < fn.body.count() 'body'
			try genStmt(try fn.body.get(i))
			i = i + 1
		end 'body'

		emit("}")
		emit("")
	end 'genFunction'

	export function genStmt(stmt Stmt) throws IrError
		if stmt.kind == StmtKind.returnStmt 'return'
			if stmt.hasValue 'hasValue'
				let temp = try genExpr(stmt.expr)
				emit("    ret i64 {temp}")
			end 'hasValue' else 'noValue'
				emit("    ret void")
			end 'noValue'
		end 'return' else if stmt.kind == StmtKind.letStmt 'let'
				let valueTemp = try genExpr(stmt.expr)
				let varTemp = newTemp()
				emit("    {varTemp} = copy i64 {valueTemp}")
				localVars.insert(stmt.name, varTemp)
		end 'let' else 'unknown-stmt'
			throw IrError.unsupportedStatement
		end 'unknown-stmt'
	end 'genStmt'

	export function genExpr(expr Expr) returns String throws IrError
		if expr.kind == ExprKind.intLiteral 'int'
			return "{expr.intValue}"
		end 'int'

		if expr.kind == ExprKind.varRef 'var'
			let varName = try localVars.get(expr.name) otherwise 'notFound'
			throw IrError.undefinedVariable
			end 'notFound'
			return varName
		end 'var'

		throw IrError.unsupportedExpression
	end 'genExpr'
end 'CodeGen'






// x86-64 Native Code Generator for the Maxon self-hosted compiler
// Minimal version - just enough to compile basic.maxon

//=============================================================================
// Code buffer for emitting bytes
//=============================================================================

export type CodeBuffer
var bytes array of byte
var size int

export function create() returns CodeBuffer
	return CodeBuffer{bytes: array of byte, size: 0}
end 'create'

export function emitByte(b byte) returns nothing
	bytes.append(b)
	size = size + 1
end 'emitByte'

export function emitWord(value int) returns nothing
	emitByte((value & 0xFF) as byte)
	emitByte(((value >> 8) & 0xFF) as byte)
end 'emitWord'

export function emitDword(value int) returns nothing
	emitByte((value & 0xFF) as byte)
	emitByte(((value >> 8) & 0xFF) as byte)
	emitByte(((value >> 16) & 0xFF) as byte)
	emitByte(((value >> 24) & 0xFF) as byte)
end 'emitDword'

export function emitQword(value int) returns nothing
	emitDword(value & 0xFFFFFFFF)
	emitDword((value >> 32) & 0xFFFFFFFF)
end 'emitQword'

export function align(alignment int) returns nothing
	while (size mod alignment) != 0 'pad'
		emitByte(0b)
	end 'pad'
end 'align'
end 'CodeBuffer'

//=============================================================================
// x86-64 Code Generator
//=============================================================================

export type X86Gen
var code CodeBuffer

export function create() returns X86Gen
	return X86Gen{code: CodeBuffer.create()}
end 'create'

export function generate(program Program) returns nothing
	// For basic.maxon: function main() int { return 42 }
	// Generate minimal code that works with our PE builder

	var i = 0
	while i < program.declarations.count() 'decls'
		genDecl(program.declarations[i])
		i = i + 1
	end 'decls'
end 'generate'

export function genDecl(decl Decl) returns nothing
	match decl 'gen'
		function_(name, params, returnType, body, isExport, isExtern, loc) then
		genFunction(name, body)
	end 'gen'
end 'genDecl'

export function genFunction(name string, body array of Stmt) returns nothing
	// For basic.maxon's main(), just generate code for the return statement
	var i = 0
	while i < body.count() 'stmts'
		genStmt(body[i])
		i = i + 1
	end 'stmts'
end 'genFunction'

export function genStmt(stmt Stmt) returns nothing
	match stmt 'gen'
		return_(value, loc) then
		if let v = value 'hasValue'
			genExpr(v)
		end 'hasValue'
		// Return value is in EAX
	end 'gen'
end 'genStmt'

export function genExpr(expr Expr) returns nothing
	match expr 'gen'
		intLiteral(value, loc) then
		// MOV EAX, imm32: B8 xx xx xx xx
		code.emitByte(0xB8 as byte)
		code.emitDword(value)
	end 'gen'
end 'genExpr'

export function getCode() returns array of byte
	return code.bytes
end 'getCode'

export function getCodeSize() returns int
	return code.size
end 'getCodeSize'
end 'X86Gen'



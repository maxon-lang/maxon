// Semantic Analyzer for the Maxon self-hosted compiler
// Minimal version - just enough to analyze basic.maxon

//=============================================================================
// Semantic Error
//=============================================================================

export struct SemanticError
    var message string
    var line int
    var column int

    export function create(message string, line int, column int) SemanticError
        return SemanticError{message: message, line: line, column: column}
    end 'create'

    export function toString() returns string
        return "Error at " + line.toString() + ":" + column.toString() + ": " + message
    end 'toString'
end 'SemanticError'

//=============================================================================
// Semantic Analyzer
//=============================================================================

export struct SemanticAnalyzer
    var errors array of SemanticError
    var warnings array of SemanticError
    var hasMain bool
    var localVars map from string to TypeRef

    export function create() SemanticAnalyzer
        return SemanticAnalyzer{
            errors: array of SemanticError,
            warnings: array of SemanticError,
            hasMain: false,
            localVars: map from string to TypeRef
        }
    end 'create'

    export function success() returns bool
        return errors.count() == 0
    end 'success'

    export returns nothing
        errors.append(SemanticError.create(message, loc.line, loc.column))
    end 'addError'

    //=========================================================================
    // Main analysis entry point
    //=========================================================================

    export returns nothing
        // Check all declarations
        var i = 0
        while i < program.declarations.count() 'decls'
            analyzeDecl(program.declarations[i])
            i = i + 1
        end 'decls'

        // Verify main() exists
        if not hasMain 'noMain'
            addError("No 'main' function found", SourceLoc.create(1, 1))
        end 'noMain'
    end 'analyze'

    export returns nothing
        match decl 'analyze'
            function_(name, params, returnType, body, isExport, isExtern, loc) then
                if name == "main" 'isMain'
                    hasMain = true
                end 'isMain'
                // Clear local vars for each function
                localVars = map from string to TypeRef
                // Analyze body statements
                var i = 0
                while i < body.count() 'bodyLoop'
                    analyzeStmt(body[i])
                    i = i + 1
                end 'bodyLoop'
        end 'analyze'
    end 'analyzeDecl'

    export returns nothing
        match stmt 'analyze'
            return_(value, loc) then
                if let v = value 'hasValue'
                    analyzeExpr(v)
                end 'hasValue'
            let_(name, typeAnnotation, value, loc) then
                analyzeExpr(value)
                // For now, assume int type (inferred from literal)
                localVars[name] = TypeRef.intType()
        end 'analyze'
    end 'analyzeStmt'

    export returns nothing
        match expr 'analyze'
            intLiteral(value, loc) then
                // Nothing to check
            varRef(name, loc) then
                if not localVars.has(name) 'undefined'
                    addError("Undefined variable: " + name, loc)
                end 'undefined'
        end 'analyze'
    end 'analyzeExpr'

    //=========================================================================
    // Error reporting
    //=========================================================================

    export returns nothing
        var i = 0
        while i < errors.count() 'errs'
            print(errors[i].toString())
            i = i + 1
        end 'errs'
    end 'printErrors'

    export returns nothing
        var i = 0
        while i < warnings.count() 'warns'
            print("Warning: " + warnings[i].toString())
            i = i + 1
        end 'warns'
    end 'printWarnings'
end 'SemanticAnalyzer'

// Semantic Analyzer for the Maxon compiler
// Simplified: just checks that main exists

export enum SemanticError is Error
	noMainFunction
end 'SemanticError'

export type SemanticAnalyzer
	var dummy int

	export static function create() returns SemanticAnalyzer
		return SemanticAnalyzer{dummy: 0}
	end 'create'

	export function analyze(program Program) throws SemanticError
		// For basic.maxon, just check main exists
		// We already know there's 1 function and it's called "main" from parsing
		if program.functions.count() == 0 'noFunctions'
			throw SemanticError.noMainFunction
		end 'noFunctions'
		// If we have functions, assume main exists for now
	end 'analyze'
end 'SemanticAnalyzer'









// Maxon Compiler - Parser (Stage 2)
// Error-tolerant parser with panic-mode recovery - uses flat/index-based AST

// ============================================================================
// AST Enums
// ============================================================================

export enum ExprKind
	intLiteral
	floatLiteral
	boolLiteral
	stringLiteral
	identifier
	binaryOp
	unaryOp
	call
	fieldAccess
	indexAccess
	errorExpr
end 'ExprKind'

export enum BinaryOp
	add
	subtract
	multiply
	divide
	modulo
	equal
	notEqual
	less
	lessEqual
	greater
	greaterEqual
	logicalAnd
	logicalOr
end 'BinaryOp'

export enum UnaryOp
	negate
	logicalNot
end 'UnaryOp'

export enum StmtKind
	returnStmt
	letStmt
	varStmt
	assignStmt
	ifStmt
	whileStmt
	forStmt
	breakStmt
	continueStmt
	exprStmt
	errorStmt
end 'StmtKind'

export enum TypeKind
	typeInt
	typeFloat
	typeBool
	typeByte
	typeString
	typeVoid
	typeNamed
	typeArray
	typeUnknown
end 'TypeKind'

// ============================================================================
// Flat AST Types - uses indices instead of recursive references
// ============================================================================

/// A type reference in the AST
export type TypeRef
	export var kind TypeKind
	export var name String           // for named types
	export var elementType int       // index for array element type (-1 if none)
	export var line int
	export var column int

	export static function createSimple(kind TypeKind, line int, column int) returns TypeRef
		return {kind: kind, name: "", elementType: -1, line: line, column: column}
	end 'createSimple'

	export static function createNamed(name String, line int, column int) returns TypeRef
		return {kind: TypeKind.typeNamed, name: name, elementType: -1, line: line, column: column}
	end 'createNamed'
end 'TypeRef'

export typealias TypeRefArray is Array with TypeRef

/// An expression node - all fields are primitives, no recursive types
export type Expr
	export var kind ExprKind
	export var intValue int          // for intLiteral
	export var floatValue float      // for floatLiteral
	export var boolValue bool        // for boolLiteral
	export var stringValue String    // for identifier, stringLiteral
	export var binaryOp BinaryOp     // for binaryOp
	export var unaryOp UnaryOp       // for unaryOp
	export var leftIndex int         // left operand / callee index
	export var rightIndex int        // right operand index (-1 if none)
	export var argsStart int         // start index in args pool for call
	export var argsCount int         // number of arguments for call
	export var line int
	export var column int
	export var hasError bool         // true if this node or children have errors

	export static function createIntLiteral(value int, line int, column int) returns Expr
		return {kind: ExprKind.intLiteral, intValue: value, floatValue: 0.0, boolValue: false, stringValue: "", binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createIntLiteral'

	export static function createFloatLiteral(value float, line int, column int) returns Expr
		return {kind: ExprKind.floatLiteral, intValue: 0, floatValue: value, boolValue: false, stringValue: "", binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createFloatLiteral'

	export static function createBoolLiteral(value bool, line int, column int) returns Expr
		return {kind: ExprKind.boolLiteral, intValue: 0, floatValue: 0.0, boolValue: value, stringValue: "", binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createBoolLiteral'

	export static function createStringLiteral(value String, line int, column int) returns Expr
		return {kind: ExprKind.stringLiteral, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: value, binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createStringLiteral'

	export static function createIdentifier(name String, line int, column int) returns Expr
		return {kind: ExprKind.identifier, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: name, binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createIdentifier'

	export static function createBinary(op BinaryOp, leftIndex int, rightIndex int, line int, column int) returns Expr
		return {kind: ExprKind.binaryOp, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: "", binaryOp: op, unaryOp: UnaryOp.negate, leftIndex: leftIndex, rightIndex: rightIndex, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createBinary'

	export static function createUnary(op UnaryOp, operandIndex int, line int, column int) returns Expr
		return {kind: ExprKind.unaryOp, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: "", binaryOp: BinaryOp.add, unaryOp: op, leftIndex: operandIndex, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createUnary'

	export static function createCall(calleeIndex int, argsStart int, argsCount int, line int, column int) returns Expr
		return {kind: ExprKind.call, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: "", binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: calleeIndex, rightIndex: -1, argsStart: argsStart, argsCount: argsCount, line: line, column: column, hasError: false}
	end 'createCall'

	export static function createFieldAccess(objectIndex int, fieldName String, line int, column int) returns Expr
		return {kind: ExprKind.fieldAccess, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: fieldName, binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: objectIndex, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: false}
	end 'createFieldAccess'

	export static function createError(line int, column int) returns Expr
		return {kind: ExprKind.errorExpr, intValue: 0, floatValue: 0.0, boolValue: false, stringValue: "", binaryOp: BinaryOp.add, unaryOp: UnaryOp.negate, leftIndex: -1, rightIndex: -1, argsStart: -1, argsCount: 0, line: line, column: column, hasError: true}
	end 'createError'
end 'Expr'

export typealias ExprArray is Array with Expr
export typealias IntArray is Array with int

/// A statement node - uses int index for expr reference
export type Stmt
	export var kind StmtKind
	export var exprIndex int         // index into expressions array
	export var varName String        // for let/var/assign
	export var typeRef int           // index into types array (-1 if inferred)
	export var thenStart int         // start index for then-block statements
	export var thenCount int         // count of then-block statements
	export var elseStart int         // start index for else-block statements
	export var elseCount int         // count of else-block statements
	export var label String          // block label
	export var line int
	export var column int
	export var hasError bool         // true if this node or children have errors

	export static function createReturn(exprIndex int, line int, column int) returns Stmt
		return {kind: StmtKind.returnStmt, exprIndex: exprIndex, varName: "", typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: false}
	end 'createReturn'

	export static function createLet(name String, typeRef int, exprIndex int, line int, column int) returns Stmt
		return {kind: StmtKind.letStmt, exprIndex: exprIndex, varName: name, typeRef: typeRef, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: false}
	end 'createLet'

	export static function createVar(name String, typeRef int, exprIndex int, line int, column int) returns Stmt
		return {kind: StmtKind.varStmt, exprIndex: exprIndex, varName: name, typeRef: typeRef, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: false}
	end 'createVar'

	export static function createAssign(name String, exprIndex int, line int, column int) returns Stmt
		return {kind: StmtKind.assignStmt, exprIndex: exprIndex, varName: name, typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: false}
	end 'createAssign'

	export static function createIf(condIndex int, thenStart int, thenCount int, elseStart int, elseCount int, label String, line int, column int) returns Stmt
		return {kind: StmtKind.ifStmt, exprIndex: condIndex, varName: "", typeRef: -1, thenStart: thenStart, thenCount: thenCount, elseStart: elseStart, elseCount: elseCount, label: label, line: line, column: column, hasError: false}
	end 'createIf'

	export static function createWhile(condIndex int, bodyStart int, bodyCount int, label String, line int, column int) returns Stmt
		return {kind: StmtKind.whileStmt, exprIndex: condIndex, varName: "", typeRef: -1, thenStart: bodyStart, thenCount: bodyCount, elseStart: -1, elseCount: 0, label: label, line: line, column: column, hasError: false}
	end 'createWhile'

	export static function createBreak(label String, line int, column int) returns Stmt
		return {kind: StmtKind.breakStmt, exprIndex: -1, varName: "", typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: label, line: line, column: column, hasError: false}
	end 'createBreak'

	export static function createContinue(label String, line int, column int) returns Stmt
		return {kind: StmtKind.continueStmt, exprIndex: -1, varName: "", typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: label, line: line, column: column, hasError: false}
	end 'createContinue'

	export static function createExprStmt(exprIndex int, line int, column int) returns Stmt
		return {kind: StmtKind.exprStmt, exprIndex: exprIndex, varName: "", typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: false}
	end 'createExprStmt'

	export static function createError(line int, column int) returns Stmt
		return {kind: StmtKind.errorStmt, exprIndex: -1, varName: "", typeRef: -1, thenStart: -1, thenCount: 0, elseStart: -1, elseCount: 0, label: "", line: line, column: column, hasError: true}
	end 'createError'
end 'Stmt'

export typealias StmtArray is Array with Stmt

/// A parameter in a function declaration
export type Parameter
	export var name String
	export var typeRef int           // index into types array
	export var defaultExpr int       // index into expressions array (-1 if no default)
	export var line int
	export var column int
end 'Parameter'

export typealias ParameterArray is Array with Parameter

/// A function declaration
export type FunctionDecl
	export var name String
	export var params ParameterArray
	export var returnType int        // index into types array
	export var bodyStart int         // start index in statements pool
	export var bodyCount int         // number of statements in body
	export var isExport bool
	export var line int
	export var column int
	export var hasError bool         // true if function contains errors
end 'FunctionDecl'

export typealias FunctionArray is Array with FunctionDecl

/// A field in a type declaration
export type FieldDecl
	export var name String
	export var typeRef int           // index into types array
	export var defaultExpr int       // index into expressions array (-1 if no default)
	export var isExport bool
	export var isMutable bool        // var vs let
	export var isStatic bool
	export var line int
	export var column int
end 'FieldDecl'

export typealias FieldArray is Array with FieldDecl

/// A type declaration (struct/class)
export type TypeDecl
	export var name String
	export var fields FieldArray
	export var methods FunctionArray
	export var interfaces IntArray   // indices into types array
	export var isExport bool
	export var line int
	export var column int
	export var hasError bool
end 'TypeDecl'

export typealias TypeDeclArray is Array with TypeDecl

/// An enum case
export type EnumCase
	export var name String
	export var rawValue int          // for int-backed enums
	export var stringValue String    // for string-backed enums
	export var hasExplicitValue bool
	export var line int
	export var column int
end 'EnumCase'

export typealias EnumCaseArray is Array with EnumCase

/// An enum declaration
export type EnumDecl
	export var name String
	export var cases EnumCaseArray
	export var methods FunctionArray
	export var isExport bool
	export var isError bool          // true if conforms to Error
	export var line int
	export var column int
	export var hasError bool
end 'EnumDecl'

export typealias EnumDeclArray is Array with EnumDecl

/// A parsed program - the root of the AST
export type Program
	export var functions FunctionArray
	export var types TypeDeclArray
	export var enums EnumDeclArray
	export var expressions ExprArray   // Pool of all expressions
	export var statements StmtArray    // Pool of all statements
	export var typeRefs TypeRefArray   // Pool of all type references
	export var hasError bool
	export var sourceFile String

	export static function create(sourceFile String) returns Program
		return {functions: FunctionArray{}, types: TypeDeclArray{}, enums: EnumDeclArray{}, expressions: ExprArray{}, statements: StmtArray{}, typeRefs: TypeRefArray{}, hasError: false, sourceFile: sourceFile}
	end 'create'

	/// Add an expression to the pool and return its index
	export function addExpr(expr Expr) returns int
		let idx = expressions.count()
		expressions.push(expr)
		if expr.hasError 'propagate'
			hasError = true
		end 'propagate'
		return idx
	end 'addExpr'

	/// Get an expression by index
	export function getExpr(idx int) returns Expr
		return try expressions.get(idx) otherwise Expr.createError(0, column: 0)
	end 'getExpr'

	/// Add a statement to the pool and return its index
	export function addStmt(stmt Stmt) returns int
		let idx = statements.count()
		statements.push(stmt)
		if stmt.hasError 'propagate'
			hasError = true
		end 'propagate'
		return idx
	end 'addStmt'

	/// Get a statement by index
	export function getStmt(idx int) returns Stmt
		return try statements.get(idx) otherwise Stmt.createError(0, column: 0)
	end 'getStmt'

	/// Add a type reference and return its index
	export function addTypeRef(typeRef TypeRef) returns int
		let idx = typeRefs.count()
		typeRefs.push(typeRef)
		return idx
	end 'addTypeRef'

	/// Get a type reference by index
	export function getTypeRef(idx int) returns TypeRef
		return try typeRefs.get(idx) otherwise TypeRef.createSimple(TypeKind.typeUnknown, line: 0, column: 0)
	end 'getTypeRef'
end 'Program'

// ============================================================================
// Parser with Error Recovery
// ============================================================================

export type Parser
	var tokens TokenArray
	var sourceFile String
	var pos int
	export var errors ErrorCollector
	var program Program
	var panicMode bool               // true when recovering from error

	export static function init(tokens TokenArray, sourceFile String) returns Parser
		return {tokens: tokens, sourceFile: sourceFile, pos: 0, errors: ErrorCollector.create(), program: Program.create(sourceFile), panicMode: false}
	end 'init'

	/// Parse the token stream into a Program
	export function parse() returns Program
		while not isAtEnd() 'mainLoop'
			skipNewlines()
			if isAtEnd() 'checkEnd'
				break 'mainLoop'
			end 'checkEnd'

			// Parse top-level declarations
			if checkKeyword("function") 'isFunc'
				parseFunction(isExport: false)
			end 'isFunc' else if checkKeyword("export") 'isExport'
					parseExportDecl()
			end 'isExport' else if checkKeyword("type") 'isType'
					parseTypeDecl(isExport: false)
			end 'isType' else if checkKeyword("enum") 'isEnum'
					parseEnumDecl(isExport: false)
			end 'isEnum' else 'skip'
				// Skip unknown tokens with error recovery
				error("unexpected token at top level")
				synchronize()
			end 'skip'
		end 'mainLoop'

		return program
	end 'parse'

	/// Parse an export declaration
	function parseExportDecl()
		advance()  // consume 'export'
		skipNewlines()

		if checkKeyword("function") 'isFunc'
			parseFunction(isExport: true)
		end 'isFunc' else if checkKeyword("type") 'isType'
				parseTypeDecl(isExport: true)
		end 'isType' else if checkKeyword("enum") 'isEnum'
				parseEnumDecl(isExport: true)
		end 'isEnum' else 'error'
			error("expected declaration after 'export'")
			synchronize()
		end 'error'
	end 'parseExportDecl'

	/// Synchronize parser state after an error (panic-mode recovery)
	/// Advances to the next statement/declaration boundary
	function synchronize()
		panicMode = true

		while not isAtEnd() 'syncLoop'
			// Stop at newline followed by a sync point
			if checkTokenType(TokenType.newline) 'atNewline'
				advance()
				skipNewlines()
				// Check for declaration/statement keywords
				if isSyncPoint() 'atSync'
					panicMode = false
					return
				end 'atSync'
			end 'atNewline' else 'notNewline'
				// Also check current token for sync keywords
				if isSyncPoint() 'atSync2'
					panicMode = false
					return
				end 'atSync2'
				advance()
			end 'notNewline'
		end 'syncLoop'

		panicMode = false
	end 'synchronize'

	/// Check if current token is a synchronization point
	function isSyncPoint() returns bool
		if isAtEnd() 'atEnd'
			return true
		end 'atEnd'
		let text = currentText()
		return text == "function" or text == "type" or text == "enum" or text == "export" or text == "end" or text == "if" or text == "while" or text == "for" or text == "return" or text == "let" or text == "var"
	end 'isSyncPoint'

	/// Parse a function declaration
	function parseFunction(isExport bool)
		var startLine = currentLine()
		var startCol = currentColumn()
		var fnHasError = false

		// function keyword
		advance()  // consume 'function'
		skipNewlines()

		// function name
		var name = expectIdentifier()
		if name == "" 'noName'
			fnHasError = true
		end 'noName'
		skipNewlines()

		// Parse parameters
		var params = ParameterArray{}
		if not checkTokenType(TokenType.lparen) 'noParen'
			error("expected '(' after function name")
			fnHasError = true
		end 'noParen' else 'hasParen'
			advance()  // consume '('
			skipNewlines()

			// Parse parameter list
			while not isAtEnd() and not checkTokenType(TokenType.rparen) 'paramLoop'
				let param = parseParameter()
				params.push(param)
				skipNewlines()

				if checkTokenType(TokenType.comma) 'hasComma'
					advance()
					skipNewlines()
				end 'hasComma' else 'noComma'
					break 'paramLoop'
				end 'noComma'
			end 'paramLoop'

			if not checkTokenType(TokenType.rparen) 'noCloseParen'
				error("expected ')' after parameters")
				fnHasError = true
			end 'noCloseParen' else 'hasCloseParen'
				advance()  // consume ')'
			end 'hasCloseParen'
		end 'hasParen'

		skipNewlines()

		// returns TYPE
		var returnTypeIdx = -1
		if checkKeyword("returns") 'hasReturns'
			advance()  // consume 'returns'
			skipNewlines()
			returnTypeIdx = parseTypeRef()
		end 'hasReturns'

		skipNewlines()

		// Parse body until 'end'
		var bodyStart = program.statements.count()
		var bodyCount = 0

		while not isAtEnd() and not checkKeyword("end") 'bodyLoop'
			skipNewlines()
			if isAtEnd() or checkKeyword("end") 'checkEnd'
				break 'bodyLoop'
			end 'checkEnd'

			let stmt = parseStatement()
			program.addStmt(stmt)
			if stmt.hasError 'stmtError'
				fnHasError = true
			end 'stmtError'
			bodyCount = bodyCount + 1
		end 'bodyLoop'

		// end 'name'
		if not checkKeyword("end") 'noEnd'
			error("expected 'end' to close function")
			fnHasError = true
		end 'noEnd' else 'hasEnd'
			advance()  // consume 'end'
			skipNewlines()

			// expect 'name' block label
			if checkTokenType(TokenType.characterLiteral) 'hasLabel'
				advance()  // consume the label
			end 'hasLabel'
		end 'hasEnd'

		var fn = FunctionDecl{name: name, params: params, returnType: returnTypeIdx, bodyStart: bodyStart, bodyCount: bodyCount, isExport: isExport, line: startLine, column: startCol, hasError: fnHasError}
		program.functions.push(fn)
	end 'parseFunction'

	/// Parse a parameter
	function parseParameter() returns Parameter
		let line = currentLine()
		let col = currentColumn()

		var name = expectIdentifier()
		skipNewlines()

		let typeIdx = parseTypeRef()

		var defaultExpr = -1
		if checkTokenType(TokenType.assign) 'hasDefault'
			advance()  // consume '='
			skipNewlines()
			let expr = parseExpression()
			defaultExpr = program.addExpr(expr)
		end 'hasDefault'

		return {name: name, typeRef: typeIdx, defaultExpr: defaultExpr, line: line, column: col}
	end 'parseParameter'

	/// Parse a type reference and return its index
	function parseTypeRef() returns int
		let line = currentLine()
		let col = currentColumn()

		if checkKeyword("int") 'isInt'
			advance()
			let tr = TypeRef.createSimple(TypeKind.typeInt, line: line, column: col)
			return program.addTypeRef(tr)
		end 'isInt'
		if checkKeyword("float") 'isFloat'
			advance()
			let tr = TypeRef.createSimple(TypeKind.typeFloat, line: line, column: col)
			return program.addTypeRef(tr)
		end 'isFloat'
		if checkKeyword("bool") 'isBool'
			advance()
			let tr = TypeRef.createSimple(TypeKind.typeBool, line: line, column: col)
			return program.addTypeRef(tr)
		end 'isBool'
		if checkKeyword("byte") 'isByte'
			advance()
			let tr = TypeRef.createSimple(TypeKind.typeByte, line: line, column: col)
			return program.addTypeRef(tr)
		end 'isByte'
		if checkTokenType(TokenType.identifier) 'isNamed'
			var name = currentText()
			advance()
			let tr = TypeRef.createNamed(name, line: line, column: col)
			return program.addTypeRef(tr)
		end 'isNamed'

		error("expected type name")
		let tr = TypeRef.createSimple(TypeKind.typeUnknown, line: line, column: col)
		return program.addTypeRef(tr)
	end 'parseTypeRef'

	/// Parse a type declaration
	function parseTypeDecl(isExport bool)
		let startLine = currentLine()
		let startCol = currentColumn()

		advance()  // consume 'type'
		skipNewlines()

		var name = expectIdentifier()
		skipNewlines()

		var fields = FieldArray{}
		var methods = FunctionArray{}
		var typeHasError = false

		// Parse body until 'end'
		while not isAtEnd() and not checkKeyword("end") 'bodyLoop'
			skipNewlines()
			if isAtEnd() or checkKeyword("end") 'checkEnd'
				break 'bodyLoop'
			end 'checkEnd'

			// For now, skip type body content
			advance()
		end 'bodyLoop'

		// end 'name'
		if not checkKeyword("end") 'noEnd'
			error("expected 'end' to close type")
			typeHasError = true
		end 'noEnd' else 'hasEnd'
			advance()  // consume 'end'
			skipNewlines()
			if checkTokenType(TokenType.characterLiteral) 'hasLabel'
				advance()
			end 'hasLabel'
		end 'hasEnd'

		var td = TypeDecl{name: name, fields: fields, methods: methods, interfaces: IntArray{}, isExport: isExport, line: startLine, column: startCol, hasError: typeHasError}
		program.types.push(td)
	end 'parseTypeDecl'

	/// Parse an enum declaration
	function parseEnumDecl(isExport bool)
		let startLine = currentLine()
		let startCol = currentColumn()

		advance()  // consume 'enum'
		skipNewlines()

		var name = expectIdentifier()
		skipNewlines()

		var isError = false
		if checkKeyword("is") 'hasIs'
			advance()
			skipNewlines()
			if checkKeyword("Error") 'isError'
				isError = true
				advance()
			end 'isError'
		end 'hasIs'

		var cases = EnumCaseArray{}
		var methods = FunctionArray{}
		var enumHasError = false

		// Parse body until 'end'
		while not isAtEnd() and not checkKeyword("end") 'bodyLoop'
			skipNewlines()
			if isAtEnd() or checkKeyword("end") 'checkEnd'
				break 'bodyLoop'
			end 'checkEnd'

			// Parse enum case
			if checkTokenType(TokenType.identifier) 'isCase'
				var caseName = currentText()
				let caseLine = currentLine()
				let caseCol = currentColumn()
				advance()
				skipNewlines()

				var rawValue = 0
				var stringValue = ""
				var hasExplicitValue = false

				if checkTokenType(TokenType.assign) 'hasValue'
					advance()
					skipNewlines()
					if checkTokenType(TokenType.integerLiteral) 'isInt'
						rawValue = parseInt(currentText())
						hasExplicitValue = true
						advance()
					end 'isInt' else if checkTokenType(TokenType.stringLiteral) 'isString'
							stringValue = currentText()
							hasExplicitValue = true
							advance()
					end 'isString'
				end 'hasValue'

				let enumCase = EnumCase{name: caseName, rawValue: rawValue, stringValue: stringValue, hasExplicitValue: hasExplicitValue, line: caseLine, column: caseCol}
				cases.push(enumCase)
			end 'isCase' else 'skip'
				advance()
			end 'skip'
		end 'bodyLoop'

		// end 'name'
		if not checkKeyword("end") 'noEnd'
			error("expected 'end' to close enum")
			enumHasError = true
		end 'noEnd' else 'hasEnd'
			advance()  // consume 'end'
			skipNewlines()
			if checkTokenType(TokenType.characterLiteral) 'hasLabel'
				advance()
			end 'hasLabel'
		end 'hasEnd'

		var ed = EnumDecl{name: name, cases: cases, methods: methods, isExport: isExport, isError: isError, line: startLine, column: startCol, hasError: enumHasError}
		program.enums.push(ed)
	end 'parseEnumDecl'

	/// Parse a statement
	function parseStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		if checkKeyword("return") 'isReturn'
			return parseReturnStatement()
		end 'isReturn'

		if checkKeyword("let") 'isLet'
			return parseLetStatement()
		end 'isLet'

		if checkKeyword("var") 'isVar'
			return parseVarStatement()
		end 'isVar'

		if checkKeyword("if") 'isIf'
			return parseIfStatement()
		end 'isIf'

		if checkKeyword("while") 'isWhile'
			return parseWhileStatement()
		end 'isWhile'

		if checkKeyword("break") 'isBreak'
			advance()
			skipNewlines()
			var label = ""
			if checkTokenType(TokenType.characterLiteral) 'hasLabel'
				label = currentText()
				advance()
			end 'hasLabel'
			return Stmt.createBreak(label, line: line, column: col)
		end 'isBreak'

		if checkKeyword("continue") 'isContinue'
			advance()
			skipNewlines()
			var label = ""
			if checkTokenType(TokenType.characterLiteral) 'hasLabel'
				label = currentText()
				advance()
			end 'hasLabel'
			return Stmt.createContinue(label, line: line, column: col)
		end 'isContinue'

		// Try to parse as expression statement or assignment
		if checkTokenType(TokenType.identifier) 'isIdent'
			return parseExprOrAssignStatement()
		end 'isIdent'

		// Unknown statement - create error node
		error("expected statement")
		advance()
		var stmt = Stmt.createError(line, column: col)
		return stmt
	end 'parseStatement'

	/// Parse a return statement
	function parseReturnStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		advance()  // consume 'return'
		skipNewlines()

		// Check if there's an expression
		if checkTokenType(TokenType.newline) or checkKeyword("end") or isAtEnd() 'noExpr'
			return Stmt.createReturn(-1, line: line, column: col)
		end 'noExpr'

		let expr = parseExpression()
		let idx = program.addExpr(expr)
		skipNewlines()

		var stmt = Stmt.createReturn(idx, line: line, column: col)
		if expr.hasError 'exprError'
			stmt.hasError = true
		end 'exprError'
		return stmt
	end 'parseReturnStatement'

	/// Parse a let statement
	function parseLetStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		advance()  // consume 'let'
		skipNewlines()

		var name = expectIdentifier()
		skipNewlines()

		var typeIdx = -1
		if checkTokenType(TokenType.identifier) 'hasType'
			typeIdx = parseTypeRef()
			skipNewlines()
		end 'hasType'

		if not checkTokenType(TokenType.assign) 'noAssign'
			error("expected '=' in let statement")
			return Stmt.createError(line, column: col)
		end 'noAssign'

		advance()  // consume '='
		skipNewlines()

		let expr = parseExpression()
		let exprIdx = program.addExpr(expr)
		skipNewlines()

		var stmt = Stmt.createLet(name, typeRef: typeIdx, exprIndex: exprIdx, line: line, column: col)
		if expr.hasError 'exprError'
			stmt.hasError = true
		end 'exprError'
		return stmt
	end 'parseLetStatement'

	/// Parse a var statement
	function parseVarStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		advance()  // consume 'var'
		skipNewlines()

		var name = expectIdentifier()
		skipNewlines()

		var typeIdx = -1
		if checkTokenType(TokenType.identifier) 'hasType'
			typeIdx = parseTypeRef()
			skipNewlines()
		end 'hasType'

		if not checkTokenType(TokenType.assign) 'noAssign'
			error("expected '=' in var statement")
			return Stmt.createError(line, column: col)
		end 'noAssign'

		advance()  // consume '='
		skipNewlines()

		let expr = parseExpression()
		let exprIdx = program.addExpr(expr)
		skipNewlines()

		var stmt = Stmt.createVar(name, typeRef: typeIdx, exprIndex: exprIdx, line: line, column: col)
		if expr.hasError 'exprError'
			stmt.hasError = true
		end 'exprError'
		return stmt
	end 'parseVarStatement'

	/// Parse an if statement
	function parseIfStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		advance()  // consume 'if'
		skipNewlines()

		let condExpr = parseExpression()
		let condIdx = program.addExpr(condExpr)
		skipNewlines()

		var label = ""
		if checkTokenType(TokenType.characterLiteral) 'hasLabel'
			label = currentText()
			advance()
		end 'hasLabel'
		skipNewlines()

		// Parse then block
		let thenStart = program.statements.count()
		var thenCount = 0

		while not isAtEnd() and not checkKeyword("end") and not checkKeyword("else") 'thenLoop'
			skipNewlines()
			if isAtEnd() or checkKeyword("end") or checkKeyword("else") 'checkEnd'
				break 'thenLoop'
			end 'checkEnd'

			let stmt = parseStatement()
			program.addStmt(stmt)
			thenCount = thenCount + 1
		end 'thenLoop'

		// Parse else block if present
		var elseStart = -1
		var elseCount = 0

		if checkKeyword("else") 'hasElse'
			advance()  // consume 'else'
			skipNewlines()

			if checkTokenType(TokenType.characterLiteral) 'hasElseLabel'
				advance()
			end 'hasElseLabel'
			skipNewlines()

			elseStart = program.statements.count()

			while not isAtEnd() and not checkKeyword("end") 'elseLoop'
				skipNewlines()
				if isAtEnd() or checkKeyword("end") 'checkEnd'
					break 'elseLoop'
				end 'checkEnd'

				let stmt = parseStatement()
				program.addStmt(stmt)
				elseCount = elseCount + 1
			end 'elseLoop'
		end 'hasElse'

		// end 'label'
		if not checkKeyword("end") 'noEnd'
			error("expected 'end' to close if statement")
		end 'noEnd' else 'hasEnd'
			advance()  // consume 'end'
			skipNewlines()
			if checkTokenType(TokenType.characterLiteral) 'hasEndLabel'
				advance()
			end 'hasEndLabel'
		end 'hasEnd'

		return Stmt.createIf(condIdx, thenStart: thenStart, thenCount: thenCount, elseStart: elseStart, elseCount: elseCount, label: label, line: line, column: col)
	end 'parseIfStatement'

	/// Parse a while statement
	function parseWhileStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		advance()  // consume 'while'
		skipNewlines()

		let condExpr = parseExpression()
		let condIdx = program.addExpr(condExpr)
		skipNewlines()

		var label = ""
		if checkTokenType(TokenType.characterLiteral) 'hasLabel'
			label = currentText()
			advance()
		end 'hasLabel'
		skipNewlines()

		// Parse body
		let bodyStart = program.statements.count()
		var bodyCount = 0

		while not isAtEnd() and not checkKeyword("end") 'bodyLoop'
			skipNewlines()
			if isAtEnd() or checkKeyword("end") 'checkEnd'
				break 'bodyLoop'
			end 'checkEnd'

			let stmt = parseStatement()
			program.addStmt(stmt)
			bodyCount = bodyCount + 1
		end 'bodyLoop'

		// end 'label'
		if not checkKeyword("end") 'noEnd'
			error("expected 'end' to close while statement")
		end 'noEnd' else 'hasEnd'
			advance()  // consume 'end'
			skipNewlines()
			if checkTokenType(TokenType.characterLiteral) 'hasEndLabel'
				advance()
			end 'hasEndLabel'
		end 'hasEnd'

		return Stmt.createWhile(condIdx, bodyStart: bodyStart, bodyCount: bodyCount, label: label, line: line, column: col)
	end 'parseWhileStatement'

	/// Parse expression statement or assignment
	function parseExprOrAssignStatement() returns Stmt
		let line = currentLine()
		let col = currentColumn()

		let expr = parseExpression()

		// Check for assignment
		if checkTokenType(TokenType.assign) 'isAssign'
			if expr.kind != ExprKind.identifier 'notIdent'
				error("can only assign to identifier")
				return Stmt.createError(line, column: col)
			end 'notIdent'

			advance()  // consume '='
			skipNewlines()

			let valueExpr = parseExpression()
			let valueIdx = program.addExpr(valueExpr)
			skipNewlines()

			var stmt = Stmt.createAssign(expr.stringValue, exprIndex: valueIdx, line: line, column: col)
			if valueExpr.hasError 'exprError'
				stmt.hasError = true
			end 'exprError'
			return stmt
		end 'isAssign'

		// Expression statement
		let exprIdx = program.addExpr(expr)
		var stmt = Stmt.createExprStmt(exprIdx, line: line, column: col)
		if expr.hasError 'exprError'
			stmt.hasError = true
		end 'exprError'
		return stmt
	end 'parseExprOrAssignStatement'

	/// Parse an expression with precedence climbing
	function parseExpression() returns Expr
		return parseOrExpr()
	end 'parseExpression'

	/// Parse logical or expression
	function parseOrExpr() returns Expr
		var left = parseAndExpr()

		while checkKeyword("or") 'orLoop'
			let line = currentLine()
			let col = currentColumn()
			advance()
			skipNewlines()
			let right = parseAndExpr()

			let leftIdx = program.addExpr(left)
			let rightIdx = program.addExpr(right)
			left = Expr.createBinary(BinaryOp.logicalOr, leftIndex: leftIdx, rightIndex: rightIdx, line: line, column: col)
			if left.hasError or right.hasError 'propagate'
				left.hasError = true
			end 'propagate'
		end 'orLoop'

		return left
	end 'parseOrExpr'

	/// Parse logical and expression
	function parseAndExpr() returns Expr
		var left = parseComparisonExpr()

		while checkKeyword("and") 'andLoop'
			let line = currentLine()
			let col = currentColumn()
			advance()
			skipNewlines()
			let right = parseComparisonExpr()

			let leftIdx = program.addExpr(left)
			let rightIdx = program.addExpr(right)
			left = Expr.createBinary(BinaryOp.logicalAnd, leftIndex: leftIdx, rightIndex: rightIdx, line: line, column: col)
			if left.hasError or right.hasError 'propagate'
				left.hasError = true
			end 'propagate'
		end 'andLoop'

		return left
	end 'parseAndExpr'

	/// Parse comparison expression
	function parseComparisonExpr() returns Expr
		var left = parseAdditiveExpr()

		while isComparisonOp() 'cmpLoop'
			let line = currentLine()
			let col = currentColumn()
			let op = getComparisonOp()
			advance()
			skipNewlines()
			let right = parseAdditiveExpr()

			let leftIdx = program.addExpr(left)
			let rightIdx = program.addExpr(right)
			left = Expr.createBinary(op, leftIndex: leftIdx, rightIndex: rightIdx, line: line, column: col)
			if left.hasError or right.hasError 'propagate'
				left.hasError = true
			end 'propagate'
		end 'cmpLoop'

		return left
	end 'parseComparisonExpr'

	function isComparisonOp() returns bool
		return checkTokenType(TokenType.equalEqual) or checkTokenType(TokenType.notEqual) or checkTokenType(TokenType.less) or checkTokenType(TokenType.lessEqual) or checkTokenType(TokenType.greater) or checkTokenType(TokenType.greaterEqual)
	end 'isComparisonOp'

	function getComparisonOp() returns BinaryOp
		if checkTokenType(TokenType.equalEqual) 'eq'
			return BinaryOp.equal
		end 'eq'
		if checkTokenType(TokenType.notEqual) 'ne'
			return BinaryOp.notEqual
		end 'ne'
		if checkTokenType(TokenType.less) 'lt'
			return BinaryOp.less
		end 'lt'
		if checkTokenType(TokenType.lessEqual) 'le'
			return BinaryOp.lessEqual
		end 'le'
		if checkTokenType(TokenType.greater) 'gt'
			return BinaryOp.greater
		end 'gt'
		return BinaryOp.greaterEqual
	end 'getComparisonOp'

	/// Parse additive expression
	function parseAdditiveExpr() returns Expr
		var left = parseMultiplicativeExpr()

		while checkTokenType(TokenType.plus) or checkTokenType(TokenType.minus) 'addLoop'
			let line = currentLine()
			let col = currentColumn()
			var op = BinaryOp.add
			if checkTokenType(TokenType.minus) 'isSub'
				op = BinaryOp.subtract
			end 'isSub'
			advance()
			skipNewlines()
			let right = parseMultiplicativeExpr()

			let leftIdx = program.addExpr(left)
			let rightIdx = program.addExpr(right)
			left = Expr.createBinary(op, leftIndex: leftIdx, rightIndex: rightIdx, line: line, column: col)
			if left.hasError or right.hasError 'propagate'
				left.hasError = true
			end 'propagate'
		end 'addLoop'

		return left
	end 'parseAdditiveExpr'

	/// Parse multiplicative expression
	function parseMultiplicativeExpr() returns Expr
		var left = parseUnaryExpr()

		while checkTokenType(TokenType.star) or checkTokenType(TokenType.slash) or checkKeyword("mod") 'mulLoop'
			let line = currentLine()
			let col = currentColumn()
			var op = BinaryOp.multiply
			if checkTokenType(TokenType.slash) 'isDiv'
				op = BinaryOp.divide
			end 'isDiv' else if checkKeyword("mod") 'isMod'
					op = BinaryOp.modulo
			end 'isMod'
			advance()
			skipNewlines()
			let right = parseUnaryExpr()

			let leftIdx = program.addExpr(left)
			let rightIdx = program.addExpr(right)
			left = Expr.createBinary(op, leftIndex: leftIdx, rightIndex: rightIdx, line: line, column: col)
			if left.hasError or right.hasError 'propagate'
				left.hasError = true
			end 'propagate'
		end 'mulLoop'

		return left
	end 'parseMultiplicativeExpr'

	/// Parse unary expression
	function parseUnaryExpr() returns Expr
		if checkTokenType(TokenType.minus) 'isNeg'
			let line = currentLine()
			let col = currentColumn()
			advance()
			skipNewlines()
			let operand = parseUnaryExpr()
			let operandIdx = program.addExpr(operand)
			var expr = Expr.createUnary(UnaryOp.negate, operandIndex: operandIdx, line: line, column: col)
			if operand.hasError 'propagate'
				expr.hasError = true
			end 'propagate'
			return expr
		end 'isNeg'

		if checkKeyword("not") 'isNot'
			let line = currentLine()
			let col = currentColumn()
			advance()
			skipNewlines()
			let operand = parseUnaryExpr()
			let operandIdx = program.addExpr(operand)
			var expr = Expr.createUnary(UnaryOp.logicalNot, operandIndex: operandIdx, line: line, column: col)
			if operand.hasError 'propagate'
				expr.hasError = true
			end 'propagate'
			return expr
		end 'isNot'

		return parsePostfixExpr()
	end 'parseUnaryExpr'

	/// Parse postfix expression (calls, field access)
	function parsePostfixExpr() returns Expr
		var left = parsePrimaryExpr()

		while true 'postfixLoop'
			if checkTokenType(TokenType.lparen) 'isCall'
				let line = currentLine()
				let col = currentColumn()
				advance()  // consume '('
				skipNewlines()

				// Parse arguments
				let argsStart = program.expressions.count()
				var argsCount = 0

				while not isAtEnd() and not checkTokenType(TokenType.rparen) 'argsLoop'
					let arg = parseExpression()
					program.addExpr(arg)
					argsCount = argsCount + 1
					skipNewlines()

					if checkTokenType(TokenType.comma) 'hasComma'
						advance()
						skipNewlines()
					end 'hasComma' else 'noComma'
						break 'argsLoop'
					end 'noComma'
				end 'argsLoop'

				if not checkTokenType(TokenType.rparen) 'noClose'
					error("expected ')' after arguments")
				end 'noClose' else 'hasClose'
					advance()
				end 'hasClose'

				let leftIdx = program.addExpr(left)
				left = Expr.createCall(leftIdx, argsStart: argsStart, argsCount: argsCount, line: line, column: col)
			end 'isCall' else if checkTokenType(TokenType.dot) 'isField'
					let line = currentLine()
					let col = currentColumn()
					advance()  // consume '.'
					skipNewlines()

					if not checkTokenType(TokenType.identifier) 'noField'
						error("expected field name after '.'")
						return Expr.createError(line, column: col)
					end 'noField'

					var fieldName = currentText()
					advance()

					let leftIdx = program.addExpr(left)
					left = Expr.createFieldAccess(leftIdx, fieldName: fieldName, line: line, column: col)
			end 'isField' else 'done'
				break 'postfixLoop'
			end 'done'
		end 'postfixLoop'

		return left
	end 'parsePostfixExpr'

	/// Parse primary expression
	function parsePrimaryExpr() returns Expr
		let line = currentLine()
		let col = currentColumn()

		if checkTokenType(TokenType.integerLiteral) 'isInt'
			let text = currentText()
			advance()
			let value = parseInt(text)
			return Expr.createIntLiteral(value, line: line, column: col)
		end 'isInt'

		if checkTokenType(TokenType.floatLiteral) 'isFloat'
			let text = currentText()
			advance()
			let value = parseFloat(text)
			return Expr.createFloatLiteral(value, line: line, column: col)
		end 'isFloat'

		if checkKeyword("true") 'isTrue'
			advance()
			return Expr.createBoolLiteral(true, line: line, column: col)
		end 'isTrue'

		if checkKeyword("false") 'isFalse'
			advance()
			return Expr.createBoolLiteral(false, line: line, column: col)
		end 'isFalse'

		if checkTokenType(TokenType.stringLiteral) 'isString'
			let text = currentText()
			advance()
			return Expr.createStringLiteral(text, line: line, column: col)
		end 'isString'

		if checkTokenType(TokenType.identifier) 'isIdent'
			let text = currentText()
			advance()
			return Expr.createIdentifier(text, line: line, column: col)
		end 'isIdent'

		if checkTokenType(TokenType.lparen) 'isParen'
			advance()  // consume '('
			skipNewlines()
			let expr = parseExpression()
			skipNewlines()
			if not checkTokenType(TokenType.rparen) 'noClose'
				error("expected ')' after expression")
			end 'noClose' else 'hasClose'
				advance()
			end 'hasClose'
			return expr
		end 'isParen'

		error("expected expression")
		return Expr.createError(line, column: col)
	end 'parsePrimaryExpr'

	/// Parse an integer from string
	function parseInt(text String) returns int
		var result = 0
		for c in text 'digits'
			let ascii = try c.asciiValue() otherwise 0
			let digit = ascii - 48  // '0' = 48
			result = result * 10 + digit
		end 'digits'
		return result
	end 'parseInt'

	/// Parse a float from string
	function parseFloat(text String) returns float
		// Simple float parsing - integer part . fractional part
		var intPart = 0
		var fracPart = 0.0
		var fracDiv = 1.0
		var pastDot = false

		for c in text 'chars'
			if c == '.' 'isDot'
				pastDot = true
			end 'isDot' else 'notDot'
				let ascii = try c.asciiValue() otherwise 0
				let digit = ascii - 48
				if pastDot 'afterDot'
					fracDiv = fracDiv * 10.0
					fracPart = fracPart + (digit as float) / fracDiv
				end 'afterDot' else 'beforeDot'
					intPart = intPart * 10 + digit
				end 'beforeDot'
			end 'notDot'
		end 'chars'

		return (intPart as float) + fracPart
	end 'parseFloat'

	/// Expect an identifier and return its text
	function expectIdentifier() returns String
		if checkTokenType(TokenType.identifier) 'isIdent'
			let text = currentText()
			advance()
			return text
		end 'isIdent'
		error("expected identifier")
		return ""
	end 'expectIdentifier'

	// ========================================================================
	// Helper methods
	// ========================================================================

	function isAtEnd() returns bool
		if pos >= tokens.count() 'pastEnd'
			return true
		end 'pastEnd'
		// Also consider EOF token as end of input
		// Note: We can't call currentToken() here because it would create infinite recursion
		let tok = try tokens.get(pos) otherwise Token.create(TokenType.eof, text: "", line: 0, column: 0)
		return tok.tokenType == TokenType.eof
	end 'isAtEnd'

	function advance()
		if not isAtEnd() 'check'
			pos = pos + 1
		end 'check'
	end 'advance'
	function skipNewlines()
		while not isAtEnd() and checkTokenType(TokenType.newline) 'skipLoop'
			advance()
		end 'skipLoop'
	end 'skipNewlines'

	function currentToken() returns Token
		if pos >= tokens.count() 'atEnd'
			return Token.create(TokenType.eof, text: "", line: 0, column: 0)
		end 'atEnd'
		return try tokens.get(pos) otherwise Token.create(TokenType.eof, text: "", line: 0, column: 0)
	end 'currentToken'

	function currentText() returns String
		return currentToken().text
	end 'currentText'

	function currentLine() returns int
		return currentToken().line
	end 'currentLine'

	function currentColumn() returns int
		return currentToken().column
	end 'currentColumn'

	function checkTokenType(expected TokenType) returns bool
		if isAtEnd() 'atEnd'
			return false
		end 'atEnd'
		return currentToken().tokenType == expected
	end 'checkTokenType'

	function checkKeyword(keyword String) returns bool
		if isAtEnd() 'atEnd'
			return false
		end 'atEnd'
		let tok = currentToken()
		return tok.text == keyword
	end 'checkKeyword'

	function error(message String)
		// Don't report errors while in panic mode
		if panicMode 'inPanic'
			return
		end 'inPanic'

		let line = currentLine()
		let col = currentColumn()
		errors.addErrorAt(ErrorCode.E2001, message: message, file: sourceFile, line: line, column: col)
		program.hasError = true
	end 'error'
end 'Parser'

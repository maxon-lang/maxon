// PE Writer for Windows x86-64 executables

export typealias ByteArray is Array with byte

export type CodeBuffer
	export var bytes ByteArray

	export static function create() returns CodeBuffer
		var b = ByteArray{}
		return {bytes: b}
	end 'create'

	export function emitByte(b byte)
		bytes.push(b)
	end 'emitByte'

	export function emitBytes(b ByteArray)
		bytes.append(b)
	end 'emitBytes'

	export function emitWord(value int)
		emitByte((value & 0xFF) as byte)
		emitByte(((value >> 8) & 0xFF) as byte)
	end 'emitWord'

	export function emitDword(value int)
		emitByte((value & 0xFF) as byte)
		emitByte(((value >> 8) & 0xFF) as byte)
		emitByte(((value >> 16) & 0xFF) as byte)
		emitByte(((value >> 24) & 0xFF) as byte)
	end 'emitDword'

	export function emitQword(value int)
		emitDword(value & 0xFFFFFFFF)
		emitDword((value >> 32) & 0xFFFFFFFF)
	end 'emitQword'

	export function align(alignment int)
		while (bytes.count() mod alignment) != 0 'pad'
			emitByte(0 as byte)
		end 'pad'
	end 'align'

	export function size() returns int
		return bytes.count()
	end 'size'
end 'CodeBuffer'

export type CompleteExeBuilder
	var buffer CodeBuffer

	export static function create() returns CompleteExeBuilder
		return {buffer: CodeBuffer.create()}
	end 'create'

	export function buildBasicExe()
		print("    buildBasicExe start\n")
		// Constants matching the Zig PE writer
		let FILE_ALIGNMENT = 512        // 0x200
		let SECTION_ALIGNMENT = 4096    // 0x1000
		let IMAGE_BASE = 0x140000000
		print("    constants set\n")

		// Calculate sizes - matching Zig layout
		let dosHeaderSize = 64
		print("    dosHeaderSize set\n")
		let peHeaderOffset = dosHeaderSize  // 64
		print("    peHeaderOffset set\n")
		let coffHeaderSize = 20
		let optionalHeaderSize = 240        // PE32+ with 16 data directories
		let sectionHeaderSize = 40
		let numSections = 2
		print("    sizes set\n")

		let headersSize = peHeaderOffset + 4 + coffHeaderSize + optionalHeaderSize + (sectionHeaderSize * numSections)
		print("    headersSize calculated\n")
		// headersSize = 64 + 4 + 20 + 240 + 80 = 408
		let headersAligned = alignUp(headersSize, FILE_ALIGNMENT)  // 512

		let textFileOffset = headersAligned  // 512
		let textRVA = SECTION_ALIGNMENT      // 4096
		let codeSize = 13  // mov ecx,42 + sub rsp,40 + call [rip+disp]
		let textRawSize = alignUp(codeSize, FILE_ALIGNMENT)  // 512
		let textVirtualSize = codeSize

		let idataFileOffset = textFileOffset + textRawSize  // 1024
		let idataRVA = textRVA + alignUp(textRawSize, SECTION_ALIGNMENT)  // 8192

		// .idata layout: IDT (40) + IAT (16) + INT (16) + strings (~30)
		let idtSize = 40          // 2 entries x 20 bytes (1 real + 1 null)
		let iatOffset = idtSize   // 40
		let iatSize = 16          // 2 entries x 8 bytes (1 func + 1 null)
		let intOffset = iatOffset + iatSize  // 56
		let intSize = 16
		let stringsOffset = intOffset + intSize  // 72

		// String layout: "kernel32.dll\0" (13) + align + hint(2) + "ExitProcess\0" (12)
		let dllNameOffset = stringsOffset      // 72
		let hintNameOffset = dllNameOffset + 14  // 86, aligned to 2
		let idataVirtualSize = hintNameOffset + 14  // ~100
		let idataRawSize = alignUp(idataVirtualSize, FILE_ALIGNMENT)  // 512

		let imageSize = alignUp(idataRVA + idataRawSize, SECTION_ALIGNMENT)  // 12288

		// --- DOS Header (64 bytes) ---
		buffer.emitWord(0x5A4D)   // MZ signature
		buffer.emitWord(0x0090)
		buffer.emitWord(0x0003)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x0004)
		buffer.emitWord(0x0000)
		buffer.emitWord(0xFFFF)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x00B8)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x0040)
		buffer.emitWord(0x0000)
		// Reserved (8 bytes)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitWord(0x0000)
		buffer.emitWord(0x0000)
		// Reserved (20 bytes)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(peHeaderOffset)  // e_lfanew = 64

		// --- PE Signature (4 bytes) ---
		buffer.emitDword(0x00004550)  // "PE\0\0"

		// --- COFF Header (20 bytes) ---
		buffer.emitWord(0x8664)      // Machine: AMD64
		buffer.emitWord(numSections) // NumberOfSections
		buffer.emitDword(0)          // TimeDateStamp
		buffer.emitDword(0)          // PointerToSymbolTable
		buffer.emitDword(0)          // NumberOfSymbols
		buffer.emitWord(optionalHeaderSize)  // SizeOfOptionalHeader (240)
		buffer.emitWord(0x0022)      // Characteristics: EXECUTABLE_IMAGE | LARGE_ADDRESS_AWARE

		// --- Optional Header PE32+ (240 bytes) ---
		buffer.emitWord(0x020B)      // Magic: PE32+
		buffer.emitByte(14 as byte)  // MajorLinkerVersion
		buffer.emitByte(0 as byte)   // MinorLinkerVersion
		buffer.emitDword(textRawSize)   // SizeOfCode
		buffer.emitDword(idataRawSize)  // SizeOfInitializedData
		buffer.emitDword(0)             // SizeOfUninitializedData
		buffer.emitDword(textRVA)       // AddressOfEntryPoint
		buffer.emitDword(textRVA)       // BaseOfCode
		buffer.emitQword(IMAGE_BASE)    // ImageBase
		buffer.emitDword(SECTION_ALIGNMENT)  // SectionAlignment
		buffer.emitDword(FILE_ALIGNMENT)     // FileAlignment
		buffer.emitWord(6)           // MajorOperatingSystemVersion
		buffer.emitWord(0)           // MinorOperatingSystemVersion
		buffer.emitWord(0)           // MajorImageVersion
		buffer.emitWord(0)           // MinorImageVersion
		buffer.emitWord(6)           // MajorSubsystemVersion
		buffer.emitWord(0)           // MinorSubsystemVersion
		buffer.emitDword(0)          // Win32VersionValue
		buffer.emitDword(imageSize)  // SizeOfImage
		buffer.emitDword(headersAligned)  // SizeOfHeaders
		buffer.emitDword(0)          // CheckSum
		buffer.emitWord(3)           // Subsystem: CONSOLE
		buffer.emitWord(0x8140)      // DllCharacteristics: DYNAMIC_BASE | NX_COMPAT | TERMINAL_SERVER_AWARE
		buffer.emitQword(0x100000)   // SizeOfStackReserve
		buffer.emitQword(0x1000)     // SizeOfStackCommit
		buffer.emitQword(0x100000)   // SizeOfHeapReserve
		buffer.emitQword(0x1000)     // SizeOfHeapCommit
		buffer.emitDword(0)          // LoaderFlags
		buffer.emitDword(16)         // NumberOfRvaAndSizes

		// --- Data Directories (16 entries x 8 bytes = 128 bytes) ---
		buffer.emitQword(0)                    // 0: Export
		buffer.emitDword(idataRVA)             // 1: Import RVA
		buffer.emitDword(idtSize)              // 1: Import Size
		buffer.emitQword(0)                    // 2: Resource
		buffer.emitQword(0)                    // 3: Exception
		buffer.emitQword(0)                    // 4: Certificate
		buffer.emitQword(0)                    // 5: Base Relocation
		buffer.emitQword(0)                    // 6: Debug
		buffer.emitQword(0)                    // 7: Architecture
		buffer.emitQword(0)                    // 8: Global Ptr
		buffer.emitQword(0)                    // 9: TLS
		buffer.emitQword(0)                    // 10: Load Config
		buffer.emitQword(0)                    // 11: Bound Import
		buffer.emitDword(idataRVA + iatOffset) // 12: IAT RVA
		buffer.emitDword(iatSize)              // 12: IAT Size
		buffer.emitQword(0)                    // 13: Delay Import
		buffer.emitQword(0)                    // 14: CLR
		buffer.emitQword(0)                    // 15: Reserved

		// --- Section Headers ---
		// .text section header
		writeSectionName(".text")
		buffer.emitDword(textVirtualSize)    // VirtualSize
		buffer.emitDword(textRVA)            // VirtualAddress
		buffer.emitDword(textRawSize)        // SizeOfRawData
		buffer.emitDword(textFileOffset)     // PointerToRawData
		buffer.emitDword(0)                  // PointerToRelocations
		buffer.emitDword(0)                  // PointerToLinenumbers
		buffer.emitWord(0)                   // NumberOfRelocations
		buffer.emitWord(0)                   // NumberOfLinenumbers
		buffer.emitDword(0xE0000020)         // Characteristics: CODE | EXECUTE | READ | WRITE

		// .idata section header
		writeSectionName(".idata")
		buffer.emitDword(idataVirtualSize)   // VirtualSize
		buffer.emitDword(idataRVA)           // VirtualAddress
		buffer.emitDword(idataRawSize)       // SizeOfRawData
		buffer.emitDword(idataFileOffset)    // PointerToRawData
		buffer.emitDword(0)                  // PointerToRelocations
		buffer.emitDword(0)                  // PointerToLinenumbers
		buffer.emitWord(0)                   // NumberOfRelocations
		buffer.emitWord(0)                   // NumberOfLinenumbers
		buffer.emitDword(0x40000040)         // Characteristics: INITIALIZED_DATA | READ

		// Pad headers to aligned size
		while buffer.size() < headersAligned 'padHeaders'
			buffer.emitByte(0 as byte)
		end 'padHeaders'

		// --- .text Section (Code) ---
		// IAT entry is at idataRVA + iatOffset = 8192 + 40 = 8232 = 0x2028
		let exitProcessIAT = idataRVA + iatOffset

		// mov ecx, 42 (5 bytes)
		buffer.emitByte(0xB9 as byte)
		buffer.emitDword(42)

		// sub rsp, 40 (4 bytes)
		buffer.emitByte(0x48 as byte)
		buffer.emitByte(0x83 as byte)
		buffer.emitByte(0xEC as byte)
		buffer.emitByte(0x28 as byte)

		// call qword ptr [rip + offset] (6 bytes)
		// After this instruction, RIP = textRVA + 15 = 4096 + 15 = 4111
		// But wait, the call is at offset 9, so RIP after = textRVA + 9 + 6 = 4111
		// Actually: mov(5) + sub(4) + FF15(2) = 11 bytes before disp
		// RIP after call instruction = textRVA + 11 + 4 = textRVA + 15
		buffer.emitByte(0xFF as byte)
		buffer.emitByte(0x15 as byte)
		let ripAfterCall = textRVA + 15
		let relOffset = exitProcessIAT - ripAfterCall
		buffer.emitDword(relOffset)

		// Pad .text section
		while buffer.size() < idataFileOffset 'padText'
			buffer.emitByte(0x90 as byte)
		end 'padText'

		// --- .idata Section (Imports) ---
		// Import Directory Table (IDT) - 2 entries (1 real + 1 null terminator)
		// Entry for kernel32.dll
		buffer.emitDword(idataRVA + intOffset)        // OriginalFirstThunk (INT)
		buffer.emitDword(0)                            // TimeDateStamp
		buffer.emitDword(0)                            // ForwarderChain
		buffer.emitDword(idataRVA + dllNameOffset)    // Name RVA
		buffer.emitDword(idataRVA + iatOffset)        // FirstThunk (IAT)

		// Null terminator entry
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)
		buffer.emitDword(0)

		// IAT - Import Address Table (at offset 40)
		buffer.emitQword(idataRVA + hintNameOffset)  // Points to hint/name for ExitProcess
		buffer.emitQword(0)                           // Null terminator

		// INT - Import Name Table (at offset 56)
		buffer.emitQword(idataRVA + hintNameOffset)  // Same as IAT before loading
		buffer.emitQword(0)                           // Null terminator

		// String table (at offset 72)
		// DLL name: "kernel32.dll\0"
		writeString("kernel32.dll")

		// Pad to align hint/name to 2 bytes if needed
		while (buffer.size() - idataFileOffset) < hintNameOffset 'padToHint'
			buffer.emitByte(0 as byte)
		end 'padToHint'

		// Hint/Name entry: hint (2 bytes) + "ExitProcess\0"
		buffer.emitWord(0)  // Hint
		writeString("ExitProcess")

		// Pad .idata section to raw size
		while buffer.size() < (idataFileOffset + idataRawSize) 'padIdata'
			buffer.emitByte(0 as byte)
		end 'padIdata'
	end 'buildBasicExe'

	function alignUp(value int, alignment int) returns int
		let added = value + alignment - 1
		let mask = 0 - alignment
		let result = added & mask
		return result
	end 'alignUp'

	export function writeSectionName(name String)
		// Section names are exactly 8 bytes, padded with nulls
		var i = 0
		for b in name.bytes() 'writeBytes'
			if i >= 8 'done'
				break 'writeBytes'
			end 'done'
			buffer.emitByte(b)
			i = i + 1
		end 'writeBytes'
		while i < 8 'pad'
			buffer.emitByte(0 as byte)
			i = i + 1
		end 'pad'
	end 'writeSectionName'

	export function writeString(s String)
		for b in s.bytes() 'writeBytes'
			buffer.emitByte(b)
		end 'writeBytes'
		buffer.emitByte(0 as byte)
	end 'writeString'

	export function getBytes() returns ByteArray
		return buffer.bytes
	end 'getBytes'

	export function size() returns int
		return buffer.bytes.count()
	end 'size'
end 'CompleteExeBuilder'

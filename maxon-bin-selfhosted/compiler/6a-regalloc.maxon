// Maxon Compiler - Register Allocator (Stage 6a)
// Linear scan register allocation for LIR

import X86Reg, x86ArgReg, x86IsCalleeSaved from "6b-x86.maxon"
import LirFunction, LirBlock, LirInstruction, LirOperand, LirOperandKind from "5-lir.maxon"

// ============================================================================
// Live Range Tracking
// ============================================================================

/// Represents the live range of a virtual register
export type LiveRange
export var vreg int      // virtual register number
export var start int     // first instruction using this vreg
export var end_ int      // last instruction using this vreg
export var reg X86Reg?   // assigned physical register (null if spilled)
export var spillSlot int // stack slot if spilled (-1 if not)

export static function create(vreg int, start int) returns LiveRange
return {vreg: vreg, start: start, end_: start, reg: null, spillSlot: -1}
end 'create'

/// Extend the range to include position
export function extendTo(pos int)
if pos > end_ 'extend'
end_ = pos
end 'extend'
end 'extendTo'

/// Check if ranges overlap
export function overlaps(other LiveRange) returns bool
return start <= other.end_ and end_ >= other.start
end 'overlaps'
end 'LiveRange'

export typealias LiveRangeArray is Array with LiveRange

// ============================================================================
// Register Allocator
// ============================================================================

/// Available registers for allocation (excluding RSP, RBP)
let allocatableRegs = [
X86Reg.rax,
X86Reg.rcx,
X86Reg.rdx,
X86Reg.rbx,
X86Reg.rsi,
X86Reg.rdi,
X86Reg.r8,
X86Reg.r9,
X86Reg.r10,
X86Reg.r11,
X86Reg.r12,
X86Reg.r13,
X86Reg.r14,
X86Reg.r15
]

/// Linear scan register allocator
export type RegAllocator
var func LirFunction ref
var ranges LiveRangeArray
var active LiveRangeArray        // currently active ranges
var nextSpillSlot int
var usedCalleeSaved Set          // track which callee-saved regs we use

export static function create(func LirFunction ref) returns RegAllocator
return {
func: func,
ranges: LiveRangeArray{},
active: LiveRangeArray{},
nextSpillSlot: 0,
usedCalleeSaved: Set{}
}
end 'create'

/// Run register allocation on the function
export function allocate()
// Step 1: Compute live ranges
computeLiveRanges()

// Step 2: Sort ranges by start position
sortRangesByStart()

// Step 3: Linear scan allocation
linearScan()

// Step 4: Rewrite function with allocated registers
rewriteFunction()

// Step 5: Set stack size
func.stackSize = nextSpillSlot * 8
end 'allocate'

/// Compute live ranges for all virtual registers
function computeLiveRanges()
var pos = 0
var rangeMap Map  // vreg -> range index

for block in func.blocks 'blocks'
for instr in block.instructions 'instrs'
// Check destination
if instr.dst != null 'hasDst'
let dst = instr.dst!
if dst.kind == LirOperandKind.vreg 'isVreg'
let vreg = dst.value
if not rangeMap.has(vreg.toString()) 'newRange'
let range = LiveRange.create(vreg, pos)
rangeMap.set(vreg.toString(), ranges.count())
ranges.push(range)
end 'newRange'
end 'isVreg'
end 'hasDst'

// Check sources - extend range
if instr.src1 != null 'hasSrc1'
extendRange(rangeMap, instr.src1!, pos)
end 'hasSrc1'
if instr.src2 != null 'hasSrc2'
extendRange(rangeMap, instr.src2!, pos)
end 'hasSrc2'

pos = pos + 1
end 'instrs'
end 'blocks'
end 'computeLiveRanges'

/// Extend range for an operand
function extendRange(rangeMap Map ref, op LirOperand, pos int)
if op.kind == LirOperandKind.vreg 'isVreg'
let key = op.value.toString()
if rangeMap.has(key) 'hasRange'
let idx = rangeMap.get(key)!.toInt()!
ranges[idx].extendTo(pos)
end 'hasRange'
end 'isVreg'
end 'extendRange'

/// Sort ranges by start position (simple bubble sort)
function sortRangesByStart()
for i in 0..ranges.count() 'outer'
for j in 0..(ranges.count() - i - 1) 'inner'
if ranges[j].start > ranges[j + 1].start 'swap'
let tmp = ranges[j]
ranges[j] = ranges[j + 1]
ranges[j + 1] = tmp
end 'swap'
end 'inner'
end 'outer'
end 'sortRangesByStart'

/// Linear scan register allocation
function linearScan()
for i in 0..ranges.count() 'eachRange'
let range = ranges[i] ref

// Expire old intervals
expireOldIntervals(range.start)

// Try to allocate a register
let reg = findFreeRegister(range)
if reg != null 'gotReg'
range.reg = reg
active.push(range)
if x86IsCalleeSaved(reg!) 'calleeSaved'
usedCalleeSaved.add(reg!.toString())
end 'calleeSaved'
end 'gotReg' else 'spill'
// Need to spill
spillAtInterval(range)
end 'spill'
end 'eachRange'
end 'linearScan'

/// Remove intervals that end before pos
function expireOldIntervals(pos int)
var newActive = LiveRangeArray{}
for a in active 'each'
if a.end_ >= pos 'stillActive'
newActive.push(a)
end 'stillActive'
end 'each'
active = newActive
end 'expireOldIntervals'

/// Find a free register not used by active intervals
function findFreeRegister(range LiveRange) returns X86Reg?
for reg in allocatableRegs 'eachReg'
var used = false
for a in active 'checkActive'
if a.reg != null and a.reg! == reg 'inUse'
used = true
end 'inUse'
end 'checkActive'
if not used 'free'
return reg
end 'free'
end 'eachReg'
return null
end 'findFreeRegister'

/// Spill at interval - either spill this or an active range
function spillAtInterval(range LiveRange ref)
// Simple: always spill the current interval
range.spillSlot = nextSpillSlot
nextSpillSlot = nextSpillSlot + 1
end 'spillAtInterval'

/// Rewrite function with allocated registers
function rewriteFunction()
for block in func.blocks 'blocks'
for instr in block.instructions 'instrs'
if instr.dst != null 'hasDst'
instr.dst = rewriteOperand(instr.dst!)
end 'hasDst'
if instr.src1 != null 'hasSrc1'
instr.src1 = rewriteOperand(instr.src1!)
end 'hasSrc1'
if instr.src2 != null 'hasSrc2'
instr.src2 = rewriteOperand(instr.src2!)
end 'hasSrc2'
end 'instrs'
end 'blocks'
end 'rewriteFunction'

/// Rewrite a single operand
function rewriteOperand(op LirOperand) returns LirOperand?
if op.kind != LirOperandKind.vreg 'notVreg'
return op
end 'notVreg'

let vreg = op.value

// Find the range for this vreg
for range in ranges 'findRange'
if range.vreg == vreg 'found'
if range.reg != null 'hasReg'
// Rewrite to physical register
return LirOperand.reg(range.reg!)
end 'hasReg' else 'spilled'
// Rewrite to stack slot
return LirOperand.stack(range.spillSlot)
end 'spilled'
end 'found'
end 'findRange'

return op
end 'rewriteOperand'

/// Get set of callee-saved registers used
export function getUsedCalleeSaved() returns Set
return usedCalleeSaved
end 'getUsedCalleeSaved'
end 'RegAllocator'

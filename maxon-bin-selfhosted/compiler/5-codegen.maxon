// MIR Code generator for the Maxon compiler

export type CodeGen
	var output string
	var tempCounter int
	var localVars map from string to string

	export function create() returns CodeGen
		return CodeGen{output: "", tempCounter: 0, localVars: map from string to string}
	end 'create'

	export function newTemp() returns string
		var temp = "%t"
		tempCounter = tempCounter + 1
		return temp
	end 'newTemp'

	export function emit(code string) returns nothing
		output = output + code + "\n"
	end 'emit'

	export function generate(program Program) returns nothing
		emit("; Maxon IR generated by self-hosted compiler")
		emit("; Source: " + program.fileName)
		emit("")

		var i = 0
		while i < program.functions.count() 'funcs'
			genFunction(program.functions[i])
			i = i + 1
		end 'funcs'
	end 'generate'

	export function genFunction(fn FunctionDecl) returns nothing
		localVars = map from string to string
		tempCounter = 0

		var returnTypeStr = "i32"
		if fn.returnType.kind == TypeKind.voidType 'void'
			returnTypeStr = "void"
		end 'void'

		emit("define " + returnTypeStr + " @" + fn.name + "() {")
		emit("entry:")

		var i = 0
		while i < fn.body.count() 'body'
			genStmt(fn.body[i])
			i = i + 1
		end 'body'

		emit("}")
		emit("")
	end 'genFunction'

	export function genStmt(stmt Stmt) returns nothing
		if stmt.kind == StmtKind.returnStmt 'return'
			if stmt.hasValue 'hasValue'
				var temp = genExpr(stmt.expr)
				emit("    ret i32 " + temp)
			end 'hasValue' else 'noValue'
				emit("    ret void")
			end 'noValue'
		end 'return'

		if stmt.kind == StmtKind.letStmt 'let'
			var valueTemp = genExpr(stmt.expr)
			var varTemp = newTemp()
			emit("    " + varTemp + " = copy i32 " + valueTemp)
			localVars.insert(stmt.name, varTemp)
		end 'let'
	end 'genStmt'

	export function genExpr(expr Expr) returns string
		if expr.kind == ExprKind.intLiteral 'int'
			return formatInt(expr.intValue)
		end 'int'

		if expr.kind == ExprKind.varRef 'var'
			return localVars.get(expr.name)
		end 'var'

		return "0"
	end 'genExpr'
end 'CodeGen'

function formatInt(value int) returns string
	if value == 0 'zero'
		return "0"
	end 'zero'

	var result = ""
	var n = value
	if n < 0 'neg'
		result = "-"
		n = 0 - n
	end 'neg'

	var digits = ""
	while n > 0 'digitLoop'
		var digit = n mod 10
		var digitChar = match digit 'toChar'
		0 gives '0'
		1 gives '1'
		2 gives '2'
		3 gives '3'
		4 gives '4'
		5 gives '5'
		6 gives '6'
		7 gives '7'
		8 gives '8'
		default gives '9'
	end 'toChar'
	digits = digitChar.toString() + digits
	n = n / 10
end 'digitLoop'

return result + digits
end 'formatInt'


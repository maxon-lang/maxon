// Maxon Compiler - Main entry point
// Orchestrates all compilation phases

/// Compile a Maxon source file
/// Returns 0 on success, non-zero on error
export function compile(sourceFile String, emitIr bool, logConfig LogConfig) returns int
	let outputFile = sourceFile.replace(".maxon", ".exe")
	let logLevel = logConfig.globalLevel

	print("Compiling: {sourceFile} -> {outputFile}\n")
	if emitIr 'showIr'
		print("  (emit IR: enabled)\n")
	end 'showIr'
	if logLevel > 0 'showLog'
		print("  (log level: {logLevel})\n")
	end 'showLog'

	// Create shared error collector
	var errors = ErrorCollector.create()

	// Read source file
	let source = try File.readText(sourceFile) otherwise 'noSource'
		print("Error: Could not read source file: {sourceFile}\n")
		return 1
	end 'noSource'

	// Phase 1: Lexical Analysis
	var lexer = Lexer.init(source, sourceFile: sourceFile, errors: errors)
	let tokens = lexer.tokenize()
	print("  Lexed {tokens.count()} tokens\n")

	// Check for lexer errors
	if errors.hasAnyErrors() 'lexerErrors'
		print("\nLexer errors:\n")
		errors.printAll()
		return 1
	end 'lexerErrors'

	// Phase 2-7: Not yet implemented
	print("  [Stages 2-7 not yet implemented]\n")

	return 0
end 'compile'

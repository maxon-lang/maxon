// Maxon Compiler
// A simple compiler for the Maxon language, written in Maxon
// Compiles Maxon source code all the way to a Windows PE executable

// NOTE: This is an idealized version of a self-hosted compiler.
// It assumes several features that don't yet exist in Maxon:
// - File I/O (readFile, writeFile, writeFileBytes)
// - Command-line argument parsing (args array of string)
// - String concatenation with +
// - Method chaining
// - Dynamic arrays with append()
// - parseInt/parseFloat functions
// - Byte arrays and bitwise operations
// These are written as they would ideally work.

export function compile(sourceFile string) int
    let outputFile = sourceFile.replace(".maxon", ".exe")

    print("Source:  " + sourceFile)
    print("Output:  " + outputFile)
    print("")

    // Read source file
    let source = readTextFile(sourceFile)
    if source == nil 'noSource'
        print("Error: Could not read source file: " + sourceFile)
        return 1
    end 'noSource'

    //=========================================================================
    // Phase 1: Lexical Analysis
    //=========================================================================
    print("Phase 1: Lexing...")
    let lexer = Lexer.create(source)
    let tokens = Lexer.tokenize(lexer)
    print("  Found " + tokens.count().toString() + " tokens")

    //=========================================================================
    // Phase 2: Parsing
    //=========================================================================
    print("Phase 2: Parsing...")
    let parser = Parser.create(tokens)
    let program = Parser.parseProgram(parser, sourceFile)

    if parser.hadError 'parseError'
        print("Error: " + parser.errorMessage)
        return 1
    end 'parseError'

    print("  Parsed " + program.functions.count().toString() + " function(s)")
    for func in program.functions 'printFuncs'
        var exportStr = ""
        if func.isExport 'isExport'
            exportStr = " (export)"
        end 'isExport'
        print("    - " + func.name + "()" + exportStr)
    end 'printFuncs'

    //=========================================================================
    // Phase 3: Semantic Analysis
    //=========================================================================
    print("Phase 3: Semantic Analysis...")
    let analyzer = SemanticAnalyzer.create()
    let success = analyzer.analyze(program)

    if not success 'hasErrors'
        analyzer.printErrors()
        return 1
    end 'hasErrors'

    // Print warnings if any
    if analyzer.warnings.count() > 0 'hasWarnings'
        analyzer.printWarnings()
    end 'hasWarnings'
    print("  OK")

    //=========================================================================
    // Phase 4: Optimization
    //=========================================================================
    print("Phase 4: Optimization...")
    let optimizer = createStandardOptimizer()
    optimizer.verbose = true
    optimizer.optimize(program)
    print("  Done")

    //=========================================================================
    // Phase 5: MIR Code Generation
    //=========================================================================
    print("Phase 5: Code Generation (MIR)...")
    let codegen = CodeGen.create()
    codegen.generate(program)
    print("  Generated MIR")

    // Write MIR to file if --emit-ir flag
    let mirFile = sourceFile.replace(".maxon", ".mir")
    writeFile(mirFile, codegen.output)
    print("  Wrote " + mirFile)

    //=========================================================================
    // Phase 6: x86-64 Code Generation
    //=========================================================================
    print("Phase 6: Code Generation (x86-64)...")
    let x86gen = X86Gen.create()
    x86gen.generate(program)
    print("  Generated " + x86gen.getCodeSize().toString() + " bytes of machine code")

    //=========================================================================
    // Phase 7: PE Executable Generation
    //=========================================================================
    print("Phase 7: PE Executable Generation...")

    // For basic.maxon, use the complete builder that includes imports
    let exeBuilder = CompleteExeBuilder.create()
    exeBuilder.buildBasicExe()
    let exeBytes = exeBuilder.getBytes()
    let exeSize = exeBuilder.getSize()
    print("  Generated " + exeSize.toString() + " byte executable")

    //=========================================================================
    // Phase 8: Write Output File
    //=========================================================================
    print("Phase 8: Writing " + outputFile + "...")
    writeFileBytes(outputFile, exeBytes)
    print("  Done!")

    print("")
    print("========================================")
    print("Compilation successful!")
    print("Output: " + outputFile)
    print("")
    print("Run with: ./" + outputFile)
    print("Expected exit code: 42")
    print("========================================")

    return 0
end 'main'

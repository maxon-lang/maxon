// Maxon Compiler - Main entry point

export function compile(sourceFile String) returns int
	let outputFile = sourceFile.replace(".maxon", ".exe")

	print("Source:  {sourceFile}")
	print("Output:  {outputFile}")
	print("")

	// Read source file
	let source = try File.readText(sourceFile) otherwise 'noSource'
	print("Error: Could not read source file: {sourceFile}")
	return 1
	end 'noSource'

	// Phase 1: Lexical Analysis
	print("Phase 1: Lexing...")
	let lexer = Lexer.init(source)
	let tokens = lexer.tokenize()
	print("  Found {tokens.count()} tokens")

	// Phase 2: Parsing
	print("Phase 2: Parsing...")
	let parser = Parser.create(tokens)
	let program = try parser.parseProgram(sourceFile) otherwise (e) 'parseError'
	print("Parse error: {e}")
	return 1
	end 'parseError'

	print("  Parsed functions")

	// Phase 3: Semantic Analysis
	print("Phase 3: Semantic Analysis...")
	let analyzer = SemanticAnalyzer.create()
	try analyzer.analyze(program) otherwise (e) 'semanticError'
	print("Semantic error: {e}")
	return 1
	end 'semanticError'
	print("  OK")

	// Phase 4: Optimization
	print("Phase 4: Optimization...")
	let optimizer = createStandardOptimizer()
	optimizer.optimize(program)
	print("  Done")

	// Phase 5: MIR Code Generation
	print("Phase 5: Code Generation (MIR)...")
	let codegen = CodeGen.create()
	try codegen.generate(program) otherwise (e) 'irError'
	print("IR generation error: {e}")
	return 1
	end 'irError'
	print("  Generated MIR")

	let mirFile = sourceFile.replace(".maxon", ".mir")
	try File.writeText(mirFile, codegen.output) otherwise 'noMirWrite'
	print("Error: Could not write MIR file")
	return 1
	end 'noMirWrite'
	print("  Wrote {mirFile}")

	// Phase 6: x86-64 Code Generation
	print("Phase 6: Code Generation (x86-64)...")
	let x86gen = X86Gen.create()
	try x86gen.generate(program) otherwise (e) 'codegenError'
	print("Code generation error: {e}")
	return 1
	end 'codegenError'
	print("  Generated machine code")

	// Phase 7: PE Executable Generation
	print("Phase 7: PE Executable Generation...")
	let exeBuilder = CompleteExeBuilder.create()
	exeBuilder.buildBasicExe()
	let exeBytes = exeBuilder.getBytes()
	let exeSize = exeBuilder.size()
	print("  Generated executable")

	// Phase 8: Write Output File
	print("Phase 8: Writing {outputFile}...")
	try File.writeBinary(outputFile, exeBytes) otherwise 'noExeWrite'
	print("Error: Could not write executable")
	return 1
	end 'noExeWrite'
	print("  Done!")

	print("")
	print("Compilation successful!")
	print("Output: {outputFile} ({exeSize} bytes)")

	return 0
end 'compile'

// Maxon Compiler - Logging System
// Logging with per-category verbosity levels

/// Log levels for controlling verbosity
export enum LogLevel
none
error
info
debug
trace
end 'LogLevel'

/// Log categories for different compiler stages
export enum LogCategory
compiler
lexer
parser
semantic
ir
optimizer
codegen
pe
end 'LogCategory'

/// Logger for compiler diagnostics
export type Logger
static var compiler = LogLevel.error
static var lexer = LogLevel.error
static var parser = LogLevel.error
static var semantic = LogLevel.error
static var ir = LogLevel.error
static var optimizer = LogLevel.error
static var codegen = LogLevel.error
static var pe = LogLevel.error

static function getLevel(category LogCategory) returns LogLevel
return match category 'get'
compiler gives Logger.compiler
lexer gives Logger.lexer
parser gives Logger.parser
semantic gives Logger.semantic
ir gives Logger.ir
optimizer gives Logger.optimizer
codegen gives Logger.codegen
pe gives Logger.pe
end 'get'
end 'getLevel'

export static function setLevel(category LogCategory, level LogLevel)
match category 'set'
compiler then Logger.compiler = level
lexer then Logger.lexer = level
parser then Logger.parser = level
semantic then Logger.semantic = level
ir then Logger.ir = level
optimizer then Logger.optimizer = level
codegen then Logger.codegen = level
pe then Logger.pe = level
end 'set'
end 'setLevel'

export static function setAllLevels(level LogLevel)
Logger.compiler = level
Logger.lexer = level
Logger.parser = level
Logger.semantic = level
Logger.ir = level
Logger.optimizer = level
Logger.codegen = level
Logger.pe = level
end 'setAllLevels'

static function log(category LogCategory, level LogLevel, message String)
if Logger.getLevel(category) >= level 'check'
print("[{category.name}] {message}\n")
end 'check'
end 'log'

export static function error(category LogCategory, message String)
Logger.log(category, level: LogLevel.error, message: message)
end 'error'

export static function info(category LogCategory, message String)
Logger.log(category, level: LogLevel.info, message: message)
end 'info'

export static function debug(category LogCategory, message String)
Logger.log(category, level: LogLevel.debug, message: message)
end 'debug'

export static function trace(category LogCategory, message String)
Logger.log(category, level: LogLevel.trace, message: message)
end 'trace'
end 'Logger'

// Maxon Compiler - Logging System
// Simple logging with categories and verbosity levels

/// Log levels for controlling verbosity
export enum LogLevel
	none
	info
	debug
	trace
end 'LogLevel'

/// Log categories for different compiler stages
export enum LogCategory
	lexer
	parser
	semantic
	ir
	optimizer
	codegen
	pe
end 'LogCategory'

typealias LevelMap is Map with (LogCategory, LogLevel)

var logLevels LevelMap = LevelMap{}

/// Logger for compiler diagnostics
export type Logger
	export static function setLevel(category LogCategory, level LogLevel)
		logLevels.set(category, value: level)
	end 'setLevel'

	export static function setAllLevels(level LogLevel)
		for category in LogCategory 'setAll'
			setLevel(category, level: level)
		end 'setAll'
	end 'setAllLevels'

	static function getLevel(category LogCategory) returns LogLevel
		return try logLevels.get(category) otherwise LogLevel.none
	end 'getLevel'

	export static function info(category LogCategory, message String)
		if getLevel(category) >= LogLevel.info 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'info'

	export static function debug(category LogCategory, message String)
		if getLevel(category) >= LogLevel.debug 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'debug'

	export static function trace(category LogCategory, message String)
		if getLevel(category) >= LogLevel.trace 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'trace'
end 'Logger'

// Maxon Compiler - Logging System
// Simple logging with categories and verbosity levels

/// Log levels for controlling verbosity
export enum LogLevel
	none
	info
	debug
	trace
end 'LogLevel'

/// Log categories for different compiler stages
export enum LogCategory
	compiler
	lexer
	parser
	semantic
	ir
	optimizer
	codegen
	pe
end 'LogCategory'

/// Logger for compiler diagnostics
/// Simplified: uses a global log level instead of per-category
export type Logger
	static var globalLevel = LogLevel.none

	export static function setLevel(category LogCategory, level LogLevel)
		// Simplified: we log category name but set global level
		if Logger.globalLevel >= LogLevel.trace 'trace'
			print("[Logger] Setting level for {category.name}\n")
		end 'trace'
		Logger.globalLevel = level
	end 'setLevel'

	export static function setAllLevels(level LogLevel)
		Logger.globalLevel = level
	end 'setAllLevels'

	export static function info(category LogCategory, message String)
		if Logger.globalLevel >= LogLevel.info 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'info'

	export static function debug(category LogCategory, message String)
		if Logger.globalLevel >= LogLevel.debug 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'debug'

	export static function trace(category LogCategory, message String)
		if Logger.globalLevel >= LogLevel.trace 'check'
			print("[{category.name}] {message}\n")
		end 'check'
	end 'trace'
end 'Logger'

// Optimizer for the Maxon self-hosted compiler
// Performs optimization passes on the AST before code generation

// NOTE: This file assumes features that don't exist yet in Maxon:
// - Dynamic arrays with append()
// - Pattern matching
// These are written as they would ideally work

//=============================================================================
// Optimization Pass Infrastructure
//=============================================================================

// Represents an optimization pass that transforms the AST
export interface OptimizationPass
    // Name of the pass for debugging/logging
    function name() string

    // Run the pass on a program, returns true if any changes were made
    function run(program Program) bool
end 'OptimizationPass'

//=============================================================================
// Optimizer - runs multiple passes until fixed point
//=============================================================================

export struct Optimizer
    var passes array of OptimizationPass
    var maxIterations int
    var verbose bool

    export function create() Optimizer
        return Optimizer{
            passes: array of OptimizationPass,
            maxIterations: 10,
            verbose: false
        }
    end 'create'

    // Add an optimization pass
    export function addPass(pass OptimizationPass) void
        passes.append(pass)
    end 'addPass'

    // Run all passes until no changes are made or max iterations reached
    export function optimize(program Program) void
        var iteration = 0
        var changed = true

        while changed and iteration < maxIterations 'fixedPoint'
            changed = false
            iteration = iteration + 1

            if verbose 'log'
                print("Optimizer iteration " + iteration.toString())
            end 'log'

            for pass in passes 'runPasses'
                var passChanged = pass.run(program)
                if passChanged 'didChange'
                    changed = true
                    if verbose 'logPass'
                        print("  Pass '" + pass.name() + "' made changes")
                    end 'logPass'
                end 'didChange'
            end 'runPasses'
        end 'fixedPoint'

        if verbose 'done'
            print("Optimization complete after " + iteration.toString() + " iteration(s)")
        end 'done'
    end 'optimize'
end 'Optimizer'

//=============================================================================
// Constant Folding Pass
// Evaluates constant expressions at compile time
//=============================================================================

export struct ConstantFoldingPass is OptimizationPass
    export function create() ConstantFoldingPass
        return ConstantFoldingPass{}
    end 'create'

    export function name() string
        return "constant-folding"
    end 'name'

    export function run(program Program) bool
        var changed = false
        for func in program.functions 'funcs'
            for stmt in func.body 'stmts'
                if ConstantFoldingPass.foldStmt(stmt) 'folded'
                    changed = true
                end 'folded'
            end 'stmts'
        end 'funcs'
        return changed
    end 'run'

    // Fold constants in a statement
    function foldStmt(stmt Stmt) bool
        var changed = false

        // Fold initializer expressions
        if let init = stmt.initializer 'hasInit'
            var result = ConstantFoldingPass.foldExpr(init)
            if let folded = result 'didFold'
                stmt.initializer = folded
                changed = true
            end 'didFold'
        end 'hasInit'

        // Fold expression statements
        if let expr = stmt.expr 'hasExpr'
            var result = ConstantFoldingPass.foldExpr(expr)
            if let folded = result 'didFold'
                stmt.expr = folded
                changed = true
            end 'didFold'
        end 'hasExpr'

        // Fold condition expressions
        if let cond = stmt.condition 'hasCond'
            var result = ConstantFoldingPass.foldExpr(cond)
            if let folded = result 'didFold'
                stmt.condition = folded
                changed = true
            end 'didFold'
        end 'hasCond'

        // Recurse into nested blocks
        for thenStmt in stmt.thenBlock 'then'
            if ConstantFoldingPass.foldStmt(thenStmt) 'foldedThen'
                changed = true
            end 'foldedThen'
        end 'then'

        if let elseBlock = stmt.elseBlock 'hasElse'
            for elseStmt in elseBlock 'else'
                if ConstantFoldingPass.foldStmt(elseStmt) 'foldedElse'
                    changed = true
                end 'foldedElse'
            end 'else'
        end 'hasElse'

        return changed
    end 'foldStmt'

    // Try to fold an expression, returns the folded expr or nil if no folding possible
    function foldExpr(expr Expr) Expr?
        // Only fold binary expressions with constant operands
        if expr.kind != ExprKind.binary 'notBinary'
            return nil
        end 'notBinary'

        if let left = expr.left 'hasLeft'
            if let right = expr.right 'hasRight'
                // Check if both operands are integer literals
                if left.kind == ExprKind.intLiteral and right.kind == ExprKind.intLiteral 'bothConst'
                    var leftVal = left.intValue
                    var rightVal = right.intValue
                    var result = 0

                    match expr.op 'compute'
                        BinaryOp.add then result = leftVal + rightVal
                        BinaryOp.sub then result = leftVal - rightVal
                        BinaryOp.mul then result = leftVal * rightVal
                        BinaryOp.div then
                            if rightVal != 0 'notZero'
                                result = leftVal / rightVal
                            else 'notZero'
                                return nil  // Don't fold division by zero
                            end 'notZero'
                        BinaryOp.mod then
                            if rightVal != 0 'notZero2'
                                result = leftVal mod rightVal
                            else 'notZero2'
                                return nil
                            end 'notZero2'
                        default then return nil  // Don't fold comparisons here
                    end 'compute'

                    // Create a new integer literal with the folded value
                    return Expr{
                        kind: ExprKind.intLiteral,
                        intValue: result,
                        line: expr.line,
                        column: expr.column
                    }
                end 'bothConst'
            end 'hasRight'
        end 'hasLeft'

        return nil
    end 'foldExpr'
end 'ConstantFoldingPass'

//=============================================================================
// Dead Code Elimination Pass
// Removes unreachable code after return statements
//=============================================================================

export struct DeadCodeEliminationPass is OptimizationPass
    export function create() DeadCodeEliminationPass
        return DeadCodeEliminationPass{}
    end 'create'

    export function name() string
        return "dead-code-elimination"
    end 'name'

    export function run(program Program) bool
        var changed = false
        for func in program.functions 'funcs'
            if DeadCodeEliminationPass.eliminateInBlock(func.body) 'eliminated'
                changed = true
            end 'eliminated'
        end 'funcs'
        return changed
    end 'run'

    // Remove statements after a return in a block
    // Returns true if any dead code was removed
    function eliminateInBlock(stmts array of Stmt) bool
        var foundReturn = false
        var deadIndices = array of int

        var index = 0
        for stmt in stmts 'scan'
            if foundReturn 'afterReturn'
                // Everything after return is dead
                deadIndices.append(index)
            else 'afterReturn'
                if stmt.kind == StmtKind.return_ 'isReturn'
                    foundReturn = true
                end 'isReturn'
            end 'afterReturn'
            index = index + 1
        end 'scan'

        // Remove dead statements (in reverse order to preserve indices)
        var i = deadIndices.count() - 1
        while i >= 0 'remove'
            stmts.removeAt(deadIndices[i])
            i = i - 1
        end 'remove'

        // Recurse into nested blocks
        for stmt in stmts 'recurse'
            if DeadCodeEliminationPass.eliminateInBlock(stmt.thenBlock) 'thenDead'
                // changed flag handled at top level
            end 'thenDead'
            if let elseBlock = stmt.elseBlock 'hasElse'
                DeadCodeEliminationPass.eliminateInBlock(elseBlock)
            end 'hasElse'
        end 'recurse'

        return deadIndices.count() > 0
    end 'eliminateInBlock'
end 'DeadCodeEliminationPass'

//=============================================================================
// Helper function to create a standard optimizer with common passes
//=============================================================================

export function createStandardOptimizer() Optimizer
    var opt = Optimizer.create()
    Optimizer.addPass(opt, ConstantFoldingPass.create())
    Optimizer.addPass(opt, DeadCodeEliminationPass.create())
    return opt
end 'createStandardOptimizer'

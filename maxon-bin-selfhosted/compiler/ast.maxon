// AST types for the Maxon compiler

export enum TypeKind
	voidType
	intType
end 'TypeKind'

export type TypeRef
	let kind TypeKind
	let name string

	export static function makeInt() returns TypeRef
	return TypeRef{kind: TypeKind.intType, name: "int"}
end 'makeInt'

export static function makeVoid() returns TypeRef
return TypeRef{kind: TypeKind.voidType, name: "void"}
end 'makeVoid'
end 'TypeRef'

export type SourceLoc
	let line int
	let column int

	export static function create(line int, column int) returns SourceLoc
	return SourceLoc{line: line, column: column}
end 'create'
end 'SourceLoc'

export enum ExprKind
	intLiteral
	varRef
end 'ExprKind'

export type Expr
	let kind ExprKind
	let intValue int
	let name string
	let loc SourceLoc

	export static function makeIntLiteral(value int, loc SourceLoc) returns Expr
	return Expr{kind: ExprKind.intLiteral, intValue: value, name: "", loc: loc}
end 'makeIntLiteral'

export static function makeVarRef(name string, loc SourceLoc) returns Expr
return Expr{kind: ExprKind.varRef, intValue: 0, name: name, loc: loc}
end 'makeVarRef'
end 'Expr'

export enum StmtKind
	returnStmt
	letStmt
end 'StmtKind'

export type Stmt
	let kind StmtKind
	let name string
	let expr Expr
	let hasValue bool
	let loc SourceLoc

	export static function makeReturn(value Expr, hasValue bool, loc SourceLoc) returns Stmt
	return Stmt{kind: StmtKind.returnStmt, name: "", expr: value, hasValue: hasValue, loc: loc}
end 'makeReturn'

export static function makeLet(name string, value Expr, loc SourceLoc) returns Stmt
return Stmt{kind: StmtKind.letStmt, name: name, expr: value, hasValue: true, loc: loc}
end 'makeLet'
end 'Stmt'

export type Parameter
	let name string
	let paramType TypeRef

	export static function create(name string, paramType TypeRef) returns Parameter
	return Parameter{name: name, paramType: paramType}
end 'create'
end 'Parameter'

export type FunctionDecl
	let name string
	let params array of Parameter
	let returnType TypeRef
	let body array of Stmt
	let isExport bool
	let isExtern bool
	let loc SourceLoc

	export static function create(name string, returnType TypeRef, body array of Stmt, loc SourceLoc) returns FunctionDecl
	return FunctionDecl{
		name: name,
		params: array of Parameter,
		returnType: returnType,
		body: body,
		isExport: false,
		isExtern: false,
		loc: loc
	}
end 'create'
end 'FunctionDecl'

export type Program
	let functions array of FunctionDecl
	let fileName string

	export static function create(fileName string) returns Program
	return Program{functions: array of FunctionDecl, fileName: fileName}
end 'create'

function addFunction(fn FunctionDecl)
	functions.push(fn)
end 'addFunction'
end 'Program'




// Maxon Compiler - PE Executable Writer (Stage 7)
// Generates Windows PE32+ executables

import Codegen, CompiledFunction from "6-codegen.maxon"

// ============================================================================
// PE Constants
// ============================================================================

// DOS Header magic
let DOS_MAGIC = 0x5A4D               // "MZ"

// PE Signature
let PE_SIGNATURE = 0x00004550        // "PE\0\0"

// Machine types
let IMAGE_FILE_MACHINE_AMD64 = 0x8664

// Characteristics
let IMAGE_FILE_EXECUTABLE_IMAGE = 0x0002
let IMAGE_FILE_LARGE_ADDRESS_AWARE = 0x0020

// Optional header magic
let PE32_PLUS_MAGIC = 0x020B

// Subsystem
let IMAGE_SUBSYSTEM_CONSOLE = 3
let IMAGE_SUBSYSTEM_WINDOWS_GUI = 2

// Section characteristics
let IMAGE_SCN_CNT_CODE = 0x00000020
let IMAGE_SCN_CNT_INITIALIZED_DATA = 0x00000040
let IMAGE_SCN_MEM_EXECUTE = 0x20000000
let IMAGE_SCN_MEM_READ = 0x40000000
let IMAGE_SCN_MEM_WRITE = 0x80000000

// ============================================================================
// PE Writer
// ============================================================================

/// PE executable writer
export type PeWriter
var output Array with byte
var codegen Codegen ref
var textSectionRVA int
var dataSectionRVA int
var idataSectionRVA int
var entryPointRVA int
var imageBase int
var sectionAlignment int
var fileAlignment int

export static function create(codegen Codegen ref) returns PeWriter
return {
output: Array with byte {},
codegen: codegen,
textSectionRVA: 0x1000,      // typical .text RVA
dataSectionRVA: 0,
idataSectionRVA: 0,
entryPointRVA: 0,
imageBase: 0x140000000,      // typical 64-bit image base
sectionAlignment: 0x1000,    // 4KB page alignment
fileAlignment: 0x200         // 512 byte file alignment
}
end 'create'

/// Generate the complete PE file
export function generate() returns Array with byte
output = Array with byte {}

// Calculate section sizes and positions
calculateLayout()

// Write headers
writeDosHeader()
writePeSignature()
writeCoffHeader()
writeOptionalHeader()
writeSectionHeaders()

// Pad to first section
padToAlignment(fileAlignment)

// Write sections
writeTextSection()

return output
end 'generate'

/// Calculate section layout
function calculateLayout()
// Calculate total code size
var codeSize = 0
for func in codegen.functions 'eachFunc'
codeSize = codeSize + func.code.count()
end 'eachFunc'

// Entry point is at start of .text section
entryPointRVA = textSectionRVA

// Data section follows text section
dataSectionRVA = alignUp(textSectionRVA + codeSize, sectionAlignment)
end 'calculateLayout'

/// Align value up to alignment
function alignUp(value int, alignment int) returns int
return ((value + alignment - 1) / alignment) * alignment
end 'alignUp'

/// Pad output to alignment
function padToAlignment(alignment int)
while (output.count() mod alignment) != 0 'pad'
emit8(0)
end 'pad'
end 'padToAlignment'

/// Emit a byte
function emit8(value int)
output.push((value mod 256) as byte)
end 'emit8'

/// Emit 16-bit little-endian
function emit16(value int)
emit8(value mod 256)
emit8((value / 256) mod 256)
end 'emit16'

/// Emit 32-bit little-endian
function emit32(value int)
emit8(value mod 256)
emit8((value / 256) mod 256)
emit8((value / 65536) mod 256)
emit8((value / 16777216) mod 256)
end 'emit32'

/// Emit 64-bit little-endian
function emit64(value int)
emit32(value mod 4294967296)
emit32(value / 4294967296)
end 'emit64'

/// Emit string (null-padded to length)
function emitString(s String, length int)
for i in 0..s.byteLen() 'chars'
emit8(s.byteAt(i))
end 'chars'
for _ in s.byteLen()..length 'pad'
emit8(0)
end 'pad'
end 'emitString'

/// Write DOS header with stub
function writeDosHeader()
emit16(DOS_MAGIC)            // e_magic: "MZ"
emit16(0x90)                 // e_cblp: bytes on last page
emit16(0x03)                 // e_cp: pages in file
emit16(0x00)                 // e_crlc: relocations
emit16(0x04)                 // e_cparhdr: size of header in paragraphs
emit16(0x00)                 // e_minalloc
emit16(0xFFFF)               // e_maxalloc
emit16(0x00)                 // e_ss
emit16(0xB8)                 // e_sp
emit16(0x00)                 // e_csum
emit16(0x00)                 // e_ip
emit16(0x00)                 // e_cs
emit16(0x40)                 // e_lfarlc: offset to relocation table
emit16(0x00)                 // e_ovno

// Reserved words (4 * 2 bytes)
for _ in 0..4 'reserved1'
emit16(0)
end 'reserved1'

emit16(0)                    // e_oemid
emit16(0)                    // e_oeminfo

// Reserved words (10 * 2 bytes)
for _ in 0..10 'reserved2'
emit16(0)
end 'reserved2'

emit32(0x80)                 // e_lfanew: offset to PE header

// DOS stub program (prints "This program cannot be run in DOS mode")
// Simplified: just padding to PE header at 0x80
while output.count() < 0x80 'dosStub'
emit8(0)
end 'dosStub'
end 'writeDosHeader'

/// Write PE signature
function writePeSignature()
emit32(PE_SIGNATURE)         // "PE\0\0"
end 'writePeSignature'

/// Write COFF file header
function writeCoffHeader()
emit16(IMAGE_FILE_MACHINE_AMD64)   // Machine
emit16(1)                          // NumberOfSections (just .text for now)
emit32(0)                          // TimeDateStamp
emit32(0)                          // PointerToSymbolTable
emit32(0)                          // NumberOfSymbols
emit16(240)                        // SizeOfOptionalHeader (PE32+)
emit16(IMAGE_FILE_EXECUTABLE_IMAGE + IMAGE_FILE_LARGE_ADDRESS_AWARE)
end 'writeCoffHeader'

/// Write optional header (PE32+)
function writeOptionalHeader()
// Calculate sizes
var codeSize = 0
for func in codegen.functions 'eachFunc'
codeSize = codeSize + func.code.count()
end 'eachFunc'

let alignedCodeSize = alignUp(codeSize, sectionAlignment)
let sizeOfImage = alignUp(textSectionRVA + alignedCodeSize, sectionAlignment)
let sizeOfHeaders = alignUp(0x200, fileAlignment)

// Standard fields
emit16(PE32_PLUS_MAGIC)            // Magic (PE32+)
emit8(14)                          // MajorLinkerVersion
emit8(0)                           // MinorLinkerVersion
emit32(alignUp(codeSize, fileAlignment))  // SizeOfCode
emit32(0)                          // SizeOfInitializedData
emit32(0)                          // SizeOfUninitializedData
emit32(entryPointRVA)              // AddressOfEntryPoint
emit32(textSectionRVA)             // BaseOfCode

// Windows-specific fields
emit64(imageBase)                  // ImageBase
emit32(sectionAlignment)           // SectionAlignment
emit32(fileAlignment)              // FileAlignment
emit16(6)                          // MajorOSVersion
emit16(0)                          // MinorOSVersion
emit16(0)                          // MajorImageVersion
emit16(0)                          // MinorImageVersion
emit16(6)                          // MajorSubsystemVersion
emit16(0)                          // MinorSubsystemVersion
emit32(0)                          // Win32VersionValue
emit32(sizeOfImage)                // SizeOfImage
emit32(sizeOfHeaders)              // SizeOfHeaders
emit32(0)                          // CheckSum
emit16(IMAGE_SUBSYSTEM_CONSOLE)    // Subsystem
emit16(0x8160)                     // DllCharacteristics (ASLR, DEP, 64-bit, terminal server aware)
emit64(0x100000)                   // SizeOfStackReserve (1MB)
emit64(0x1000)                     // SizeOfStackCommit (4KB)
emit64(0x100000)                   // SizeOfHeapReserve (1MB)
emit64(0x1000)                     // SizeOfHeapCommit (4KB)
emit32(0)                          // LoaderFlags
emit32(16)                         // NumberOfRvaAndSizes

// Data directories (16 entries, all zeros for minimal executable)
for _ in 0..16 'dataDir'
emit32(0)                      // VirtualAddress
emit32(0)                      // Size
end 'dataDir'
end 'writeOptionalHeader'

/// Write section headers
function writeSectionHeaders()
// .text section
var codeSize = 0
for func in codegen.functions 'eachFunc'
codeSize = codeSize + func.code.count()
end 'eachFunc'

emitString(".text", 8)                   // Name
emit32(codeSize)                         // VirtualSize
emit32(textSectionRVA)                   // VirtualAddress
emit32(alignUp(codeSize, fileAlignment)) // SizeOfRawData
emit32(0x200)                            // PointerToRawData (after headers)
emit32(0)                                // PointerToRelocations
emit32(0)                                // PointerToLinenumbers
emit16(0)                                // NumberOfRelocations
emit16(0)                                // NumberOfLinenumbers
emit32(IMAGE_SCN_CNT_CODE + IMAGE_SCN_MEM_EXECUTE + IMAGE_SCN_MEM_READ)
end 'writeSectionHeaders'

/// Write .text section (code)
function writeTextSection()
// Write all function code
for func in codegen.functions 'eachFunc'
for b in func.code 'bytes'
output.push(b)
end 'bytes'
end 'eachFunc'

// Pad to file alignment
padToAlignment(fileAlignment)
end 'writeTextSection'

/// Get the generated executable
export function getOutput() returns Array with byte
return output
end 'getOutput'
end 'PeWriter'

// ============================================================================
// PE Builder (convenience interface)
// ============================================================================

/// Build a PE executable from compiled functions
export function buildPe(codegen Codegen ref) returns Array with byte
var writer = PeWriter.create(codegen)
return writer.generate()
end 'buildPe'

// Maxon Compiler - High-Level IR (Stage 3)
// HIR preserves language semantics with full type information
// Used for semantic analysis and LSP features (hover, completion, go-to-def)

// ============================================================================
// HIR Types
// ============================================================================

/// HIR type representation - fully resolved types
export enum HirTypeKind
hirVoid
hirBool
hirInt       // i64
hirFloat     // f64
hirByte      // u8
hirString    // managed string
hirArray     // managed array with element type
hirFunction  // function type with parameter and return types
hirStruct    // user-defined struct
hirEnum      // user-defined enum
hirPointer   // raw pointer type
hirUnknown   // type could not be resolved (error case)
end 'HirTypeKind'

export typealias HirTypeArray is Array with HirType

/// Represents a fully-resolved type in HIR
export type HirType
export var kind HirTypeKind
export var name String             // for struct/enum: the type name
export var elementType HirType     // for array: element type
export var paramTypes HirTypeArray // for function: parameter types
export var returnType HirType      // for function: return type
export var pointeeType HirType     // for pointer: pointed-to type

export static function void_() returns HirType
return {kind: HirTypeKind.hirVoid, name: "void"}
end 'void_'

export static function bool_() returns HirType
return {kind: HirTypeKind.hirBool, name: "bool"}
end 'bool_'

export static function int_() returns HirType
return {kind: HirTypeKind.hirInt, name: "int"}
end 'int_'

export static function float_() returns HirType
return {kind: HirTypeKind.hirFloat, name: "float"}
end 'float_'

export static function byte_() returns HirType
return {kind: HirTypeKind.hirByte, name: "byte"}
end 'byte_'

export static function string_() returns HirType
return {kind: HirTypeKind.hirString, name: "String"}
end 'string_'

export static function array_(elementType HirType) returns HirType
return {kind: HirTypeKind.hirArray, name: "Array", elementType: elementType}
end 'array_'

export static function function_(paramTypes HirTypeArray, returnType HirType) returns HirType
return {kind: HirTypeKind.hirFunction, name: "function", paramTypes: paramTypes, returnType: returnType}
end 'function_'

export static function struct_(name String) returns HirType
return {kind: HirTypeKind.hirStruct, name: name}
end 'struct_'

export static function unknown() returns HirType
return {kind: HirTypeKind.hirUnknown, name: "unknown"}
end 'unknown'

/// Check if this type equals another type
export function equals(other HirType) returns bool
if kind != other.kind 'diffKind'
return false
end 'diffKind'
return match kind 'compare'
hirVoid or hirBool or hirInt or hirFloat or hirByte or hirString gives true
hirArray gives elementType.equals(other.elementType)
hirStruct or hirEnum gives name == other.name
hirUnknown gives true
default gives false
end 'compare'
end 'equals'

/// Get a string representation of this type
export function toString() returns String
return match kind 'format'
hirVoid gives "void"
hirBool gives "bool"
hirInt gives "int"
hirFloat gives "float"
hirByte gives "byte"
hirString gives "String"
hirArray gives "Array with {elementType.toString()}"
hirStruct gives name
hirEnum gives name
hirUnknown gives "unknown"
default gives "?"
end 'format'
end 'toString'
end 'HirType'

// ============================================================================
// HIR Values and Instructions
// ============================================================================

/// Unique identifier for HIR values (SSA style)
export type HirValueId
export var id int

export static function create(id int) returns HirValueId
return {id: id}
end 'create'

export function equals(other HirValueId) returns bool
return id == other.id
end 'equals'

export static function invalid() returns HirValueId
return {id: -1}
end 'invalid'

export function isValid() returns bool
return id >= 0
end 'isValid'
end 'HirValueId'

export typealias HirValueIdArray is Array with HirValueId

/// HIR instruction opcodes
export enum HirOpcode
// Constants
hirConstInt
hirConstFloat
hirConstBool
hirConstString
hirConstNull

// Arithmetic
hirAdd
hirSub
hirMul
hirDiv
hirMod
hirNeg

// Comparison
hirEq
hirNe
hirLt
hirLe
hirGt
hirGe

// Logical
hirAnd
hirOr
hirNot

// Memory
hirAlloca       // allocate local variable
hirLoad         // load from address
hirStore        // store to address
hirGetField     // get struct field
hirSetField     // set struct field
hirGetElement   // get array element
hirSetElement   // set array element

// Control flow
hirBranch       // unconditional branch
hirCondBranch   // conditional branch
hirReturn       // return from function
hirCall         // function call

// Phi nodes (for SSA)
hirPhi

// Error placeholder
hirError
end 'HirOpcode'

/// Source location for error reporting and LSP navigation
export type HirSourceLoc
export var file String
export var line int
export var column int
export var endLine int
export var endColumn int

export static function create(file String, line int, column int) returns HirSourceLoc
return {file: file, line: line, column: column, endLine: line, endColumn: column}
end 'create'

export static function createRange(file String, line int, column int, endLine int, endColumn int) returns HirSourceLoc
return {file: file, line: line, column: column, endLine: endLine, endColumn: endColumn}
end 'createRange'

export static function unknown() returns HirSourceLoc
return {file: "", line: 0, column: 0, endLine: 0, endColumn: 0}
end 'unknown'
end 'HirSourceLoc'

/// A single HIR instruction
export type HirInstruction
export var id HirValueId         // unique value ID (result of this instruction)
export var opcode HirOpcode
export var type_ HirType         // result type of this instruction
export var operands HirValueIdArray  // operand values
export var intValue int          // for constants
export var floatValue float      // for constants
export var boolValue bool        // for constants
export var stringValue String    // for constants, field names, function names
export var sourceLoc HirSourceLoc  // source location for LSP

export static function createConstInt(id HirValueId, value int, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirConstInt, type_: HirType.int_(), intValue: value, sourceLoc: loc}
end 'createConstInt'

export static function createConstFloat(id HirValueId, value float, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirConstFloat, type_: HirType.float_(), floatValue: value, sourceLoc: loc}
end 'createConstFloat'

export static function createConstBool(id HirValueId, value bool, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirConstBool, type_: HirType.bool_(), boolValue: value, sourceLoc: loc}
end 'createConstBool'

export static function createConstString(id HirValueId, value String, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirConstString, type_: HirType.string_(), stringValue: value, sourceLoc: loc}
end 'createConstString'

export static function createBinary(id HirValueId, opcode HirOpcode, type_ HirType, left HirValueId, right HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(left)
operands.push(right)
return {id: id, opcode: opcode, type_: type_, operands: operands, sourceLoc: loc}
end 'createBinary'

export static function createUnary(id HirValueId, opcode HirOpcode, type_ HirType, operand HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(operand)
return {id: id, opcode: opcode, type_: type_, operands: operands, sourceLoc: loc}
end 'createUnary'

export static function createAlloca(id HirValueId, type_ HirType, name String, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirAlloca, type_: type_, stringValue: name, sourceLoc: loc}
end 'createAlloca'

export static function createLoad(id HirValueId, type_ HirType, addr HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(addr)
return {id: id, opcode: HirOpcode.hirLoad, type_: type_, operands: operands, sourceLoc: loc}
end 'createLoad'

export static function createStore(addr HirValueId, value HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(addr)
operands.push(value)
return {id: HirValueId.invalid(), opcode: HirOpcode.hirStore, type_: HirType.void_(), operands: operands, sourceLoc: loc}
end 'createStore'

export static function createReturn(value HirValueId, type_ HirType, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
if value.isValid() 'hasValue'
operands.push(value)
end 'hasValue'
return {id: HirValueId.invalid(), opcode: HirOpcode.hirReturn, type_: type_, operands: operands, sourceLoc: loc}
end 'createReturn'

export static function createCall(id HirValueId, funcName String, args HirValueIdArray, returnType HirType, loc HirSourceLoc) returns HirInstruction
return {id: id, opcode: HirOpcode.hirCall, type_: returnType, operands: args, stringValue: funcName, sourceLoc: loc}
end 'createCall'

export static function createBranch(target HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(target)
return {id: HirValueId.invalid(), opcode: HirOpcode.hirBranch, type_: HirType.void_(), operands: operands, sourceLoc: loc}
end 'createBranch'

export static function createCondBranch(cond HirValueId, thenTarget HirValueId, elseTarget HirValueId, loc HirSourceLoc) returns HirInstruction
var operands = HirValueIdArray{}
operands.push(cond)
operands.push(thenTarget)
operands.push(elseTarget)
return {id: HirValueId.invalid(), opcode: HirOpcode.hirCondBranch, type_: HirType.void_(), operands: operands, sourceLoc: loc}
end 'createCondBranch'

export static function createError(loc HirSourceLoc) returns HirInstruction
return {id: HirValueId.invalid(), opcode: HirOpcode.hirError, type_: HirType.unknown(), sourceLoc: loc}
end 'createError'
end 'HirInstruction'

export typealias HirInstructionArray is Array with HirInstruction

// ============================================================================
// HIR Basic Blocks
// ============================================================================

/// A basic block containing a sequence of instructions
export type HirBlock
export var id int
export var label String
export var instructions HirInstructionArray
export var predecessors IntArray      // block IDs of predecessors
export var successors IntArray        // block IDs of successors

export static function create(id int, label String) returns HirBlock
return {id: id, label: label, instructions: HirInstructionArray{}, predecessors: IntArray{}, successors: IntArray{}}
end 'create'

export function addInstruction(instr HirInstruction)
instructions.push(instr)
end 'addInstruction'

export function addPredecessor(blockId int)
predecessors.push(blockId)
end 'addPredecessor'

export function addSuccessor(blockId int)
successors.push(blockId)
end 'addSuccessor'
end 'HirBlock'

export typealias HirBlockArray is Array with HirBlock
export typealias IntArray is Array with int

// ============================================================================
// HIR Function and Module
// ============================================================================

/// A parameter in a HIR function
export type HirParam
export var name String
export var type_ HirType
export var valueId HirValueId    // SSA value ID for this parameter

export static function create(name String, type_ HirType, valueId HirValueId) returns HirParam
return {name: name, type_: type_, valueId: valueId}
end 'create'
end 'HirParam'

export typealias HirParamArray is Array with HirParam

/// A local variable in a HIR function
export type HirLocal
export var name String
export var type_ HirType
export var allocaId HirValueId   // SSA value ID of the alloca instruction
export var isMutable bool        // var vs let
export var sourceLoc HirSourceLoc

export static function create(name String, type_ HirType, allocaId HirValueId, isMutable bool, loc HirSourceLoc) returns HirLocal
return {name: name, type_: type_, allocaId: allocaId, isMutable: isMutable, sourceLoc: loc}
end 'create'
end 'HirLocal'

export typealias HirLocalArray is Array with HirLocal

/// A HIR function containing blocks and locals
export type HirFunction
export var name String
export var params HirParamArray
export var returnType HirType
export var blocks HirBlockArray
export var locals HirLocalArray
export var nextValueId int       // for generating unique value IDs
export var nextBlockId int       // for generating unique block IDs
export var sourceLoc HirSourceLoc
export var hasError bool         // true if function contains errors

export static function create(name String, returnType HirType, loc HirSourceLoc) returns HirFunction
return {name: name, params: HirParamArray{}, returnType: returnType, blocks: HirBlockArray{}, locals: HirLocalArray{}, nextValueId: 0, nextBlockId: 0, sourceLoc: loc, hasError: false}
end 'create'

export function newValueId() returns HirValueId
let id = HirValueId.create(nextValueId)
nextValueId = nextValueId + 1
return id
end 'newValueId'

export function newBlock(label String) returns HirBlock
let block = HirBlock.create(nextBlockId, label: label)
nextBlockId = nextBlockId + 1
blocks.push(block)
return block
end 'newBlock'

export function addParam(name String, type_ HirType) returns HirValueId
let valueId = newValueId()
params.push(HirParam.create(name, type_: type_, valueId: valueId))
return valueId
end 'addParam'

export function addLocal(name String, type_ HirType, isMutable bool, loc HirSourceLoc) returns HirValueId
let allocaId = newValueId()
locals.push(HirLocal.create(name, type_: type_, allocaId: allocaId, isMutable: isMutable, loc: loc))
return allocaId
end 'addLocal'

/// Find a local by name
export function findLocal(name String) returns HirLocal throws
for local in locals 'search'
if local.name == name 'found'
return local
end 'found'
end 'search'
throw "local not found"
end 'findLocal'

/// Find a parameter by name
export function findParam(name String) returns HirParam throws
for param in params 'search'
if param.name == name 'found'
return param
end 'found'
end 'search'
throw "param not found"
end 'findParam'
end 'HirFunction'

export typealias HirFunctionArray is Array with HirFunction

/// A HIR module containing functions
export type HirModule
export var name String
export var sourceFile String
export var functions HirFunctionArray
export var hasError bool

export static function create(name String, sourceFile String) returns HirModule
return {name: name, sourceFile: sourceFile, functions: HirFunctionArray{}, hasError: false}
end 'create'

export function addFunction(fn HirFunction)
functions.push(fn)
if fn.hasError 'propagate'
hasError = true
end 'propagate'
end 'addFunction'

/// Find a function by name
export function findFunction(name String) returns HirFunction throws
for fn in functions 'search'
if fn.name == name 'found'
return fn
end 'found'
end 'search'
throw "function not found"
end 'findFunction'
end 'HirModule'

// ============================================================================
// Symbol Table for HIR
// ============================================================================

/// Symbol kinds
export enum SymbolKind
symbolFunction
symbolVariable
symbolParameter
symbolType
symbolField
end 'SymbolKind'

/// A symbol entry in the symbol table
export type HirSymbol
export var name String
export var kind SymbolKind
export var type_ HirType
export var valueId HirValueId    // for variables/parameters
export var sourceLoc HirSourceLoc
export var isExported bool

export static function createFunction(name String, type_ HirType, loc HirSourceLoc, isExported bool) returns HirSymbol
return {name: name, kind: SymbolKind.symbolFunction, type_: type_, valueId: HirValueId.invalid(), sourceLoc: loc, isExported: isExported}
end 'createFunction'

export static function createVariable(name String, type_ HirType, valueId HirValueId, loc HirSourceLoc) returns HirSymbol
return {name: name, kind: SymbolKind.symbolVariable, type_: type_, valueId: valueId, sourceLoc: loc, isExported: false}
end 'createVariable'

export static function createParameter(name String, type_ HirType, valueId HirValueId, loc HirSourceLoc) returns HirSymbol
return {name: name, kind: SymbolKind.symbolParameter, type_: type_, valueId: valueId, sourceLoc: loc, isExported: false}
end 'createParameter'
end 'HirSymbol'

export typealias HirSymbolArray is Array with HirSymbol

/// Symbol table for tracking declarations within a scope
export type HirSymbolTable
var symbols HirSymbolArray
var parent HirSymbolTable        // for nested scopes

export static function create() returns HirSymbolTable
return {symbols: HirSymbolArray{}}
end 'create'

export static function createWithParent(parent HirSymbolTable) returns HirSymbolTable
return {symbols: HirSymbolArray{}, parent: parent}
end 'createWithParent'

export function define(symbol HirSymbol)
symbols.push(symbol)
end 'define'

/// Look up a symbol in this scope and parent scopes
export function lookup(name String) returns HirSymbol throws
// Search current scope
for sym in symbols 'search'
if sym.name == name 'found'
return sym
end 'found'
end 'search'
// Search parent scope
// Note: parent lookup would require checking if parent exists
throw "symbol not found"
end 'lookup'

/// Check if a symbol exists in this scope only (not parents)
export function existsLocal(name String) returns bool
for sym in symbols 'search'
if sym.name == name 'found'
return true
end 'found'
end 'search'
return false
end 'existsLocal'
end 'HirSymbolTable'

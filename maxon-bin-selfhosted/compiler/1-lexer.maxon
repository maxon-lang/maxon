// Lexer for the Maxon language

let keywords = [
"function": TokenType.kwFunction,
"end": TokenType.kwEnd,
"return": TokenType.kwReturn,
"let": TokenType.kwLet,
"int": TokenType.kwInt,
"returns": TokenType.kwReturns
]

export type Lexer
	let source string
	var pos StringIndex
	var line int
	var column int

	export static function create(source string) returns Lexer
		return Lexer{source: source, pos: source.startIndex(), line: 1, column: 1}
	end 'create'

	export function isAtEnd() returns bool
		return pos == source.endIndex()
	end 'isAtEnd'

	export function peek() returns character or nil
		if isAtEnd() 'eof'
			return nil
		end 'eof'
		return source.charAt(pos)
	end 'peek'

	export function advance() returns character or nil
		let c = peek() or 'eof'
			return nil
		end 'eof'

		if let nextpos = source.indexAfter(pos) 'got_next'
			pos = nextpos
		end 'got_next'

		if c == '\n' 'newline'
			line = line + 1
			column = 1
		end 'newline' else 'notNewline'
			column = column + 1
		end 'notNewline'

		return c
	end 'advance'

	export function skipWhitespace()
		while not isAtEnd() 'loop'
			let c = peek() or 'done'
				return
			end 'done'
			if c == ' ' or c == '\t' 'ws'
				advance()
			end 'ws' else 'notWs'
				return
			end 'notWs'
		end 'loop'
	end 'skipWhitespace'

	export function isDigit(c character) returns bool
		return c >= '0' and c <= '9'
	end 'isDigit'

	export function isAlpha(c character) returns bool
		return (c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or c == '_'
	end 'isAlpha'

	export function isAlphaNumeric(c character) returns bool
		return isDigit(c) or isAlpha(c)
	end 'isAlphaNumeric'

	export function keywordOrIdentifier(lexeme string) returns TokenType
		let result = keywords.get(lexeme) or 'notFound'
			return TokenType.identifier
		end 'notFound'
		return result
	end 'keywordOrIdentifier'

	export function scanIdentifier() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		while not isAtEnd() 'scan'
			let c = peek() or 'done'
				break 'scan'
			end 'done'
			if not isAlphaNumeric(c) 'notAlphaNum'
				break 'scan'
			end 'notAlphaNum'
			advance()
		end 'scan'

		let lexeme = source.slice(startPos, pos).toString()
		let kind = keywordOrIdentifier(lexeme)
		return makeToken(kind, lexeme, startLine, startColumn)
	end 'scanIdentifier'

	export function scanNumber() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		while not isAtEnd() 'intPart'
			let c = peek() or 'done'
				break 'intPart'
			end 'done'
			if not isDigit(c) 'notDigit'
				break 'intPart'
			end 'notDigit'
			advance()
		end 'intPart'

		let lexeme = source.slice(startPos, pos).toString()
		return makeToken(TokenType.intLiteral, lexeme, startLine, startColumn)
	end 'scanNumber'

	export function scanBlockLabel() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		advance()  // consume opening quote

		while not isAtEnd() 'content'
			let c = peek() or 'done'
				break 'content'
			end 'done'
			if c == '\'' 'closeQuote'
				break 'content'
			end 'closeQuote'
			advance()
		end 'content'

		if not isAtEnd() 'closeQuote'
			advance()
		end 'closeQuote'

		let lexeme = source.slice(startPos, pos).toString()
		return makeToken(TokenType.blockLabel, lexeme, startLine, startColumn)
	end 'scanBlockLabel'

	export function nextToken() returns Token
		skipWhitespace()

		if isAtEnd() 'eof'
			return makeToken(TokenType.eof, "", line, column)
		end 'eof'

		let startLine = line
		let startColumn = column
		let startPos = pos
		let c = advance() or 'unexpected_eof'
			return makeToken(TokenType.eof, "", line, column)
		end 'unexpected_eof'

		if isAlpha(c) 'alpha'
			pos = startPos
			column = startColumn
			return scanIdentifier()
		end 'alpha'

		if isDigit(c) 'digit'
			pos = startPos
			column = startColumn
			return scanNumber()
		end 'digit'

		if c == '\'' 'quote'
			pos = startPos
			column = startColumn
			return scanBlockLabel()
		end 'quote'

		if c == '(' 'lparen'
			return makeToken(TokenType.lparen, "(", startLine, startColumn)
		end 'lparen'

		if c == ')' 'rparen'
			return makeToken(TokenType.rparen, ")", startLine, startColumn)
		end 'rparen'

		if c == '=' 'equals'
			return makeToken(TokenType.equals, "=", startLine, startColumn)
		end 'equals'

		if c == '\n' 'newline'
			return makeToken(TokenType.newline, "\n", startLine, startColumn)
		end 'newline'

		return makeToken(TokenType.error, "{c}", startLine, startColumn)
	end 'nextToken'

	export function tokenize() returns array of Token
		var tokens = array of Token

		while true 'loop'
			let tok = nextToken()
			tokens.push(tok)

			if tok.kind == TokenType.eof 'done'
				break 'loop'
			end 'done'
		end 'loop'

		return tokens
	end 'tokenize'
end 'Lexer'










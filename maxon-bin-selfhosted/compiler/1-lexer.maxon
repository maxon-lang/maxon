// Maxon Compiler - Lexer (Stage 1)
// Tokenizes source code into a stream of tokens

export enum TokenType
	function
	returns
	return
	end
	int
	identifier
	integer
	charLiteral
	lparen
	rparen
	newline
	eof
end 'TokenType'

export enum KeywordCategory
	control
	other
	logical
	constant
	type_keyword
end 'KeywordCategory'

export type KeywordInfo
	export var text String
	export var category KeywordCategory
	export var description String
	export var requiresLabel bool
end 'KeywordInfo'

typealias TokenTypeMap is Map with (TokenType, KeywordInfo)

export let keyword_map = [
	TokenType.function: KeywordInfo{text: "function", category: KeywordCategory.other, description: "Declares a function. Functions contain executable code and can return values.", requiresLabel: false},
	TokenType.returns: KeywordInfo{text: "returns", category: KeywordCategory.other, description: "Specifies the return type of a function.", requiresLabel: false},
	TokenType.return: KeywordInfo{text: "return", category: KeywordCategory.control, description: "Returns a value from a function and exits the function.", requiresLabel: false},
	TokenType.end: KeywordInfo{text: "end", category: KeywordCategory.control, description: "Ends a block (function, type, if, for, while, etc.). Must be followed by the block's label in quotes.", requiresLabel: true}
]

/// A single token with type, text, and position
export type Token
	export var tokenType TokenType
	export var text String
	export var line int
	export var column int

	export static function create(tokenType TokenType, text String, line int, column int) returns Token
		return {tokenType: tokenType, text: text, line: line, column: column}
	end 'create'
end 'Token'

export typealias TokenArray is Array with Token

/// Lexer state for tokenizing source code
export type Lexer
	var source String
	var sourceFile String
	var pos int
	var line int
	var column int
	export var errors ErrorCollector

	export static function init(source String, sourceFile String) returns Lexer
		return {source: source, sourceFile: sourceFile, pos: 0, line: 1, column: 1, errors: ErrorCollector.create()}
	end 'init'

	export function tokenize() returns TokenArray
		var tokens = TokenArray{}

		while not isAtEnd() 'mainLoop'
			skipWhitespaceExceptNewline()

			if isAtEnd() 'checkEnd'
				break 'mainLoop'
			end 'checkEnd'

			let c = peek()

			match c 'dispatch'
			'\n' then tokens.push(scanNewline())
			'(' then tokens.push(scanSingleChar(TokenType.lparen, text: "("))
			')' then tokens.push(scanSingleChar(TokenType.rparen, text: ")"))
			'\'' then tokens.push(scanCharLiteral())
			'/' then scanSlashOrComment(tokens)
			default then scanDefaultCase(c, tokens: tokens)
			end 'dispatch'
		end 'mainLoop'

		tokens.push(makeToken(TokenType.eof, text: ""))

		return tokens
	end 'tokenize'

	function scanNewline() returns Token
		let tok = makeToken(TokenType.newline, text: "\n")
		advance()
		line = line + 1
		column = 1
		return tok
	end 'scanNewline'

	function scanSingleChar(tokenType TokenType, text String) returns Token
		let tok = makeToken(tokenType, text: text)
		advance()
		return tok
	end 'scanSingleChar'

	function scanSlashOrComment(tokens TokenArray)
		if peekNext() == '/' 'isComment'
			skipToEndOfLine()
		end 'isComment' else 'notComment'
			// Future: tokens.push(scanSingleChar(TokenType.slash, text: "/"))
			advance()
		end 'notComment'
	end 'scanSlashOrComment'

	function scanDefaultCase(c Character, tokens TokenArray)
		if isDigit(c) 'number'
			tokens.push(scanNumber())
		end 'number' else 'notNumber'
			if isIdentifierStart(c) 'ident'
				tokens.push(scanIdentifierOrKeyword())
			end 'ident' else 'notIdent'
				errors.addErrorAt(ErrorCode.E1001, message: "invalid character", file: sourceFile, line: line, column: column)
				advance()
			end 'notIdent'
		end 'notNumber'
	end 'scanDefaultCase'

	function isAtEnd() returns bool
		return pos >= source.byteLength()
	end 'isAtEnd'

	function peek() returns Character
		if isAtEnd() 'atEnd'
			return '\0'
		end 'atEnd'
		return source.charAt(byteIndexToStringIndex(pos))
	end 'peek'

	function peekNext() returns Character
		let nextPos = pos + 1
		if nextPos >= source.byteLength() 'atEnd'
			return '\0'
		end 'atEnd'
		return source.charAt(byteIndexToStringIndex(nextPos))
	end 'peekNext'

	function byteIndexToStringIndex(byteIdx int) returns StringIndex
		var idx = source.startIndex()
		var i = 0
		while i < byteIdx 'walk'
			if let nextIdx = try source.indexAfter(idx) 'getNext'
				idx = nextIdx
			end 'getNext' else 'noMore'
				break 'walk'
			end 'noMore'
			i = i + 1
		end 'walk'
		return idx
	end 'byteIndexToStringIndex'

	function advance() returns Character
		if isAtEnd() 'atEnd'
			return '\0'
		end 'atEnd'
		let c = peek()
		pos = pos + 1
		column = column + 1
		return c
	end 'advance'

	function skipWhitespaceExceptNewline()
		while not isAtEnd() 'skipLoop'
			let c = peek()
			if c == ' ' or c == '\t' or c == '\r' 'isWhitespace'
				advance()
			end 'isWhitespace' else 'notWhitespace'
				break 'skipLoop'
			end 'notWhitespace'
		end 'skipLoop'
	end 'skipWhitespaceExceptNewline'

	function skipToEndOfLine()
		while not isAtEnd() and peek() != '\n' 'skipLoop'
			advance()
		end 'skipLoop'
	end 'skipToEndOfLine'

	function makeToken(tokenType TokenType, text String) returns Token
		return Token.create(tokenType, text: text, line: line, column: column)
	end 'makeToken'

	function scanCharLiteral() returns Token
		let startCol = column
		advance()
		let textStart = pos
		while not isAtEnd() and peek() != '\'' 'collectChars'
			advance()
		end 'collectChars'
		let text = extractSubstring(textStart, endPos: pos)
		if not isAtEnd() and peek() == '\'' 'hasClose'
			advance()
		end 'hasClose' else 'noClose'
			errors.addErrorAt(ErrorCode.E1002, message: "unterminated character literal", file: sourceFile, line: line, column: startCol)
		end 'noClose'
		return Token.create(TokenType.charLiteral, text: text, line: line, column: startCol)
	end 'scanCharLiteral'

	function scanNumber() returns Token
		let startCol = column
		let startPos = pos
		while not isAtEnd() and isDigit(peek()) 'digits'
			advance()
		end 'digits'
		let text = extractSubstring(startPos, endPos: pos)
		return Token.create(TokenType.integer, text: text, line: line, column: startCol)
	end 'scanNumber'

	function scanIdentifierOrKeyword() returns Token
		let startCol = column
		let startPos = pos
		advance()
		while not isAtEnd() and isIdentifierContinue(peek()) 'identChars'
			advance()
		end 'identChars'
		let text = extractSubstring(startPos, endPos: pos)
		let tokType = getKeywordType(text)
		return Token.create(tokType, text: text, line: line, column: startCol)
	end 'scanIdentifierOrKeyword'

	function extractSubstring(startPos int, endPos int) returns String
		let startIdx = byteIndexToStringIndex(startPos)
		let endIdx = byteIndexToStringIndex(endPos)
		return source.slice(startIdx, endIndex: endIdx)
	end 'extractSubstring'

	function isDigit(c Character) returns bool
		return c >= '0' and c <= '9'
	end 'isDigit'

	function isIdentifierStart(c Character) returns bool
		return (c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or c == '_'
	end 'isIdentifierStart'

	function isIdentifierContinue(c Character) returns bool
		return (c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or (c >= '0' and c <= '9') or c == '_'
	end 'isIdentifierContinue'

	function getKeywordType(text String) returns TokenType
		return match text 'keyword'
			"function" gives TokenType.keywordFunction
			"returns" gives TokenType.keywordReturns
			"return" gives TokenType.keywordReturn
			"end" gives TokenType.keywordEnd
			"int" gives TokenType.keywordInt
			default gives TokenType.identifier
		end 'keyword'
	end 'getKeywordType'
end 'Lexer'

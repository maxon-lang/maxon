// Lexer for the Maxon language (minimal version for basic.maxon)

export enum TokenType
	// Keywords
	kwFunction
	kwReturns
	kwReturn
	kwEnd
	kwInt

	// Literals
	identifier
	integer
	charLiteral

	// Punctuation
	lparen
	rparen

	// Formatting
	newline

	// Special
	eof
end 'TokenType'

export type Token
	export let kind TokenType
	export let text String
	export let line int
	export let column int
end 'Token'

export type Lexer
	let source String
	var pos StringIndex
	var line int
	var column int

	export static function init(source String) returns Lexer
		return Lexer{source: source, pos: source.startIndex(), line: 1, column: 1}
	end 'init'

	export function tokenize() returns Array of Token
		var tokens = Array of Token{}

		while pos != source.endIndex() 'mainLoop'
			skipWhitespaceExceptNewline()
			if pos == source.endIndex() 'done'
				break 'mainLoop'
			end 'done'

			let c = source.charAt(pos)

			// Newline
			if c == '\n' 'newline'
				tokens.push(Token{kind: TokenType.newline, text: "\n", line: line, column: column})
				pos = try source.indexAfter(pos) otherwise pos
				line = line + 1
				column = 1
				continue 'mainLoop'
			end 'newline'

			// Skip comments
			let nextPos = try source.indexAfter(pos) otherwise pos
			if c == '/' and nextPos != source.endIndex() and source.charAt(nextPos) == '/' 'comment'
				while pos != source.endIndex() and source.charAt(pos) != '\n' 'skipComment'
					pos = try source.indexAfter(pos) otherwise pos
					column = column + 1
				end 'skipComment'
				continue 'mainLoop'
			end 'comment'

			// Single character tokens
			if c == '(' 'lparen'
				tokens.push(Token{kind: TokenType.lparen, text: "(", line: line, column: column})
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
				continue 'mainLoop'
			end 'lparen'

			if c == ')' 'rparen'
				tokens.push(Token{kind: TokenType.rparen, text: ")", line: line, column: column})
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
				continue 'mainLoop'
			end 'rparen'

			// Character literal (single quotes) - used for end labels like 'main'
			if c == '\'' 'charLit'
				let startCol = column
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
				let start = pos
				while pos != source.endIndex() and source.charAt(pos) != '\'' 'scanChar'
					pos = try source.indexAfter(pos) otherwise pos
					column = column + 1
				end 'scanChar'
				let text = source.slice(start, endIndex: pos)
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
				tokens.push(Token{kind: TokenType.charLiteral, text: text, line: line, column: startCol})
				continue 'mainLoop'
			end 'charLit'

			// Number literal
			if isDigit(c) 'number'
				let start = pos
				let startCol = column
				while pos != source.endIndex() and isDigit(source.charAt(pos)) 'scanDigits'
					pos = try source.indexAfter(pos) otherwise pos
					column = column + 1
				end 'scanDigits'
				let text = source.slice(start, endIndex: pos)
				tokens.push(Token{kind: TokenType.integer, text: text, line: line, column: startCol})
				continue 'mainLoop'
			end 'number'

			// Identifier or keyword
			if isIdentifierStart(c) 'ident'
				let start = pos
				let startCol = column
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
				while pos != source.endIndex() and isIdentifierContinue(source.charAt(pos)) 'scanIdent'
					pos = try source.indexAfter(pos) otherwise pos
					column = column + 1
				end 'scanIdent'
				let text = source.slice(start, endIndex: pos)
				let tokenType = getKeyword(text)
				tokens.push(Token{kind: tokenType, text: text, line: line, column: startCol})
				continue 'mainLoop'
			end 'ident'

			// Unknown character - skip
			pos = try source.indexAfter(pos) otherwise pos
			column = column + 1
		end 'mainLoop'

		tokens.push(Token{kind: TokenType.eof, text: "", line: line, column: column})
		return tokens
	end 'tokenize'

	function skipWhitespaceExceptNewline()
		while pos != source.endIndex() 'loop'
			let c = source.charAt(pos)
			if c == ' ' or c == '\t' or c == '\r' 'ws'
				pos = try source.indexAfter(pos) otherwise pos
				column = column + 1
			end 'ws' else 'done'
				break 'loop'
			end 'done'
		end 'loop'
	end 'skipWhitespaceExceptNewline'

	function isDigit(c Character) returns bool
		return c >= '0' and c <= '9'
	end 'isDigit'

	function isIdentifierStart(c Character) returns bool
		return (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z') or c == '_'
	end 'isIdentifierStart'

	function isIdentifierContinue(c Character) returns bool
		return isIdentifierStart(c) or isDigit(c)
	end 'isIdentifierContinue'

	function getKeyword(text String) returns TokenType
		if text == "function" 'kw1'
			return TokenType.kwFunction
		end 'kw1'
		if text == "returns" 'kw2'
			return TokenType.kwReturns
		end 'kw2'
		if text == "return" 'kw3'
			return TokenType.kwReturn
		end 'kw3'
		if text == "end" 'kw4'
			return TokenType.kwEnd
		end 'kw4'
		if text == "int" 'kw5'
			return TokenType.kwInt
		end 'kw5'
		return TokenType.identifier
	end 'getKeyword'
end 'Lexer'

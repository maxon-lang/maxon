// Lexer for the Maxon language

let keywords = [
"function": TokenType.kwFunction,
"end": TokenType.kwEnd,
"return": TokenType.kwReturn,
"let": TokenType.kwLet,
"int": TokenType.kwInt,
"returns": TokenType.kwReturns
]

export type Lexer
	var source string
	var chars array of character
	var pos int
	var line int
	var column int

	export function create(source string) returns Lexer
		var charArray = source.chars()
		return Lexer{source: source, chars: charArray, pos: 0, line: 1, column: 1}
	end 'create'

	export function isAtEnd() returns bool
		return pos >= chars.count()
	end 'isAtEnd'

	export function peek() returns character
		if isAtEnd() 'eof'
			return '\0'
		end 'eof'
		return chars[pos]
	end 'peek'

	export function advance() returns character
		var c = peek()
		pos = pos + 1
		if c == '\n' 'newline'
			line = line + 1
			column = 1
		end 'newline' else 'notNewline'
			column = column + 1
		end 'notNewline'
		return c
	end 'advance'

	export function skipWhitespace() returns nothing
		while not isAtEnd() 'loop'
			var c = peek()
			if c == ' ' or c == '\t' 'ws'
				advance()
			end 'ws' else 'notWs'
				return
			end 'notWs'
		end 'loop'
	end 'skipWhitespace'

	export function isDigit(c character) returns bool
		return c >= '0' and c <= '9'
	end 'isDigit'

	export function isAlpha(c character) returns bool
		return (c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or c == '_'
	end 'isAlpha'

	export function isAlphaNumeric(c character) returns bool
		return isDigit(c) or isAlpha(c)
	end 'isAlphaNumeric'

	export function buildLexeme(startPos int, endPos int) returns string
		var result = ""
		var i = startPos
		while i < endPos 'build'
			result = "{result}{chars[i]}"
			i = i + 1
		end 'build'
		return result
	end 'buildLexeme'

	export function keywordOrIdentifier(lexeme string) returns TokenType
		if keywords.contains(lexeme) 'found'
			return keywords.get(lexeme)
		end 'found'
		return TokenType.identifier
	end 'keywordOrIdentifier'

	export function scanIdentifier() returns Token
		var startPos = pos
		var startLine = line
		var startColumn = column

		while not isAtEnd() and isAlphaNumeric(peek()) 'scan'
			advance()
		end 'scan'

		var lexeme = buildLexeme(startPos, pos)
		var kind = keywordOrIdentifier(lexeme)
		return makeToken(kind, lexeme, startLine, startColumn)
	end 'scanIdentifier'

	export function scanNumber() returns Token
		var startPos = pos
		var startLine = line
		var startColumn = column

		while isDigit(peek()) 'intPart'
			advance()
		end 'intPart'

		var lexeme = buildLexeme(startPos, pos)
		return makeToken(TokenType.intLiteral, lexeme, startLine, startColumn)
	end 'scanNumber'

	export function scanBlockLabel() returns Token
		var startPos = pos
		var startLine = line
		var startColumn = column

		advance()  // consume opening quote

		while not isAtEnd() and peek() != '\'' 'content'
			advance()
		end 'content'

		if not isAtEnd() 'closeQuote'
			advance()
		end 'closeQuote'

		var lexeme = buildLexeme(startPos, pos)
		return makeToken(TokenType.blockLabel, lexeme, startLine, startColumn)
	end 'scanBlockLabel'

	export function nextToken() returns Token
		skipWhitespace()

		if isAtEnd() 'eof'
			return makeToken(TokenType.eof, "", line, column)
		end 'eof'

		var startLine = line
		var startColumn = column
		var c = advance()

		if isAlpha(c) 'alpha'
			pos = pos - 1
			column = column - 1
			return scanIdentifier()
		end 'alpha'

		if isDigit(c) 'digit'
			pos = pos - 1
			column = column - 1
			return scanNumber()
		end 'digit'

		if c == '\'' 'quote'
			pos = pos - 1
			column = column - 1
			return scanBlockLabel()
		end 'quote'

		if c == '(' 'lparen'
			return makeToken(TokenType.lparen, "(", startLine, startColumn)
		end 'lparen'

		if c == ')' 'rparen'
			return makeToken(TokenType.rparen, ")", startLine, startColumn)
		end 'rparen'

		if c == '=' 'equals'
			return makeToken(TokenType.equals, "=", startLine, startColumn)
		end 'equals'

		if c == '\n' 'newline'
			return makeToken(TokenType.newline, "\n", startLine, startColumn)
		end 'newline'

		return makeToken(TokenType.error, c.toString(), startLine, startColumn)
	end 'nextToken'

	export function tokenize() returns array of Token
		var tokens = array of Token

		while true 'loop'
			var tok = nextToken()
			tokens.push(tok)

			if tok.kind == TokenType.eof 'done'
				break 'loop'
			end 'done'
		end 'loop'

		return tokens
	end 'tokenize'
end 'Lexer'







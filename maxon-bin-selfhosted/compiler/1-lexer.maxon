// Lexer for the Maxon language

export type Lexer
	let source String
	var pos StringIndex
	var line int
	var column int

	export static function create(source String) returns Lexer
		// Workaround: pre-compute startIndex() into local variable.
		// Using source.startIndex() inline causes incorrect struct initialization in multi-file builds.
		var startIdx = source.startIndex()
		return Lexer{source: source, pos: startIdx, line: 1, column: 1}
	end 'create'

	export function isAtEnd() returns bool
		return pos == source.endIndex()
	end 'isAtEnd'

	export function peek() returns Character or nil
		if isAtEnd() 'eof'
			return nil
		end 'eof'
		return source.charAt(pos)
	end 'peek'

	export function advance() returns Character or nil
		let c = peek() or 'eof'
			return nil
		end 'eof'

		let maybeNext = source.indexAfter(pos)
		if let nextpos = maybeNext 'got_next'
			var mutablePos = nextpos
			pos = mutablePos
		end 'got_next'

		// Check for newline - handle both LF and CRLF (which is a single grapheme)
		if isNewlineChar(c) 'newline'
			line = line + 1
			column = 1
		end 'newline' else 'notNewline'
			column = column + 1
		end 'notNewline'

		return c
	end 'advance'

	// Helper to check if character is a newline (LF or CRLF grapheme)
	function isNewlineChar(c Character) returns bool
		return c == '\n' or c == '\r\n'
	end 'isNewlineChar'

	export function skipWhitespace()
		while not isAtEnd() 'loop'
			let c = peek() or 'done'
				return
			end 'done'
			if c == ' ' or c == '\t' 'ws'
				advance()
			end 'ws' else 'notWs'
				return
			end 'notWs'
		end 'loop'
	end 'skipWhitespace'

	export function isDigit(c Character) returns bool
		return c >= '0' and c <= '9'
	end 'isDigit'

	export function isAlpha(c Character) returns bool
		return (c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z') or c == '_'
	end 'isAlpha'

	export function isAlphaNumeric(c Character) returns bool
		return isDigit(c) or isAlpha(c)
	end 'isAlphaNumeric'

	export function keywordOrIdentifier(lexeme String) returns TokenType
		// Use if-else chain instead of global map to avoid potential global init issues
		if lexeme == "function" 'kw'
			return TokenType.kwFunction
		end 'kw'
		if lexeme == "end" 'kw2'
			return TokenType.kwEnd
		end 'kw2'
		if lexeme == "return" 'kw3'
			return TokenType.kwReturn
		end 'kw3'
		if lexeme == "let" 'kw4'
			return TokenType.kwLet
		end 'kw4'
		if lexeme == "int" 'kw5'
			return TokenType.kwInt
		end 'kw5'
		if lexeme == "returns" 'kw6'
			return TokenType.kwReturns
		end 'kw6'
		return TokenType.identifier
	end 'keywordOrIdentifier'

	export function scanIdentifier() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		while not isAtEnd() 'scan'
			let c = peek() or 'done'
				break 'scan'
			end 'done'
			if not isAlphaNumeric(c) 'notAlphaNum'
				break 'scan'
			end 'notAlphaNum'
			advance()
		end 'scan'

		let lexeme = source.slice(startPos, pos, nil)
		let kind = keywordOrIdentifier(lexeme)
		return makeToken(kind, lexeme, startLine, startColumn)
	end 'scanIdentifier'

	export function scanNumber() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		while not isAtEnd() 'intPart'
			let c = peek() or 'done'
				break 'intPart'
			end 'done'
			if not isDigit(c) 'notDigit'
				break 'intPart'
			end 'notDigit'
			advance()
		end 'intPart'

		let lexeme = source.slice(startPos, pos, nil)
		return makeToken(TokenType.intLiteral, lexeme, startLine, startColumn)
	end 'scanNumber'

	export function scanBlockLabel() returns Token
		let startPos = pos
		let startLine = line
		let startColumn = column

		advance()  // consume opening quote

		while not isAtEnd() 'content'
			let c = peek() or 'done'
				break 'content'
			end 'done'
			if c == '\'' 'closeQuote'
				break 'content'
			end 'closeQuote'
			advance()
		end 'content'

		if not isAtEnd() 'closeQuote'
			advance()
		end 'closeQuote'

		let lexeme = source.slice(startPos, pos, nil)
		return makeToken(TokenType.blockLabel, lexeme, startLine, startColumn)
	end 'scanBlockLabel'

	export function nextToken() returns Token
		skipWhitespace()

		if isAtEnd() 'eof'
			return makeToken(TokenType.eof, "", line, column)
		end 'eof'

		let startLine = line
		var startColumn = column
		var startPos = pos
		let c = advance() or 'unexpected_eof'
			return makeToken(TokenType.eof, "", line, column)
		end 'unexpected_eof'

		if isAlpha(c) 'alpha'
			pos = startPos
			column = startColumn
			return scanIdentifier()
		end 'alpha'

		if isDigit(c) 'digit'
			pos = startPos
			column = startColumn
			return scanNumber()
		end 'digit'

		if c == '\'' 'quote'
			pos = startPos
			column = startColumn
			return scanBlockLabel()
		end 'quote'

		if c == '(' 'lparen'
			return makeToken(TokenType.lparen, "(", startLine, startColumn)
		end 'lparen'

		if c == ')' 'rparen'
			return makeToken(TokenType.rparen, ")", startLine, startColumn)
		end 'rparen'

		if c == '=' 'equals'
			return makeToken(TokenType.equals, "=", startLine, startColumn)
		end 'equals'

		// Handle newlines (LF or CRLF grapheme cluster)
		if isNewlineChar(c) 'newline'
			return makeToken(TokenType.newline, "\n", startLine, startColumn)
		end 'newline'

		return makeToken(TokenType.error, "{c}", startLine, startColumn)
	end 'nextToken'

	export function tokenize() returns Array of Token
		var tokens = Array of Token{}

		while true 'loop'
			let tok = nextToken()
			tokens.push(tok)

			if tok.kind == TokenType.eof 'done'
				break 'loop'
			end 'done'
		end 'loop'

		return tokens
	end 'tokenize'
end 'Lexer'











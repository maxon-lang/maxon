// Maxon Compiler - Lexer (Stage 1)
// Tokenizes source code into a stream of tokens

export enum TokenType
	// Keywords
	keywordFunction
	keywordReturns
	keywordReturn
	keywordEnd
	keywordInt
	keywordFloat
	keywordBool
	keywordByte
	keywordString
	keywordLet
	keywordVar
	keywordIf
	keywordElse
	keywordWhile
	keywordFor
	keywordBreak
	keywordContinue
	keywordTrue
	keywordFalse
	keywordAnd
	keywordOr
	keywordNot
	keywordMod
	keywordIn
	keywordExport

	// Literals
	identifier
	integer
	float
	string
	charLiteral

	// Operators
	plus
	minus
	star
	slash
	assign
	equalEqual
	notEqual
	less
	lessEqual
	greater
	greaterEqual
	comma
	colon
	dot

	// Delimiters
	lparen
	rparen
	lbrace
	rbrace
	lbracket
	rbracket

	// Special
	newline
	eof
	errorToken    // For error-tolerant lexing
end 'TokenType'

export enum KeywordCategory
	control
	other
	logical
	constant
	type_keyword
end 'KeywordCategory'

export type KeywordInfo
	export var text String
	export var category KeywordCategory
	export var description String
	export var requiresLabel bool
end 'KeywordInfo'

typealias TokenTypeMap is Map with (TokenType, KeywordInfo)

export let keyword_map = [
	TokenType.keywordFunction: KeywordInfo{text: "function", category: KeywordCategory.other, description: "Declares a function.", requiresLabel: false},
	TokenType.keywordReturns: KeywordInfo{text: "returns", category: KeywordCategory.other, description: "Specifies the return type of a function.", requiresLabel: false},
	TokenType.keywordReturn: KeywordInfo{text: "return", category: KeywordCategory.control, description: "Returns a value from a function.", requiresLabel: false},
	TokenType.keywordEnd: KeywordInfo{text: "end", category: KeywordCategory.control, description: "Ends a block.", requiresLabel: true},
	TokenType.keywordLet: KeywordInfo{text: "let", category: KeywordCategory.other, description: "Declares an immutable variable.", requiresLabel: false},
	TokenType.keywordVar: KeywordInfo{text: "var", category: KeywordCategory.other, description: "Declares a mutable variable.", requiresLabel: false},
	TokenType.keywordIf: KeywordInfo{text: "if", category: KeywordCategory.control, description: "Conditional statement.", requiresLabel: true},
	TokenType.keywordElse: KeywordInfo{text: "else", category: KeywordCategory.control, description: "Alternative branch.", requiresLabel: false},
	TokenType.keywordWhile: KeywordInfo{text: "while", category: KeywordCategory.control, description: "Loop statement.", requiresLabel: true},
	TokenType.keywordFor: KeywordInfo{text: "for", category: KeywordCategory.control, description: "Iterator loop.", requiresLabel: true},
	TokenType.keywordBreak: KeywordInfo{text: "break", category: KeywordCategory.control, description: "Exit a loop.", requiresLabel: false},
	TokenType.keywordContinue: KeywordInfo{text: "continue", category: KeywordCategory.control, description: "Skip to next iteration.", requiresLabel: false}
]

/// A single token with type, text, and position
export type Token
	export var tokenType TokenType
	export var text String
	export var line int
	export var column int

	export static function create(tokenType TokenType, text String, line int, column int) returns Token
		return {tokenType: tokenType, text: text, line: line, column: column}
	end 'create'
end 'Token'

export typealias TokenArray is Array with Token

/// Lexer state for tokenizing source code
export type Lexer
	var source String
	var sourceFile String
	var pos int
	var line int
	var column int
	export var errors ErrorCollector

	export static function init(source String, sourceFile String) returns Lexer
		return {source: source, sourceFile: sourceFile, pos: 0, line: 1, column: 1, errors: ErrorCollector.create()}
	end 'init'

	export function tokenize() returns TokenArray
		var tokens = TokenArray{}

		while not isAtEnd() 'mainLoop'
			skipWhitespaceExceptNewline()

			if isAtEnd() 'checkEnd'
				break 'mainLoop'
			end 'checkEnd'

			let c = peek()

			match c 'dispatch'
			'\n' then tokens.push(scanNewline())
			'(' then tokens.push(scanSingleChar(TokenType.lparen, text: "("))
			')' then tokens.push(scanSingleChar(TokenType.rparen, text: ")"))
			'{' then tokens.push(scanSingleChar(TokenType.lbrace, text: "\{"))
			'}' then tokens.push(scanSingleChar(TokenType.rbrace, text: "}"))
			'[' then tokens.push(scanSingleChar(TokenType.lbracket, text: "["))
			']' then tokens.push(scanSingleChar(TokenType.rbracket, text: "]"))
			',' then tokens.push(scanSingleChar(TokenType.comma, text: ","))
			':' then tokens.push(scanSingleChar(TokenType.colon, text: ":"))
			'.' then tokens.push(scanSingleChar(TokenType.dot, text: "."))
			'+' then tokens.push(scanSingleChar(TokenType.plus, text: "+"))
			'-' then tokens.push(scanSingleChar(TokenType.minus, text: "-"))
			'*' then tokens.push(scanSingleChar(TokenType.star, text: "*"))
			'/' then scanSlashOrComment(tokens)
			'=' then scanEquals(tokens)
			'!' then scanBang(tokens)
			'<' then scanLess(tokens)
			'>' then scanGreater(tokens)
			'\'' then tokens.push(scanCharLiteral())
			'"' then tokens.push(scanString())
			'0'..='9' then tokens.push(scanNumber())
			'a'..='z' or 'A'..='Z' or '_' then tokens.push(scanIdentifierOrKeyword())
			default then tokens.push(scanErrorToken())
			end 'dispatch'
		end 'mainLoop'

		tokens.push(makeToken(TokenType.eof, text: ""))

		return tokens
	end 'tokenize'

	function scanErrorToken() returns Token
		let tok = makeToken(TokenType.errorToken, text: "")
		errors.addErrorAt(ErrorCode.E1001, message: "invalid character", file: sourceFile, line: line, column: column)
		advance()
		return tok
	end 'scanErrorToken'

	function scanNewline() returns Token
		let tok = makeToken(TokenType.newline, text: "\n")
		advance()
		line = line + 1
		column = 1
		return tok
	end 'scanNewline'

	function scanSingleChar(tokenType TokenType, text String) returns Token
		let tok = makeToken(tokenType, text: text)
		advance()
		return tok
	end 'scanSingleChar'

	function scanSlashOrComment(tokens TokenArray)
		if peekNext() == '/' 'isComment'
			skipToEndOfLine()
		end 'isComment' else 'notComment'
			tokens.push(scanSingleChar(TokenType.slash, text: "/"))
		end 'notComment'
	end 'scanSlashOrComment'

	function scanEquals(tokens TokenArray)
		if peekNext() == '=' 'isEqualEqual'
			let tok = makeToken(TokenType.equalEqual, text: "==")
			advance()
			advance()
			tokens.push(tok)
		end 'isEqualEqual' else 'isAssign'
			tokens.push(scanSingleChar(TokenType.assign, text: "="))
		end 'isAssign'
	end 'scanEquals'

	function scanBang(tokens TokenArray)
		if peekNext() == '=' 'isNotEqual'
			let tok = makeToken(TokenType.notEqual, text: "!=")
			advance()
			advance()
			tokens.push(tok)
		end 'isNotEqual' else 'error'
			// Bare ! is not valid - 'not' is the keyword
			tokens.push(scanErrorToken())
		end 'error'
	end 'scanBang'

	function scanLess(tokens TokenArray)
		if peekNext() == '=' 'isLessEqual'
			let tok = makeToken(TokenType.lessEqual, text: "<=")
			advance()
			advance()
			tokens.push(tok)
		end 'isLessEqual' else 'isLess'
			tokens.push(scanSingleChar(TokenType.less, text: "<"))
		end 'isLess'
	end 'scanLess'

	function scanGreater(tokens TokenArray)
		if peekNext() == '=' 'isGreaterEqual'
			let tok = makeToken(TokenType.greaterEqual, text: ">=")
			advance()
			advance()
			tokens.push(tok)
		end 'isGreaterEqual' else 'isGreater'
			tokens.push(scanSingleChar(TokenType.greater, text: ">"))
		end 'isGreater'
	end 'scanGreater'

	function scanString() returns Token
		let startCol = column
		let startLine = line
		advance()  // skip opening "
		let textStart = pos
		while not isAtEnd() and peek() != '"' and peek() != '\n' 'collectChars'
			if peek() == '\\' 'isEscape'
				advance()  // skip backslash
				if not isAtEnd() 'hasEscaped'
					advance()  // skip escaped char
				end 'hasEscaped'
			end 'isEscape' else 'normalChar'
				advance()
			end 'normalChar'
		end 'collectChars'
		let text = extractSubstring(textStart, endPos: pos)
		if not isAtEnd() and peek() == '"' 'hasClose'
			advance()  // skip closing "
		end 'hasClose' else 'noClose'
			errors.addErrorAt(ErrorCode.E1002, message: "unterminated string literal", file: sourceFile, line: startLine, column: startCol)
		end 'noClose'
		return Token.create(TokenType.string, text: text, line: startLine, column: startCol)
	end 'scanString'

	function isAtEnd() returns bool
		return pos >= source.byteLength()
	end 'isAtEnd'

	function peek() returns Character
		if isAtEnd() 'atEnd'
			return '\0'
		end 'atEnd'
		return source.charAt(byteIndexToStringIndex(pos))
	end 'peek'

	function peekNext() returns Character
		let nextPos = pos + 1
		if nextPos >= source.byteLength() 'atEnd'
			return '\0'
		end 'atEnd'
		return source.charAt(byteIndexToStringIndex(nextPos))
	end 'peekNext'

	function byteIndexToStringIndex(byteIdx int) returns StringIndex
		var idx = source.startIndex()
		var i = 0
		while i < byteIdx 'walk'
			if let nextIdx = try source.indexAfter(idx) 'getNext'
				idx = nextIdx
			end 'getNext' else 'noMore'
				break 'walk'
			end 'noMore'
			i = i + 1
		end 'walk'
		return idx
	end 'byteIndexToStringIndex'

	function advance() returns Character
		if isAtEnd() 'atEnd'
			return '\0'
		end 'atEnd'
		let c = peek()
		pos = pos + 1
		column = column + 1
		return c
	end 'advance'

	function skipWhitespaceExceptNewline()
		while not isAtEnd() 'skipLoop'
			let c = peek()
			if c == ' ' or c == '\t' or c == '\r' 'isWhitespace'
				advance()
			end 'isWhitespace' else 'notWhitespace'
				break 'skipLoop'
			end 'notWhitespace'
		end 'skipLoop'
	end 'skipWhitespaceExceptNewline'

	function skipToEndOfLine()
		while not isAtEnd() and peek() != '\n' 'skipLoop'
			advance()
		end 'skipLoop'
	end 'skipToEndOfLine'

	function makeToken(tokenType TokenType, text String) returns Token
		return Token.create(tokenType, text: text, line: line, column: column)
	end 'makeToken'

	function scanCharLiteral() returns Token
		let startCol = column
		advance()
		let textStart = pos
		while not isAtEnd() and peek() != '\'' 'collectChars'
			advance()
		end 'collectChars'
		let text = extractSubstring(textStart, endPos: pos)
		if not isAtEnd() and peek() == '\'' 'hasClose'
			advance()
		end 'hasClose' else 'noClose'
			errors.addErrorAt(ErrorCode.E1002, message: "unterminated character literal", file: sourceFile, line: line, column: startCol)
		end 'noClose'
		return Token.create(TokenType.charLiteral, text: text, line: line, column: startCol)
	end 'scanCharLiteral'

	function scanNumber() returns Token
		let startCol = column
		let startPos = pos
		while not isAtEnd() and isDigit(peek()) 'digits'
			advance()
		end 'digits'

		// Check for decimal point (float)
		if peek() == '.' and isDigit(peekNext()) 'isFloat'
			advance()  // consume the dot
			while not isAtEnd() and isDigit(peek()) 'fracDigits'
				advance()
			end 'fracDigits'
			let text = extractSubstring(startPos, endPos: pos)
			return Token.create(TokenType.float, text: text, line: line, column: startCol)
		end 'isFloat'

		let text = extractSubstring(startPos, endPos: pos)
		return Token.create(TokenType.integer, text: text, line: line, column: startCol)
	end 'scanNumber'

	function scanIdentifierOrKeyword() returns Token
		let startCol = column
		let startPos = pos
		advance()
		while not isAtEnd() and isIdentifierContinue(peek()) 'identChars'
			advance()
		end 'identChars'
		let text = extractSubstring(startPos, endPos: pos)
		let tokType = getKeywordType(text)
		return Token.create(tokType, text: text, line: line, column: startCol)
	end 'scanIdentifierOrKeyword'

	function extractSubstring(startPos int, endPos int) returns String
		let startIdx = byteIndexToStringIndex(startPos)
		let endIdx = byteIndexToStringIndex(endPos)
		return source.slice(startIdx, endIndex: endIdx)
	end 'extractSubstring'

	function isDigit(c Character) returns bool
		return match c 'check'
			'0'..='9' gives true
			default gives false
		end 'check'
	end 'isDigit'

	function isIdentifierContinue(c Character) returns bool
		return match c 'check'
			'A'..='Z' or 'a'..='z' or '0'..='9' or '_' gives true
			default gives false
		end 'check'
	end 'isIdentifierContinue'

	function getKeywordType(text String) returns TokenType
		return match text 'keyword'
			"function" gives TokenType.keywordFunction
			"returns" gives TokenType.keywordReturns
			"return" gives TokenType.keywordReturn
			"end" gives TokenType.keywordEnd
			"let" gives TokenType.keywordLet
			"var" gives TokenType.keywordVar
			"if" gives TokenType.keywordIf
			"else" gives TokenType.keywordElse
			"while" gives TokenType.keywordWhile
			"for" gives TokenType.keywordFor
			"break" gives TokenType.keywordBreak
			"continue" gives TokenType.keywordContinue
			"true" gives TokenType.keywordTrue
			"false" gives TokenType.keywordFalse
			"and" gives TokenType.keywordAnd
			"or" gives TokenType.keywordOr
			"not" gives TokenType.keywordNot
			"mod" gives TokenType.keywordMod
			"in" gives TokenType.keywordIn
			"export" gives TokenType.keywordExport
			"int" gives TokenType.keywordInt
			"float" gives TokenType.keywordFloat
			"bool" gives TokenType.keywordBool
			"byte" gives TokenType.keywordByte
			"String" gives TokenType.keywordString
			default gives TokenType.identifier
		end 'keyword'
	end 'getKeywordType'
end 'Lexer'

// Maxon Command Line Tool
// Main entry point for the maxon toolchain

let VERSION = "0.3.0"

function main(args Array of String) returns int
	if args.count() < 2 'noCommand'
		printUsage()
		return 1
	end 'noCommand'

	let command = try args.get(1) otherwise ignore

	return match command 'dispatch'
	"compile" gives compileCommand(args)
	"run" gives runCommand(args)
	"version" gives versionCommand()
	"help" gives helpCommand()
	default gives unknownCommand(command)
	end 'dispatch'
end 'main'

function compileCommand(args Array of String) returns int
	if args.count() < 3 'noFile'
		print("Usage: maxon compile <file.maxon>")
		return 1
	end 'noFile'

	let sourcFiles = try args.get(2) otherwise ignore
	return compile(sourceFile)
end 'compileCommand'

function helpCommand() returns int
	printUsage()
	return 0
end 'helpCommand'

function unknownCommand(command String) returns int
	print("Unknown command: {command}")
	print("")
	printUsage()
	return 1
end 'unknownCommand'

function printUsage() returns int
	print("Maxon {VERSION}")
	print("")
	print("Usage: maxon <command> [options]")
	print("")
	print("Commands:")
	print("  compile <file.maxon>  Compile a Maxon source file")
	print("  run <file.maxon>      Compile and run a Maxon program")
	print("  version               Print version information")
	print("  help                  Show this help message")
	print("")
	print("Examples:")
	print("  maxon compile basic.maxon")
	print("  maxon run basic.maxon")
	return 0
end 'printUsage'

function versionCommand() returns int
	print("Maxon {VERSION}")
	print("Self-hosted compiler for Windows x86-64")
	return 0
end 'versionCommand'

function runCommand(args Array of String) returns int
	if args.count() < 3 'noFile'
		print("Usage: maxon run <file.maxon>")
		return 1
	end 'noFile'

	if let sourceFile = try args.get(2) 'hasFile'
		let result = compile(sourceFile)
		if result != 0 'compileFailed'
			return result
		end 'compileFailed'

		// Run the executable
		let exeFile = sourceFile.replace(".maxon", ".exe")
		print("")
		print("Running {exeFile}...")
		print("----------------------------------------")
		let exitCode = executeProcess(exeFile)
		print("----------------------------------------")
		print("Exit code: {exitCode}")

		return exitCode
	end 'hasFile' else 'noFile2'
		print("Usage: maxon run <file.maxon>")
		return 1
	end 'noFile2'
end 'runCommand'





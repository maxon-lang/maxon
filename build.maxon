typealias Timeout = int(0 to u64.max)

// Build a space-prefixed string of CLI args forwarded by `maxon run`,
// skipping argv[0] (the program path).
function forwardedArgs() returns String
	let allArgs = CommandLine.args()
	var result = ""
	for (iter, arg) in allArgs.withIterator() 'each'
		if iter.index() > 0 'skipExe'
			result.append(" {arg}")
		end 'skipExe'
	end 'each'
	return result
end 'forwardedArgs'

// Run a command with a status message, returning its exit code
function run(description String, command String, timeoutMs Timeout) returns ExitCode
	print("{description}...\n")
	let result = Process.execute(command, timeoutMs: timeoutMs)
	if result != 0 'failed'
		print("{description} failed\n")
		if result < 0 'error'
			return 1
		end 'error'
		return result
	end 'failed'
	return 0
end 'run'

// Build the C# bootstrap compiler (maxon-sharp)
export function build_sharp() returns ExitCode
	let result = run("Building maxon-sharp", command: "dotnet build maxon-sharp/MaxonSharp.csproj", timeoutMs: 120000)
	if result != 0 'failed'
		return result
	end 'failed'
	print("maxon-sharp built successfully\n")
	return 0
end 'build_sharp'

// Build the C# compiler and run its spec tests
export function spec_test_sharp() returns ExitCode
	let buildResult = build_sharp()
	if buildResult != 0 'failed'
		return buildResult
	end 'failed'

	let testResult = run("Running sharp spec tests", command: "./bin/maxon.exe spec-test{forwardedArgs()}", timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All sharp spec tests passed\n")
	return 0
end 'spec_test_sharp'

// Compile the self-hosted compiler using the bootstrap compiler
export function build_selfhosted() returns ExitCode
	let result = run("Compiling self-hosted compiler", command: "./bin/maxon.exe build maxon-selfhosted", timeoutMs: 120000)
	if result != 0 'failed'
		return result
	end 'failed'
	print("Self-hosted compiler built successfully\n")
	return 0
end 'build_selfhosted'

// Compile the self-hosted compiler and run its spec tests
export function spec_test_selfhosted() returns ExitCode
	let compileResult = build_selfhosted()
	if compileResult != 0 'failed'
		return compileResult
	end 'failed'

	let testResult = run("Running self-hosted spec tests", command: "./maxon-selfhosted/.maxon/maxon-selfhosted.exe spec-test{forwardedArgs()}", timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All self-hosted spec tests passed\n")
	return 0
end 'spec_test_selfhosted'

// Compile the self-hosted compiler and run its Wasm spec tests
export function spec_test_wasm() returns ExitCode
	let compileResult = build_selfhosted()
	if compileResult != 0 'failed'
		return compileResult
	end 'failed'

	let testResult = run("Running self-hosted Wasm spec tests", command: "./maxon-selfhosted/.maxon/maxon-selfhosted.exe spec-test --target=wasm32-wasi{forwardedArgs()}", timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All self-hosted Wasm spec tests passed\n")
	return 0
end 'spec_test_wasm'

typealias Timeout = int(0 to u64.max)

// Host-OS executable extension. The compiler produces ".exe"-suffixed binaries
// on Windows and no suffix on Linux/macOS; this constant keeps the runner's
// path literals correct on whichever OS built it.
#if os(Windows)
	let exeExt = ".exe"
#else
	let exeExt = ""
#endif

// Collect the CLI args forwarded by `maxon run`, skipping argv[0] (the
// program path itself). These are appended verbatim to each command we
// invoke, so flags like `--filter=foo` reach the inner spec-test runner.
function forwardedArgs() returns StringArray
	let allArgs = CommandLine.args()
	var result = StringArray.create()
	for (iter, arg) in allArgs.withIterator() 'each'
		if iter.index() > 0 'skipExe'
			result.push(arg)
		end 'skipExe'
	end 'each'
	return result
end 'forwardedArgs'

// Run a process with a status message, returning its exit code. A non-zero
// exit propagates; a spawn / timeout / I/O failure prints the reason and
// returns 1. The child's stdout/stderr are inherited so the user sees its
// output live — `Subprocess.run`'s default `collect` mode would swallow it.
function run(description String, exe Executable, argv StringArray, timeoutMs Timeout) returns ExitCode
	print("{description}...\n")
	var config = Configuration.create(exe)
	config.arguments = argv
	config.workingDirectory = Directory.currentPath()
	config.timeoutMs = timeoutMs
	config.standardOutput = OutputDestination.inherit
	config.standardError = OutputDestination.inherit
	let result = try config.run() otherwise (err) 'spawn'
		print("{description} failed: {err.displayReason()}\n")
		return 1
	end 'spawn'
	let code = result.exitCode()
	if code == 0 'ok'
		return 0
	end 'ok'
	print("{description} failed (exit {code})\n")
	if code < 0 'negative'
		return 1
	end 'negative'
	if code > u32.max 'overflow'
		return 1
	end 'overflow'
	return code as ExitCode
end 'run'

/// Build the C# bootstrap compiler (maxon-sharp).
export function build_sharp() returns ExitCode
	var argv = StringArray.create()
	argv.push("build")
	argv.push("maxon-sharp/MaxonSharp.csproj")
	let result = run("Building maxon-sharp", exe: Executable.name("dotnet"), argv: argv, timeoutMs: 120000)
	if result != 0 'failed'
		return result
	end 'failed'
	print("maxon-sharp built successfully\n")
	return 0
end 'build_sharp'

/// Build the C# compiler and run its spec tests.
export function spec_test_sharp() returns ExitCode
	let buildResult = build_sharp()
	if buildResult != 0 'failed'
		return buildResult
	end 'failed'

	let sharpExe = try FilePath.from("./bin/maxon{exeExt}") otherwise panic("spec_test_sharp: literal path should be valid")
	var argv = StringArray.create()
	argv.push("spec-test")
	argv.append(forwardedArgs())
	let testResult = run("Running sharp spec tests", exe: Executable.path(sharpExe), argv: argv, timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All sharp spec tests passed\n")
	return 0
end 'spec_test_sharp'

/// Compile the self-hosted compiler using the bootstrap compiler.
export function build_selfhosted() returns ExitCode
	let sharpExe = try FilePath.from("./bin/maxon{exeExt}") otherwise panic("build_selfhosted: literal path should be valid")
	var argv = StringArray.create()
	argv.push("build")
	argv.push("maxon-selfhosted")
	let result = run("Compiling self-hosted compiler", exe: Executable.path(sharpExe), argv: argv, timeoutMs: 120000)
	if result != 0 'failed'
		return result
	end 'failed'
	print("Self-hosted compiler built successfully\n")
	return 0
end 'build_selfhosted'

/// Compile the self-hosted compiler and run its spec tests.
export function spec_test_selfhosted() returns ExitCode
	let compileResult = build_selfhosted()
	if compileResult != 0 'failed'
		return compileResult
	end 'failed'

	let selfExe = try FilePath.from("./maxon-selfhosted/.maxon/maxon-selfhosted{exeExt}") otherwise panic("spec_test_selfhosted: literal path should be valid")
	var argv = StringArray.create()
	argv.push("spec-test")
	argv.append(forwardedArgs())
	let testResult = run("Running self-hosted spec tests", exe: Executable.path(selfExe), argv: argv, timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All self-hosted spec tests passed\n")
	return 0
end 'spec_test_selfhosted'

/// Build the maxon-dev MCP server (the Claude Code tool host).
// Depends on the C# bootstrap; the server is a Maxon project built through
// `./bin/maxon.exe build`.
export function build_dev_mcp() returns ExitCode
	let bootstrapResult = build_sharp()
	if bootstrapResult != 0 'failed'
		return bootstrapResult
	end 'failed'

	let sharpExe = try FilePath.from("./bin/maxon{exeExt}") otherwise panic("build_dev_mcp: literal path should be valid")
	var argv = StringArray.create()
	argv.push("build")
	argv.push("maxon-dev-mcp")
	let buildResult = run("Building maxon-dev MCP server", exe: Executable.path(sharpExe), argv: argv, timeoutMs: 120000)
	if buildResult != 0 'failed2'
		return buildResult
	end 'failed2'

	print("maxon-dev MCP server built successfully\n")
	return 0
end 'build_dev_mcp'

/// Build and run the MCP server's test suite.
// Chains: C# bootstrap, MCP server, test runner, then runs the runner. The
// runner pipes fixture JSON-RPC into the server and walks structural
// assertions over the responses; non-zero exit on any fixture failure.
export function test_dev_mcp() returns ExitCode
	let mcpResult = build_dev_mcp()
	if mcpResult != 0 'failed'
		return mcpResult
	end 'failed'

	let sharpExe = try FilePath.from("./bin/maxon{exeExt}") otherwise panic("test_dev_mcp: literal path should be valid")
	var buildArgv = StringArray.create()
	buildArgv.push("build")
	buildArgv.push("maxon-dev-mcp-test")
	let runnerBuild = run("Building MCP test runner", exe: Executable.path(sharpExe), argv: buildArgv, timeoutMs: 60000)
	if runnerBuild != 0 'runnerFail'
		return runnerBuild
	end 'runnerFail'

	let runnerExe = try FilePath.from("./maxon-dev-mcp-test/.maxon/maxon-dev-mcp-test{exeExt}") otherwise panic("test_dev_mcp: literal runner path should be valid")
	let runResult = run("Running MCP tests", exe: Executable.path(runnerExe), argv: StringArray.create(), timeoutMs: 1200000)
	if runResult != 0 'testFail'
		return runResult
	end 'testFail'

	print("MCP tests passed\n")
	return 0
end 'test_dev_mcp'

/// Compile the self-hosted compiler and run its Wasm spec tests.
export function spec_test_wasm() returns ExitCode
	let compileResult = build_selfhosted()
	if compileResult != 0 'failed'
		return compileResult
	end 'failed'

	let selfExe = try FilePath.from("./maxon-selfhosted/.maxon/maxon-selfhosted{exeExt}") otherwise panic("spec_test_wasm: literal path should be valid")
	var argv = StringArray.create()
	argv.push("spec-test")
	argv.push("--target=wasm32-wasi")
	argv.append(forwardedArgs())
	let testResult = run("Running self-hosted Wasm spec tests", exe: Executable.path(selfExe), argv: argv, timeoutMs: 600000)
	if testResult != 0 'failed2'
		return testResult
	end 'failed2'

	print("All self-hosted Wasm spec tests passed\n")
	return 0
end 'spec_test_wasm'

// Maxon Language Test File
// Use this file to test your LSP features

// Test 1: Function declaration with hover
function fibonacci(n int) int
    var a = 0
    var b = 1
    var temp = 0
    var counter = n
    
    while counter > 0
        temp = a
        a = b
        b = temp + b
        counter = counter - 1
    end
    
    return a
end

// Test 2: Conditional statements
function max(x int, y int) int
    if x > y
        return x
    else
        return y
    end
end

// Test 3: Main function
function main() int
    var result = 0
    var num1 = 10
    var num2 = 20
    
    // Test go-to-definition: F12 on 'max' or 'fibonacci'
    result = max(num1, num2)
    
    // Test hover: hover over keywords like 'if', 'while', 'var'
    if result > 15
        result = fibonacci(result)
    end
    
    return result
end

// LSP Features to Test:
// 
// 1. Syntax Highlighting
//    - Keywords should be colored: function, var, if, else, while, end, return
//    - Types should be colored: int
//    - Numbers should be colored: 0, 1, 10, 20, 15
//    - Comments should be colored (gray/green)
//    - Operators should be visible: +, -, >, =
//
// 2. Code Completion (Ctrl+Space)
//    - Type "func" and press Ctrl+Space → should suggest "function"
//    - Type "v" and press Ctrl+Space → should suggest "var"
//    - Type part of an identifier → should suggest existing variables
//
// 3. Hover Information
//    - Hover over "function" → should show keyword documentation
//    - Hover over "int" → should show type information
//    - Hover over variable names → should show identifier info
//
// 4. Go to Definition (F12)
//    - Place cursor on 'max' in main() and press F12 → jumps to max function
//    - Place cursor on 'fibonacci' and press F12 → jumps to fibonacci function
//    - Place cursor on variable usage → jumps to var declaration
//
// 5. Document Symbols (Ctrl+Shift+O)
//    - Should show outline:
//      - fibonacci (function)
//      - max (function)  
//      - main (function)
//      - All variables
//
// 6. Diagnostics (Problems Panel)
//    - Try introducing errors:
//      - Remove 'end' keyword → should show error
//      - Use undefined variable → should show error
//      - Invalid syntax → should show error
//
// 7. Comments (Ctrl+/)
//    - Select lines and press Ctrl+/ → should toggle comments
//
// 8. Auto-closing
//    - Type '(' → should auto-insert ')'
//    - Type '"' → should auto-insert closing quote
//
// 9. Folding
//    - Click the arrow next to "function" → should fold the function body
//    - Unfold to see content again

// Test with intentional errors (uncomment to test diagnostics):
// functin broken() int  // Typo: 'functin' instead of 'function'
//     var x = y         // Undefined variable 'y'
//     return x
// // Missing 'end'

// Test nested structures:
function complex() int
    var x = 1
    
    if x > 0
        var y = 2
        
        while y < 10
            if y = 5
                y = y + 2
            else
                y = y + 1
            end
        end
        
        return y
    else
        return 0
    end
end

// Test arithmetic:
function calculate() int
    var a = 10
    var b = 5
    var sum = a + b
    var diff = a - b
    var prod = a * b
    var quot = a / b
    
    // Hover over 'sum', 'diff', etc. to test
    return sum + diff + prod + quot
end

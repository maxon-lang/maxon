{
  "name": "maxon-lsp-client",
  "displayName": "Maxon Language Support",
  "description": "Language support for Maxon programming language",
  "version": "0.1.0",
  "publisher": "maxon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "maxon",
        "aliases": [
          "Maxon",
          "maxon"
        ],
        "extensions": [
          ".maxon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "maxon",
        "scopeName": "source.maxon",
        "path": "./syntaxes/maxon.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.11.9",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.2"
  }
}

// Test: challenge-struct-field-assign.struct-field-reassignment.1
type Counter
    var value int
end 'Counter'

function main() returns int
    var c = Counter{value: 10}
    c.value = 42
    return c.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    %8 = memset %c 0
    %tmp_const.1 = const.i64 i64 42
    ret %tmp_const.1
}

---

// Test: if-statements.if-statements.else.1
function main() returns int
    var x = 5
    if x == 5 'is5'
        return 1
    end 'is5' else 'not5'
        return 0
    end 'not5'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.eq i64 %tmp_load %tmp_const.1
    %tmp_load = br.cond %tmp_icmp @block1
then:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
else:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
end:
}

---

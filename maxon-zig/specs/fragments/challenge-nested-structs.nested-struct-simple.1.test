// Test: challenge-nested-structs.nested-struct-simple.1
type Inner
    var x int
    var y int
end 'Inner'

type Outer
    var inner Inner
    var z int
end 'Outer'

function main() returns int
    var inner = Inner{x: 10, y: 20}
    var outer = Outer{inner: inner, z: 30}
    return outer.inner.x + outer.inner.y + outer.z
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %0 = alloca.sized ptr 16
    %5 = alloca.sized ptr 16
    %6 = getfieldptr ptr %5 0
    store %6 %0
    %7 = getfieldptr ptr %5 8
    %8 = const.i64 i64 30
    store %7 %8
    %9 = getfieldptr ptr %5 0
    %10 = getfieldptr ptr %9 0
    %11 = load i64 %10
    %12 = getfieldptr ptr %5 0
    %13 = getfieldptr ptr %12 8
    %14 = load i64 %13
    %15 = add i64 %11 %14
    %16 = getfieldptr ptr %5 8
    %17 = load i64 %16
    %18 = add i64 %15 %17
    ret %18
}


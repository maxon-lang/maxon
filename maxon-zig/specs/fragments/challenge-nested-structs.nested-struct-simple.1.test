// Test: challenge-nested-structs.nested-struct-simple.1
type Inner
    var x int
    var y int
end 'Inner'

type Outer
    var inner Inner
    var z int
end 'Outer'

function main() returns int
    var inner = Inner{x: 10, y: 20}
    var outer = Outer{inner: inner, z: 30}
    return outer.inner.x + outer.inner.y + outer.z
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %tmp_add.1 = const.i64 i64 60
    ret %tmp_add.1
}

---

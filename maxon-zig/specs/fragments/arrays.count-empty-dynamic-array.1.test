// Test: arrays.count-empty-dynamic-array.1
function main() returns int
    var arr_size = 0
    var arr = array of arr_size int
    return arr.count()
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %arr_size = alloca ptr
    store %arr_size %tmp_const
    %tmp_load = load i64 %arr_size
    %tmp_const.1 = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const.1
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.2 = load i64 %arr_size
    %tmp_load.3 = load ptr %arr
    heap.free %tmp_load.3
    ret %tmp_load.2
}

---

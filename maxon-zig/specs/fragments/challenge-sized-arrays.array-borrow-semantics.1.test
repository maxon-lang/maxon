    %4 = const.i64 i64 0
    %5 = const.i64 i64 42
    %6 = getelemptr ptr %3 %4
    store %6 %5
    %7 = call i64 @readFirst(%3)
    %9 = const.i64 i64 0
    %10 = getelemptr ptr %3 %9
    %11 = load i64 %10
    %13 = add i64 %11 %7
    ret %13
}


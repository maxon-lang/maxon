// Test: challenge-sized-arrays.array-borrow-semantics.1
function readFirst(arr array of 3 int) returns int
    return arr[0]
end 'readFirst'

function main() returns int
    var arr = array of 3 int
    arr[0] = 42
    var result = readFirst(arr)
    return arr[0] + result
end 'main'
---
ExitCode: 84
---
function readFirst() -> i64 {
entry:
    %arr = param ptr 0
    %tmp_const = const.i64 i64 0
    %2 = getelemptr ptr %arr %tmp_const
    %tmp_load = load i64 %2
    ret %tmp_load
}

function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 42
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_call = call i64 @readFirst(%arr)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_const.2 = const.i64 i64 0
    %7 = getelemptr ptr %arr %tmp_const.2
    %tmp_load = load i64 %7
    %tmp_load.1 = load i64 %result
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}


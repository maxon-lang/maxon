// Test: alloc-tracking.array-in-loop.1
function main() returns int
    var i = 0
    var sum = 0
    while i < 3 'loop'
        let size = 5
        var arr = array of size int
        arr[0] = i
        sum = sum + arr[0]
        i = i + 1
    end 'loop'
    return sum
end 'main'

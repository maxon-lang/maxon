// Test: challenge-sized-arrays.array-move-then-reassign.1
function consume(arr array of 3 int) returns int
    arr[0] = 100
    return arr[0]
end 'consume'

function main() returns int
    var arr = array of 3 int
    arr[0] = 10
    var first = consume(arr)
    arr = array of 3 int
    arr[0] = 20
    var second = consume(arr)
    return first + second
end 'main'
---
ExitCode: 200
---
function consume() -> i64 {
entry:
    %arr = param ptr 0
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 100
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_const.2 = const.i64 i64 0
    %5 = getelemptr ptr %arr %tmp_const.2
    %tmp_load = load i64 %5
    ret %tmp_load
}

function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 10
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_call = call i64 @consume(%arr)
    %first = alloca ptr
    store %first %tmp_call
    %tmp_alloca.2 = alloca.sized ptr 24
    %tmp_const.2 = const.i64 i64 0
    %tmp_const.3 = const.i64 i64 20
    %9 = getelemptr ptr %tmp_alloca.2 %tmp_const.2
    store %9 %tmp_const.3
    %tmp_call.1 = call i64 @consume(%tmp_alloca.2)
    %second = alloca ptr
    store %second %tmp_call.1
    %tmp_load = load i64 %first
    %tmp_load.1 = load i64 %second
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

---

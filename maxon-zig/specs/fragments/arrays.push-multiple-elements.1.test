// Test: arrays.push-multiple-elements.1
function main() returns int
    var arr_size = 0
    var arr = array of arr_size int
    arr.push(10)
    arr.push(20)
    arr.push(30)
    var sum = 0
    if let a = arr[0] 'g1'
        sum = sum + a
    end 'g1'
    if let b = arr[1] 'g2'
        sum = sum + b
    end 'g2'
    if let c = arr[2] 'g3'
        sum = sum + c
    end 'g3'
    return sum
end 'main'

// Test: ownership.moved-array-not-double-freed.1
function mutateFirst(arr array of int) returns int
    arr[0] = 100
    return arr[0]
end 'mutateFirst'

function main() returns int
    let size = 3
    var arr = array of size int
    arr[0] = 42
    return mutateFirst(arr)
end 'main'

function mutateFirst() -> i64 {
entry:
    %tmp_param = param ptr 0
    %arr = alloca ptr
    store %arr %tmp_param
    %tmp_load = load ptr %arr
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 100
    %5 = getelemptr ptr %tmp_load %tmp_const
    store %5 %tmp_const.1
    %tmp_load.1 = load ptr %arr
    %tmp_const.2 = const.i64 i64 0
    %8 = getelemptr ptr %tmp_load.1 %tmp_const.2
    %tmp_load.2 = load i64 %8
    %tmp_load.3 = load ptr %arr
    heap.free %tmp_load.3
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %size = alloca ptr
    store %size %tmp_const
    %tmp_load = load i64 %size
    %tmp_const.1 = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const.1
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.1 = load ptr %arr
    %tmp_const.2 = const.i64 i64 0
    %tmp_const.3 = const.i64 i64 42
    %10 = getelemptr ptr %tmp_load.1 %tmp_const.2
    store %10 %tmp_const.3
    %tmp_load.2 = load ptr %arr
    %tmp_call = call i64 @mutateFirst(%tmp_load.2)
    ret %tmp_call
}


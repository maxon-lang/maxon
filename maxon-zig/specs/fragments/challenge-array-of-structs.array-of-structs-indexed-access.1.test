// Test: challenge-array-of-structs.array-of-structs-indexed-access.1
type Pair
    var first int
    var second int
end 'Pair'

function main() returns int
    var p = Pair{first: 10, second: 20}
    var arr = [p]
    return arr[0].first + arr[0].second
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %arr = alloca.sized ptr 8
    %tmp_const.2 = const.i64 i64 0
    %7 = getelemptr ptr %arr %tmp_const.2
    store %7 %p
    %tmp_const.3 = const.i64 i64 0
    %9 = getelemptr ptr %arr %tmp_const.3
    %tmp_load = load ptr %9
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_load 0
    %tmp_load.1 = load i64 %tmp_fieldptr.2
    %tmp_const.4 = const.i64 i64 0
    %14 = getelemptr ptr %arr %tmp_const.4
    %tmp_load.2 = load ptr %14
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_load.2 8
    %tmp_load.3 = load i64 %tmp_fieldptr.3
    %tmp_add = add i64 %tmp_load.1 %tmp_load.3
    ret %tmp_add
}

---

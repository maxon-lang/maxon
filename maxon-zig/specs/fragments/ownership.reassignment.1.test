// Test: ownership.reassignment.1
function main() returns int
    var a = 10
    a = 20
    a = 30
    return a
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 20
    store %a %tmp_const.1
    %tmp_const.2 = const.i64 i64 30
    store %a %tmp_const.2
    %tmp_load = load i64 %a
    ret %tmp_load
}

---

// Test: challenge-sized-arrays.variable-sized-array-computed-size.1
function main() returns int
    var base = 2
    var multiplier = 3
    var size = base * multiplier
    var arr = array of size int
    arr[5] = 99
    return arr[5]
end 'main'
---
ExitCode: 99
---
function main() -> i64 {
entry:
    %11 = alloca.sized ptr 64
    %12 = const.i64 i64 5
    %13 = const.i64 i64 99
    %14 = getelemptr ptr %11 %12
    store %14 %13
    %15 = const.i64 i64 5
    %16 = getelemptr ptr %11 %15
    %17 = load i64 %16
    ret %17
}


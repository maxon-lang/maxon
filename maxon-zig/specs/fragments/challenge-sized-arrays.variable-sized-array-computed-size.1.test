// Test: challenge-sized-arrays.variable-sized-array-computed-size.1
function main() returns int
    var base = 2
    var multiplier = 3
    var size = base * multiplier
    var arr = array of size int
    arr[5] = 99
    return arr[5]
end 'main'
---
ExitCode: 99
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 2
    %base = alloca ptr
    store %base %tmp_const
    %tmp_const.1 = const.i64 i64 3
    %multiplier = alloca ptr
    store %multiplier %tmp_const.1
    %tmp_load = load i64 %base
    %tmp_load.1 = load i64 %multiplier
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %size = alloca ptr
    store %size %tmp_mul
    %tmp_load.2 = load i64 %size
    %tmp_const.2 = const.i64 i64 8
    %tmp_mul.1 = mul i64 %tmp_load.2 %tmp_const.2
    %arr = heap.alloc ptr %tmp_mul.1
    %tmp_const.3 = const.i64 i64 5
    %tmp_const.4 = const.i64 i64 99
    %14 = getelemptr ptr %arr %tmp_const.3
    store %14 %tmp_const.4
    %tmp_const.5 = const.i64 i64 5
    %16 = getelemptr ptr %arr %tmp_const.5
    %tmp_load.3 = load i64 %16
    ret %tmp_load.3
}

---

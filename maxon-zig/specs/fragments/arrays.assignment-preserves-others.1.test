// Test: arrays.assignment-preserves-others.1
function main() returns int
    var arr = [10, 20, 30]
    arr[0] = 100
    return arr[1]
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry:
    %0 = const.i64 i64 10
    %1 = alloca.sized ptr 24
    %2 = const.i64 i64 0
    %3 = getelemptr ptr %1 %2
    store %3 %0
    %4 = const.i64 i64 20
    %5 = const.i64 i64 1
    %6 = getelemptr ptr %1 %5
    store %6 %4
    %7 = const.i64 i64 30
    %8 = const.i64 i64 2
    %9 = getelemptr ptr %1 %8
    store %9 %7
    %10 = const.i64 i64 0
    %11 = const.i64 i64 100
    %12 = getelemptr ptr %1 %10
    store %12 %11
    %13 = const.i64 i64 1
    %14 = getelemptr ptr %1 %13
    %15 = load i64 %14
    ret %15
}


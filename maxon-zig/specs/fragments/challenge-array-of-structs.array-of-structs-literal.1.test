// Test: challenge-array-of-structs.array-of-structs-literal.1
type Point
    var x int
    var y int
end 'Point'

function main() returns int
    var p1 = Point{x: 1, y: 2}
    var p2 = Point{x: 3, y: 4}
    var points = [p1, p2]
    return points[0].x + points[1].y
end 'main'

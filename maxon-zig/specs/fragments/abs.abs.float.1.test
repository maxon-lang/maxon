// Test: abs.abs.float.1
function main() returns int
    var neg = 0.0 - 5.5
    var x = abs(neg)
    var y = trunc(x)
    return y
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 0
    %tmp_fconst.1 = const.f64 f64 5.5
    %tmp_fsub = fsub f64 %tmp_fconst %tmp_fconst.1
    %neg = alloca ptr
    store %neg %tmp_fsub
    %tmp_load = load f64 %neg
    %tmp_fabs = fabs f64 %tmp_load
    %x = alloca ptr
    store %x %tmp_fabs
    %tmp_load.1 = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load.1
    %y = alloca ptr
    store %y %tmp_fptosi
    %tmp_load.2 = load i64 %y
    ret %tmp_load.2
}

---

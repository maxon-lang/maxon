// Test: challenge-struct-lifetime.pass-struct-to-function-and-return.1
type Counter
    var value int
end 'Counter'

function increment(c Counter) returns Counter
    return Counter{value: c.value + 1}
end 'increment'

function main() returns int
    var c1 = Counter{value: 10}
    var c2 = increment(c1)
    return c2.value
end 'main'
---
ExitCode: 11
---
function increment() -> ptr {
entry:
    %tmp_param = param ptr 0
    %c = param ptr 1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    %tmp_fieldptr.1 = getfieldptr ptr %c 0
    %tmp_load = load i64 %tmp_fieldptr.1
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    store %tmp_fieldptr %tmp_add
    ret %tmp_param
}

function main() -> i64 {
entry:
    %c1 = alloca.sized ptr 8
    %tmp_fieldptr = getfieldptr ptr %c1 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %c2 = alloca.sized ptr 8
    %tmp_call = call ptr @increment(%c2, %c1)
    %tmp_fieldptr.1 = getfieldptr ptr %c2 0
    %tmp_load = load i64 %tmp_fieldptr.1
    ret %tmp_load
}

---

// Test: arrays.literal-middle.1
function main() returns int
    var arr = [10, 20, 30]
    return arr[1]
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %arr = alloca.sized ptr 24
    %tmp_const.1 = const.i64 i64 0
    %3 = getelemptr ptr %arr %tmp_const.1
    store %3 %tmp_const
    %tmp_const.2 = const.i64 i64 20
    %tmp_const.3 = const.i64 i64 1
    %6 = getelemptr ptr %arr %tmp_const.3
    store %6 %tmp_const.2
    %tmp_const.4 = const.i64 i64 30
    %tmp_const.5 = const.i64 i64 2
    %9 = getelemptr ptr %arr %tmp_const.5
    store %9 %tmp_const.4
    %tmp_const.6 = const.i64 i64 1
    %11 = getelemptr ptr %arr %tmp_const.6
    %tmp_load = load i64 %11
    ret %tmp_load
}


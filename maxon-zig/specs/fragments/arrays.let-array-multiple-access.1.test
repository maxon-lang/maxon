// Test: arrays.let-array-multiple-access.1
function main() returns int
    let arr = [5, 10, 15, 20]
    return arr[0] + arr[3]
end 'main'
---
ExitCode: 25
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %arr = alloca.sized ptr 32
    %tmp_const.1 = const.i64 i64 0
    %3 = getelemptr ptr %arr %tmp_const.1
    store %3 %tmp_const
    %tmp_const.2 = const.i64 i64 10
    %tmp_const.3 = const.i64 i64 1
    %6 = getelemptr ptr %arr %tmp_const.3
    store %6 %tmp_const.2
    %tmp_const.4 = const.i64 i64 15
    %tmp_const.5 = const.i64 i64 2
    %9 = getelemptr ptr %arr %tmp_const.5
    store %9 %tmp_const.4
    %tmp_const.6 = const.i64 i64 20
    %tmp_const.7 = const.i64 i64 3
    %12 = getelemptr ptr %arr %tmp_const.7
    store %12 %tmp_const.6
    %tmp_const.8 = const.i64 i64 0
    %14 = getelemptr ptr %arr %tmp_const.8
    %tmp_load = load i64 %14
    %tmp_const.9 = const.i64 i64 3
    %17 = getelemptr ptr %arr %tmp_const.9
    %tmp_load.1 = load i64 %17
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}


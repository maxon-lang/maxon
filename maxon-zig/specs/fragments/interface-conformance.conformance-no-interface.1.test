// Test: interface-conformance.conformance-no-interface.1
type Standalone
    var value int

    function get() returns int
        return value
    end 'get'
end 'Standalone'

function main() returns int
    var s = Standalone{value: 42}
    return s.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %s = alloca.sized ptr 8
    %tmp_fieldptr = getfieldptr ptr %s 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @Standalone$get(%s)
    ret %tmp_call
}

function Standalone$get() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

---

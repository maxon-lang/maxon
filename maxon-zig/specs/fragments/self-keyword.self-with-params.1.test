// Test: self-keyword.self-with-params.1
type Accumulator
    var total int

    function add(value int)
        self.total = self.total + value
    end 'add'

    function getTotal() returns int
        return self.total
    end 'getTotal'
end 'Accumulator'

function main() returns int
    var acc = Accumulator{total: 0}
    acc.add(10)
    acc.add(20)
    acc.add(12)
    return acc.getTotal()
end 'main'
---
ExitCode: 42

// Test: arrays.multiple-assignments.1
function main() returns int
    var arr = [0, 0, 0]
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    var sum = 0
    if let a = arr[0] 'g1'
        sum = sum + a
    end 'g1'
    if let b = arr[1] 'g2'
        sum = sum + b
    end 'g2'
    if let c = arr[2] 'g3'
        sum = sum + c
    end 'g3'
    return sum
end 'main'

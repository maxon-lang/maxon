// Test: challenge-sized-arrays.variable-sized-array-from-parameter.1
function make_array(size int) returns int
    var arr = array of size int
    arr[0] = 42
    return arr[0]
end 'make_array'

function main() returns int
    return make_array(5)
end 'main'
---
ExitCode: 42
---
function make_array() -> i64 {
entry:
    %size = param i64 0
    %size.1 = alloca ptr
    store %size.1 %size
    %tmp_load = load i64 %size.1
    %tmp_const = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.1 = load ptr %arr
    %tmp_const.1 = const.i64 i64 0
    %tmp_const.2 = const.i64 i64 42
    %10 = getelemptr ptr %tmp_load.1 %tmp_const.1
    store %10 %tmp_const.2
    %tmp_load.2 = load ptr %arr
    %tmp_const.3 = const.i64 i64 0
    %13 = getelemptr ptr %tmp_load.2 %tmp_const.3
    %tmp_load.3 = load i64 %13
    %tmp_load.4 = load ptr %arr
    heap.free %tmp_load.4
    ret %tmp_load.3
}

function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @make_array(%tmp_const)
    ret %tmp_call
}


// Test: challenge-sized-arrays.variable-sized-array-from-parameter.1
function make_array(size int) returns int
    var arr = array of size int
    arr[0] = 42
    return arr[0]
end 'make_array'

function main() returns int
    return make_array(5)
end 'main'
---
ExitCode: 42
---
function make_array() -> i64 {
entry:
    %0 = param i64 0
    %3 = const.i64 i64 8
    %4 = mul i64 %0 %3
    %5 = heap.alloc ptr %4
    %6 = const.i64 i64 0
    %7 = const.i64 i64 42
    %8 = getelemptr ptr %5 %6
    store %8 %7
    %9 = const.i64 i64 0
    %10 = getelemptr ptr %5 %9
    %11 = load i64 %10
    ret %11
}

function main() -> i64 {
entry:
    %0 = const.i64 i64 5
    %1 = call i64 @make_array(%0)
    ret %1
}


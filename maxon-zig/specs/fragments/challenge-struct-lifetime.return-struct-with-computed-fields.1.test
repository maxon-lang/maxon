// Test: challenge-struct-lifetime.return-struct-with-computed-fields.1
type Result
    var sum int
    var product int
end 'Result'

function compute(a int, b int) returns Result
    return Result{sum: a + b, product: a * b}
end 'compute'

function main() returns int
    var r = compute(3, 4)
    return r.sum + r.product
end 'main'
---
ExitCode: 19
---
function compute() -> ptr {
entry:
    %0 = param ptr 0
    %1 = param i64 1
    %3 = param i64 2
    %5 = getfieldptr ptr %0 0
    %8 = add i64 %1 %3
    store %5 %8
    %9 = getfieldptr ptr %0 8
    %12 = mul i64 %1 %3
    store %9 %12
    ret %0
}

function main() -> i64 {
entry:
    %0 = alloca.sized ptr 16
    %1 = const.i64 i64 3
    %2 = const.i64 i64 4
    %3 = call ptr @compute(%0, %1, %2)
    %4 = getfieldptr ptr %0 0
    %5 = load i64 %4
    %6 = getfieldptr ptr %0 8
    %7 = load i64 %6
    %8 = add i64 %5 %7
    ret %8
}


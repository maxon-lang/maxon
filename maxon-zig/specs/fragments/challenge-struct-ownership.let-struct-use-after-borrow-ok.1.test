// Test: challenge-struct-ownership.let-struct-use-after-borrow-ok.1
type Data
    var value int
end 'Data'

function readOnly(d Data) returns int
    return d.value
end 'readOnly'

function main() returns int
    let d = Data{value: 25}
    var result = readOnly(d)
    return d.value + result
end 'main'
---
ExitCode: 50
---
function readOnly() -> i64 {
entry:
    %0 = param ptr 0
    %1 = getfieldptr ptr %0 0
    %2 = load i64 %1
    ret %2
}

function main() -> i64 {
entry:
    %0 = alloca.sized ptr 8
    %1 = getfieldptr ptr %0 0
    %2 = const.i64 i64 25
    store %1 %2
    %3 = call i64 @readOnly(%0)
    %5 = getfieldptr ptr %0 0
    %6 = load i64 %5
    %8 = add i64 %6 %3
    ret %8
}

---

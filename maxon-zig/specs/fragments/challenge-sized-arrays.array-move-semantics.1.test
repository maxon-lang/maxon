// Test: challenge-sized-arrays.array-move-semantics.1
function mutate(arr array of 3 int) returns int
    arr[0] = 100
    return arr[0]
end 'mutate'

function main() returns int
    var arr = array of 3 int
    arr[0] = 42
    return mutate(arr)
end 'main'
---
ExitCode: 100
---
function mutate() -> i64 {
entry:
    %tmp_param = param ptr 0
    %arr = alloca ptr
    store %arr %tmp_param
    %tmp_load = load ptr %arr
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 100
    %5 = getelemptr ptr %tmp_load %tmp_const
    store %5 %tmp_const.1
    %tmp_load.1 = load ptr %arr
    %tmp_const.2 = const.i64 i64 0
    %8 = getelemptr ptr %tmp_load.1 %tmp_const.2
    %tmp_load.2 = load i64 %8
    ret %tmp_load.2
}

function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 42
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_call = call i64 @mutate(%arr)
    ret %tmp_call
}

---

// Test: arrays.push-in-loop.1
function main() returns int
    var arr_size = 0
    var arr = array of arr_size int
    var i = 0
    while i < 3 'loop'
        arr.push(i * 10)
        i = i + 1
    end 'loop'
    return arr[0] + arr[1] + arr[2]
end 'main'
---
ExitCode: 30

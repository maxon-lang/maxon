// Test: arrays.push-in-loop.1
function main() returns int
    var arr_size = 0
    var arr = array of arr_size int
    var i = 0
    while i < 3 'loop'
        arr.push(i * 10)
        i = i + 1
    end 'loop'
    var sum = 0
    if let a = arr[0] 'g1'
        sum = sum + a
    end 'g1'
    if let b = arr[1] 'g2'
        sum = sum + b
    end 'g2'
    if let c = arr[2] 'g3'
        sum = sum + c
    end 'g3'
    return sum
end 'main'

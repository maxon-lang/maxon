// Test: challenge-struct-ownership.struct-move-semantics.1
type Data
    var value int
end 'Data'

function takeOwnership(d Data) returns int
    d.value = 100
    return d.value
end 'takeOwnership'

function main() returns int
    var d = Data{value: 42}
    return takeOwnership(d)
end 'main'
---
ExitCode: 100
---
function takeOwnership() -> i64 {
entry:
    %0 = param ptr 0
    %1 = getfieldptr ptr %0 0
    %2 = const.i64 i64 100
    store %1 %2
    %3 = getfieldptr ptr %0 0
    %4 = load i64 %3
    ret %4
}

function main() -> i64 {
entry:
    %0 = alloca.sized ptr 8
    %1 = getfieldptr ptr %0 0
    %2 = const.i64 i64 42
    store %1 %2
    %3 = call i64 @takeOwnership(%0)
    ret %3
}

---

// Test: challenge-struct-ownership.var-from-let-can-move.1
type Data
    var value int
end 'Data'

function consume(d Data) returns int
    d.value = 100
    return d.value
end 'consume'

function main() returns int
    let original = Data{value: 42}
    var copy = original
    return consume(copy)
end 'main'
---
ExitCode: 100
---
function consume() -> i64 {
entry:
    %0 = param ptr 0
    %1 = getfieldptr ptr %0 0
    %2 = const.i64 i64 100
    store %1 %2
    %3 = getfieldptr ptr %0 0
    %4 = load i64 %3
    ret %4
}

function main() -> i64 {
entry:
    %0 = alloca.sized ptr 8
    %1 = getfieldptr ptr %0 0
    %2 = const.i64 i64 42
    store %1 %2
    %3 = call i64 @consume(%0)
    ret %3
}

---

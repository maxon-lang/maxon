// Test: challenge-sized-arrays.variable-sized-array-basic.1
function main() returns int
    var n = 3
    var arr = array of n int
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    return arr[0] + arr[1] + arr[2]
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %n = alloca ptr
    store %n %tmp_const
    %tmp_load = load i64 %n
    %tmp_const.1 = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const.1
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.1 = load ptr %arr
    %tmp_const.2 = const.i64 i64 0
    %tmp_const.3 = const.i64 i64 10
    %10 = getelemptr ptr %tmp_load.1 %tmp_const.2
    store %10 %tmp_const.3
    %tmp_load.2 = load ptr %arr
    %tmp_const.4 = const.i64 i64 1
    %tmp_const.5 = const.i64 i64 20
    %14 = getelemptr ptr %tmp_load.2 %tmp_const.4
    store %14 %tmp_const.5
    %tmp_load.3 = load ptr %arr
    %tmp_const.6 = const.i64 i64 2
    %tmp_const.7 = const.i64 i64 30
    %18 = getelemptr ptr %tmp_load.3 %tmp_const.6
    store %18 %tmp_const.7
    %tmp_load.4 = load ptr %arr
    %tmp_const.8 = const.i64 i64 0
    %21 = getelemptr ptr %tmp_load.4 %tmp_const.8
    %tmp_load.5 = load i64 %21
    %tmp_load.6 = load ptr %arr
    %tmp_const.9 = const.i64 i64 1
    %25 = getelemptr ptr %tmp_load.6 %tmp_const.9
    %tmp_load.7 = load i64 %25
    %tmp_add = add i64 %tmp_load.5 %tmp_load.7
    %tmp_load.8 = load ptr %arr
    %tmp_const.10 = const.i64 i64 2
    %30 = getelemptr ptr %tmp_load.8 %tmp_const.10
    %tmp_load.9 = load i64 %30
    %tmp_add.1 = add i64 %tmp_add %tmp_load.9
    %tmp_load.10 = load ptr %arr
    heap.free %tmp_load.10
    ret %tmp_add.1
}

---

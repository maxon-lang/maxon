// Test: challenge-sized-arrays.variable-sized-array-basic.1
function main() returns int
    var n = 3
    var arr = array of n int
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    return arr[0] + arr[1] + arr[2]
end 'main'
---
ExitCode: 60
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %n = alloca ptr
    store %n %tmp_const
    %tmp_load = load i64 %n
    %tmp_const.1 = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const.1
    %arr = heap.alloc ptr %tmp_mul
    %tmp_const.2 = const.i64 i64 0
    %tmp_const.3 = const.i64 i64 10
    %8 = getelemptr ptr %arr %tmp_const.2
    store %8 %tmp_const.3
    %tmp_const.4 = const.i64 i64 1
    %tmp_const.5 = const.i64 i64 20
    %11 = getelemptr ptr %arr %tmp_const.4
    store %11 %tmp_const.5
    %tmp_const.6 = const.i64 i64 2
    %tmp_const.7 = const.i64 i64 30
    %14 = getelemptr ptr %arr %tmp_const.6
    store %14 %tmp_const.7
    %tmp_const.8 = const.i64 i64 0
    %16 = getelemptr ptr %arr %tmp_const.8
    %tmp_load.1 = load i64 %16
    %tmp_const.9 = const.i64 i64 1
    %19 = getelemptr ptr %arr %tmp_const.9
    %tmp_load.2 = load i64 %19
    %tmp_add = add i64 %tmp_load.1 %tmp_load.2
    %tmp_const.10 = const.i64 i64 2
    %23 = getelemptr ptr %arr %tmp_const.10
    %tmp_load.3 = load i64 %23
    %tmp_add.1 = add i64 %tmp_add %tmp_load.3
    ret %tmp_add.1
}

---

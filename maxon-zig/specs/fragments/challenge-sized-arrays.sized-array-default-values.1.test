// Test: challenge-sized-arrays.sized-array-default-values.1
function main() returns int
    var arr = array of 3 int
    arr[1] = 42
    return arr[1]
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 1
    %tmp_const.1 = const.i64 i64 42
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_const.2 = const.i64 i64 1
    %5 = getelemptr ptr %arr %tmp_const.2
    %tmp_load = load i64 %5
    ret %tmp_load
}

---

// Test: arrays.count-dynamic-array.1
function main() returns int
    var arr_size = 3
    var arr = array of arr_size int
    return arr.count()
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 3
    %arr_size = alloca ptr
    store %arr_size %tmp_const
    %tmp_load = load i64 %arr_size
    %tmp_const.1 = const.i64 i64 8
    %tmp_mul = mul i64 %tmp_load %tmp_const.1
    %tmp_heap = heap.alloc ptr %tmp_mul
    %arr = alloca ptr
    store %arr %tmp_heap
    %tmp_load.1 = load i64 %arr_size
    %tmp_load.2 = load ptr %arr
    heap.free %tmp_load.2
    ret %tmp_load.1
}

---

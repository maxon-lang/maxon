// Test: challenge-nested-structs.struct-with-multiple-nested-fields.1
type Point
    var x int
    var y int
end 'Point'

type Line
    var start Point
    var finish Point
end 'Line'

function main() returns int
    var p1 = Point{x: 1, y: 2}
    var p2 = Point{x: 10, y: 20}
    var line = Line{start: p1, finish: p2}
    return line.start.x + line.start.y + line.finish.x + line.finish.y
end 'main'
---
ExitCode: 33
---
function main() -> i64 {
entry:
    %tmp_add.2 = const.i64 i64 33
    ret %tmp_add.2
}


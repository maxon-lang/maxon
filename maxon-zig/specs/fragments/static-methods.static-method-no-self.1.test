// Test: static-methods.static-method-no-self.1
type Math
    var unused int

    static function add(a int, b int) returns int
        return a + b
    end 'add'
end 'Math'

function main() returns int
    return Math.add(20, 22)
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 20
    %tmp_const.1 = const.i64 i64 22
    %tmp_call = call i64 @Math$add(%tmp_const, %tmp_const.1)
    ret %tmp_call
}

function Math$add() -> i64 {
entry:
    %a = param i64 0
    %a.1 = alloca ptr
    store %a.1 %a
    %b = param i64 1
    %b.1 = alloca ptr
    store %b.1 %b
    %tmp_load = load i64 %a.1
    %tmp_load.1 = load i64 %b.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}

---

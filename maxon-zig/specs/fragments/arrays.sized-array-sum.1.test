// Test: arrays.sized-array-sum.1
function main() returns int
    var arr = array of 4 int
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4
    return arr[0] + arr[1] + arr[2] + arr[3]
end 'main'

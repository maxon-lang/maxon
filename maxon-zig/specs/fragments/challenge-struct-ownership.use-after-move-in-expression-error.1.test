// Test: challenge-struct-ownership.use-after-move-in-expression-error.1
type Data
    var value int
end 'Data'

function consume(d Data)
    d.value = 0
end 'consume'

function main() returns int
    var d = Data{value: 42}
    consume(d)
    consume(d)
    return 0
end 'main'

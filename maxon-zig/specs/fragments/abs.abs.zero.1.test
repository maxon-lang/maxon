// Test: abs.abs.zero.1
function main() returns int
    var x = abs(0.0)
    return trunc(x)
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 0
    %tmp_fabs = fabs f64 %tmp_fconst
    %x = alloca ptr
    store %x %tmp_fabs
    %tmp_load = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}

---

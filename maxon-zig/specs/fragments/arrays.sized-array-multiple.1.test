// Test: arrays.sized-array-multiple.1
function main() returns int
    var arr = array of 3 int
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    return arr[1]
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 10
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_const.2 = const.i64 i64 1
    %tmp_const.3 = const.i64 i64 20
    %6 = getelemptr ptr %arr %tmp_const.2
    store %6 %tmp_const.3
    %tmp_const.4 = const.i64 i64 2
    %tmp_const.5 = const.i64 i64 30
    %9 = getelemptr ptr %arr %tmp_const.4
    store %9 %tmp_const.5
    %tmp_const.6 = const.i64 i64 1
    %11 = getelemptr ptr %arr %tmp_const.6
    %tmp_load = load i64 %11
    ret %tmp_load
}

---

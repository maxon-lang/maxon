// Test: ownership.assign-expression.1
function main() returns int
    var a = 5
    var b = 3
    a = a * b + 2
    return a
end 'main'
---
ExitCode: 17
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 5
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 3
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_mul = mul i64 %tmp_load %tmp_load.1
    %tmp_const.2 = const.i64 i64 2
    %tmp_add = add i64 %tmp_mul %tmp_const.2
    store %a %tmp_add
    %tmp_load.2 = load i64 %a
    ret %tmp_load.2
}

---

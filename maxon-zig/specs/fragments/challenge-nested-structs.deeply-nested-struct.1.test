// Test: challenge-nested-structs.deeply-nested-struct.1
type Level1
    var value int
end 'Level1'

type Level2
    var inner Level1
end 'Level2'

type Level3
    var inner Level2
end 'Level3'

function main() returns int
    var l1 = Level1{value: 42}
    var l2 = Level2{inner: l1}
    var l3 = Level3{inner: l2}
    return l3.inner.inner.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    ret %tmp_const
}

---

// Test: challenge-nested-structs.deeply-nested-struct.1
type Level1
    var value int
end 'Level1'

type Level2
    var inner Level1
end 'Level2'

type Level3
    var inner Level2
end 'Level3'

function main() returns int
    var l1 = Level1{value: 42}
    var l2 = Level2{inner: l1}
    var l3 = Level3{inner: l2}
    return l3.inner.inner.value
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %l1 = alloca.sized ptr 8
    %tmp_fieldptr.4 = memset %l1 0
    %tmp_fieldptr = getfieldptr ptr %l1 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %l2 = alloca.sized ptr 8
    %tmp_fieldptr.4 = memset %l2 0
    %tmp_fieldptr.1 = getfieldptr ptr %l2 0
    %tmp_fieldptr.4 = memcpy %tmp_fieldptr.1 %l1
    %l3 = alloca.sized ptr 8
    %tmp_fieldptr.4 = memset %l3 0
    %tmp_fieldptr.2 = getfieldptr ptr %l3 0
    %tmp_fieldptr.4 = memcpy %tmp_fieldptr.2 %l2
    %tmp_fieldptr.3 = getfieldptr ptr %l3 0
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_fieldptr.3 0
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_fieldptr.4 0
    %tmp_load = load i64 %tmp_fieldptr.5
    ret %tmp_load
}

---

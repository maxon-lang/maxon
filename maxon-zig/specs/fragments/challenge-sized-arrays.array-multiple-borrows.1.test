// Test: challenge-sized-arrays.array-multiple-borrows.1
function readFirst(arr array of 3 int) returns int
    return arr[0]
end 'readFirst'

function main() returns int
    var arr = array of 3 int
    arr[0] = 10
    var a = readFirst(arr)
    var b = readFirst(arr)
    var c = readFirst(arr)
    return a + b + c
end 'main'
---
ExitCode: 30
---
function readFirst() -> i64 {
entry:
    %tmp_param = param ptr 0
    %arr = alloca ptr
    store %arr %tmp_param
    %tmp_load = load ptr %arr
    %tmp_const = const.i64 i64 0
    %4 = getelemptr ptr %tmp_load %tmp_const
    %tmp_load.1 = load i64 %4
    ret %tmp_load.1
}

function main() -> i64 {
entry:
    %arr = alloca.sized ptr 24
    %tmp_const = const.i64 i64 0
    %tmp_const.1 = const.i64 i64 10
    %3 = getelemptr ptr %arr %tmp_const
    store %3 %tmp_const.1
    %tmp_call = call i64 @readFirst(%arr)
    %a = alloca ptr
    store %a %tmp_call
    %tmp_call.1 = call i64 @readFirst(%arr)
    %b = alloca ptr
    store %b %tmp_call.1
    %tmp_call.2 = call i64 @readFirst(%arr)
    %c = alloca ptr
    store %c %tmp_call.2
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_load.2 = load i64 %c
    %tmp_add.1 = add i64 %tmp_add %tmp_load.2
    ret %tmp_add.1
}

---

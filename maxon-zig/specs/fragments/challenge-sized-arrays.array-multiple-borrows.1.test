// Test: challenge-sized-arrays.array-multiple-borrows.1
function readFirst(arr array of 3 int) returns int
    return arr[0]
end 'readFirst'

function main() returns int
    var arr = array of 3 int
    arr[0] = 10
    var a = readFirst(arr)
    var b = readFirst(arr)
    var c = readFirst(arr)
    return a + b + c
end 'main'
---
ExitCode: 30
---
function readFirst() -> i64 {
entry:
    %0 = param ptr 0
    %1 = const.i64 i64 0
    %2 = getelemptr ptr %0 %1
    %3 = load i64 %2
    ret %3
}

function main() -> i64 {
entry:
    %0 = alloca.sized ptr 24
    %1 = const.i64 i64 0
    %2 = const.i64 i64 10
    %3 = getelemptr ptr %0 %1
    store %3 %2
    %4 = call i64 @readFirst(%0)
    %6 = call i64 @readFirst(%0)
    %8 = call i64 @readFirst(%0)
    %12 = add i64 %4 %6
    %14 = add i64 %12 %8
    ret %14
}


// Test: challenge-sized-arrays.array-multiple-borrows.1
function readFirst(arr array of 3 int) returns int
    return arr[0]
end 'readFirst'

function main() returns int
    var arr = array of 3 int
    arr[0] = 10
    var a = readFirst(arr)
    var b = readFirst(arr)
    var c = readFirst(arr)
    return a + b + c
end 'main'
---
ExitCode: 30
---
function readFirst() -> i64 {
entry:
    %0 = param ptr 0
    %1 = const.i64 i64 0
    %2 = getelemptr ptr %0 %1
    %3 = load i64 %2
    ret %3
}

function main() -> i64 {
entry:
    %3 = alloca.sized ptr 64
    %4 = const.i64 i64 0
    %5 = const.i64 i64 10
    %6 = getelemptr ptr %3 %4
    store %6 %5
    %7 = call i64 @readFirst(%3)
    %9 = call i64 @readFirst(%3)
    %11 = call i64 @readFirst(%3)
    %15 = add i64 %7 %9
    %17 = add i64 %15 %11
    ret %17
}


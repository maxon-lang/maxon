    %9 = getelemptr ptr %arr %tmp_const.5
    store %9 %tmp_const.4
    %tmp_const.6 = const.i64 i64 20
    %tmp_const.7 = const.i64 i64 3
    %12 = getelemptr ptr %arr %tmp_const.7
    store %12 %tmp_const.6
    %tmp_const.8 = const.i64 i64 25
    %tmp_const.9 = const.i64 i64 4
    %15 = getelemptr ptr %arr %tmp_const.9
    store %15 %tmp_const.8
    %tmp_const.10 = const.i64 i64 4
    %17 = getelemptr ptr %arr %tmp_const.10

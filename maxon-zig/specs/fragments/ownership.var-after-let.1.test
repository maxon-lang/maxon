// Test: ownership.var-after-let.1
function main() returns int
    let x = 10
    var y = x
    y = y + 5
    return y
end 'main'
---
ExitCode: 15
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %y = alloca ptr
    store %y %tmp_load
    %tmp_load.1 = load i64 %y
    %tmp_const.1 = const.i64 i64 5
    %tmp_add = add i64 %tmp_load.1 %tmp_const.1
    store %y %tmp_add
    %tmp_load.2 = load i64 %y
    ret %tmp_load.2
}

---

// Test: multi-file.type-with-method-basic.1
type Counter
    var value int

    function add(n int) returns int
        value = value + n
        return value
    end 'add'
end 'Counter'

function main() returns int
    var c = Counter{value: 0}
    c.add(20)
    return c.add(22)
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    %8 = memset %c 0
    %tmp_fieldptr = getfieldptr ptr %c 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %tmp_call = call i64 @Counter$add(%c, %tmp_const.1)
    %tmp_const.2 = const.i64 i64 22
    %tmp_call.1 = call i64 @Counter$add(%c, %tmp_const.2)
    ret %tmp_call.1
}

function Counter$add() -> i64 {
entry:
    %self = param ptr 0
    %n = param i64 1
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_load.1 = load i64 %n.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret %tmp_add
}

---

// Test: challenge-struct-field-assign.nested-struct-field-reassignment.1
type Inner
    var x int
end 'Inner'

type Outer
    var inner Inner
end 'Outer'

function main() returns int
    var i = Inner{x: 10}
    var o = Outer{inner: i}
    o.inner.x = 42
    return o.inner.x
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %0 = alloca.sized ptr 8
    %3 = alloca.sized ptr 8
    %4 = getfieldptr ptr %3 0
    store %4 %0
    %5 = getfieldptr ptr %3 0
    %6 = getfieldptr ptr %5 0
    %7 = const.i64 i64 42
    store %6 %7
    %8 = getfieldptr ptr %3 0
    %9 = getfieldptr ptr %8 0
    %10 = load i64 %9
    ret %10
}


// Test: challenge-struct-field-assign.nested-struct-field-reassignment.1
type Inner
    var x int
end 'Inner'

type Outer
    var inner Inner
end 'Outer'

function main() returns int
    var i = Inner{x: 10}
    var o = Outer{inner: i}
    o.inner.x = 42
    return o.inner.x
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const.1 = const.i64 i64 42
    ret %tmp_const.1
}

---
